;; std/project.blsp — the project model + test runner (ADR-020), in Brood.
;;
;;   (require 'project)       ; loaded on demand; baked into the binary
;;   (run-project-tests)      ; find project.blsp, discover tests, run them once
;;
;; This is the policy behind `nest test`. Convention over configuration: `src/`
;; holds the project's source (added to *load-path*), `tests/` holds tests
;; discovered as <name>_test.blsp. A `project.blsp` manifest declares identity
;; and may override the conventional paths. Rust supplies only the filesystem
;; mechanism (cwd / file-exists? / dir? / list-dir) and `load`; everything here
;; is ordinary Brood.

(defmodule project
  "The project model and test runner behind `nest` (ADR-020), written in Brood.
Convention over configuration: `src/` holds source (added to *load-path*),
`tests/` holds <name>_test.blsp cases; a `project.blsp` manifest declares
identity and may override those paths. Also home to the user-config loader and
the `nest new` scaffolder."
  ;; NOT `(:use test)`: that would `(require 'test)` at *load* time, so a lean
  ;; release runtime (which strips the test framework, ADR-038) couldn't even
  ;; load `project` to boot a bundle. The test runner needs test only when it
  ;; actually runs — `run-project-tests` `(require 'test)`s and qualifies it.
  (:use format))

;; --- the project, as set by the manifest -------------------------------------

(def *project-root* nil)
(def *project-name* nil)
(def *project-version* nil)
(def *project-source-paths* (list "src"))
; conventional default
(def *project-test-paths* (list "tests"))
; conventional default
(def *project-main* (list 'main 'main))
; (module fn) — `nest run` entry, as declared by the manifest's `:main`
(def *project-main-override* nil)
; (module fn) or nil — a `nest run --main` override that wins over the manifest.
; A separate slot (not `*project-main*`) because the manifest is re-applied
; inside `run-project` (via `project-setup`), which would otherwise clobber an
; override set before the run.
(def *project-dependencies* nil)
; list of normalised dep maps from the manifest's :dependencies (ADR-037)
(def *project-format-headers* nil)
; the manifest's :format-headers map ({head-symbol → header-count}) — extra formatter
; rules for this project's own macros; nil when unset
(def *project-format-plugins* nil)
; the manifest's :format-plugins vector ([dep-name …]) — deps whose own
; :format-headers this project pulls in (so a framework ships its macro shapes)

;; (plist-get '(:a 1 :b 2) :b) => 2 — the value after key k in a flat kv list, or nil.
(defn plist-get (kvs k)
  (cond (empty? kvs) nil (= (first kvs) k) (second kvs) else (plist-get (rest (rest kvs)) k)))

;; Normalise the manifest's `:main` value into a `(module fn)` pair of symbols.
;;   'foo           => '(foo main)        ; module foo, default fn name `main`
;;   '(foo bar)     => '(foo bar)         ; module foo, fn bar
;;   anything else  => error
(defn project--parse-main (v)
  (cond
    (symbol? v) (list v 'main)
    ;; `:main 'app` / `:main '(app start)` reads as `(quote …)` — the manifest is
    ;; data and never evaluated, so the quote is literal, not stripped. Catch it
    ;; with a fix-it instead of silently parsing module `quote`.
    (and (pair? v) (= (first v) 'quote)) (error "project: :main takes a bare symbol, not a quoted one — write `:main "
                                           (second v)
                                           "` (the manifest is data, so drop the leading quote)")
    (and (pair? v) (symbol? (first v)) (pair? (rest v)) (symbol? (second v)) (nil? (rest (rest v)))) (list (first v)
                                                                                                       (second v))
    else (error "project: :main must be a module symbol or '(module fn), got " v)))

;; Parse a CLI entry spec — "module" or "module/fn" — into a `(module fn)` pair.
;; The `nest run --main` override: a one-off entry without editing the manifest.
;;   "app"        => (app main)
;;   "app/start"  => (app start)
(defn project--parse-main-spec (spec)
  (let (parts (string-split spec "/")
         ; reject blank module/fn halves so a typo like "" or "/start" errors
         ; cleanly here, not as a malformed `(require '||)` downstream.
         ok?
         (fn (p) (not (blank? p))))
    (cond
      (and (= (count parts) 1) (ok? (first parts))) (list (symbol (first parts)) 'main)
      (and (= (count parts) 2) (ok? (first parts)) (ok? (second parts))) (list (symbol (first parts))
                                                                           (symbol (second parts)))
      else (error "nest run --main: expected \"module\" or \"module/fn\", got " spec))))

(defn set-project-main (spec)
  "Override the `nest run` entry point from a CLI spec string (`\"module\"` or `\"module/fn\"`), without editing the manifest's `:main`. Sets a dedicated override slot that wins over the manifest even though `run-project` re-applies the manifest internally. Backs `nest run --main`."
  (def *project-main-override* (project--parse-main-spec spec)))

;; --- dependency manifest parsing (ADR-037, packages.md) ----------------------
;; Each :dependencies entry is a vector: `[name :git URL :ref REF]` or
;; `[name :path PATH]` — `name` is the local symbol `require` will see. Parsed
;; into a normalised dep map ({:name :kind :url/:path :ref}) for the package
;; manager (std/package.blsp) to consume. The reserved opts :branch/:dir/:features
;; are recognised but rejected in v1, so the manifest shape stays forward-compatible.

(def *project--reserved-dep-opts* (list :branch :dir :features))

;; The elements of vector `v` from index `start` onward, as a list (tail-recursive).
(defn project--vec-drop (v start) (project--vec-drop--acc v start (dec (vector-length v)) nil))
(defn project--vec-drop--acc (v start i acc)
  (if (< i start) acc (project--vec-drop--acc v start (dec i) (cons (vector-ref v i) acc))))

;; The keys of a flat plist (every other element from the head).
(defn project--plist-keys (kvs)
  (if (empty? kvs) nil (cons (first kvs) (project--plist-keys (rest (rest kvs))))))

;; Reject any reserved opt key present in `opts`, naming the offending dep.
(defn project--reject-reserved-opts (name opts)
  (fold (fn (_ k)
          (when (includes? *project--reserved-dep-opts* k)
            (error "project: dependency "
              name
              " uses "
              k
              ", which is reserved for a future version")))
    nil
    (project--plist-keys opts)))

(defn project--parse-git-dep (name entry)
  (let (url (vector-ref entry 2)
        opts (project--vec-drop entry 3)
        ref (plist-get opts :ref))
    (when (not (string? url))
      (error "project: :git dependency " name " URL must be a string, got " url))
    (when (not (string? ref))
      (error "project: :git dependency " name " needs a :ref \"<tag-or-commit>\""))
    (project--reject-reserved-opts name opts)
    {:name name :kind :git :url url :ref ref}))

(defn project--parse-path-dep (name entry)
  (let (path (vector-ref entry 2)
        opts (project--vec-drop entry 3))
    (when (not (string? path))
      (error "project: :path dependency " name " path must be a string, got " path))
    (project--reject-reserved-opts name opts)
    {:name name :kind :path :path path}))

;; Normalise one `[name kind spec & opts]` entry into a dep map.
(defn project--parse-dep (entry)
  (when (not (vector? entry))
    (error "project: each :dependencies entry must be a vector, got " entry))
  (when (< (vector-length entry) 3) (error "project: dependency entry is too short: " entry))
  (let (name (vector-ref entry 0)
        kind (vector-ref entry 1))
    (when (not (symbol? name)) (error "project: dependency name must be a symbol, got " name))
    (cond
      (= kind :git) (project--parse-git-dep name entry)
      (= kind :path) (project--parse-path-dep name entry)
      else (error "project: dependency " name " must be :git or :path, got " kind))))

;; Parse the manifest's :dependencies value into a list of normalised dep maps.
;; Omitted/nil => empty list.
(defn project--parse-deps (deps)
  (cond
    (nil? deps) nil
    (vector? deps) (map project--parse-dep deps)
    else (error "project: :dependencies must be a vector of dep entries, got " deps)))

;; The (project ...) manifest form: records identity, and overrides the
;; conventional source/test paths, the `nest run` entry, and the dependency set
;; when given. Missing keys keep their defaults. Called when a project.blsp is loaded.
;;
;; It is a macro that treats its arguments as **literal data** (it quotes them and
;; hands them to `project--apply`), so a manifest writes bare symbols — dep names
;; and the `:main` pair — without quoting. Manifests are static data; nothing in
;; them is ever evaluated.
(defmacro project (& opts)
  "Declare the project manifest (ADR-020/037): `:name` `:version` `:source-paths` `:test-paths` `:main` and `:dependencies`. Arguments are literal data — write dep names and the `:main` pair as bare symbols."
  ;; quasiquote (not `(list 'project--apply …)`) so α qualifies `project--apply`
  ;; to `project/project--apply` at this macro's definition (ADR-065 §7).
  `(project--apply (quote ~opts)))

(defn project--apply (opts)
  (def *project-name* (plist-get opts :name))
  (def *project-version* (plist-get opts :version))
  (let (src (plist-get opts :source-paths)
        tst (plist-get opts :test-paths)
        m (plist-get opts :main))
    (when src (def *project-source-paths* src))
    (when tst (def *project-test-paths* tst))
    (when m (def *project-main* (project--parse-main m))))
  (def *project-dependencies* (project--parse-deps (plist-get opts :dependencies)))
  (def *project-format-headers* (plist-get opts :format-headers))
  (def *project-format-plugins* (plist-get opts :format-plugins))
  *project-name*)

;; --- finding the project + discovering tests ---------------------------------
;; Walk up from `dir` toward the filesystem root, looking for project.blsp.
;; parent-dir is its own fixed point at "/" and ".", which terminates the walk.
(defn project--find-root (dir)
  (cond
    (file-exists? (path-join dir "project.blsp")) dir
    (= dir (parent-dir dir)) nil
    else (project--find-root (parent-dir dir))))

(defn project--abs-paths (root rels) (map (fn (r) (path-join root r)) rels))

;; Recursively collect every <name>_test.blsp path under `dir` (skipping nothing
;; else). Returns a list of full paths; nil if `dir` isn't a directory.
(defn project--collect-tests (dir)
  (if (dir? dir)
    (fold (fn (acc entry)
            (let (p (path-join dir entry))
              (cond
                (dir? p) (append acc (project--collect-tests p))
                (ends-with? entry "_test.blsp") (append acc (list p))
                else acc)))
      nil
      (list-dir dir))
    nil))

;; Recursively collect every .blsp under `dir` (the project's source files).
(defn project--collect-sources (dir)
  (if (dir? dir)
    (fold (fn (acc entry)
            (let (p (path-join dir entry))
              (cond
                (dir? p) (append acc (project--collect-sources p))
                (ends-with? entry ".blsp") (append acc (list p))
                else acc)))
      nil
      (list-dir dir))
    nil))

;; The feature a source file provides — the name of its top-level `(defmodule NAME …)`
;; as a string, or nil when it declares none. Parses the file read-only (never
;; evaluates it), so the loader can tell whether a file is already loaded (its module
;; on `*features*`) without running it. A parse error yields nil → the file is loaded,
;; and the load surfaces the real error.
(defn project--file-feature (path)
  (try
    (fold (fn (acc f)
            (if (and (nil? acc) (pair? f) (= (first f) 'defmodule) (symbol? (second f)))
              (name (second f))
              acc))
      nil
      (read-all (slurp path)))
    (catch e nil)))

;; Whether to (re-)load a source file that provides feature `feat`, given the
;; `*features*` snapshot `before` taken at the start of this walk:
;;   - no module header (`feat` nil) → always load (can't dedup it).
;;   - `skip-all?` (the check pre-flight) → load only if not already provided.
;;   - otherwise → load unless `feat` was provided *during this walk* (in `*features*`
;;     now but not in `before`): that means an earlier file already `require`d it, so
;;     re-loading would wipe its just-built state (e.g. an interactive-command
;;     registry) and re-`defmacro` it. A module provided in a PRIOR walk (so present
;;     in `before`) is still reloaded — that's the long-lived-image re-run picking up
;;     edits.
(defn project--should-load? (feat skip-all? before)
  (cond
    (nil? feat) true
    skip-all? (not (member? feat *features*))
    else (or (not (member? feat *features*)) (member? feat before))))

;; Load every source file under the project's source paths, so tests and other
;; code can use the project's definitions directly — no per-file `require`. Within
;; one walk each module loads once even when an earlier file `require`d it (its
;; `defmodule` `provide` is the load-once key — see `project--should-load?`); across
;; separate walks a file is re-loaded, so a re-run in a long-lived image picks up
;; edits (the hot-reload contract; the file watcher in std/reload uses `reload-defs`).
;; With `:skip-loaded`, any module already on `*features*` is skipped (the check
;; pre-flight, which runs *after* the image is loaded and must not re-evaluate it).
(defn project-load-sources (root & opts)
  (let (skip-all? (member? :skip-loaded opts)
        before *features*)
    (fold (fn (_ dir)
            (fold (fn (_ f)
                    (when (project--should-load? (project--file-feature f) skip-all? before)
                      (load f)))
              nil
              (project--collect-sources dir)))
      nil
      (project--abs-paths root *project-source-paths*))))

;; Load the manifest (if present) and put the project's source dirs on *load-path*
;; so its modules are require-able by name.
;; --- formatter rules from the manifest (+ its :format-plugins deps) ----------
;; A package declares `:format-headers {head-symbol count …}` in its own manifest;
;; a project pulls a dep's rules in with `:format-plugins [dep …]`, and may add its
;; own `:format-headers`. The effective EXTRA table (layered over format's built-ins)
;; is plugin deps' rules in declaration order, then this project's own on top.

(defn project--path-dep-dir (dep-name)
  "The local directory of `:path` dependency `dep-name` (relative to the project
root), or nil if there's no such :path dep. (Only :path deps can supply formatter
rules today; a :git plugin is a no-op.)"
  (fold (fn (acc d)
          (if (and (nil? acc) (= (get d :name) dep-name) (= (get d :kind) :path))
            (get d :path)
            acc))
    nil
    *project-dependencies*))

(defn project--manifest-format-headers (manifest-path)
  "Read the `:format-headers` map declared in the manifest at `manifest-path`; {} if
the file is missing or declares none."
  (if (file-exists? manifest-path)
    (let (form (read-first (slurp manifest-path)))
      (if (and (pair? form) (= (first form) 'project))
        (or (plist-get (rest form) :format-headers) {})
        {}))
    {}))

(defn project--plugin-format-headers (root plugin-name)
  "The `:format-headers` a `:format-plugins` entry contributes — read from that
:path dep's own project.blsp. {} for a non-:path dep."
  (let (dir (project--path-dep-dir plugin-name))
    (if (nil? dir)
      {}
      (project--manifest-format-headers (path-join (path-join root dir) "project.blsp")))))

(defn project--effective-format-headers (root)
  "The extra formatter-header table for this project: each `:format-plugins` dep's
rules merged in declaration order, then this project's own `:format-headers` on top
(so a project can retune a framework rule). {} when none are declared."
  (let (from-plugins (fold (fn (acc plugin) (merge acc (project--plugin-format-headers root plugin)))
                       {}
                       (or *project-format-plugins* (list)))
        own (or *project-format-headers* {}))
    (merge from-plugins own)))

(defn project-setup (root)
  (def *project-root* root)
  ;; Read the manifest as *data* and apply it — rather than `load`ing it, which
  ;; would need the `(project …)` macro bound bare in the (root) manifest file
  ;; (it now lives in this namespace). Manifests stay written `(project …)`.
  (let (mf (path-join root "project.blsp"))
    (when (file-exists? mf)
      (let (form (read-first (slurp mf)))
        (when (and (pair? form) (= (first form) 'project))
          (project--apply (rest form))))))
  (def *load-path* (append (project--abs-paths root *project-source-paths*) *load-path*))
  (project--ensure-deps-on-path root)
  ;; Hand the formatter this project's (+ its plugins') macro-shape rules, so
  ;; `nest format`/LSP/MCP indent framework macros correctly. Always set (resetting
  ;; any stale value from a prior setup in a long-lived tooling image).
  (def *format-headers-extra* (project--effective-format-headers root))
  root)

;; Load a full project image for **tooling** (the LSP and the `nest mcp` server):
;; put the project's sources on *load-path* and load them (so cross-module names
;; resolve), then require the `test` and `format` frameworks so their macros and
;; functions (`describe`/`test`/`assert=`/`is`, `format-source`) are bound too —
;; otherwise a buffer that uses them false-positives as "unbound" in the advisory
;; checker the tooling runs. One definition both servers share, so they can't
;; drift on which frameworks a tooling image carries. Returns `root`.
(defn setup-tooling-image (root)
  "Bootstrap a project image for tooling (LSP / MCP): load the project's sources
plus the test + format frameworks, so cross-module names and framework macros
resolve in the advisory checker. Returns the project root."
  (project-setup root)
  (project-load-sources root)
  (require 'test)
  (require 'format)
  root)

;; If the manifest declared :dependencies, resolve them (writing/refreshing
;; project.lock.blsp) and append each dep's source dir to *load-path* so its
;; modules are require-able. Deferred to the package module (ADR-037), required
;; lazily so a depless project never loads it. Dep dirs go at the END of the path,
;; after the project's own sources, so the project's modules win on a name clash.
(defn project--ensure-deps-on-path (root)
  (when *project-dependencies*
    ;; `package` is required lazily (not `:use`d) to avoid a project↔package load
    ;; cycle; qualify its one entry point here.
    (require 'package)
    (def *load-path* (append *load-path* (package/ensure-deps root *project-dependencies*)))))

;; Every .blsp file the project owns — its source files plus its test files.
;; The set the advisory type-checker walks for `(check-project)`.
(defn project--all-files (root)
  (let (src-dirs (project--abs-paths root *project-source-paths*)
        test-dirs (project--abs-paths root *project-test-paths*))
    (append (fold (fn (a d) (append a (project--collect-sources d))) nil src-dirs)
      (fold (fn (a d) (append a (project--collect-tests d))) nil test-dirs))))

;; (check-project) — advisory pre-flight: run `check-file` over every source +
;; test file in the project, printing each warning to stderr as a GNU
;; `FILE:LINE:COL: warning: …` line (editor-parseable, matches `brood --check`).
;; Returns the total warning count. Advisory only — never raises, never stops a
;; run. Called by `run-project-tests` and `run-project` before they hand off to
;; the test runner / entry-point, so users see type-misuse / arity / unbound
;; diagnostics without an extra command (`docs/types.md` — Step 4 auto-run).
;;
;; Runs *after* the project's sources are loaded (in the caller), so
;; cross-module names resolve through the heap's globals — `(check-file p)`
;; sees every prelude / std / project-source definition. File-local defns are
;; handled by `check-file`'s own per-file accumulator. The trade-off: a
;; file whose load fails never reaches the check; that error surfaces through
;; the normal eval path instead.
;; Internal: walk a list of files with `check-file`, print each warning to
;; stderr (GNU FILE:LINE:COL format), return the total count. Honors the
;; `BROOD_NO_CHECK=1` opt-out — the same flag the `brood` CLI respects, so
;; callers' "exit non-zero on warning" gating gets 0 (no print) under it.
(defn project--check-files (files)
  (if (= (getenv "BROOD_NO_CHECK") "1")
    0
    (fold (fn (n f) (fold (fn (k w) (eprintln w) (+ k 1)) n (check-file f))) 0 files)))

;; Make sure the project is set up and all its sources are loaded — the
;; precondition for the checker to resolve cross-file names through the
;; heap's globals. Loads with `:skip-loaded`, so a module already on
;; `*features*` (loaded by the `run-project`/`run-project-tests` that called the
;; check pre-flight, or by a prior require) is NOT re-evaluated — which would
;; re-run its `defmacro`s and trip the hot-reload "macro redefined" warning.
;; Standalone callers (`nest check`, an interactive `(check-project)`) start from
;; an image with nothing loaded, so this still loads every source.
(defn project--ensure-loaded (root) (project-setup root) (project-load-sources root :skip-loaded))

;; Structured analogue of `check-project` — returns a flat list of
;; `{:file :line :col :message}` maps instead of printing GNU lines + a
;; count. Backs the `nest mcp` `check` tool (`std/mcp.blsp`, step 1c-a).
;; Honors `BROOD_NO_CHECK=1` the same way `check-project` does: returns
;; an empty list under the flag.
(defn check-project-structured ()
  "Advisory type-check the whole project, returning a list of `{:file :line :col :message}` diagnostic maps (one per warning) instead of printing. Returns nil under `BROOD_NO_CHECK=1`. Errors if not in a project. Backs the `nest mcp` `check` tool."
  (let (root (project--find-root (cwd)))
    (when (nil? root)
      (error "check-project-structured: not in a Brood project (no project.blsp found from "
        (cwd)
        ")"))
    (project--ensure-loaded root)
    (if (= (getenv "BROOD_NO_CHECK") "1")
      nil
      (fold (fn (acc f) (append acc (check-file-structured f)))
        nil
        (project--all-files root)))))

;; --- duplicate-global detection (flat namespace, ADR-019) --------------------
;; The project shares one flat global table: exactly one binding per name across
;; every source file. If two files each `(defn main …)`, the last loaded silently
;; wins with no error — an expensive, invisible failure (a real one hit in
;; docs/feedback-retro-game-of-life.md). This advisory pass parses each source
;; file's top-level def-style forms (via `parse-source`'s CST — no eval) and
;; warns when one name is defined in more than one file.

;; CST node accessors (see the `parse-source` doc in builtins.rs): a node is
;; `[kind v]` — for a leaf `v` is the raw source text, for a container
;; (`[:list …]`, `[:root …]`) `v` is the vector of child nodes.
(defn project--node-kind (n) (vector-ref n 0))
(defn project--node-val (n) (vector-ref n 1))

;; Top-level heads that bind a global (each expands to `def`). `defmodule` is
;; excluded — it registers a module feature, not a clashing value binding.
(def *project--def-heads* ["def" "defn" "defmacro" "defdyn" "defonce"])

;; The global name a top-level list node introduces (a string), or nil if the
;; node isn't a recognised def-style form.
(defn project--def-name (list-node)
  (let (kids (filter (fn (c) (not (includes? [:whitespace :comment] (project--node-kind c))))
               (project--node-val list-node)))
    (when (>= (count kids) 2)
      (let (head (first kids) nm (second kids))
        (when (and (= (project--node-kind head) :symbol)
                (includes? *project--def-heads* (project--node-val head))
                (= (project--node-kind nm) :symbol))
          (project--node-val nm))))))

;; An "earmuffed" `*foo*` name — ambient/root regardless of any enclosing
;; namespace (ADR-065/066), mirroring the kernel resolver's `is_ambient`.
(defn project--ambient? (name)
  (and (> (string-length name) 2) (starts-with? name "*") (ends-with? name "*")))

;; The namespace a top-level `(defmodule ns …)` node declares (a string), or nil
;; if the node isn't a `defmodule`. The file-level shape of `project--def-name`.
(defn project--module-name (list-node)
  (let (kids (filter (fn (c) (not (includes? [:whitespace :comment] (project--node-kind c))))
               (project--node-val list-node)))
    (when (>= (count kids) 2)
      (let (head (first kids) nm (second kids))
        (when (and (= (project--node-kind head) :symbol)
                (= (project--node-val head) "defmodule")
                (= (project--node-kind nm) :symbol))
          (project--node-val nm))))))

;; The effective *global* key a def binds, mirroring the kernel resolver
;; (`eval::macros`): `ns/name` under a file's `(defmodule ns)` (ADR-065), but
;; left bare for an already-qualified name, an ambient `*earmuff*`, or a file
;; with no module header (the root namespace). This is what makes the duplicate
;; check namespace-sound — two files' same short name in different namespaces no
;; longer collide.
(defn project--qualify (ns name)
  (if (or (nil? ns) (project--ambient? name) (string-contains? name "/"))
    name
    (str ns "/" name)))

;; Every global *key* defined at top level in the file at `path` — each a fully
;; resolved `ns/name` (or bare, per `project--qualify`), in source order.
;; `parse-source` never raises — malformed input just yields fewer recognised
;; defs — so a syntax error in one file can't abort the scan.
(defn project--file-def-names (path)
  (let (nodes (filter (fn (c) (= (project--node-kind c) :list))
                (project--node-val (parse-source (slurp path))))
        ns (first (keep project--module-name nodes)))
    (map (fn (nm) (project--qualify ns nm)) (keep project--def-name nodes))))

;; The project's source files (no tests) — the set the flat-namespace rule binds.
(defn project--source-files (root)
  (fold (fn (acc d) (append acc (project--collect-sources d)))
    nil
    (project--abs-paths root *project-source-paths*)))

;; Warning strings for a *qualified* global key (`ns/name`, per
;; `project--file-def-names`) defined across more than one source file. Under
;; namespaces (ADR-065) this fires only on a genuine collision — two files in
;; the *same* namespace binding the same name, or an ambient `*earmuff*` / root
;; name bound twice — not on a short name reused across distinct namespaces.
(defn project--duplicate-def-warnings (files)
  (let (by-name (fold (fn (acc path)
                        (fold (fn (m nm) (map-assoc m nm (cons path (map-get m nm nil))))
                          acc
                          (project--file-def-names path)))
                  {}
                  files))
    (keep (fn (entry)
            (let ([nm paths] entry
                  where (sort (distinct paths)))
              (when (> (count where) 1)
                (str "warning: global '"
                  nm
                  "' is defined in "
                  (count where)
                  " source files ("
                  (join ", " where)
                  ") — same namespace; the last loaded wins (ADR-065)"))))
      by-name)))

;; Print the duplicate-def warnings to stderr and return the count. Advisory
;; (never raises, never stops a run) and honors `BROOD_NO_CHECK=1` like the
;; type-check pre-flight. Shared by `check-project` / `check-project-sources`.
(defn project--check-duplicate-defs (files)
  (if (= (getenv "BROOD_NO_CHECK") "1")
    0
    (fold (fn (n w) (eprintln w) (+ n 1)) 0 (project--duplicate-def-warnings files))))

(defn check-project ()
  "Advisory type-check the whole project (every source + test file), printing GNU-style `FILE:LINE:COL:` warnings to stderr. Errors if not in a Brood project. Backs `nest check`."
  (let (root (project--find-root (cwd)))
    (when (nil? root)
      (error "check-project: not in a Brood project (no project.blsp found from " (cwd) ")"))
    (project--ensure-loaded root)
    (project--check-duplicate-defs (project--source-files root))
    (project--check-files (project--all-files root))))

;; (check-files paths) — advisory-check a specific list of files, the entry
;; behind `nest check FILE…`. Loads the project image *first* (same
;; `project--ensure-loaded` as `check-project`) so cross-module / namespace
;; imports resolve through the heap's globals exactly as in a whole-project
;; check — without it a single-file check of a namespaced file false-flags every
;; `:use`d / qualified name as unbound. Then runs the *same* per-file walk
;; (`project--check-files`: GNU stderr lines + BROOD_NO_CHECK opt-out + count),
;; so both `nest check` forms share one checker, not two divergent paths.
;; Outside a project (no project.blsp) it skips loading and checks each file
;; against the prelude alone — the standalone-file behaviour.
(defn check-files (paths)
  "Advisory type-check the listed files with the project image loaded first (so cross-module/namespace imports resolve), printing GNU `FILE:LINE:COL:` warnings to stderr and returning the total count. The entry behind `nest check FILE…`; shares its loader and per-file walk with `check-project`. Outside a project, checks against the prelude alone."
  (let (root (project--find-root (cwd)))
    (when root (project--ensure-loaded root))
    (project--check-files paths)))

;; Sources-only variant for `run-project`'s auto pre-flight: skip `tests/`,
;; because test files depend on the test-framework macros (`describe`/`test`/
;; `assert=`/`is`) loaded by `(require 'test)`, which `nest run` doesn't
;; do — so checking them there would emit spurious "unbound symbol" warnings.
;; `nest test` keeps using `check-project` (full coverage; `test` is loaded).
(defn check-project-sources ()
  "Like `check-project`, but checks only the project's source paths (skips `tests/`, whose files reference test-framework macros). Used by `nest run`'s pre-flight."
  (let (root (project--find-root (cwd)))
    (when (nil? root)
      (error "check-project-sources: not in a Brood project (no project.blsp found from " (cwd) ")"))
    (project--ensure-loaded root)
    (let (srcs (project--source-files root))
      (project--check-duplicate-defs srcs)
      (project--check-files srcs))))

;; (run-project-tests & opts) — find the project from the cwd, set it up, load
;; every <name>_test.blsp under its test paths (which only REGISTER tests via the
;; test framework), then run the whole suite once. opts pass through to run-tests
;; (e.g. :trace / :slow). Raises if there's no project here, or if any test fails.
;;
;; A `(check-project)` advisory pre-flight runs after all loads but before
;; `(run-tests)`, so the checker sees every source + test file once
;; cross-module names are resolvable through the loaded heap.
(defn run-project-tests (& opts)
  "Discover, load (register-only), and run the project's whole test suite once, from the cwd. `opts` pass through to `run-tests` (e.g. `:slow`). Runs an advisory `check-project` pre-flight. Errors if not in a project or if any test fails. Backs `nest test`."
  (let (root (project--find-root (cwd)))
    (when (nil? root)
      (error "run-project-tests: not in a Brood project (no project.blsp found from " (cwd) ")"))
    (project-setup root)
    (require 'test)
    (project-load-sources root)
    ; the project's own src/, so tests use it directly
    (test/reset-units!)
    ; drop any stale registrations from a prior run (long-lived image / hot reload)
    (let (dirs (project--abs-paths root *project-test-paths*)
          files (fold (fn (acc d) (append acc (project--collect-tests d))) nil dirs))
      (fold (fn (_ f) (load f)) nil files)
      ; load each: registers its tests
      (check-project)
      ; advisory; warnings to stderr
      (apply test/run-tests opts))))

;; Structured analogue of `run-project-tests` — same bootstrap (discovery,
;; load, type-check pre-flight) but `(run-tests-structured)` at the end, so
;; the caller gets `{:total :passed :failed :ms :results [...]}` instead of
;; printed output + a throw on failure. Backs the `nest mcp` `run-tests`
;; tool (step 1c-b).
(defn run-project-tests-structured (& opts)
  "Like `run-project-tests`, but returns the structured result `{:total :passed :failed :ms :results [...]}` instead of printing and raising on failure. Backs the `nest mcp` `run-tests` tool."
  (let (root (project--find-root (cwd)))
    (when (nil? root)
      (error "run-project-tests-structured: not in a Brood project (no project.blsp found from "
        (cwd)
        ")"))
    (project-setup root)
    (require 'test)
    (project-load-sources root)
    (test/reset-units!)
    ; drop any stale registrations so a re-run in a long-lived `nest mcp` image
    ; (each `load` re-registers, ADR-013) counts each test once, not N times
    (let (dirs (project--abs-paths root *project-test-paths*)
          files (fold (fn (acc d) (append acc (project--collect-tests d))) nil dirs))
      (fold (fn (_ f) (load f)) nil files)
      ; loader-only: tests register themselves
      (apply test/run-tests-structured opts))))

;; (run-project args) — find the project from the cwd, set it up (which may
;; override *project-main* via the manifest), `require` the entry module, and
;; call its entry fn with `args` (a list of strings from the CLI). The default
;; entry is `(main main)` — module `main`, fn `main` — so most projects ship a
;; bare manifest and a `(defn main () ...)` in src/main.blsp. Errors if there's
;; no project here, or if the entry fn isn't defined or callable.
(defn run-project (args)
  "Run the project's entry point (default module `main`, fn `main`; overridable via the manifest's `:main`), passing `args` (a list of CLI string arguments). Runs an advisory sources-only pre-flight. Errors if not in a project or the entry fn is missing/uncallable. Backs `nest run`."
  (let (root (project--find-root (cwd)))
    (when (nil? root)
      (error "run-project: not in a Brood project (no project.blsp found from " (cwd) ")"))
    (project-setup root)
    ;; A `--main` override (set via `set-project-main`) wins over the manifest's
    ;; `:main`, which `project-setup` just re-applied into `*project-main*`.
    (let (entry (or *project-main-override* *project-main*)
          modname (first entry) fname (second entry))
      (require modname)
      ;; A `(defmodule …)` entry defines its fn as `modname/fname` (ADR-065); a
      ;; module file with no `defmodule` header defines it bare. Prefer the
      ;; qualified name, fall back to bare.
      (let (qual (symbol (str (name modname) "/" (name fname))))
        (let (target (cond (bound? qual) qual (bound? fname) fname else nil))
          (when (nil? target)
            (error "run-project: entry fn '" fname "' is not defined (module '" modname "')"))
          ;; Advisory pre-flight: warnings go to stderr so they don't pollute the
          ;; entry point's own stdout. After `require` so cross-module names see
          ;; the heap's globals (see `check-project`). Sources only — `tests/` is
          ;; out of scope for `nest run`, and its files reference test-framework
          ;; macros that `(require 'test)` introduces (which we don't run here).
          (check-project-sources)
          (let (f (eval target))
            (unless (fn? f)
              (error "run-project: entry '" fname "' is not callable (" (type-of f) ")"))
            (apply f args)))))))

;; --- single-binary release (ADR-038) -----------------------------------------
;; `nest release` appends a project's source to a copy of the `brood` binary;
;; the resulting executable boots `:main` with no interpreter, project dir, or
;; source files on the target. Two halves: `bundle-collect` (here) gathers the
;; source for `nest` to embed, and `run-bundle` (below) boots it inside the
;; embedded runtime. Mechanism (append/extract the archive) is Rust; this is the
;; policy (ADR-006).

;; The module name `require` knows a source file by — its path **relative to the
;; source dir it lives under**, without the `.blsp` extension. For a top-level file
;; that's just the stem (`src/main.blsp` → `main`); for a namespaced module it keeps
;; the namespace (`…/net/sse.blsp` under `…/src` → `net/sse`), exactly the key
;; `require 'net/sse` looks up. So a bundle keyed this way resolves through the same
;; `%builtin-module` path as the baked-in std (whose table is likewise keyed by full
;; name, e.g. `editor/buffer`) — with no load-path on disk.
(defn project--bundle-name (dir path)
  (let (prefix (if (ends-with? dir "/") dir (str dir "/"))
        rel (if (starts-with? path prefix)
              (substring path (string-length prefix) (string-length path))
              (path-basename path)))
    (if (ends-with? rel ".blsp")
      (substring rel 0 (- (string-length rel) 5))
      rel)))

(defn bundle-collect (root)
  "Collect a project's shippable source for `nest release`: a flat list of
strings `(manifest-src name0 src0 name1 src1 …)` the `nest` side embeds in the
binary (ADR-038). Includes resolved dependency sources; excludes `tests/`. Modules
are keyed by their require-name — the path relative to the source dir, sans `.blsp`,
so a namespaced module (`net/sse`) keeps its namespace and resolves like the baked-in
std. Errors if `root` is nil (not in a project)."
  (when (nil? root)
    (error "bundle-collect: not in a Brood project (no project.blsp found)"))
  (let (manifest (slurp (path-join root "project.blsp")))
    ;; Apply the manifest as DATA (not `load`) to learn its source paths + deps,
    ;; mirroring `project-setup`. We don't load any source here — just read it.
    (let (form (read-first manifest))
      (when (and (pair? form) (= (first form) 'project)) (project--apply (rest form))))
    ;; Project source dirs first, then resolved dependency dirs (so a project
    ;; module wins a stem clash with a dep — matches `*load-path*` ordering).
    (let (src-dirs (project--abs-paths root *project-source-paths*)
          dep-dirs (if *project-dependencies*
                     (do (require 'package) (package/ensure-deps root *project-dependencies*))
                     nil)
          all-dirs (append src-dirs dep-dirs))
      ;; Pair each file with the source dir it was found under, so its require-name
      ;; (relative to that dir) keeps any namespace — `src/main.blsp` → `main`,
      ;; `src/net/sse.blsp` → `net/sse`. Dir order (project dirs first)
      ;; is preserved, so a project module still wins a name clash with a dep.
      (cons manifest
        (fold (fn (acc d)
                (fold (fn (a f) (append a (list (project--bundle-name d f) (slurp f))))
                  acc
                  (project--collect-sources d)))
          nil
          all-dirs)))))

;; (run-bundle args) — boot an embedded release bundle. The `brood` binary,
;; detecting its appended archive, calls this instead of starting a REPL. No
;; disk/cwd: every module comes from the embedded archive via `%builtin-module`
;; (which `require-one` consults). Mirrors `run-project`'s entry resolution minus
;; the project walk and the advisory checker (a shipped app isn't a dev image).
(defn run-bundle (args)
  "Run an embedded release bundle's entry point, passing `args` (a list of CLI
string arguments). The `brood` binary calls this when it detects it is a `nest
release` bundle. Loads the embedded manifest + modules and invokes `:main`
(default module `main`, fn `main`). Errors if the entry fn is missing/uncallable."
  (let (form (read-first (%bundle-manifest)))
    (when (and (pair? form) (= (first form) 'project)) (project--apply (rest form))))
  ;; Load every embedded module once. Order-independent: cross-module
  ;; `:use`/`require` resolve through the same embedded table, and require is
  ;; idempotent — so a `(:use foo)` in the first module pulls `foo` on demand.
  (map require-one (%bundle-module-names))
  (let (entry (or *project-main-override* *project-main*)
        modname (first entry) fname (second entry))
    (require modname)
    (let (qual (symbol (str (name modname) "/" (name fname))))
      (let (target (cond (bound? qual) qual (bound? fname) fname else nil))
        (when (nil? target)
          (error "run-bundle: entry fn '" fname "' is not defined (module '" modname "')"))
        (let (f (eval target))
          (unless (fn? f)
            (error "run-bundle: entry '" fname "' is not callable (" (type-of f) ")"))
          (apply f args))))))

;; --- user config (~/.config/brood/config.blsp) -------------------------------
;; A user-level Brood file of tooling preferences — the sibling of project.blsp.
;; It's auto-created with documented defaults on first tool use, then loaded by
;; the `nest` subcommands. Rust mechanism: getenv (locate it) + run-process.
(def *config-git-init* false)
; nest new: run `git init` in the new project?

(defn config (& opts)
  "Set user-level tooling preferences — the form the user config file (`~/.config/brood/config.blsp`) contains. Recognized keys: `:git-init` (whether `nest new` runs `git init`). Sets only the keys given; returns nil."
  (let (gi (plist-get opts :git-init)) (unless (nil? gi) (def *config-git-init* gi)))
  nil)

(defn config--base-dir ()
  ; $XDG_CONFIG_HOME, else ~/.config
  (let (xdg (getenv "XDG_CONFIG_HOME")) (if (nil? xdg) (path-join (getenv "HOME") ".config") xdg)))
(defn config--dir () (path-join (config--base-dir) "brood"))
(defn config--path () (path-join (config--dir) "config.blsp"))

(def *config-default-source*
  (str ";; Brood user config — tooling preferences (the sibling of project.blsp).\n"
    ";; Edit to taste; any `nest` command re-reads it.\n"
    "(config\n"
    "  :git-init false)   ; run `git init` in projects made by `nest new`\n"))

;; Ensure the config exists (writing a documented default the first time), then
;; apply it. Called by the `brood` subcommands, so a tool use always leaves an
;; editable config behind.
(defn load-config ()
  "Ensure the user config (`~/.config/brood/config.blsp`) exists — writing a documented default on first use — then apply it. Called by the `nest` subcommands."
  (let (p (config--path))
    (unless (file-exists? p)
      (make-dir (config--dir))
      (spit p *config-default-source*)
      (println (str "Created " p)))
    ;; Read the config as DATA and apply the `(config …)` form directly, rather
    ;; than `(load)`-ing it as code. `load` evaluates a file at the *root*
    ;; namespace with a fresh (empty) import table (ADR-065), so a bare
    ;; `(config …)` written in the user file would not resolve to this module's
    ;; `project/config`. Reading-as-data keeps the user config a clean bare DSL
    ;; (the project manifest is read the same way, ADR-020) and decouples it from
    ;; namespace resolution — `config` here is `project/config` (this body is
    ;; compiled in the `project` namespace), so the apply resolves.
    (let (form (read-first (slurp p)))
      (when (and (pair? form) (= (first form) 'config))
        (apply config (rest form)))))
  nil)

;; --- scaffolding a new project (`nest new <name>`) ---------------------------
;; True if the 1-char string `ch` occurs in `s` (a short scan — Brood has no char
;; index yet, and project names/paths are short).
(defn str-contains? (s ch)
  (cond
    (= (string-length s) 0) false
    (= (substring s 0 1) ch) true
    else (str-contains? (substring s 1 (string-length s)) ch)))

;; A project name must be a single, fresh path component in the current
;; directory: non-empty, no path separators or whitespace, no NUL, and not
;; one of the path-traversal / hidden / flag-shaped names (`.`, `..`, leading
;; `.`/`-`/`~`/`\`). This blocks `nest new ..` and friends from scaffolding
;; into a parent or hidden directory — see CLAUDE.md / docs/devlog.md.
(defn project--valid-name? (nm)
  (and (> (string-length nm) 0)
    (not (= nm "."))
    (not (= nm ".."))
    (not (str-contains? nm "/"))
    (not (str-contains? nm "\\"))
    (not (str-contains? nm " "))
    (not (str-contains? nm "\t"))
    (not (str-contains? nm "\n"))
    (not (str-contains? nm "\0"))
    (not (= (substring nm 0 1) "."))
    (not (= (substring nm 0 1) "-"))
    (not (= (substring nm 0 1) "~"))))

;; --- file templates (the starter skeleton) ---
(defn project--manifest-template (nm)
  (str ";; "
    nm
    " — a Brood project.\n"
    "(project\n"
    "  :name    \""
    nm
    "\"\n"
    "  :version \"0.1.0\")\n"
    "\n"
    ";; To depend on other Brood packages, add a :dependencies vector to the form\n"
    ";; above (ADR-037). Dep names are bare symbols (no quoting):\n"
    ";;\n"
    ";;   :dependencies [[pretty :git \"https://github.com/you/brood-pretty.git\" :ref \"v1.0.0\"]\n"
    ";;                  [shared :path \"../shared\"]]\n"
    ";;\n"
    ";; Then any `nest` command resolves them. project.lock.blsp is committed;\n"
    ";; _deps/ (the cache) is gitignored.\n"))

(defn project--main-template (nm)
  (str "(defmodule main \"The "
    nm
    " project's entry-point module — wired up as\n"
    "the `nest run` entry by default (module `main`, fn `main`).\"\n"
    "  (:use hello)\n"
    "  (:use log))  ; the async, safe logger (std/log)\n"
    "\n"
    "(defn main ()\n"
    "  \"Entry point: start the logger and print the project's greeting.\"\n"
    "  ;; `start-logger` spawns a logging process (async — each `log-*` call is\n"
    "  ;; fire-and-forget, and one process serialises every write, so lines never\n"
    "  ;; interleave). The default backend writes to stdout at :info and up.\n"
    "  (start-logger)\n"
    "  (log-info \"starting "
    nm
    "\")\n"
    "  ;; Add backends to fan output out — e.g. to a file, or to a process that\n"
    "  ;; owns a buffer (an editor's *Messages*); the line is sent as [:io-write s]:\n"
    "  ;;   (add-backend (file-backend \"app.log\"))\n"
    "  ;;   (add-backend (process-backend buffer-pid))\n"
    "  ;; To redirect plain `println` the same way, `(require 'io)` and use\n"
    "  ;;   (with-out (process-port buffer-pid) (println \"…\")).\n"
    "  (println (greeting)))\n"))

(defn project--hello-template (nm)
  (str "(defmodule hello \"A second module in the "
    nm
    " project — `main` does\n"
    "`(:use hello)` to call `greeting`. Showcases the module/namespace system\n"
    "(ADR-065): `hello` defines `greeting` as `hello/greeting`; `(:use hello)`\n"
    "imports it so `main` can call it bare.\")\n"
    "\n"
    "(defn greeting ()\n"
    "  \"Return the project's greeting string.\"\n"
    "  \"hello "
    nm
    "\")\n"))

(defn project--main-test-template (nm)
  (str ";; Tests for the main module. `(:use main)` brings `main` into scope;\n"
    ";; `(:use test)` the describe/test/is macros. `nest test` loads src/ first.\n"
    "(defmodule main-test (:use main) (:use test))\n"
    "\n"
    "(describe \"main\"\n"
    "  (test \"main is callable\" (is (fn? main))))\n"))

(defn project--hello-test-template (nm)
  (str ";; Tests for the hello module. `(:use hello)` brings `greeting` into scope;\n"
    ";; `(:use test)` the describe/test/assert= macros.\n"
    "(defmodule hello-test (:use hello) (:use test))\n"
    "\n"
    "(describe \"hello\"\n"
    "  (test \"greeting\" (assert= (greeting) \"hello "
    nm
    "\")))\n"))

;; --- alternate starter templates (`nest new --template …`) ------------------

;; `tui-loop`: a terminal-animation loop — the cellular-automaton / roguelike /
;; game genre. A pure state tuple threaded through a tail-recursive loop (Brood
;; has no `while`), one frame per tick. Pairs with `nest run --for 2s` to run it
;; for a bounded time. Kept to plain stdout for portability; for a real
;; full-screen UI use the `term-*` seam (docs/building-an-editor.md).
(defn project--tui-main-template (nm)
  (str "(defmodule main \""
    nm
    " — a terminal animation loop.\n"
    "Run it bounded:  nest run --for 2s   (Ctrl-C also stops it).\")\n"
    "\n"
    ";; State is threaded through a tail-recursive loop — no mutation, no `while`.\n"
    "\n"
    "(defn render (pos width)\n"
    "  \"One frame: a marker at column `pos` on a `width`-wide track.\"\n"
    "  (str \"[\" (string-repeat \" \" pos) \"*\" (string-repeat \" \" (- width pos 1)) \"]\"))\n"
    "\n"
    "(defn step (pos dir width)\n"
    "  \"Advance one cell, bouncing off either wall. Returns [pos dir].\"\n"
    "  (let (nxt (+ pos dir))\n"
    "    (cond\n"
    "      (< nxt 0)      [1 1]\n"
    "      (>= nxt width) [(- width 2) -1]\n"
    "      else           [nxt dir])))\n"
    "\n"
    "(defn loop (pos dir width)\n"
    "  (println (render pos width))\n"
    "  (sleep 80)\n"
    "  (let ([p d] (step pos dir width))\n"
    "    (loop p d width)))\n"
    "\n"
    "(defn main ()\n"
    "  \"Entry point: animate a bouncing marker.\"\n"
    "  (loop 0 1 20))\n"))

(defn project--tui-test-template (nm)
  (str ";; Test the pure frame logic directly — the loop itself is exercised by\n"
    ";; `nest run --for`, its pure functions by `nest test`.\n"
    "(defmodule main-test (:use main) (:use test))\n"
    "\n"
    "(describe \"animation\"\n"
    "  (test \"step bounces off the left wall\" (assert= (step 0 -1 20) [1 1]))\n"
    "  (test \"step bounces off the right wall\" (assert= (step 19 1 20) [18 -1]))\n"
    "  (test \"step advances in open space\" (assert= (step 5 1 20) [6 1]))\n"
    "  (test \"render marks the right column\" (assert= (render 0 3) \"[*  ]\")))\n"))

;; `gen`: a stateful process (gen_server-style) via the `proc/gen` framework.
;; Genuine mutable state lives in a process's loop, not a variable (ADR-026):
;; async `cast` threads new state, synchronous `call` reads/updates it.
(defn project--gen-main-template (nm)
  (str "(defmodule main \""
    nm
    " — a stateful process built with the proc/gen framework.\"\n"
    "  (:use proc/gen))\n"
    "\n"
    ";; A counter server. State `n` is the process's; messages drive it.\n"
    "(defprocess counter\n"
    "  (n)\n"
    "  (cast :inc (+ n 1))      ; async: bump the count\n"
    "  (cast [:add m] (+ n m))  ; async: add m\n"
    "  (call :value [n n]))     ; sync: reply n, state unchanged\n"
    "\n"
    "(defn main ()\n"
    "  \"Entry point: start a counter, drive it, read the result.\"\n"
    "  (let (c (spawn-server counter 0))\n"
    "    (! c :inc)\n"
    "    (! c :inc)\n"
    "    (! c [:add 10])\n"
    "    (println \"counter =\" (gen-call c :value))))\n"))

(defn project--gen-test-template (nm)
  (str ";; `(:use main)` brings `counter`; `(:use proc/gen)` the `!`/`gen-call` API;\n"
    ";; `(:use test)` the macros. :isolated — these spawn processes.\n"
    "(defmodule main-test (:use main) (:use proc/gen) (:use test))\n"
    "\n"
    "(describe \"counter\"\n"
    "  :isolated\n"
    "  (test \"casts thread state; a call reads it\"\n"
    "    (let (c (spawn-server counter 0))\n"
    "      (! c :inc) (! c :inc) (! c [:add 10])\n"
    "      (assert= (gen-call c :value) 12))))\n"))

;; `editor`: a tiny text editor on the `ui` framework (std/ui.blsp) — a `ui-run`
;; client like the observer. The buffer is a list of line strings + a [row col]
;; cursor; every edit is a pure `(model -> model)` function (testable without a
;; terminal); `view`/`update` plug into `ui-run`, which owns the loop + teardown.
;; Runs in the terminal (`*term-display*`) or, with `--features gui`, a window.
(defn project--editor-main-template (nm)
  (str "(defmodule main \""
    nm
    " — a tiny text editor built on the `ui` framework.\n"
    "\n"
    "Run it:  nest run   (type to edit, arrows move, Enter splits a line, Backspace\n"
    "deletes, Ctrl-C quits). The buffer is a list of line strings with a [row col]\n"
    "cursor; every edit is a pure (model -> model) function and `ui-run` drives the\n"
    "loop — render `view`, poll a key, fold it with `update`, repeat. Swap\n"
    "`*term-display*` for `(gui-display)` (a --features gui build) to run in a window.\"\n"
    "  (:use editor/ui)        ; the app framework: display frontends + the `ui-run` loop\n"
    "  (:use editor/display))  ; the render-op constructors (clear / text / cursor / frame)\n"
    "\n"
    "(def *welcome*\n"
    "  (list \"hello, world\"\n"
    "        \"\"\n"
    "        \"a tiny editor — grow it from here.\"))\n"
    "\n"
    "(defn ed-init ()\n"
    "  \"The starting model: the welcome buffer, cursor at the top-left.\"\n"
    "  {:lines *welcome* :row 0 :col 0 :done false :tick-ms 30000})\n"
    "\n"
    "(defn ed-line (m) \"The line the cursor is on.\" (nth (get m :lines) (get m :row)))\n"
    "\n"
    "(defn ed-set-line (lines row s)\n"
    "  \"`lines` with line `row` replaced by `s` (lists are immutable — rebuild it).\"\n"
    "  (concat (take row lines) (cons s (drop (inc row) lines))))\n"
    "\n"
    "(defn ed-move (m drow dcol)\n"
    "  \"Move the cursor by [drow dcol], clamped to the buffer and the target line.\"\n"
    "  (let (lines (get m :lines)\n"
    "        row (max 0 (min (dec (count lines)) (+ (get m :row) drow)))\n"
    "        col (max 0 (min (string-length (nth lines row)) (+ (get m :col) dcol))))\n"
    "    (assoc m :row row :col col)))\n"
    "\n"
    "(defn ed-insert (m ch)\n"
    "  \"Insert the printable string `ch` at the cursor.\"\n"
    "  (let (ln (ed-line m) col (get m :col)\n"
    "        ln2 (str (substring ln 0 col) ch (substring ln col (string-length ln))))\n"
    "    (assoc m :lines (ed-set-line (get m :lines) (get m :row) ln2)\n"
    "             :col (+ col (string-length ch)))))\n"
    "\n"
    "(defn ed-newline (m)\n"
    "  \"Split the current line at the cursor into two lines.\"\n"
    "  (let (ln (ed-line m) row (get m :row) col (get m :col) lines (get m :lines))\n"
    "    (assoc m\n"
    "           :lines (concat (take row lines)\n"
    "                          (list (substring ln 0 col) (substring ln col (string-length ln)))\n"
    "                          (drop (inc row) lines))\n"
    "           :row (inc row) :col 0)))\n"
    "\n"
    "(defn ed-backspace (m)\n"
    "  \"Delete the char before the cursor; at column 0, join with the previous line.\"\n"
    "  (let (row (get m :row) col (get m :col) lines (get m :lines))\n"
    "    (cond\n"
    "      (> col 0)\n"
    "        (let (ln (ed-line m))\n"
    "          (assoc m :lines (ed-set-line lines row\n"
    "                            (str (substring ln 0 (dec col)) (substring ln col (string-length ln))))\n"
    "                   :col (dec col)))\n"
    "      (> row 0)\n"
    "        (let (prev (nth lines (dec row)))\n"
    "          (assoc m\n"
    "                 :lines (concat (take (dec row) lines)\n"
    "                                (cons (str prev (ed-line m)) (drop (inc row) lines)))\n"
    "                 :row (dec row) :col (string-length prev)))\n"
    "      else m)))\n"
    "\n"
    "(defn ed-fit (s w) \"Clip `s` to `w` columns.\" (if (> (string-length s) w) (substring s 0 w) s))\n"
    "\n"
    "(defn ed-view (m cols rows)\n"
    "  \"ui-run view: a `text` op per line, a reverse-video status bar, cursor at point.\"\n"
    "  (apply frame\n"
    "    (append\n"
    "      [(clear)]\n"
    "      (map (fn ([i ln]) (text i 0 (ed-fit ln cols))) (enumerate (get m :lines)))\n"
    "      [(text (dec rows) 0\n"
    "             (ed-fit (str \" \" (inc (get m :row)) \":\" (get m :col) \"  —  Ctrl-C to quit\") cols)\n"
    "             {:reverse true})\n"
    "       (cursor (get m :row) (get m :col))])))\n"
    "\n"
    "(defn ed-update (m input cols rows)\n"
    "  \"ui-run update: printable keys insert, specials move/edit, Ctrl-C (or Esc)\n"
    "quits. `:tick` (the refresh beat) is a no-op here — nothing animates.\"\n"
    "  (cond\n"
    "    (= input :tick) m\n"
    "    (or (= input :ctrl-c) (= input :escape)) (assoc m :done true)\n"
    "    (= input :up)    (ed-move m -1 0)\n"
    "    (= input :down)  (ed-move m 1 0)\n"
    "    (= input :left)  (ed-move m 0 -1)\n"
    "    (= input :right) (ed-move m 0 1)\n"
    "    (= input :enter)     (ed-newline m)\n"
    "    (= input :backspace) (ed-backspace m)\n"
    "    (string? input)      (ed-insert m input)\n"
    "    else m))\n"
    "\n"
    "(defn main ()\n"
    "  \"Run the editor in the terminal (Ctrl-C quits). For a window, build with\n"
    "--features gui and pass `(gui-display)` instead of `*term-display*`.\"\n"
    "  (ui-run (ed-init) ed-view ed-update *term-display*))\n"))

(defn project--editor-test-template (nm)
  (str ";; `(:use main)` brings the pure edit fns (ed-insert, …); `(:use test)` the macros.\n"
    ";; The loop is `ui-run`'s; here we test the edits — pure `(model -> model)`.\n"
    "(defmodule main-test (:use main) (:use test))\n"
    "\n"
    "(describe \"editor edits\"\n"
    "  (test \"insert puts a char at the cursor\"\n"
    "    (assert= (get (ed-insert {:lines (list \"ac\") :row 0 :col 1} \"b\") :lines) (list \"abc\")))\n"
    "  (test \"backspace deletes the char before the cursor\"\n"
    "    (assert= (get (ed-backspace {:lines (list \"abc\") :row 0 :col 2}) :lines) (list \"ac\")))\n"
    "  (test \"backspace at column 0 joins with the previous line\"\n"
    "    (let (m (ed-backspace {:lines (list \"ab\" \"cd\") :row 1 :col 0}))\n"
    "      (assert= (get m :lines) (list \"abcd\"))\n"
    "      (assert= (get m :row) 0)\n"
    "      (assert= (get m :col) 2)))\n"
    "  (test \"newline splits the line at the cursor\"\n"
    "    (let (m (ed-newline {:lines (list \"abcd\") :row 0 :col 2}))\n"
    "      (assert= (get m :lines) (list \"ab\" \"cd\"))\n"
    "      (assert= (get m :row) 1)))\n"
    "  (test \"move clamps the column onto a shorter line\"\n"
    "    (assert= (get (ed-move {:lines (list \"ab\" \"c\") :row 0 :col 2} 1 0) :col) 1)))\n"))

;; `gui`: a windowed app on the `ui` framework — like `editor`, a `ui-run` client,
;; but opened in a NATIVE WINDOW via `(gui-display)` (needs a `--features gui`
;; runtime) and styled through the shared `face` registry (define the look once,
;; restyle in one place). The model is a plain map threaded through `ui-run`'s
;; loop; the starting point for a real GUI app (e.g. a daemon dashboard).
(defn project--gui-main-template (nm)
  (str "(defmodule main \""
    nm
    " — a windowed GUI app on the `ui` framework.\n"
    "\n"
    "Run it:  nest run   (opens a native window — needs the runtime built with the\n"
    "GUI backend: `./configure --with-gui && make install`, or run with\n"
    "`--features brood/gui`). ↑/↓ change the counter, Enter resets, Ctrl-C or the\n"
    "window's close button quits. The model is a plain map; `ui-run` drives the loop\n"
    "— render `view`, poll a key, fold it with `update`, repeat — over a window from\n"
    "`(gui-display)`. Swap that for `*term-display*` to run in the terminal instead.\"\n"
    "  (:use editor/ui)        ; the app framework: display frontends + the `ui-run` loop\n"
    "  (:use editor/display)   ; the render-op constructors (clear / text / cursor / frame)\n"
    "  (:use editor/face))     ; named text faces — style the sections in one place\n"
    "\n"
    ";; Faces: define the look once. Restyle by editing these (or, live, e.g.\n"
    ";; `(face-set :app/count {:fg :magenta})`). On the GUI a face may also carry a\n"
    ";; font `:family` / `:italic`; the terminal honours the colours + bold/reverse.\n"
    "(def-face :app/title {:inherit :ui/header})\n"
    "(def-face :app/count {:fg :cyan :bold true})\n"
    "(def-face :app/hint  {:inherit :ui/dim})\n"
    "\n"
    "(defn app-init ()\n"
    "  \"The starting model (`:done` quits; `:tick-ms` is the refresh beat).\"\n"
    "  {:count 0 :done false :tick-ms 1000})\n"
    "\n"
    "(defn app-step (m d) \"Change the counter by `d` (pure).\" (assoc m :count (+ (get m :count) d)))\n"
    "\n"
    "(defn app-center (s cols) \"Left column that centres `s` in `cols`.\"\n"
    "  (max 0 (quot (- cols (string-length s)) 2)))\n"
    "\n"
    "(defn app-view (m cols rows)\n"
    "  \"ui-run view: a centred title, the counter, and key hints (pure).\"\n"
    "  (let (mid   (quot rows 2)\n"
    "        title \""
    nm
    "\"\n"
    "        count (str \"count: \" (get m :count))\n"
    "        hint  \"up/down change · enter reset · ctrl-c quit\")\n"
    "    (frame\n"
    "      (clear)\n"
    "      (text (- mid 2) (app-center title cols) title (face :app/title))\n"
    "      (text mid       (app-center count cols) count (face :app/count))\n"
    "      (text (+ mid 2) (app-center hint cols)  hint  (face :app/hint)))))\n"
    "\n"
    "(defn app-update (m input cols rows)\n"
    "  \"ui-run update: arrows change the count, Enter resets, Ctrl-C/Esc quit. The\n"
    "window's close button (the X) quits on its own — it arrives as a `:close` input\n"
    "and `ui-run` quits on that automatically, so you never wire it up here (and it\n"
    "stays distinct from the Esc *key*, which an app is free to bind elsewhere).\n"
    "`:tick` (the refresh beat) is a no-op here — nothing animates yet.\"\n"
    "  (cond\n"
    "    (= input :up)    (app-step m 1)\n"
    "    (= input :down)  (app-step m -1)\n"
    "    (= input :enter) (assoc m :count 0)\n"
    "    (or (= input :ctrl-c) (= input :escape)) (assoc m :done true)\n"
    "    else m))\n"
    "\n"
    "(defn main ()\n"
    "  \"Open the app in a native window. Needs a --features gui build (see the module\n"
    "doc); for the terminal instead, pass `*term-display*` for `(gui-display)`.\"\n"
    "  (ui-run (app-init) app-view app-update (gui-display)))\n"))

(defn project--gui-test-template (nm)
  (str ";; `(:use main)` brings the pure fns; `(:use test)` the macros. The window loop is\n"
    ";; `ui-run`'s (untested here — it needs a display); we test the pure `update` and\n"
    ";; `view` — `(model -> model)` / `(model -> frame)`.\n"
    "(defmodule main-test (:use main) (:use test))\n"
    "\n"
    "(describe \""
    nm
    " counter\"\n"
    "  (test \"up increments, down decrements\"\n"
    "    (assert= (get (app-update {:count 5} :up 80 24) :count) 6)\n"
    "    (assert= (get (app-update {:count 5} :down 80 24) :count) 4))\n"
    "  (test \"enter resets to zero\"\n"
    "    (assert= (get (app-update {:count 9} :enter 80 24) :count) 0))\n"
    "  (test \"ctrl-c and escape quit\"\n"
    "    (is (get (app-update {:count 0} :ctrl-c 80 24) :done))\n"
    "    (is (get (app-update {:count 0} :escape 80 24) :done)))\n"
    "  (test \"view shows the counter value\"\n"
    "    (let (f (app-view {:count 3} 80 24))\n"
    "      (is (> (count (filter (fn (op) (and (= (first op) :text)\n"
    "                                          (string-contains? (nth op 3) \"count: 3\")))\n"
    "                            f))\n"
    "             0)))))\n"))

;; `CLAUDE.md` for a fresh project — short project-specific intro that points
;; at the language reference (which `nest new` also drops into `docs/`, so the
;; project is self-contained and an AI assistant has everything it needs in-tree).
(defn project--claude-md-template (nm)
  (str "# "
    nm
    " — guidance for Claude\n"
    "\n"
    "This is a Brood (`.blsp`) project scaffolded by `nest new`. Replace this stub\n"
    "with project-specific guidance — commands, conventions, gotchas.\n"
    "\n"
    "## Running\n"
    "\n"
    "- `nest test`   — run the test suite (each test runs in its own green process).\n"
    "- `nest run`    — invoke the entry point. Defaults to the `main` function in\n"
    "  the `main` module; override in `project.blsp` with `:main` (bare symbols,\n"
    "  the manifest is data — `:main app` runs `app/main`; `:main (app start)`\n"
    "  runs `app/start`; never quote them).\n"
    "  Each module is a namespace (ADR-065): a file's `defmodule name` makes its\n"
    "  `def`/`defn` define `name/foo`; a bare reference resolves in the current\n"
    "  namespace, then through `(:use …)` imports, then root/prelude. So the same\n"
    "  short name in two modules is fine (`a/parse` vs `b/parse`) — only earmuffed\n"
    "  `*foo*` vars are ambient/bare and must stay unique.\n"
    "- `nest run --for 2s` — run a loop / full-screen TUI for a bounded time, then\n"
    "  exit cleanly (`2s`, `500ms`, or a bare integer of ms). The way to exercise\n"
    "  a never-returning program end-to-end or in CI.\n"
    "- `nest format` — format Brood source.\n"
    "\n"
    "## Writing Brood\n"
    "\n"
    "`docs/brood-for-claude.md` is the language reference geared for AI assistants\n"
    "— syntax, idioms, and the patterns that aren't shared with other Lisps. Read\n"
    "it before generating Brood code. The `.claude/skills/writing-brood` skill\n"
    "carries the short version and auto-loads when Claude Code edits `.blsp` files.\n"
    "\n"
    "Brood ships randomness (`rand-int`/`rand-float`/`shuffle`/`sample` — pure and\n"
    "seedable, thread the seed), bitwise ops (`bit-and`/`bit-or`/`bit-xor`/...),\n"
    "and discovery (`apropos`, `all-globals`, `doc-search`) — use the last three to\n"
    "find what exists instead of guessing names.\n"
    "\n"
    "## MCP integration\n"
    "\n"
    "`.mcp.json` points Claude Code at this project's `nest mcp` server, so `cd "
    nm
    " && claude`\n"
    "auto-attaches an agent that can `eval`, `load`, `lookup`, `macroexpand`, `format`,\n"
    "and discover the image with `apropos` / `all-globals` / `doc-search`, against the\n"
    "live image (ADR-036, `docs/mcp.md` upstream).\n"))

;; `.mcp.json` for a fresh project — points Claude Code (and other MCP-aware
;; agents) at this project's `nest mcp` server. The dispatcher runs from the
;; project root (which is wherever the agent invoked `claude`), so a relative
;; `command: nest` works as long as `nest` is on PATH. Keeping the file
;; minimal: a single `brood` server entry. Users can add more (their own
;; MCP servers) without losing the scaffold.
(defn project--mcp-json-template (nm)
  (str "{\n"
    "  \"mcpServers\": {\n"
    "    \"brood\": {\n"
    "      \"command\": \"nest\",\n"
    "      \"args\": [\"mcp\"]\n"
    "    }\n"
    "  }\n"
    "}\n"))

;; The scaffolded .gitignore: the package cache is regenerable from the lock
;; file (which IS committed), so it's ignored (ADR-037).
(defn project--gitignore-template ()
  (str "# Brood package cache — regenerable from project.lock.blsp (which is committed)\n"
    "_deps/\n"
    "\n"
    "# Editor / OS cruft\n"
    "*.swp\n"
    ".DS_Store\n"))

;; The scaffolded .gitattributes: GitHub's Linguist doesn't know the `.blsp`
;; extension, so it renders Brood source as plain text. Until Brood is its own
;; Linguist language, map `.blsp` to Clojure — the closest common Lisp grammar
;; (it highlights [] vectors, {} maps, and :keywords, all of which Brood uses).
;; `linguist-detectable=false` keeps `.blsp` out of the repo's language stats
;; (so a Brood project isn't mislabelled "Clojure") while still highlighting.
(defn project--gitattributes-template ()
  (str "# Brood source (.blsp) is a Lisp; until it's its own Linguist language,\n"
    "# highlight it as Clojure on GitHub — the closest common grammar — but keep\n"
    "# it out of the language stats (it's Brood, not Clojure).\n"
    "*.blsp linguist-language=Clojure linguist-detectable=false\n"))

;; --- `hatch` template: Hatch web app + Postgres-backed form ----------------
;; Generates a minimal but runnable Hatch web application with a message board
;; backed by PostgreSQL. The scaffold is self-contained: `nest run` starts the
;; server after setting $PG* env vars (or with a local Postgres at the defaults).
;;
;; Files generated (in addition to the shared manifest + docs):
;;   project.blsp (overwritten with hatch + store-postgres deps)
;;   src/main.blsp           — entry point: logger + DB + HTTP
;;   src/db.blsp             — DB singleton (schema + CRUD helpers)
;;   src/web/endpoint.blsp   — HTTP listener
;;   src/web/layout.blsp     — HTML shell (Tailwind + daisyUI via CDN)
;;   src/web/routes.blsp     — routes with session/CSRF pipeline
;;   src/web/views/home.blsp — home page
;;   src/web/views/messages.blsp — Postgres-backed message board
;;   tests/main_test.blsp
;;   tests/web/views/messages_test.blsp

(defn project--hatch-manifest-template (nm)
  (str ";; " nm " — a Hatch web application.\n"
    ";;\n"
    ";; Serves a Postgres-backed message board at GET/POST /messages.\n"
    ";; Swap the :path deps for :git deps when targeting a published release.\n"
    "(project\n"
    "  :name \"" nm "\"\n"
    "  :version \"0.1.0\"\n"
    "  :dependencies [[hatch :path \"../hatch\"]\n"
    "                 [store-postgres :path \"../store-postgres\"]]\n"
    "  :format-plugins [hatch])\n"))

(defn project--hatch-main-template (nm)
  (str "(defmodule main \"Entry point for " nm ".\"\n"
    "  (:use web/endpoint :only [serve])\n"
    "  (:use web/application :only [start default-logger-opts])\n"
    "  (:alias db)\n"
    "  (:alias pg))\n"
    "\n"
    "(defn main ()\n"
    "  \"Start logging, open the DB pool, boot the endpoint, and park.\"\n"
    "  (start\n"
    "    {:logger   (default-logger-opts)\n"
    "     :children [(fn () (db/start (pg/opts-from-env \"" nm "\")))\n"
    "                (fn () (serve))]}))\n"))

(defn project--hatch-db-template (_nm)
  (str "(defmodule db\n"
    "  \"Database singleton: the shared repo handle and messages schema.\n"
    "  Call `(db/start opts)` once from `main`; handlers then use\n"
    "  `(db/all-messages)` / `(db/insert-message row)`.\"\n"
    "  (:alias repo)\n"
    "  (:alias query)\n"
    "  (:alias pg)\n"
    "  (:alias web/repo))\n"
    "\n"
    "(def *repo* nil)\n"
    "\n"
    "(def messages-schema\n"
    "  {:table :messages\n"
    "   :primary-key :id\n"
    "   :fields {:id :serial :name :text :body :text}})\n"
    "\n"
    "(defn start (opts)\n"
    "  \"Open the Postgres pool, migrate the messages table, and warm up the connections.\"\n"
    "  (def *repo* (web/repo/start (pg/adaptor) opts [messages-schema])))\n"
    "\n"
    "(defn all-messages ()\n"
    "  \"All messages, oldest first (id ASC).\"\n"
    "  (repo/all *repo* (-> (query/from :messages) (query/order-by :id :asc))))\n"
    "\n"
    "(defn insert-message (row)\n"
    "  \"Insert a `{:name ... :body ...}` row; return the inserted row with `:id`.\"\n"
    "  (repo/insert *repo* :messages row))\n"))

(defn project--hatch-db-setup-template (nm)
  (str "(defmodule db-setup\n"
    "  \"Create the app database if absent, then run schema migrations.\n"
    "  Run with: `nest run --main db-setup`\"\n"
    "  (:alias pg)\n"
    "  (:alias db))\n"
    "\n"
    "(defn main ()\n"
    "  (let (o (pg/opts-from-env \"" nm "\"))\n"
    "    (pg/create-database o)\n"
    "    (db/start o)\n"
    "    (println \"Done. Run `nest run` to start the server.\")))\n"))

(defn project--hatch-endpoint-template (_nm)
  (str "(defmodule web/endpoint \"HTTP endpoint: bridges raw requests through the router.\"\n"
    "  (:alias http/server)\n"
    "  (:alias web/conn)\n"
    "  (:alias web/routes)\n"
    "  (:alias web/live)\n"
    "  (:alias web/errors)\n"
    "  (:alias task))\n"
    "\n"
    "; Hard deadline per request — kills a wedged handler and returns 504.\n"
    "(def *handler-timeout-ms* 30000)\n"
    "\n"
    "(defn adapter (request)\n"
    "  \"Bridge an http/server request through the router to a response.\"\n"
    "  (let (conn (conn/build request)\n"
    "        h (task/task\n"
    "            (fn () (conn/conn->response (routes/app-router conn)))\n"
    "            {:timeout *handler-timeout-ms*}))\n"
    "    (receive\n"
    "      ([:task-done ~h resp] (errors/themed resp))\n"
    "      ([:task-error ~h _msg] (errors/error-response 500))\n"
    "      ([:task-timeout ~h] (errors/error-response 504)))))\n"
    "\n"
    "(defn port ()\n"
    "  \"Serve on $HATCH_PORT if set and numeric, else 5000.\"\n"
    "  (or (string->number (or (getenv \"HATCH_PORT\") \"\")) 5000))\n"
    "\n"
    "(defn serve ()\n"
    "  \"Start the HTTP listener on `(port)`.\"\n"
    "  (server/start (port) adapter (live/live-dispatcher) {}))\n"))

(defn project--hatch-layout-template (nm)
  (str "(defmodule web/layout \"Shared HTML page shell — Tailwind + daisyUI via CDN.\"\n"
    "  (:use web/template))\n"
    "\n"
    "(defn layout (title & children)\n"
    "  [:html {:data-theme \"light\"}\n"
    "    [:head {}\n"
    "      [:meta {:charset \"utf-8\"}]\n"
    "      [:meta {:name \"viewport\" :content \"width=device-width, initial-scale=1\"}]\n"
    "      [:title {} title]\n"
    "      [:link {:rel \"stylesheet\"\n"
    "              :href \"https://cdn.jsdelivr.net/npm/daisyui@4/dist/full.min.css\"}]\n"
    "      [:script {:src \"https://cdn.tailwindcss.com\"} \"\"]]\n"
    "    [:body {:class \"min-h-screen bg-base-100 text-base-content\"}\n"
    "      [:div {:class \"navbar bg-base-300 shadow-sm sticky top-0 z-50\"}\n"
    "        [:div {:class \"navbar-start\"}\n"
    "          [:a {:href \"/\" :class \"btn btn-ghost text-xl\"} \"" nm "\"]]\n"
    "        [:div {:class \"navbar-end\"}\n"
    "          [:a {:href \"/messages\" :class \"btn btn-ghost btn-sm\"} \"Messages\"]]]\n"
    "      [:main {:class \"max-w-2xl mx-auto p-6\"} children]]])\n"))

(defn project--hatch-routes-template (_nm)
  (str "(defmodule web/routes \"HTTP routes — session + CSRF protected.\"\n"
    "  (:use web/router)\n"
    "  (:alias web/session)\n"
    "  (:alias web/csrf))\n"
    "\n"
    "; Set $SECRET_KEY_BASE in production. Never ship this dev fallback.\n"
    "(def session-secret\n"
    "  (or (getenv \"SECRET_KEY_BASE\") \"dev-only-insecure-secret-change-me\"))\n"
    "\n"
    "(defrouter app-router\n"
    "  (get \"/\" web/views/home/index)\n"
    "  (through [(session/fetch-session session-secret) session/fetch-flash csrf/protect-from-forgery]\n"
    "    (get \"/messages\" web/views/messages/index)\n"
    "    (post \"/messages\" web/views/messages/create)))\n"))

(defn project--hatch-home-template (nm)
  (str "(defmodule web/views/home \"Home page.\"\n"
    "  (:use web/page)\n"
    "  (:use web/layout))\n"
    "\n"
    "(defn index (conn)\n"
    "  \"GET / — welcome page.\"\n"
    "  (page conn\n"
    "    (layout \"" nm "\"\n"
    "      [:h1 {:class \"text-3xl font-bold mb-4\"} \"Welcome to " nm "!\"]\n"
    "      [:p {:class \"mb-4 opacity-70\"} \"A Hatch web app backed by PostgreSQL.\"]\n"
    "      [:a {:href \"/messages\" :class \"btn btn-primary\"} \"View messages\"])))\n"))

(defn project--hatch-messages-view-template (_nm)
  (str "(defmodule web/views/messages\n"
    "  \"GET /messages — list messages + form. POST /messages — insert + redirect.\"\n"
    "  (:use web/page)\n"
    "  (:use web/layout)\n"
    "  (:use web/conn)\n"
    "  (:alias web/session)\n"
    "  (:alias web/csrf)\n"
    "  (:alias db))\n"
    "\n"
    "(defn index (conn)\n"
    "  \"GET /messages — render the message board.\"\n"
    "  (let (msgs (db/all-messages))\n"
    "    (page conn\n"
    "      (layout \"Messages\"\n"
    "        [:h1 {:class \"text-2xl font-bold mb-4\"} \"Message board\"]\n"
    "        (flash-banner conn)\n"
    "        (message-list msgs)\n"
    "        (new-message-form conn)))))\n"
    "\n"
    "(defn flash-banner (conn)\n"
    "  \"One-shot success banner from the flash, or nothing.\"\n"
    "  (let (msg (web/session/get-flash conn \"info\"))\n"
    "    (if (nil? msg) \"\" [:div {:class \"alert alert-success mb-4\"} [:span {} msg]])))\n"
    "\n"
    "(defn message-list (msgs)\n"
    "  \"Render message cards, or an empty-state prompt.\"\n"
    "  (if (empty? msgs)\n"
    "    [:p {:class \"opacity-60 mb-6\"} \"No messages yet -- be the first!\"]\n"
    "    [:div {:class \"space-y-3 mb-6\"}\n"
    "      (map (fn (m)\n"
    "             [:div {:class \"card bg-base-200\"}\n"
    "               [:div {:class \"card-body py-3\"}\n"
    "                 [:p {:class \"font-semibold\"} (get m :name)]\n"
    "                 [:p {} (get m :body)]]])\n"
    "           msgs)]))\n"
    "\n"
    "(defn new-message-form (conn)\n"
    "  \"The form to post a new message.\"\n"
    "  [:form {:method \"post\" :action \"/messages\" :class \"card bg-base-200\"}\n"
    "    [:div {:class \"card-body space-y-3\"}\n"
    "      [:h2 {:class \"card-title\"} \"Post a message\"]\n"
    "      (web/csrf/csrf-input conn)\n"
    "      [:label {:class \"label\"} [:span {:class \"label-text\"} \"Name\"]]\n"
    "      [:input {:name \"name\" :placeholder \"Your name\"\n"
    "               :class \"input input-bordered w-full\"}]\n"
    "      [:label {:class \"label\"} [:span {:class \"label-text\"} \"Message\"]]\n"
    "      [:textarea {:name \"body\" :rows \"3\" :placeholder \"Say something...\"\n"
    "                  :class \"textarea textarea-bordered w-full\"} \"\"]\n"
    "      [:div {:class \"card-actions\"}\n"
    "        [:button {:class \"btn btn-primary\"} \"Post\"]]]])\n"
    "\n"
    "(defn create (conn)\n"
    "  \"POST /messages -- validate, insert into Postgres, and PRG-redirect.\"\n"
    "  (let (name (or (param conn \"name\") \"\")\n"
    "        body (or (param conn \"body\") \"\"))\n"
    "    (if (or (blank? name) (blank? body))\n"
    "      (-> conn\n"
    "        (web/session/put-flash \"info\" \"Name and message are required.\")\n"
    "        (redirect-resp \"/messages\"))\n"
    "      (do\n"
    "        (db/insert-message {:name name :body body})\n"
    "        (-> conn\n"
    "          (web/session/put-flash \"info\" \"Message posted!\")\n"
    "          (redirect-resp \"/messages\"))))))\n"))

(defn project--hatch-main-test-template (_nm)
  (str ";; Smoke test: ensure main loads without error.\n"
    "(defmodule main-test (:use main) (:use test))\n"
    "\n"
    "(describe \"main\"\n"
    "  (test \"main is callable\" (is (fn? main))))\n"))

(defn project--hatch-messages-test-template (_nm)
  (str ";; Pure rendering tests for web/views/messages -- no database needed.\n"
    ";; (db/*repo* starts nil at load time; DB functions are only called at request time.)\n"
    "(defmodule web-views-messages-test\n"
    "  (:use test)\n"
    "  (:use web/template :only [render])\n"
    "  (:use web/views/messages :only [message-list]))\n"
    "\n"
    "(describe \"message-list\"\n"
    "  (test \"empty state shows invitation\"\n"
    "    (is (> (index-of (render (message-list (list))) \"No messages yet\") -1)))\n"
    "  (test \"renders message name and body\"\n"
    "    (let (html (render (message-list (list {:id 1 :name \"Ada\" :body \"Hello!\"}))))\n"
    "      (is (> (index-of html \"Ada\") -1))\n"
    "      (is (> (index-of html \"Hello!\") -1)))))\n"))

;; (new-project "foobar") — scaffold ./foobar with a runnable two-module
;; skeleton: project.blsp + src/main.blsp + src/hello.blsp (where main `require`s
;; hello and calls into it) + a paired test file for each, so `cd foobar && nest
;; test` *and* `nest run` both pass immediately. Also drops CLAUDE.md +
;; docs/brood-for-claude.md (the baked-in language guide) + a
;; .claude/skills/writing-brood skill, so the project is self-contained for
;; AI-assisted editing. Errors on a bad name; an existing folder is reused (its
;; scaffold files overwritten), not rejected.
(def *project-templates* ["default" "tui-loop" "gen" "editor" "gui" "hatch"])

;; Write the template-specific src/ + tests/ files; return the list of relative
;; paths written (for the summary). The shared files (manifest, CLAUDE.md, guide,
;; …) are written by the caller; only the starter code varies by template.
(defn project--write-template (tmpl nm src-dir tests-dir actual-name)
  (cond
    (= tmpl "tui-loop") (do
                          (spit (path-join src-dir "main.blsp")
                            (project--tui-main-template actual-name))
                          (spit (path-join tests-dir "main_test.blsp")
                            (project--tui-test-template actual-name))
                          [(str nm "/src/main.blsp") (str nm "/tests/main_test.blsp")])
    (= tmpl "gen") (do
                     (spit (path-join src-dir "main.blsp")
                       (project--gen-main-template actual-name))
                     (spit (path-join tests-dir "main_test.blsp")
                       (project--gen-test-template actual-name))
                     [(str nm "/src/main.blsp") (str nm "/tests/main_test.blsp")])
    (= tmpl "editor") (do
                        (spit (path-join src-dir "main.blsp")
                          (project--editor-main-template actual-name))
                        (spit (path-join tests-dir "main_test.blsp")
                          (project--editor-test-template actual-name))
                        [(str nm "/src/main.blsp") (str nm "/tests/main_test.blsp")])
    (= tmpl "gui") (do
                     (spit (path-join src-dir "main.blsp") (project--gui-main-template actual-name))
                     (spit (path-join tests-dir "main_test.blsp")
                       (project--gui-test-template actual-name))
                     [(str nm "/src/main.blsp") (str nm "/tests/main_test.blsp")])
    (= tmpl "hatch") (let (web-dir (path-join src-dir "web")
                           views-dir (path-join web-dir "views")
                           tests-web-dir (path-join tests-dir "web")
                           tests-views-dir (path-join tests-web-dir "views"))
                       (make-dir web-dir)
                       (make-dir views-dir)
                       (make-dir tests-web-dir)
                       (make-dir tests-views-dir)
                       (spit (path-join nm "project.blsp") (project--hatch-manifest-template actual-name))
                       (spit (path-join src-dir "main.blsp") (project--hatch-main-template actual-name))
                       (spit (path-join src-dir "db.blsp") (project--hatch-db-template actual-name))
                       (spit (path-join src-dir "db-setup.blsp") (project--hatch-db-setup-template actual-name))
                       (spit (path-join web-dir "endpoint.blsp") (project--hatch-endpoint-template actual-name))
                       (spit (path-join web-dir "layout.blsp") (project--hatch-layout-template actual-name))
                       (spit (path-join web-dir "routes.blsp") (project--hatch-routes-template actual-name))
                       (spit (path-join views-dir "home.blsp") (project--hatch-home-template actual-name))
                       (spit (path-join views-dir "messages.blsp") (project--hatch-messages-view-template actual-name))
                       (spit (path-join tests-dir "main_test.blsp") (project--hatch-main-test-template actual-name))
                       (spit (path-join tests-views-dir "messages_test.blsp") (project--hatch-messages-test-template actual-name))
                       [(str nm "/src/main.blsp") (str nm "/src/db.blsp")
                         (str nm "/src/db-setup.blsp")
                         (str nm "/src/web/endpoint.blsp") (str nm "/src/web/layout.blsp")
                         (str nm "/src/web/routes.blsp")
                         (str nm "/src/web/views/home.blsp") (str nm "/src/web/views/messages.blsp")
                         (str nm "/tests/main_test.blsp")
                         (str nm "/tests/web/views/messages_test.blsp")])
    else (do
           (spit (path-join src-dir "main.blsp") (project--main-template actual-name))
           (spit (path-join src-dir "hello.blsp") (project--hello-template actual-name))
           (spit (path-join tests-dir "main_test.blsp") (project--main-test-template actual-name))
           (spit (path-join tests-dir "hello_test.blsp") (project--hello-test-template actual-name))
           [(str nm "/src/main.blsp") (str nm "/src/hello.blsp")
             (str nm "/tests/main_test.blsp")
             (str nm "/tests/hello_test.blsp")])))

(defn new-project (nm &optional template)
  "Scaffold a new project named `nm` (or `\".\"` for the current directory, taking the project name from the cwd's basename): a `project.blsp` manifest, the baked-in language guide, and starter code chosen by `template` — `\"default\"` (a `main`+`hello` module pair, the default), `\"tui-loop\"` (a tail-recursive animation loop), `\"gen\"` (a stateful gen_server process), `\"editor\"` (a tiny text editor on the `ui` framework), `\"gui\"` (a windowed app on the `ui` framework, opened with `(gui-display)` — needs a `--features gui` runtime), or `\"hatch\"` (a Hatch web app with a Postgres-backed message board — requires hatch + store-postgres as sibling path deps; run `nest run --main db-setup` once to create the database, then `nest run` to start). Existing scaffold files are overwritten, not rejected. Backs `nest new [--template …]`."
  ;; `nest new .` scaffolds into the current directory (cargo init's shape);
  ;; the project name is then the cwd's basename. Both forms — `nest new .` and
  ;; `nest new foobar` — *overwrite* existing scaffold files rather than
  ;; refusing on an existing folder: re-running `new` re-stamps the skeleton.
  ;; `reusing-dir` only drives the printed summary.
  (let (in-place (= nm ".")
        actual-name (if in-place (path-basename (cwd)) nm)
        reusing-dir (file-exists? nm)
        tmpl (or template "default"))
    (unless (includes? *project-templates* tmpl)
      (error "new: unknown template '" tmpl "' (use one of: " (join ", " *project-templates*) ")"))
    (unless (or in-place (project--valid-name? nm))
      (error "new: invalid project name '" nm "' (no '/' or spaces, and not empty)"))
    (when (and in-place (= actual-name ""))
      (error "new: cwd has no basename — cannot derive a project name"))
    (let (src-dir (path-join nm "src")
          tests-dir (path-join nm "tests")
          docs-dir (path-join nm "docs")
          skill-dir (path-join nm ".claude/skills/writing-brood"))
      (make-dir src-dir)
      (make-dir tests-dir)
      (make-dir docs-dir)
      (make-dir skill-dir)
      (spit (path-join nm "project.blsp") (project--manifest-template actual-name))
      (spit (path-join nm ".gitignore") (project--gitignore-template))
      (spit (path-join nm ".gitattributes") (project--gitattributes-template))
      (spit (path-join nm "CLAUDE.md") (project--claude-md-template actual-name))
      (spit (path-join nm ".mcp.json") (project--mcp-json-template actual-name))
      (spit (path-join docs-dir "brood-for-claude.md") (%builtin-doc 'brood-for-claude))
      (spit (path-join skill-dir "SKILL.md") (%builtin-doc 'writing-brood-skill))
      (let (code-files (project--write-template tmpl nm src-dir tests-dir actual-name))
        (println (str "Created Brood project '"
                   actual-name
                   "'"
                   (if (= tmpl "default") "" (str " [" tmpl " template]"))
                   (cond
                     in-place " (in-place — files in current directory overwritten)"
                     reusing-dir " (existing files overwritten)"
                     else "")))
        (println (str "  " nm "/project.blsp"))
        (println (str "  " nm "/.gitignore"))
        (println (str "  " nm "/.gitattributes"))
        (println (str "  " nm "/CLAUDE.md"))
        (println (str "  " nm "/.mcp.json"))
        (println (str "  " nm "/docs/brood-for-claude.md"))
        (println (str "  " nm "/.claude/skills/writing-brood/SKILL.md"))
        (dolist (f code-files) (println (str "  " f))))
      (when *config-git-init*
        (if (= 0 (run-process "git" (list "init" "-q" nm)))
          (println "  initialized a git repository")
          (println "  (git init failed)")))
      (println (if in-place
                 "Next:  nest test && nest run"
                 (str "Next:  cd " nm " && nest test && nest run")))
      nm)))
