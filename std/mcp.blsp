(defmodule mcp
  "Model Context Protocol tool surface for `nest mcp` (ADR-036, docs/mcp.md).

The dispatcher in `crates/nest/src/mcp.rs` reads `(mcp-tools)` on every
`tools/list` *and* `tools/call`, so a `def` in a previous `eval` (hot reload,
ADR-013) reshapes the surface immediately ŌĆö and a project's own `mcp.blsp`
can shadow this entire catalogue (step 5 territory; the dispatcher already
does the right thing if the project rebinds `mcp-tools`).

Each catalogue entry is a map: `:name` (string, the MCP tool name),
`:description` (optional, agent-visible), `:schema` (JSON Schema for the
arguments ŌĆö a Brood map projected to JSON by the dispatcher), and `:handler`
(a function `(handler args-map)` returning the tool's result; the dispatcher
JSON-ifies the return value and wraps it in MCP's content envelope).

Args arrive as a *keyword-keyed* Brood map (JSON object keys become Brood
keywords) ŌĆö so `(get args :source)` is the idiomatic accessor. Handlers
return Brood data (nil, bool, int, float, string, keyword/symbol,
list/vector, map). Closures, refs, pids etc. can't be JSON-ified and surface
as errors."
  (:use format)
  (:use project))

;; ---- handlers --------------------------------------------------------------
;; Each handler is `(handler args-map) -> result-map`. Handlers `throw` on
;; argument-shape problems (the dispatcher renders the throw as a JSON-RPC
;; error); soft failures (an unbound name in `lookup`, a parse error in `eval`)
;; become a typed field in the returned map so the agent can branch on it
;; without re-parsing an error string.

;; Coerce a caught value into the structured error shape MCP tools return.
;; Built-in errors are already maps (`{:kind :code :message :file :line :col
;; :hint}` ŌĆö see `LispError::to_value_map` in the kernel); user `(throw v)`s
;; come through as the value itself, so we wrap them as `{:kind :user :payload
;; v}` to keep `:error` always a map for the agent's JSON consumers. The
;; asymmetry ŌĆö built-in vs user ŌĆö is deliberate per `docs/llm-native.md` ┬¦4.
(defn mcp--error-shape (e)
  (if (map? e) e {:kind :user :payload e}))

(defn mcp-eval-tool (args)
  "`eval` ŌĆö evaluate `:source` in the session's global env. State persists
across calls (hot reload, ADR-013): a `def` here is visible to the next call
and to spawned processes. Returns `{:value pr-str-of-result}` on success and
`{:error msg}` on failure; the dispatcher catches `throw`s, but a parse/eval
error inside the user expression surfaces here as the `:error` branch."
  (let (src (get args :source))
    (when (not (string? src))
      (throw "eval: :source must be a string"))
    (try
      (let (form (read-string src)
            value (eval form))
        {:value (pr-str value)})
      (catch e
        {:error (mcp--error-shape e)}))))

;; Cross-file shadow warnings involving `file`: the *qualified* names
;; (`ns/name`, per `project--file-def-names`) this file defines that another
;; project source file also defines. Namespace-sound (ADR-065) ŌĆö a short name
;; reused across distinct namespaces is not a collision, only a same-namespace
;; (or ambient/root) rebinding is. Empty (and silent) outside a project.
;; Best-effort ŌĆö never raises.
(defn mcp--shadows-for (file)
  (try
    (let (root (project/project--find-root (cwd)))
      (if (nil? root)
        nil
        (let (defined (project--file-def-names file))
          (filter (fn (w) (some? (fn (nm) (string-contains? w (str "'" nm "'"))) defined))
            (project--duplicate-def-warnings (project--source-files root))))))
    (catch _ nil)))

(defn mcp-load-tool (args)
  "`load` ŌĆö load a `.blsp` file into the session and check it. Side-effects
(`def`, `defn`, `defmacro`) persist. Returns `{:ok true :diagnostics [...]
:shadows [...]}` ŌĆö `diagnostics` are advisory `{:file :line :col :message}`
type/arity/unbound/non-tail-recursion warnings from `check-file-structured`;
`shadows` flags names this file defines that another project source file also
defines (the silent flat-namespace collision). On a load error:
`{:ok false :error msg}`."
  (let (file (get args :file))
    (when (not (string? file))
      (throw "load: :file must be a string"))
    (try
      (do
        (load file)
        {:ok true
         :diagnostics (or (check-file-structured file) [])
         :shadows (or (mcp--shadows-for file) [])})
      (catch e
        {:ok false :error (mcp--error-shape e)}))))

;; ---- the project sandbox for write/edit -----------------------------------
;; Every file the MCP server writes goes through `mcp--project-path`, which
;; refuses to resolve anything outside `*project-root*`. That's the whole
;; guarantee the `write`/`edit` tools rest on: an agent driving nest mcp can only
;; touch files **inside the project it serves**, never the wider filesystem.

(defn mcp--safe-rel? (rel)
  "Whether `rel` is a safe project-relative path: a non-empty string, not
absolute (`/ŌĆ”`) or home-anchored (`~ŌĆ”`), with no `..` segment that could climb
out of the project. Purely lexical ŌĆö symlinks inside the tree aren't chased (an
acceptable bar for a project-scoped tool)."
  (and (string? rel)
    (> (string-length rel) 0)
    (not (starts-with? rel "/"))
    (not (starts-with? rel "~"))
    (not (includes? (string-split rel "/") ".."))))

(defn mcp--project-path (rel)
  "Resolve project-relative `rel` to an absolute path under `*project-root*`, or
`throw` if it would escape the project (an absolute/`~`/`..` path, or no project
root at all). The sandbox boundary the `write`/`edit` tools share."
  (when (nil? *project-root*)
    (throw "no project root ŌĆö nest mcp must run inside a Brood project"))
  (when (not (mcp--safe-rel? rel))
    (throw (str "path must be project-relative ŌĆö no leading '/' or '~', no '..': " (pr-str rel))))
  (path-join *project-root* rel))

(defn mcp-write-tool (args)
  "`write` ŌĆö create or overwrite a project file through the live image. `:path`
is **project-relative** (sandboxed under the project root ŌĆö an absolute path,
`~`, or any `..` segment is rejected); `:content` is the full new file contents.
Missing parent directories are created. A `.blsp` file is then loaded into the
session and checked, so the result carries `:diagnostics` and `:shadows` exactly
like the `load` tool ŌĆö closing the editŌåÆloadŌåÆcheck loop in one call; any other
file is written verbatim. Returns `{:ok true :path rel :diagnostics [...]
:shadows [...]}` or `{:ok false :error ...}`. This is how an agent writes code ŌĆö
through nest mcp, never the raw filesystem."
  (let (rel (get args :path)
        content (get args :content))
    (when (not (string? content))
      (throw "write: :content must be a string"))
    (try
      (let (abs (mcp--project-path rel)
            _dir (make-dir (parent-dir abs))
            _w (spit abs content))
        (if (ends-with? rel ".blsp")
          (assoc (mcp-load-tool {:file abs}) :path rel)
          {:ok true :path rel}))
      (catch e
        {:ok false :error (mcp--error-shape e)}))))

(defn mcp-edit-tool (args)
  "`edit` ŌĆö exact-string replacement in a project file through the live image.
`:path` is **project-relative** (the same sandbox as `write`); `:old` must occur
**exactly once** in the file (so the edit is unambiguous) and is replaced by
`:new`. A `.blsp` file is reloaded and checked afterwards (result carries
`:diagnostics`/`:shadows`, like `load`). Returns `{:ok true :path rel ...}`, or
`{:ok false :error msg}` when the file is missing, or `:old` is absent or not
unique. The editor's exact-replace Edit, routed through nest mcp so the session
image stays in sync with disk."
  (let (rel (get args :path)
        old (get args :old)
        new (get args :new))
    (when (not (string? old))
      (throw "edit: :old must be a string"))
    (when (not (string? new))
      (throw "edit: :new must be a string"))
    (when (= old "")
      (throw "edit: :old must be non-empty"))
    (try
      (let (abs (mcp--project-path rel))
        (if (not (file-exists? abs))
          {:ok false :error (str "edit: no such file: " rel)}
          (let (text (slurp abs)
                hits (- (count (string-split text old)) 1))
            (cond
              (= hits 0) {:ok false :error (str "edit: :old not found in " rel)}
              (> hits 1) {:ok false
                          :error (str "edit: :old occurs " hits " times in " rel " ŌĆö make it unique")}
              :else (let (_w (spit abs (replace text old new)))
                      (if (ends-with? rel ".blsp")
                        (assoc (mcp-load-tool {:file abs}) :path rel)
                        {:ok true :path rel}))))))
      (catch e
        {:ok false :error (mcp--error-shape e)}))))

(defn mcp-lookup-tool (args)
  "`lookup` ŌĆö describe a global name. Returns `{:name :arglist :doc
:source-location}` (arglist a list of param symbols incl. `&optional`/`&`
markers; doc a string or nil; source-location `[file line col]` or nil).
Unbound names come back as `{:name :error}` rather than a thrown error, so
the agent can branch on `(get r :error)` cleanly."
  (let (name (get args :name))
    (when (not (string? name))
      (throw "lookup: :name must be a string"))
    (let (sym (read-string name))
      (try
        ;; `arglist` and `doc` want the *function value*; `(eval sym)`
        ;; resolves the name. `source-location` wants the symbol itself.
        (let (val (eval sym))
          {:name name
           :arglist (arglist val)
           :doc (doc val)
           :source-location (source-location sym)})
        (catch e
          {:name name :error (mcp--error-shape e)})))))

(defn mcp-macroexpand-tool (args)
  "`macroexpand` ŌĆö expand `:form` (a source string) once (`:mode \"1\"`, the
default) or recursively (`:mode \"all\"`). Returns `{:expanded pr-str}`.
Reads the form ourselves rather than letting it interpolate into surrounding
text ŌĆö unbalanced parens in `:form` can't break the host expression."
  (let (src (get args :form)
        mode (get args :mode))
    (when (not (string? src))
      (throw "macroexpand: :form must be a string"))
    (try
      (let (form (read-string src)
            out (if (= mode "all")
                  (macroexpand form)
                  (macroexpand-1 form)))
        {:expanded (pr-str out)})
      (catch e
        {:error (mcp--error-shape e)}))))

(defn mcp-format-tool (args)
  "`format` ŌĆö reformat `:source` via `std/format.blsp`'s `(format-source ...)`.
Idempotent. The require is lazy and cached, so the per-call cost is a hash
check after the first invocation."
  (require 'format)
  (let (src (get args :source))
    (when (not (string? src))
      (throw "format: :source must be a string"))
    (try
      {:formatted (format-source src)}
      (catch e
        {:error (mcp--error-shape e)}))))

(defn mcp-check-tool (args)
  "`check` ŌĆö advisory type-check the project. Returns
`{:diagnostics [{:file :line :col :message} ...]}` (one entry per warning,
position omitted when the checker can't supply one ŌĆö ADR-024). Backed by
`(check-project-structured)` in `std/project.blsp` (step 1c-a). `(or ŌĆ” [])`
so a clean project renders as `{:diagnostics []}` rather than `{:diagnostics
null}` ŌĆö agents shouldn't have to disambiguate \"no warnings\" from
\"missing field\"."
  (require 'project)
  (try
    {:diagnostics (or (check-project-structured) [])}
    (catch e
      {:error (str e)})))

(defn mcp-run-tests-tool (args)
  "`run-tests` ŌĆö run the project test suite. Returns the structured runner
result from `(run-project-tests-structured)` ŌĆö `{:total :passed :failed
:failed-assertions :ms :results [{:group :name :passed :ms :failures ...}]}`.
Outside a Brood project, returns `{:error msg}`."
  (require 'project)
  (try
    (run-project-tests-structured)
    (catch e
      {:error (str e)})))

(defn mcp-processes-tool (args)
  "`processes` ŌĆö snapshot every live green process with its runtime stats.
Returns `{:processes [{:id :pid :node :name :status :mailbox :memory
:collections :reductions :monitored-by :parent} ...]}` ŌĆö the same
`(process-info pid)` map the observer reads, so an agent sees mailbox
backlog, cumulative reductions (Erlang's work counter ŌĆö is it busy?),
heap bytes, GC count and monitors per process, not just the id. Order
is unspecified ŌĆö sort by `:id` (or `:reductions` to find the busiest)
if you need stability. A process that dies mid-snapshot is dropped
(`process-info` ŌåÆ nil, filtered). `(or ŌĆ” [])` so an empty runtime
renders as JSON `[]` rather than `null`."
  {:processes (filter (fn (p) (not (nil? p)))
                (map process-info (or (list-processes) [])))})

(defn mcp--pid-by-id (id)
  "The live local pid whose numeric id is `id`, or nil if none. Lets the
`process-info` tool take the plain integer id an agent sees in a
`processes` listing rather than a reconstructed pid value."
  (first (filter (fn (p)
                   (let (info (process-info p))
                     (and (not (nil? info)) (= (get info :id) id))))
           (or (list-processes) []))))

(defn mcp-process-info-tool (args)
  "`process-info` ŌĆö the full stat map for a single process by `:id` (an
integer from a `processes` listing). Returns the `(process-info pid)`
map (`{:id :pid :node :name :status :mailbox :memory :collections
:reductions :monitored-by :parent}`), or `{:error msg}` if no live
process carries that id."
  (let (id (get args :id))
    (when (not (int? id))
      (throw "process-info: :id must be an integer"))
    (let (pid (mcp--pid-by-id id))
      (if (nil? pid)
        {:error (str "no live process with id " id)}
        (process-info pid)))))

(defn mcp-node-tool (args)
  "`node` ŌĆö runtime-wide stats, the header the observer shows: which node
this is, the scheduler's worker-thread pool size, the high-water marks
for concurrency and memory, the total processes spawned since start,
the current live-process count, current/peak memory, and connected
peers. Returns `{:node :workers :peak-threads :spawned :process-count
:mem-bytes :mem-peak :peers}`. The \"is the runtime healthy / busy?\"
overview, complementing per-process `processes`."
  {:node (node-name)
   :workers (worker-threads)
   :peak-threads (peak-threads)
   :spawned (spawn-count)
   :process-count (count (or (list-processes) []))
   :mem-bytes (mem-bytes)
   :mem-peak (mem-peak)
   :peers (or (nodes) [])})

(defn mcp-callers-tool (args)
  "`callers` ŌĆö every reference to the global `:name` across the project's source
and test files, as `{:references [{:file :line :col} ...]}` (1-based line/col).
Cross-file under the flat module model (ADR-019): a global is one binding
everywhere, so this is the union over every project file; locals that merely
share the spelling are excluded. Source-occurrence based (ADR-031) ŌĆö references
synthesised by macros aren't included. Complements `lookup` (which gives the
*definition* site): this gives the *use* sites."
  (let (name (get args :name))
    (when (not (string? name))
      (throw "callers: :name must be a string"))
    {:references (mapcat (fn (f)
                           (try
                             (map (fn (lc) {:file f :line (first lc) :col (second lc)})
                               (references-in-source name (slurp f)))
                             (catch _ nil)))
                   (project--all-files *project-root*))}))

(defn mcp-apropos-tool (args)
  "`apropos` ŌĆö discover globals whose name contains a pattern. Returns
`{:matches [name ...]}` (names as strings, sorted). The way to answer \"does X
exist?\" without guessing names one at a time."
  (let (pattern (get args :pattern))
    (when (not (string? pattern))
      (throw "apropos: :pattern must be a string"))
    {:matches (map name (apropos pattern))}))

(defn mcp-all-globals-tool (args)
  "`all-globals` ŌĆö every globally bound name in the image. Returns
`{:globals [name ...]}` (sorted strings)."
  {:globals (map name (all-globals))})

(defn mcp-doc-search-tool (args)
  "`doc-search` ŌĆö find globals whose docstring contains a query string. Returns
`{:results [{:name :doc} ...]}` ŌĆö searches behaviour, not just names."
  (let (query (get args :query))
    (when (not (string? query))
      (throw "doc-search: :query must be a string"))
    {:results (map (fn (pair) {:name (name (first pair)) :doc (second pair)}) (doc-search query))}))

(defn mcp--bench-loop (form n)
  "Eval `form` `n` more times for timing, discarding the results; returns nil."
  (when (> n 0)
    (eval form)
    (mcp--bench-loop form (- n 1))))

(defn mcp-bench-tool (args)
  "`bench` ŌĆö time evaluating `:source` in the session image. Runs it
`:iterations` times (default 1) and returns `{:ms total :iterations n
:per-iter-ms float :value pr-str-of-last-result}`. Resolution is the
millisecond `now` clock, so time a sub-millisecond expression with a larger
`:iterations` to amortise it. Side effects persist ŌĆö it really runs the code,
like `eval`. Returns `{:error msg}` on failure."
  (let (src (get args :source)
        iters (or (get args :iterations) 1))
    (when (not (string? src))
      (throw "bench: :source must be a string"))
    (when (not (and (int? iters) (> iters 0)))
      (throw "bench: :iterations must be a positive integer"))
    (try
      (let (form (read-string src)
            t0 (now)
            value (eval form)
            _done (mcp--bench-loop form (- iters 1))
            total (- (now) t0))
        {:ms total
         :iterations iters
         :per-iter-ms (/ (* 1.0 total) iters)
         :value (pr-str value)})
      (catch e
        {:error (mcp--error-shape e)}))))

;; ---- catalogue -------------------------------------------------------------

(defn mcp-tools ()
  "The tool catalogue `nest mcp` reads on every `tools/list`/`tools/call`.
A project's own `mcp.blsp` (loaded after this) can replace `mcp-tools` with
its own list that conses additional entries onto this one ŌĆö `def` rebinds
globals (ADR-013), so the dispatcher sees the project's version on its next
fetch.

Eighteen tools work today: the eight v0 tools, `callers` (cross-file
find-references), the three discovery tools `apropos` / `all-globals` /
`doc-search` (search the flat namespace by name or docstring rather than
looking up a name you already know), `bench` (time an expression in the
live image), the runtime-introspection pair `process-info` (one process's
stats by id) and `node` (runtime-wide stats) ŌĆö which, with the now-enriched
`processes`, give an agent the same live view the observer
(`std/observer.blsp`) shows ŌĆö and the project-scoped editing pair `write`
(create/overwrite a file) and `edit` (exact-string replace), both sandboxed
under `*project-root*` so an agent writes code *through* nest mcp rather than
the raw filesystem."
  (list {:name "eval"
         :description "Evaluate a Brood expression in the session's global environment. State persists across calls (hot reload ŌĆö `def` mutates the runtime image, ADR-013)."
         :schema {:type "object"
                  :properties {:source {:type "string" :description "Brood source to evaluate"}}
                  :required ["source"]}
         :handler mcp-eval-tool}
    {:name "load"
     :description "Load a `.blsp` file into the session's image. Side-effects (def/defn/defmacro) persist."
     :schema {:type "object"
              :properties {:file {:type "string" :description "Path to a .blsp file"}}
              :required ["file"]}
     :handler mcp-load-tool}
    {:name "write"
     :description "Create or overwrite a project file (the way to write code through nest mcp, not the raw filesystem). :path is project-relative and sandboxed under the project root ŌĆö absolute paths, '~', and '..' are rejected. A .blsp file is loaded into the session and checked, so the result carries :diagnostics + :shadows like `load`. Returns {:ok true :path :diagnostics :shadows} or {:ok false :error}."
     :schema {:type "object"
              :properties {:path {:type "string" :description "Project-relative file path (no leading '/' or '~', no '..')"}
                           :content {:type "string" :description "Full new file contents"}}
              :required ["path" "content"]}
     :handler mcp-write-tool}
    {:name "edit"
     :description "Exact-string replacement in a project file (sandboxed like `write`). :old must occur exactly once in the file and is replaced by :new. A .blsp file is reloaded and checked (result carries :diagnostics/:shadows). Returns {:ok true :path ...} or {:ok false :error}."
     :schema {:type "object"
              :properties {:path {:type "string" :description "Project-relative file path (no leading '/' or '~', no '..')"}
                           :old {:type "string" :description "Exact text to replace ŌĆö must be unique in the file"}
                           :new {:type "string" :description "Replacement text"}}
              :required ["path" "old" "new"]}
     :handler mcp-edit-tool}
    {:name "lookup"
     :description "Look up a global name: returns its arglist, docstring, and source location (file/line/col)."
     :schema {:type "object"
              :properties {:name {:type "string"
                                  :description "The name to look up (no leading quote)"}}
              :required ["name"]}
     :handler mcp-lookup-tool}
    {:name "macroexpand"
     :description "Macro-expand a form. Default is one step (`:mode \"1\"`); pass `:mode \"all\"` for full expansion."
     :schema {:type "object"
              :properties {:form {:type "string" :description "Source for the form to expand"}
                           :mode {:type "string"
                                  :enum ["1" "all"]
                                  :description "\"1\" (default) or \"all\""}}
              :required ["form"]}
     :handler mcp-macroexpand-tool}
    {:name "format"
     :description "Reformat Brood source. Idempotent ŌĆö formatting the result is a fixed point."
     :schema {:type "object"
              :properties {:source {:type "string" :description "Brood source to reformat"}}
              :required ["source"]}
     :handler mcp-format-tool}
    {:name "check"
     :description "Advisory type-check the project. Returns one diagnostic per warning ({:diagnostics [...]})."
     :schema {:type "object" :properties {}}
     :handler mcp-check-tool}
    {:name "run-tests"
     :description "Run the project test suite. Returns the structured runner result ({:total :passed :failed ...})."
     :schema {:type "object" :properties {}}
     :handler mcp-run-tests-tool}
    {:name "processes"
     :description "Snapshot every live green process with its runtime stats ŌĆö id, name, status, mailbox backlog, memory, GC collections, cumulative reductions (Erlang's work counter), monitors and parent. The same per-process view the observer shows. Returns {:processes [{:id :status :mailbox :reductions ...} ...]}. Sort by :reductions to find the busiest process."
     :schema {:type "object" :properties {}}
     :handler mcp-processes-tool}
    {:name "process-info"
     :description "Full stat map for one process by numeric :id (from a `processes` listing): status, mailbox, memory, collections, reductions, monitors, parent. Returns the process-info map, or {:error msg} if no live process has that id."
     :schema {:type "object"
              :properties {:id {:type "integer"
                                :description "The numeric process id (as shown in `processes`)"}}
              :required ["id"]}
     :handler mcp-process-info-tool}
    {:name "node"
     :description "Runtime-wide stats (the observer's header): node name, scheduler worker count, peak concurrency, total spawned, current live-process count, current/peak memory, connected peers. Returns {:node :workers :peak-threads :spawned :process-count :mem-bytes :mem-peak :peers}."
     :schema {:type "object" :properties {}}
     :handler mcp-node-tool}
    {:name "callers"
     :description "Find every reference to a global name across the project's source and test files (cross-file find-references). Returns {:references [{:file :line :col} ...]}. Complements `lookup`, which gives the definition site."
     :schema {:type "object"
              :properties {:name {:type "string"
                                  :description "The global name to find references to (no leading quote)"}}
              :required ["name"]}
     :handler mcp-callers-tool}
    {:name "apropos"
     :description "Discover globals whose name contains a pattern (substring search over the flat namespace). Returns {:matches [name ...]}. Use this to find out whether something exists before guessing exact names."
     :schema {:type "object"
              :properties {:pattern {:type "string"
                                     :description "Substring to search for in global names"}}
              :required ["pattern"]}
     :handler mcp-apropos-tool}
    {:name "all-globals"
     :description "List every globally bound name in the image (prelude + project), sorted. Returns {:globals [name ...]}."
     :schema {:type "object" :properties {}}
     :handler mcp-all-globals-tool}
    {:name "doc-search"
     :description "Find globals whose docstring contains a query string ŌĆö searches behaviour, not just names. Returns {:results [{:name :doc} ...]}. Complements apropos (which matches names)."
     :schema {:type "object"
              :properties {:query {:type "string" :description "Text to search for in docstrings"}}
              :required ["query"]}
     :handler mcp-doc-search-tool}
    {:name "bench"
     :description "Time evaluating a Brood expression in the session image. Runs it :iterations times (default 1) and returns {:ms :iterations :per-iter-ms :value}. Side effects persist (it really runs the code). Raise :iterations to amortise sub-millisecond expressions against the ms clock."
     :schema {:type "object"
              :properties {:source {:type "string" :description "Brood source to time"}
                           :iterations {:type "integer"
                                        :description "How many times to run it (default 1); raise to amortise sub-ms expressions"}}
              :required ["source"]}
     :handler mcp-bench-tool}))

;; ---- project-defined extensions (step 5b) ---------------------------------
;; If the project root has its own `mcp.blsp`, load it now so it can:
;;   - bind additional `defn`s the catalogue references,
;;   - `def mcp-tools` to a richer list (e.g. wrap the std catalogue:
;;     `(let (base mcp-tools) (defn mcp-tools () (append (base) (list ...))))`).
;; Runs **once**: this whole file body executes once per session (the dispatcher
;; calls `(require 'mcp)` which `provide`s 'mcp early, so subsequent requires
;; are no-ops). Failures in the project mcp.blsp surface as load errors during
;; `nest mcp` startup, which is exactly when the agent's `.mcp.json` would
;; have wired it up ŌĆö the right time for a hard error.
(require 'project)
(let (root (project/project--find-root (cwd)))
  (when root
    (let (project-mcp (path-join root "mcp.blsp"))
      (when (file-exists? project-mcp)
        (load project-mcp)))))
