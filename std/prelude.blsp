;; Brood prelude / core library
;; ------------------------------
;; Most of the language lives here, in Brood itself. Rust provides only a small
;; primitive kernel (see crates/lisp/src/builtins.rs — the `%`-prefixed ops and
;; a few constructors/predicates); everything below is ordinary Brood.
;;
;; Style note: code is made of lists, so parameter lists are written as lists —
;; (defn f (x y) ...). Vectors [ ] are a *data* type (O(1) indexing); they are
;; still accepted in parameter/binding positions, but lists are idiomatic.
;;
;; The very first definition is `defn`, a macro. Everything after it is written
;; with `defn`, so the library is defined exactly the way you would define your
;; own functions — including `+`, which is "just a function".

;; `defn` itself: forwards everything after the name to `fn`, so it inherits
;; both single-clause — (defn f (x) ...) => (def f (fn (x) ...)) — and the
;; multi-clause pattern form — (defn f ((0) 1) ((n) ...)) => (def f (fn ((0) 1) ((n) ...))).
(defmacro defn (name & clauses)
  "Define a global function `name`, forwarding the clauses to `fn` — so it supports both the single-clause form `(defn f (x) body...)` and multi-clause pattern dispatch."
  `(def ~name (fn ~@clauses)))

;; ---- logic ----
(defn not (x)
  "Logical negation: `nil`/`false` become `true`, everything else `false`."
  (if x false true))

;; `empty?` — true for the empty value of any collection. Defined here, before
;; `fold`/`reduce` use it, so it's written with the raw kernel ops (`%eq`,
;; `type-of`, `string-length`, `vector-length`, `map-pairs`) rather than the type
;; predicates / `cond`, which are defined further down. (Not a Rust primitive: the
;; empty list is `nil`, and every other collection's emptiness is a length the
;; kernel already exposes.)
(defn empty? (x)
  "True if `x` is an empty collection (`nil`, `()`, `[]`, `\"\"`, or `{}`)."
  (if (%eq (type-of x) :nil)
    true
    (if (%eq (type-of x) :pair)
      false
      (if (%eq (type-of x) :string)
        (%eq (string-length x) 0)
        (if (%eq (type-of x) :vector)
          (%eq (vector-length x) 0)
          (if (%eq (type-of x) :map)
            (%eq (map-pairs x) nil)
            (throw (str "empty?: not a collection: " (pr-str x)))))))))

;; ---- universal list view ----
;; `seq` is what lets every list-shaped op (map/filter/fold/reduce/…) walk a
;; *map* without callers reaching for `(zip (keys m) (vals m))`: a map becomes
;; its `[k v]` pairs in one O(n) `map-pairs` pass; lists, vectors, strings, and
;; `nil` pass through unchanged. Defined here with raw kernel ops (`%eq`,
;; `type-of`, `map-pairs`) because `fold` calls it before the `map?` predicate /
;; `cond` macro are available.
(defn seq (coll)
  "A list view of `coll`. A map becomes its `[k v]` pairs; lists, vectors, strings, and `nil` pass through. Used by `map`/`filter`/`fold` so they accept any collection."
  (if (%eq (type-of coll) :map) (map-pairs coll) coll))
(def entries map-pairs)

;; ---- folding (the workhorse; tail-recursive, so it is stack-safe) ----
;; The public entry coerces once via `seq`; the inner `fold--loop` then stays in
;; list form for the recursion, so a map costs one extra `map-pairs` pass total
;; rather than O(n) per step.
(defn fold (f acc coll)
  "Left-fold: combine the items of `coll` left-to-right with `(f acc item)`, starting from `acc`. Tail-recursive, so it is stack-safe. Maps fold as their `[k v]` pairs."
  (fold--loop f acc (seq coll)))
(defn fold--loop (f acc coll)
  (if (empty? coll) acc (fold--loop f (f acc (first coll)) (rest coll))))

;; `cons` with its arguments flipped — the workhorse passed to `fold` to build a
;; list in reverse (then reversed once at the end). Hoisted to the top level so
;; the list builders that reverse-accumulate don't each allocate a fresh closure
;; on every call.
(defn flip-cons (acc x) (cons x acc))

(defn reverse (coll) "The items of `coll` in reverse order, as a list." (fold flip-cons nil coll))

;; reduce supports both (reduce f init coll) and (reduce f coll). The 2-arg
;; form must seq-coerce `x` itself before splitting head/tail, because the bare
;; `(first x)`/`(rest x)` calls bypass fold's coercion and a map would error.
(defn reduce (f x & more)
  "Reduce a collection with `f`. Either `(reduce f init coll)` or `(reduce f coll)` (using the first item as the initial value). Maps reduce as their `[k v]` pairs."
  (if (empty? more)
    (let (s (seq x)) (fold f (first s) (rest s)))
    (fold f x (first more))))

;; ---- arithmetic (variadic, built on the 2-arg primitives) ----
;; Multi-arity (ADR-047): the 0/1/2-argument clauses bind their parameters
;; *directly* and call the primitive — no `& xs` rest-list, no `fold`, just one
;; env frame — so the overwhelmingly common 2-argument call (`(+ a b)`) is ~40×
;; cheaper than folding over a variadic rest-list. Only the 3+-argument fallback
;; folds, starting from the first two combined so it never re-walks them. (This
;; is the dogfooding payoff: writing `+` in Brood surfaced the missing
;; multi-arity dispatch; we built that capability rather than moving `+` to Rust
;; — CLAUDE.md "dogfood first; optimize by building the language up".)
(defn +
  "Sum of all arguments (0 with none)."
  (() 0)
  ((a) a)
  ((a b) (%add a b))
  ((a b & more) (fold %add (%add a b) more)))
(defn *
  "Product of all arguments (1 with none)."
  (() 1)
  ((a) a)
  ((a b) (%mul a b))
  ((a b & more) (fold %mul (%mul a b) more)))
(defn -
  "Subtract the rest from `x`; negate `x` if it's the only argument."
  ((x) (%sub 0 x))
  ((a b) (%sub a b))
  ((x & xs) (fold %sub x xs)))
(defn /
  "Divide `x` by the rest; reciprocal of `x` if it's the only argument. Errors on division by zero."
  ((x) (%div 1 x))
  ((a b) (%div a b))
  ((x & xs) (fold %div x xs)))

(defn inc (n) "Return `n` + 1." (%add n 1))
(defn dec (n) "Return `n` - 1." (%sub n 1))

;; ---- comparison & equality (variadic chains over %lt / %eq) ----
;; chain? checks a predicate holds for every adjacent pair: (chain? < (1 2 3)).
(defn chain? (pred xs)
  (if (empty? xs)
    true
    (if (empty? (rest xs))
      true
      (if (pred (first xs) (first (rest xs))) (chain? pred (rest xs)) false))))

;; Binary comparison kernels, hoisted to the top level so the variadic chains
;; below pass an *existing* function to `chain?` rather than allocating a fresh
;; closure on every call. `<` and `=` reuse the `%lt`/`%eq` primitives directly;
;; the swapped/negated ones get a named Brood helper (still policy in Brood).
(defn cmp--gt (a b) (%lt b a))
(defn cmp--le (a b) (not (%lt b a)))
(defn cmp--ge (a b) (not (%lt a b)))

;; Multi-arity like arithmetic above: a direct 2-argument clause (the common
;; case — `(< a b)`, `(= a b)`) calls the primitive with one env frame; the
;; variadic clause chains over adjacent pairs for 3+ (or 0/1, trivially true).
(defn <
  "True if the arguments are in strictly increasing order."
  ((a b) (%lt a b))
  ((& xs) (chain? %lt xs)))
(defn >
  "True if the arguments are in strictly decreasing order."
  ((a b) (%lt b a))
  ((& xs) (chain? cmp--gt xs)))
(defn <=
  "True if the arguments are in non-decreasing order."
  ((a b) (not (%lt b a)))
  ((& xs) (chain? cmp--le xs)))
(defn >=
  "True if the arguments are in non-increasing order."
  ((a b) (not (%lt a b)))
  ((& xs) (chain? cmp--ge xs)))
(defn =
  "True if all arguments are structurally equal."
  ((a b) (%eq a b))
  ((& xs) (chain? %eq xs)))
(defn not=
  "True if the arguments are not all equal."
  ((a b) (not (%eq a b)))
  ((& xs) (not (apply = xs))))

;; ---- control-flow macros ----
;; These read like special forms but are ordinary macros over `if`/`do`/`let`.
;; The compile pass (macroexpand-all) expands them once, so they cost nothing at
;; runtime while the evaluator's core stays just `if`/`do`/`let`/`fn`/… — policy
;; in Brood, mechanism in Rust (ADR-006/008). There is no `while`: data is
;; immutable and there's no local mutation (ADR-026), so loops are recursion (TCO
;; keeps the stack O(1)) or processes.

(defmacro when (test & body)
  "Evaluate `body` (returning the last) when `test` is truthy, else `nil`."
  `(if ~test (do ~@body) nil))

(defmacro unless (test & body)
  "Evaluate `body` (returning the last) when `test` is falsy, else `nil`."
  `(if ~test nil (do ~@body)))

;; `defonce` — define only if the name is not already bound. The point is
;; hot-reload: re-evaluating a file (via `reload-defs` or `load`) re-runs every
;; `def…` form, which would reset top-level state and re-create singletons (a
;; fresh `(spawn …)`, a reopened connection) on every save. `defonce` makes the
;; init run *once* — the value survives reload, exactly like Emacs `defvar`.
;; Idiomatic for global state and resources: (defonce *server* (spawn (serve))),
;; (defonce *registry* {}). Plain behaviour stays `defn`/`def`. To force re-init,
;; restart or re-`def` explicitly. (`bound?` returns false on an unbound symbol,
;; so this is safe on first definition — docs/live-editing.md Stage 1.)
(defmacro defonce (name val)
  "Bind `name` to `val` only if it isn't already bound, so the value survives
hot-reload (cf. Emacs `defvar`). Once bound, re-evaluating is a no-op; restart
or re-`def` to force re-init."
  `(unless (bound? '~name) (def ~name ~val)))

;; `and`/`or` short-circuit left-to-right and return the deciding value, with
;; each subexpression evaluated at most once (a gensym holds it across the test).
(defmacro and (& xs)
  "Logical AND: evaluate left-to-right, short-circuiting on the first falsy value (which it returns); `true` if none. Each argument is evaluated at most once."
  (if (empty? xs)
    true
    (if (empty? (rest xs))
      (first xs)
      (let (g (gensym "and")) `(let (~g ~(first xs)) (if ~g (and ~@(rest xs)) ~g))))))

(defmacro or (& xs)
  "Logical OR: evaluate left-to-right, short-circuiting on the first truthy value (which it returns); `nil` if none. Each argument is evaluated at most once."
  (if (empty? xs)
    nil
    (if (empty? (rest xs))
      (first xs)
      (let (g (gensym "or")) `(let (~g ~(first xs)) (if ~g ~g (or ~@(rest xs))))))))

;; cond: flat test/expr pairs (ADR-004); `else` or `:else` is the catch-all.
(defmacro cond (& clauses)
  "Multi-way branch over `test expr` pairs: return the `expr` of the first truthy `test`. A final `else` (or `:else`) test always matches; `nil` if none do."
  (if (empty? clauses)
    nil
    (let (test (first clauses) expr (first (rest clauses)) more (rest (rest clauses)))
      ;; compare with the `%eq` primitive, not the variadic `=` — `=` builds a
      ;; lambda, and doing that *at expansion time* during the prelude's own
      ;; compile pass would strand a local-env closure (breaks the freeze).
      (if (or (%eq test 'else) (%eq test :else)) expr `(if ~test ~expr (cond ~@more))))))

;; ---- macro expansion --------------------------------------------------------
;; Fully expand `form`'s head macro by iterating the single-step `macroexpand-1`
;; primitive to a fixpoint. Written in Brood, not Rust (ADR-064): the loop's state
;; is an env-bound local the evaluator already roots, so it can't strand a handle
;; across a GC safepoint the way a hand-rooted Rust loop could. `macroexpand-1` is
;; the irreducible single-shot primitive (one expansion, holding nothing across
;; its `apply`); this just drives it. Tail-recursive, so it is O(1) stack.
(defn macroexpand (form)
  "Repeatedly expand `form`'s head macro until the head is no longer a macro call."
  (let (stepped (macroexpand-1 form))
    (if (= stepped form) form (macroexpand stepped))))

;; ---- type predicates --------------------------------------------------------
;; Each is a thin wrapper over `type-of`, the one reflective primitive (it
;; returns the runtime tag as a keyword). These were Rust builtins; since they
;; are expressible in the language they are policy, so they live here — only
;; `type-of` itself is irreducible. (`%eq` not `=`: no dependency on the
;; variadic comparison, and it can't be shadowed by a local `=`.)
(defn nil? (x) "True if `x` is `nil`." (%eq (type-of x) :nil))
(defn pair? (x) "True if `x` is a cons pair." (%eq (type-of x) :pair))
(defn int? (x) "True if `x` is an integer." (%eq (type-of x) :int))
(defn float? (x) "True if `x` is a float." (%eq (type-of x) :float))
(defn bool? (x) "True if `x` is a boolean." (%eq (type-of x) :bool))
(defn string? (x) "True if `x` is a string." (%eq (type-of x) :string))
(defn symbol? (x) "True if `x` is a symbol." (%eq (type-of x) :symbol))
(defn keyword? (x) "True if `x` is a keyword." (%eq (type-of x) :keyword))
(defn vector? (x) "True if `x` is a vector." (%eq (type-of x) :vector))
(defn map? (x) "True if `x` is a map." (%eq (type-of x) :map))
(defn ref? (x) "True if `x` is a `(ref)` token (a unique reference)." (%eq (type-of x) :ref))
(defn pid? (x) "True if `x` is a process id (from `self`/`spawn`)." (%eq (type-of x) :pid))
(defn rope? (x) "True if `x` is a rope (editor buffer text from `string->rope`)." (%eq (type-of x) :rope))
;; `fn?` holds for both Brood closures (:fn) and Rust builtins (:native).
(defn fn? (x)
  "True if `x` is callable (a closure or a primitive)."
  (or (%eq (type-of x) :fn) (%eq (type-of x) :native)))

;; ---- derived predicates ----
(defn number? (x) "True if `x` is an int or a float." (or (int? x) (float? x)))
(defn list? (x) "True if `x` is a proper list (`nil` or a pair)." (or (nil? x) (pair? x)))

;; ---- list aliases & accessors ----
(def car first)
(def cdr rest)
(defn list (& xs) "A list of the given arguments." xs)
(defn second (coll) "The second item of `coll`." (first (rest coll)))
(defn third (coll) "The third item of `coll`." (first (rest (rest coll))))

;; ---- sequence operations ----
(defn map (f coll)
  "A list of `(f x)` for each `x` in `coll`."
  (reverse (fold (fn (acc x) (cons (f x) acc)) nil coll)))

(defn filter (pred coll)
  "A list of the items of `coll` for which `(pred x)` is truthy."
  (reverse (fold (fn (acc x) (if (pred x) (cons x acc) acc)) nil coll)))

(defn append-two (a b) "Concatenate two lists (`a` before `b`)." (fold flip-cons b (reverse a)))

;; Prepend every element of `lst` onto `acc` (so `acc` collects all elements in
;; reverse); `append` folds this over the lists, then reverses once.
(defn append--onto (acc lst) (fold flip-cons acc lst))
(defn append (& lists)
  "Concatenate any number of lists into one, left to right."
  ;; O(total length) and fully tail-recursive — so `mapcat` (via `apply append`)
  ;; stays stack-safe on many/long lists. The previous left fold of `append-two`
  ;; re-reversed the growing accumulator each step, making it O(lists²).
  (reverse (fold append--onto nil lists)))

(defn count (coll)
  "The number of items in `coll` (a list, vector, string, or map)."
  (cond
    (string? coll) (string-length coll)
    (map? coll) (count (map-pairs coll))
    else (fold (fn (acc x) (inc acc)) 0 coll)))
(def length count)

(defn nth-list (coll i d)
  (cond (empty? coll) d (= i 0) (first coll) else (nth-list (rest coll) (- i 1) d)))

(defn nth (coll i & default)
  "The item at index `i` of `coll` (0-based), or `default` (else `nil`) if out of range."
  (if (vector? coll)
    (if (and (>= i 0) (< i (vector-length coll))) (vector-ref coll i) (first default))
    (nth-list coll i (first default))))

;; ---- numeric helpers ----
;; ---- map operations ----
;; Maps are immutable: `assoc`/`dissoc` return a fresh map, never mutate.
;; `{ }` literals and `hash-map` construct them; these wrap the `map-*` kernel
;; primitives with the variadic / default-bearing surface.

;; (get coll k) -> value or nil if absent; (get coll k default) -> value or default.
(defn get (coll k & default)
  "The value at key/index `k` in `coll`, or `default` (else `nil`) if absent.
Maps look up by key; vectors, lists, and strings index by integer position
(out-of-range yields the default, never an error)."
  (cond
    (map? coll) (map-get coll k (first default))
    (string? coll) (if (and (int? k) (>= k 0) (< k (string-length coll)))
                     (char-at coll k)
                     (first default))
    :else (nth coll k (first default))))

;; (assoc m k1 v1 k2 v2 …) -> a fresh map with each pair added/updated.
(defn assoc--pairs (m kvs)
  (if (empty? kvs) m (assoc--pairs (map-assoc m (first kvs) (second kvs)) (rest (rest kvs)))))
(defn assoc (m & kvs)
  "A fresh map like `m` with each `key value` pair added or updated."
  (assoc--pairs m kvs))

;; (dissoc m k1 k2 …) -> a fresh map with each key removed.
(defn dissoc (m & ks)
  "A fresh map like `m` with each of the given keys removed."
  (fold map-dissoc m ks))

;; `map-pairs` (kernel) is the single map enumerator: the entries as a list of
;; [k v] vectors, in one O(n) pass. `keys`/`vals`/`contains?`/`reduce-kv` are all
;; Brood over it — no per-key `get`, so no O(n²) (this replaced the old `map-keys`
;; primitive + get-per-key `vals`).
(defn keys (m) "The keys of map `m`, in insertion order." (map first (map-pairs m)))
(defn vals (m) "The values of map `m`, in insertion order." (map second (map-pairs m)))
(defn contains? (m k)
  "True if map `m` has key `k` (distinguishes a stored `nil`/`false` from
absence). O(1) via the CHAMP hash path (`map-get`), not an O(n) key scan: probe
with two distinct sentinels — a present key returns its stored value both times;
an absent key returns each sentinel, and those differ. (One sentinel can't tell
absence from a key whose *stored value* happens to equal it; two distinct ones
can.)"
  (let (a (map-get m k :%contains-miss-a))
    (if (= a :%contains-miss-a)
      (not (= (map-get m k :%contains-miss-b) :%contains-miss-b))
      true)))
(defn reduce-kv (f init m)
  "Fold over the entries of map `m`, calling `(f acc k v)`, starting from `init`."
  (fold (fn (acc p) (f acc (first p) (second p))) init (map-pairs m)))

;; ---- map: merge / update / nested access -----------------------------------
;; All Brood over the kernel ops (`map-assoc`/`map-pairs`) and the surface above
;; (`reduce-kv`/`contains?`/`get`). Every one returns a fresh map — maps are
;; immutable (ADR-026). The builders fold with the 3-arg kernel `map-assoc` (no
;; per-step rest-list, unlike variadic `assoc`).

(defn merge--into (acc m) (if (nil? m) acc (reduce-kv map-assoc acc m)))
(defn merge (& maps)
  "A single map combining the given maps left to right; on a duplicate key the rightmost map wins. `nil` maps are skipped, so `(merge)` is `{}`."
  (fold merge--into {} maps))

;; merge-with: on a shared key, combine with `(f existing new)` instead of replacing.
(defn merge-with--step (f a k v) (if (contains? a k) (map-assoc a k (f (get a k) v)) (map-assoc a k v)))
(defn merge-with (f & maps)
  "Like `merge`, but when two maps share a key the combined value is `(f value-so-far next-value)` rather than just the latter. `nil` maps are skipped."
  (fold (fn (acc m) (if (nil? m) acc (reduce-kv (fn (a k v) (merge-with--step f a k v)) acc m))) {} maps))

(defn update (m k f & args)
  "A map like `m` with the value at `k` replaced by `(apply f current args)`, where `current` is the existing value (`nil` if `k` is absent)."
  (assoc m k (apply f (get m k) args)))

(defn update-vals (m f)
  "A map like `m` with `f` applied to every value."
  (reduce-kv (fn (acc k v) (map-assoc acc k (f v))) {} m))
(defn update-keys (m f)
  "A map like `m` with `f` applied to every key (later keys win on a collision)."
  (reduce-kv (fn (acc k v) (map-assoc acc (f k) v)) {} m))

(defn select-keys (m ks)
  "A map of just the entries of `m` whose key is in `ks` (keys absent from `m` are skipped)."
  (fold (fn (acc k) (if (contains? m k) (map-assoc acc k (get m k)) acc)) {} ks))

(defn zipmap (ks vs)
  "A map pairing each key in `ks` with the value at the same position in `vs`, stopping at the shorter."
  (into {} (zip ks vs)))

;; Nested-map access along a `path` (a sequence of keys). `get-in` walks; missing
;; key → default. `assoc-in` rebuilds, coercing a non-map node to `{}` so it can
;; create intermediate maps; `update-in` is `get-in` then `assoc-in`.
(defn get-in--walk (m path default)
  (cond
    (empty? path) m
    (and (map? m) (contains? m (first path))) (get-in--walk (get m (first path)) (rest path) default)
    else default))
(defn get-in (m path & default)
  "The value in nested maps `m` at the key sequence `path`, or `default` (else `nil`) if any key along the way is absent. `(get-in m ())` is `m`."
  (get-in--walk m path (first default)))

(defn assoc-in (m path v)
  "A nested copy of `m` with `v` stored at the key sequence `path`, creating intermediate maps as needed (a non-map node along the path becomes a fresh map)."
  (let (m (if (map? m) m {}) k (first path) ks (rest path))
    (if (empty? ks)
      (assoc m k v)
      (assoc m k (assoc-in (get m k) ks v)))))

(defn update-in (m path f & args)
  "A nested copy of `m` with the value at the key sequence `path` replaced by `(apply f current args)` (creating intermediate maps as needed)."
  (assoc-in m path (apply f (get-in m path) args)))

(defn identity (x) "Return `x` unchanged." x)
(defn zero? (n) "True if `n` is zero." (= n 0))
(defn positive? (n) "True if `n` is greater than zero." (> n 0))
(defn negative? (n) "True if `n` is less than zero." (< n 0))
(defn abs (n) "The absolute value of `n`." (if (< n 0) (- n) n))
;; Variadic, fold over the first arg (so at least one is required); a strict `>`
;; keeps the *first* of equal maxima, matching a left fold.
(defn max (x & xs)
  "The largest of the arguments (at least one required)."
  (fold (fn (a b) (if (> b a) b a)) x xs))
(defn min (x & xs)
  "The smallest of the arguments (at least one required)."
  (fold (fn (a b) (if (< b a) b a)) x xs))
(defn sum (xs) "The sum of the numbers in `xs`." (fold %add 0 xs))
(defn product (xs) "The product of the numbers in `xs`." (fold %mul 1 xs))
(defn even? (n) "True if integer `n` is even." (= (rem n 2) 0))
(defn odd? (n) "True if integer `n` is odd." (not (even? n)))

;; Rounding & roots, all Brood over the one Float->Int primitive `floor` (toward
;; -inf) plus `rem`/`/`/`*`. `floor` of an int is itself, so these pass ints
;; through unchanged.
(defn ceil (x) "Round `x` toward positive infinity to an integer." (- (floor (- x))))
;; round half away from zero: floor(x+0.5) for x>=0, mirrored for x<0.
(defn round (x)
  "Round `x` to the nearest integer (halves away from zero)."
  (if (< x 0) (- (floor (+ (- x) 0.5))) (floor (+ x 0.5))))

;; (round-to x places) — round to a fixed number of decimal places, staying a
;; number (for a fixed-width *string*, e.g. "3.10", use the `to-fixed` primitive).
;; Subject to the usual binary-float caveat: a "halfway" decimal like 1.255 isn't
;; exactly representable, so it may round the way its nearest f64 actually lies.
(defn round-to (x places)
  "Round `x` to `places` decimal places (halves away from zero); returns a number."
  (let (scale (pow 10 places)) (/ (round (* x scale)) scale)))

;; (quot a b) — truncated integer division (toward zero), the quotient partner to
;; `rem`. (a - (rem a b)) is exactly divisible by b, so `/` returns an exact int
;; (no float round-trip — correct even for large i64, unlike (floor (/ a b))).
(defn quot (a b)
  "Truncated integer division of `a` by `b` (toward zero); the quotient partner to `rem`."
  (/ (- a (rem a b)) b))

;; (pow base exp) — `exp` must be an integer (use `sqrt` for roots). Int base +
;; non-negative exp stays an int (overflow raises, like `*`); a negative exp gives
;; the reciprocal (a float). Tail-recursive, so a large exponent is O(1) stack.
(defn pow (base exp)
  "`base` raised to integer `exp`. A negative exponent gives the (float) reciprocal."
  (cond
    (not (int? exp)) (error "pow: exponent must be an integer (use sqrt for roots), got " exp)
    (< exp 0) (/ 1 (pow base (- exp)))
    else (pow--acc base exp 1)))
(defn pow--acc (base exp acc) (if (= exp 0) acc (pow--acc base (- exp 1) (* acc base))))

;; (sqrt n) — Newton's method (Babylonian): guess' = (guess + n/guess)/2, iterated
;; to the fixed point. Pure Brood, so it's *approximate* (a few ULPs, not the
;; hardware sqrt) but needs no Rust; redefine it if you ever need bit-exactness.
;; Always returns a Float; a negative argument raises.
(defn sqrt (n)
  "The square root of `n` (Newton's method; always a float). Negative `n` raises."
  (cond (< n 0) (error "sqrt: negative argument " n) (= n 0) 0.0 else (sqrt--iter n (/ n 2.0) 100)))
(defn sqrt--iter (n guess steps)
  (let (next (/ (+ guess (/ n guess)) 2.0))
    (if (or (= steps 0) (= next guess)) next (sqrt--iter n next (- steps 1)))))

;; Euclidean modulo: the result is always non-negative and lies in
;; [0, (abs b)). Brood over the `rem` primitive (truncated remainder), nudged
;; back into range when `rem` comes out negative. (÷0 raises via `rem`.)
;; Note this is *not* floored modulo: `(mod 7 -3)` is 1, not -2.
(defn mod (a b)
  "Euclidean modulo: the result is always non-negative and lies in [0, |b|)."
  (let (r (rem a b)) (if (< r 0) (+ r (abs b)) r)))

;; ---- I/O --------------------------------------------------------------------
;; `print` (no newline) is the primitive; `println` just appends one.
(defn println (& xs)
  "Write the display forms of the arguments to stdout, followed by a newline."
  (apply print xs)
  (print "\n"))
(defn eprintln (& xs)
  "Write the display forms of the arguments to stderr, followed by a newline."
  (apply eprint xs)
  (eprint "\n"))

;; ---- threading macros (demonstrate that macros compute at expansion time) ----
;; (-> x (f a) (g b))  =>  (g (f x a) b)   ; thread as FIRST argument
;; (->> x (f a) (g b)) =>  (g b (f a x))   ; thread as LAST argument
(defn thread-first-step (acc form)
  (if (pair? form) (cons (first form) (cons acc (rest form))) (list form acc)))
(defmacro -> (x & forms)
  "Thread `x` through the forms as each one's *first* argument: `(-> x (f a) (g b))` is `(g (f x a) b)`."
  (reduce thread-first-step x forms))

(defn thread-last-step (acc form) (if (pair? form) (append form (list acc)) (list form acc)))
(defmacro ->> (x & forms)
  "Thread `x` through the forms as each one's *last* argument: `(->> x (f a) (g b))` is `(g b (f a x))`."
  (reduce thread-last-step x forms))

;; ---- error handling ----
;; The kernel gives us `throw` (raise) and `%try` (low-level catch). Everything
;; user-facing — `error`, `try`/`catch` — is written here in Brood.
(defn last (xs) "The last item of `xs`." (first (reverse xs)))
(defn but-last (xs) "All but the last item of `xs`, as a list." (reverse (rest (reverse xs))))

(defn error (& parts)
  "Raise an error whose message is the concatenated display forms of `parts`."
  (throw (apply str parts)))

;; (try body... (catch e handler...)) => (%try (fn () body...) (fn (e) handler...))
;; With no catch clause, it's just (do body...).
(defmacro try (& body)
  "Evaluate `body`; if a final `(catch e handler...)` clause is present, run it with the raised value bound to `e` when `body` throws."
  (let (clause (last body))
    (if (and (pair? clause) (= (first clause) 'catch))
      (let (init (but-last body) evar (second clause) handler (rest (rest clause)))
        `(%try (fn () ~@init) (fn (~evar) ~@handler)))
      `(do ~@body))))

;; ---- dynamic variables ------------------------------------------------------
;; Process-scoped, dynamically-bound variables (Lisp "special" vars), for
;; config-style knobs like *print-depth*. `defdyn` declares one with a default;
;; `binding` rebinds it for the dynamic extent of a body, restoring on exit (even
;; on error). A reference to the var resolves to the innermost active `binding`,
;; else the default. Bindings are per-process — they do NOT reach a `spawn`ed
;; child (it starts from the defaults). The kernel supplies only `%declare-dynamic`,
;; `%binding`, and `dynamic?`; the surface is these two macros (the `try` precedent).

;; (defdyn *x* 10) => declare *x* dynamic, then def its default.
(defmacro defdyn (name default)
  "Declare `name` a dynamic (process-scoped special) variable with the given default, rebindable via `binding`."
  `(do (%declare-dynamic '~name) (def ~name ~default)))

;; Split a flat binding list (*a* va *b* vb) into its names and value forms, at
;; expansion time (like the threading-macro helpers above).
(defn binding--names (b) (if (nil? b) nil (cons (first b) (binding--names (rest (rest b))))))
(defn binding--vals (b) (if (nil? b) nil (cons (second b) (binding--vals (rest (rest b))))))

;; (binding (*a* 1 *b* 2) body...) => (%binding '(*a* *b*) [1 2] (fn () body...))
;; The names go out as a quoted list and the values as a vector literal — both
;; reader/evaluator syntax, never function calls — so a locally-shadowed `list`
;; or `map` can't break the expansion (`fn`/`quote` are special forms).
(defmacro binding (bindings & body)
  "Rebind the dynamic variables in `bindings` (a flat `name value ...` list) for the dynamic extent of `body`, restoring them on exit (even on error)."
  (if (odd? (count bindings))
    (error "binding: bindings must be name/value pairs, got " bindings)
    `(%binding (quote ~(binding--names bindings)) [~@(binding--vals bindings)] (fn () ~@body))))

;; ---- pattern matching -------------------------------------------------------
;; The matcher is written in Brood, not Rust: a pattern->code compiler (a macro
;; plus expand-time helper `defn`s, exactly like the threading macros compute at
;; expansion time) that emits nested `if`/`let` over existing primitives —
;; `pair?`, `first`, `rest`, `nil?`, `vector?`, `vector-ref`, `vector-length`,
;; and `%eq` (the kernel equality op, used by convention over `=` so a local
;; binding named `=` can't hijack a generated match). No new special form (the
;; `try`/`catch` precedent: a macro over primitives). One compiler serves `match`
;; here, and the `let` / `fn` special forms delegate to it for destructuring.
;; See docs/pattern-matching.md.
;; (Note: the other emitted primitives — `first`/`rest`/`pair?`/… — are still
;; ordinary names a local binding could shadow; full macro hygiene is deferred.)
;;
;; THE ONE TRAP: a bare symbol in a pattern *binds* (and shadows); it does not
;; test against a same-named value. Match a known value with a keyword (:ok), a
;; quoted symbol ('none), or a pin (~x). The grammar:
;;   _              wildcard (matches anything, binds nothing)
;;   x              binds x  (a repeated x is an equality constraint — non-linear)
;;   42 "s" :k nil  a literal, matched by =
;;   'sym           the literal symbol sym
;;   ~expr          the current value of expr (a pin)
;;   (p1 p2 ...)    a list of that exact length, element-wise
;;   (p1 & rest)    head(s) + tail bound (the & rest marker)
;;   [p1 p2 ...]    a vector of that exact length (the tagged-data / tuple idiom)

;; -- pattern shape predicates --
(defn match-wildcard? (p) (= p '_))
(defn match-bind-sym? (p) (and (symbol? p) (not (= p '_)) (not (= p '&))))
(defn match-quoted? (p) (and (pair? p) (= (first p) 'quote)))
(defn match-pin? (p) (and (pair? p) (= (first p) 'unquote)))

;; -- expand-time helpers --
(defn match-member? (x xs)
  (cond (empty? xs) false (= x (first xs)) true else (match-member? x (rest xs))))

(defn match-vec->list (v) (match-vec-collect v (dec (vector-length v)) nil))
(defn match-vec-collect (v i acc)
  (if (< i 0) acc (match-vec-collect v (dec i) (cons (vector-ref v i) acc))))

;; The variables a pattern binds. Threaded as `bound` through the compiler so a
;; variable that recurs becomes an equality check (non-linear patterns).
(defn pattern-vars (pat)
  (cond
    (match-wildcard? pat) nil
    (match-bind-sym? pat) (list pat)
    (match-quoted? pat) nil
    (match-pin? pat) nil
    (pair? pat) (match-seq-vars pat)
    (vector? pat) (match-seq-vars (match-vec->list pat))
    else nil))
(defn match-seq-vars (pats)
  (cond
    (empty? pats) nil
    (= (first pats) '&) (match-seq-vars (rest pats))
    else (append (pattern-vars (first pats)) (match-seq-vars (rest pats)))))

;; The core: compile `pat` against the value of the symbol `target`, given the
;; already-`bound` names; on a match run `success`, else `fail`. Returns code.
(defn match-compile (pat target bound success fail)
  (cond
    (match-wildcard? pat) success
    (match-bind-sym? pat) (if (match-member? pat bound)
                            `(if (%eq ~target ~pat) ~success ~fail)
                            ; non-linear: equal to earlier binding
                            `(let (~pat ~target) ~success))
    ; fresh bind
    (match-quoted? pat) `(if (%eq ~target ~pat) ~success ~fail)
    ; 'sym self-evaluates to the symbol
    (match-pin? pat) `(if (%eq ~target ~(second pat)) ~success ~fail)
    ; ~expr: match the value of expr
    (pair? pat) (match-compile-list pat target bound success fail)
    (vector? pat) (match-compile-vector pat target bound success fail)
    else `(if (%eq ~target ~pat) ~success ~fail)))
; literal (number/string/keyword/bool/nil)

;; list pattern: split off an optional `& rest` tail, then bind element-wise.
(defn match-split (pats)
  (cond
    (empty? pats) [nil nil false]
    (= (first pats) '&) (if (= (count (rest pats)) 1)
                          [nil (second pats) true]
                          (error "match: '&' must be followed by exactly one tail pattern"))
    else (let (sub (match-split (rest pats)))
           [(cons (first pats) (nth sub 0)) (nth sub 1) (nth sub 2)])))

(defn match-compile-list (pat target bound success fail)
  (let (parts (match-split pat))
    (match-compile-seq (nth parts 0) (nth parts 1) (nth parts 2) target bound success fail)))

(defn match-compile-seq (pats rest-pat has-rest target bound success fail)
  (if (empty? pats)
    (if has-rest
      (match-compile rest-pat target bound success fail)
      ; bind the rest to what remains
      `(if (nil? ~target) ~success ~fail))
    ; require the list exhausted
    (let (p (first pats)
          hd (gensym "hd")
          tl (gensym "tl")
          inner (match-compile-seq (rest pats)
                  rest-pat
                  has-rest
                  tl
                  (append bound (pattern-vars p))
                  success
                  fail)
          head (match-compile p hd bound inner fail))
      `(if (pair? ~target) (let (~hd (first ~target) ~tl (rest ~target)) ~head) ~fail))))

;; vector pattern: a fixed-length tuple, matched element-wise by index.
(defn match-compile-vector (pat target bound success fail)
  (let (elems (match-vec->list pat) n (count elems))
    (when (match-member? '& elems)
      (error "match: '&' (rest) is not allowed in a vector pattern — vectors are fixed-length"))
    `(if (and (vector? ~target) (%eq (vector-length ~target) ~n))
       ~(match-compile-velems elems target 0 bound success fail)
       ~fail)))

(defn match-compile-velems (pats target i bound success fail)
  (if (empty? pats)
    success
    (let (p (first pats)
          el (gensym "el")
          inner (match-compile-velems (rest pats)
                  target
                  (inc i)
                  (append bound (pattern-vars p))
                  success
                  fail)
          this (match-compile p el bound inner fail))
      `(let (~el (vector-ref ~target ~i)) ~this))))

;; -- clauses: (pattern [:when guard] body...) — one shape for match / fn / receive --
(defn match-parse-clause (clause)
  (if (not (pair? clause))
    (error (str "match: each clause must be a (pattern body...) list, got " (pr-str clause)))
    (let (pat (first clause) more (rest clause))
      (if (= (first more) :when)
        (if (empty? (rest more))
          (error "match: :when must be followed by a guard expression")
          [pat (second more) (rest (rest more))])
        [pat nil more]))))

;; A clause is irrefutable (always matches) iff its pattern is _ or a bare bind
;; and it has no guard. Such a clause must be last; anything after it is dead.
(defn match-irrefutable? (pat guard)
  (and (nil? guard) (or (match-wildcard? pat) (match-bind-sym? pat))))

(defn match-compile-clause (clause target fail)
  (let (parsed (match-parse-clause clause)
        pat (nth parsed 0)
        guard (nth parsed 1)
        body (nth parsed 2)
        success (if (nil? guard) `(do ~@body) `(if ~guard (do ~@body) ~fail)))
    (match-compile pat target nil success fail)))

;; The no-match failure: a structured, catchable, self-describing value carrying
;; the context (:match / :let / a fn name), the value, and the patterns tried.
(defn match-no-match (context target patterns)
  `(throw [:match-error (quote ~context) ~target (quote ~patterns)]))

(defn match-clause-patterns (clauses) (map (fn (c) (if (pair? c) (first c) c)) clauses))

(defn match-check-reachable (clause following)
  (let (parsed (match-parse-clause clause))
    (when (and (match-irrefutable? (nth parsed 0) (nth parsed 1)) (not (empty? following)))
      (error "match: unreachable clause after a catch-all (an irrefutable pattern must come last)"))))

;; Chain the clauses: each clause's fail-continuation is the code for the rest;
;; the innermost fail is the structured no-match throw. Each chosen body lands in
;; tail position of the generated if/let, so a `match` in tail position is TCO-safe.
(defn match-build-from (clauses target fail)
  (if (empty? clauses)
    fail
    (let (clause (first clauses)
          following (rest clauses)
          rest-code (match-build-from following target fail))
      (match-check-reachable clause following)
      (match-compile-clause clause target rest-code))))

(defn match-build (clauses target context)
  (match-build-from clauses target (match-no-match context target (match-clause-patterns clauses))))

;; match* — the shared engine. `context` (a keyword like :match/:let, or a fn
;; name) is embedded in the failure. `match` is the value-dispatch surface; the
;; `let` and `fn` special forms target match* directly with their own context.
(defmacro match* (context expr & clauses)
  (let (v (gensym "m")) `(let (~v ~expr) ~(match-build clauses v context))))

;; (match expr (pattern [:when guard] body...) ...) — match `expr` against each
;; clause in order; the first whose pattern (and guard) matches runs its body.
;; No clause matching crashes with a structured value; add a `_` clause to total it.
(defmacro match (expr & clauses)
  "Match `expr` against each `(pattern [:when guard] body...)` clause, running the first that fits (binding the pattern's variables). Errors if none match."
  `(match* :match ~expr ~@clauses))

;; ---- spawn: run an expression as a new green process ------------------------
;; (spawn expr) runs `expr` in a fresh process and returns its pid. The expression
;; is wrapped in a 0-arg thunk, so its free *locals* are captured lexically (the
;; closure carries them) and its free *globals* resolve in the child — which is why
;; the thunk is shippable to another node (a closure serialises as data; see
;; docs/decisions.md). Note `(self)` inside `expr` is the *child's* pid: to hand the
;; parent's pid in, capture it first — `(let (me (self)) (spawn (work me)))`.
;; `spawn` has two shapes:
;;   (spawn expr)          → anonymous; always creates a fresh process.
;;   (spawn name expr)     → **named & idempotent**. If a process is already
;;                            registered under `name` (a keyword/symbol) and
;;                            is still alive, the call is a no-op and returns
;;                            the existing pid; `expr` is never evaluated.
;;                            Otherwise spawns fresh and registers the new
;;                            pid under `name`.
;;
;; The named form is the replacement for the old `(defonce *worker* (spawn
;; (worker)))` hot-reload pattern (ADR-039). A file containing
;; `(spawn :worker (worker))` reloaded by a hot-reload supervisor sees the
;; name is alive and does nothing — the running worker keeps going with its
;; current state, picking up the new code via the next global lookup of
;; `worker`. When the process dies, its registered name is reaped automatically
;; (`process::deregister` calls `dist::unregister_dead_pid`), so a fresh
;; reload spawns again — no stale entries.
;; spawn — two shapes via arity dispatch:
;;   (spawn expr)         → (%spawn (fn () expr))             — anonymous
;;   (spawn name expr)    → (%spawn-named name (fn () expr))  — idempotent on name
;; The named form replaces the `defonce *worker* (spawn …)` hot-reload
;; pattern (ADR-039). The reloaded file sees the name is alive and the
;; second `(spawn :worker …)` is a no-op — the running worker keeps going,
;; picking up the new code via the next global lookup. When the process
;; dies, its registered name is reaped (`process::deregister` →
;; `dist::unregister_dead_pid`), so a later reload re-spawns cleanly.
(defmacro spawn (head & more)
  "Run an expression in a new green process; returns its pid. Two shapes:
  - `(spawn expr)` — anonymous.
  - `(spawn name expr)` — named & idempotent: returns the existing pid if
    a live process is already registered under `name`. The hot-reload-friendly
    form (reloading the file doesn't fire a second worker).

  Erlang **let-it-crash** (`spawn/1`): an uncaught throw kills the process and
  any monitors see `[:down pid [:error msg]]` immediately."
  ;; Param name is `more` (not `rest`) so the body can still call the
  ;; prelude's `rest` function without param-shadowing itself.
  (if (empty? more)
    `(%spawn (fn () ~head))
    (if (empty? (rest more))
      `(%spawn-named ~head (fn () ~(first more)))
      (throw "spawn: expected (spawn expr) or (spawn name expr)"))))

;; A long-lived `:remote-spawn` server: the receiver-side machinery behind the
;; `remote-spawn` macro. Receives `[:run thunk]` messages and applies the thunk
;; in a fresh local process — that's "the receiver runs my code". A permanent
;; loop so it stays a stable address; the closure crosses the wire as data
;; (ADR-033), so any peer node running the same prelude can run it.
(defn remote--spawn-server ()
  (receive
    ([:run thunk] (do (spawn (thunk)) (remote--spawn-server)))
    (_ (remote--spawn-server))))

(defn start-remote-spawn ()
  "Idempotently start + register the local `:remote-spawn` server so peers can `(remote-spawn this-node …)` against this node. Safe to call multiple times — only the first call spawns a server. Typically called once at startup, after `(node-start …)`."
  (when (nil? (whereis :remote-spawn))
    (register :remote-spawn (spawn (remote--spawn-server))))
  nil)

(defmacro remote-spawn (node expr)
  "Run `expr` in a fresh process on `node` (a node-name keyword/symbol — `(node-name)` for the local node, or a connected peer's). Returns `nil`; the spawned process lives on the remote and runs detached (capture the parent's pid in a `let` and `(send parent (self))` from inside `expr` if you need its pid). `expr` ships as a closure (ADR-033) — free locals ride along, free globals re-resolve on the receiver. The **receiver** must have called `(start-remote-spawn)` (typically right after `node-start`); the macro itself does no setup on either side."
  `(do
     (send {:name :remote-spawn :node ~node} [:run (fn () ~expr)])
     nil))

;; ---- node-link reconnect: policy in Brood over connect + monitor-node ------
;; Today's `(connect addr)` is one-shot; if the peer is down it raises, if it
;; later disconnects nothing notices. `ensure-link` is a thin reconnect loop —
;; a small green process that watches a node via `monitor-node` (persistent,
;; fires on each down) and re-`connect`s with backoff. No Rust support needed:
;; `connect` + `monitor-node` + `receive (after …)` are enough.

;; Split "alpha@127.0.0.1:9000" → :alpha (the keyword). Used internally so the
;; loop can match `[:nodedown peer]` against the address it's maintaining.
(defn ensure-link--peer-name (addr)
  (let (i 0 n (string-length addr))
    (ensure-link--peer-name--scan addr i n)))
(defn ensure-link--peer-name--scan (addr i n)
  (cond
    (>= i n) (error "ensure-link: address missing '@', got " addr)
    (= (substring addr i (inc i)) "@") (keyword (substring addr 0 i))
    else (ensure-link--peer-name--scan addr (inc i) n)))

;; Sleep `ms` milliseconds in the current process. A bare `(receive (after ms …))`
;; would *consume* the next queued message — an empty clause list matches anything,
;; so `%receive` grabs whatever is in the mailbox and returns immediately instead of
;; waiting. We pin a fresh, unforgeable `(ref)` as the only real clause (`~never`):
;; no message can ever match it, so selective receive leaves every real message
;; queued and the timeout always fires. Parks the green process on the scheduler's
;; timer (it does NOT block a worker thread) — which is why sleep is pure Brood
;; rather than a Rust primitive.
(defn sleep (ms)
  "Park the current process for `ms` milliseconds without touching its mailbox — every queued message stays queued. Parks on the scheduler timer; it does not block a worker thread."
  (let (never (ref)) (receive (~never nil) (after ms nil))))

;; Retry `(connect addr)` on a 200ms backoff until it succeeds — used both on
;; first :nodedown and inside the supervisor loop. `monitor-node` is
;; *transition-triggered* (fires when the link goes from up→down, not
;; continuously while down), so one missed connect would otherwise wedge the
;; supervisor; we drive the retry off connect's own success/failure here.
(defn ensure-link--reconnect (addr)
  (if (try (do (connect addr) true) (catch _ false))
    nil
    (do (sleep 200) (ensure-link--reconnect addr))))

;; The supervisor receive loop: on each `[:nodedown peer]`, sleep a beat,
;; reconnect (retrying until success), then go back to listening. Exits
;; cleanly on `:stop`.
(defn ensure-link--loop (addr peer)
  (receive
    ([:nodedown p]
      (when (= p peer)
        (sleep 200)
        (ensure-link--reconnect addr)
        (ensure-link--loop addr peer)))
    (:stop nil)
    (_ (ensure-link--loop addr peer))))

(defn ensure-link (addr)
  "Maintain a persistent link to a peer node addressed as `\"name@host:port\"`. Synchronously attempts the initial `(connect addr)` (errors are swallowed — caller still gets a supervisor); spawns a small supervisor process that `monitor-node`s the peer and re-`connect`s with backoff on every `[:nodedown …]`. Returns the supervisor pid; send it `:stop` to disable. Pure Brood policy over `connect` + `monitor-node` + `receive (after …)`: no extra runtime support."
  (let (peer (ensure-link--peer-name addr))
    ;; Initial connect synchronously so the caller's next `send` doesn't race
    ;; the link-up. If it fails, the supervisor will retry on each subsequent
    ;; `:nodedown` — which `monitor-node` fires immediately when the peer
    ;; isn't connected, so we'll be back here soon.
    (try (connect addr) (catch _ nil))
    (spawn (do (monitor-node peer)
               (ensure-link--loop addr peer)))))

;; ---- receive: selective, pattern-matched message receipt --------------------
;; (receive clause...) where each clause is (pattern [:when guard] body...), with an
;; optional trailing (after ms body...) timeout clause. Reuses the match compiler
;; (match-build-from) to build a *matcher* fn: given a message it returns the clause
;; body as a thunk on a match, or nil on no match. The %receive primitive runs that
;; over the mailbox — scanning in order, removing+running the first match, leaving
;; non-matching messages queued (true Erlang selective receive).
;;
;;   (receive
;;     ([:say text]      (println text))
;;     (n :when (int? n) (handle n))
;;     (after 5000       (throw [:timeout])))   ; catchable via try/catch
;;
;; (receive) with no clauses blocks for the next message and returns it.
;; (after 0 ...) is a non-blocking poll; (after ms>0 ...) waits up to ms.

;; Wrap a clause's body in a (fn () body...) thunk, so a matched body runs only after
;; %receive commits to (and removes) the message — not during the scan. Preserves the
;; :when guard so the match compiler still gates on it.
(defn receive--thunk-clause (clause)
  (let (pat (first clause) more (rest clause))
    (if (= (first more) :when)
      `(~pat :when ~(second more) (fn () ~@(rest (rest more))))
      `(~pat (fn () ~@more)))))

;; Split clauses into [real-clauses ms-or-nil timeout-thunk-or-nil], peeling an
;; optional trailing (after ms body...). `after` as a final clause head is reserved.
(defn receive--split (clauses)
  (let (lst (last clauses))
    (if (and (pair? lst) (= (first lst) 'after))
      [(but-last clauses) (second lst) `(fn () ~@(rest (rest lst)))]
      ;; no `after`: ms nil (wait forever) and a do-nothing timeout thunk, so the
      ;; on-timeout slot is always a fn (the `((%receive …))` wrap applies it).
      [clauses nil `(fn () nil)])))

(defmacro receive (& clauses)
  "Selectively receive a message from the mailbox: run the first `(pattern [:when guard] body...)` clause that matches, leaving others queued. An optional final `(after ms body...)` clause fires on timeout; `(receive)` blocks for the next message."
  (let (parts (receive--split clauses)
        real (nth parts 0)
        ms (nth parts 1)
        on-time (nth parts 2)
        msg (gensym "msg")
        matcher (if (empty? real)
                  `(fn (~msg) (fn () ~msg))
                  ; no clauses: take the next message as-is
                  `(fn (~msg) ~(match-build-from (map receive--thunk-clause real) msg nil))))
    ;; `%receive` returns the matched (or timeout) body *thunk*; applying it here —
    ;; in tail position — is what keeps a receive loop O(1) stack (eval TCO).
    `((%receive ~matcher ~ms ~on-time))))

;; ---- a general membership test ----------------------------------------------
(defn member? (x xs)
  "True if `x` is equal to some item of list `xs`."
  (cond (empty? xs) false (= x (first xs)) true else (member? x (rest xs))))

;; ---- sequence library -------------------------------------------------------
;; All in Brood over the list primitives (`first`/`rest`/`cons`/`empty?`) and
;; `take`/`drop`. Every builder is tail-recursive (it accumulates a reversed list
;; and reverses once at the end), so these stay stack-safe on long inputs — which
;; matters because a `test` body runs in a green process with a small coroutine
;; stack. Sequences are cons-lists; `zip` pairs are 2-vectors (the tuple idiom).

;; (range hi) -> 0..hi-1 ; (range lo hi) -> lo..hi-1 ; (range lo hi step).
(defn range (a & more)
  "A list of integers: `(range hi)` is 0..hi-1, `(range lo hi)` is lo..hi-1, `(range lo hi step)` strides by `step`."
  (cond
    (empty? more) (range--collect 0 a 1 nil)
    (empty? (rest more)) (range--collect a (first more) 1 nil)
    else (range--collect a (first more) (second more) nil)))
(defn range--collect (i hi step acc)
  (if (if (> step 0) (< i hi) (> i hi))
    (range--collect (+ i step) hi step (cons i acc))
    (reverse acc)))

;; (take n coll) -> the first n elements (fewer if coll is shorter).
(defn take (n coll)
  "The first `n` items of `coll` (fewer if it is shorter), as a list."
  (take--acc n coll nil))
(defn take--acc (n coll acc)
  (if (or (<= n 0) (empty? coll))
    (reverse acc)
    (take--acc (- n 1) (rest coll) (cons (first coll) acc))))

;; (drop n coll) -> coll without its first n elements.
(defn drop (n coll)
  "`coll` without its first `n` items."
  (if (or (<= n 0) (empty? coll)) coll (drop (- n 1) (rest coll))))

;; (take-while pred coll) / (drop-while pred coll) split on the first failure.
(defn take-while (pred coll)
  "The leading items of `coll` for which `(pred x)` holds."
  (take-while--acc pred coll nil))
(defn take-while--acc (pred coll acc)
  (if (and (pair? coll) (pred (first coll)))
    (take-while--acc pred (rest coll) (cons (first coll) acc))
    (reverse acc)))
(defn drop-while (pred coll)
  "`coll` with its leading items for which `(pred x)` holds removed."
  (if (and (pair? coll) (pred (first coll))) (drop-while pred (rest coll)) coll))

;; (some? pred coll) -> true if pred holds for any element; (every? pred coll) ->
;; true if it holds for all (vacuously true on the empty list). Booleans, by the
;; `?` convention — use `find` to recover the matching element itself.
(defn some? (pred coll)
  "True if `(pred x)` holds for at least one item of `coll`."
  (cond (empty? coll) false (pred (first coll)) true else (some? pred (rest coll))))
(defn every? (pred coll)
  "True if `(pred x)` holds for every item of `coll` (vacuously true if empty)."
  (cond (empty? coll) true (pred (first coll)) (every? pred (rest coll)) else false))

;; (find pred coll) -> the first element satisfying pred, or nil.
(defn find (pred coll)
  "The first item of `coll` for which `(pred x)` holds, or `nil`."
  (cond (empty? coll) nil (pred (first coll)) (first coll) else (find pred (rest coll))))

;; (zip a b) -> a list of [x y] vectors, stopping at the shorter input.
(defn zip (a b)
  "A list of `[x y]` pairs from `a` and `b`, stopping at the shorter input."
  (zip--acc a b nil))
(defn zip--acc (a b acc)
  (if (or (empty? a) (empty? b))
    (reverse acc)
    (zip--acc (rest a) (rest b) (cons [(first a) (first b)] acc))))

;; (partition n coll) -> consecutive n-sized chunks; a trailing partial chunk is
;; dropped (Clojure `partition` semantics). `has-at-least?` avoids re-counting.
(defn has-at-least? (n coll)
  (cond (<= n 0) true (empty? coll) false else (has-at-least? (- n 1) (rest coll))))
(defn partition (n coll)
  "Split `coll` into consecutive `n`-sized chunks; a trailing partial chunk is dropped."
  (partition--acc n coll nil))
(defn partition--acc (n coll acc)
  (if (has-at-least? n coll)
    (partition--acc n (drop n coll) (cons (take n coll) acc))
    (reverse acc)))

;; (sort coll) ascending via `<` (numbers) or structural order (anything else);
;; (sort less? coll) with a strict less-than predicate. (sort-by key-fn coll)
;; sorts by `(< (key-fn x) (key-fn y))`. A stable, O(n log n) merge sort: the
;; merge prefers the left run on ties (stable) and is tail-recursive; recursion
;; depth is O(log n), so it's stack-safe.
;;
;; The single-arg `(sort coll)` case has two Rust fast paths: `%sort-asc` for
;; the all-numeric case (~50× faster than the in-Brood mergesort because every
;; comparison is a Rust `match` instead of an `eval::apply` round-trip), and
;; `%sort-cmp` for the heterogeneous / structural case (vectors, strings,
;; keywords, …). Dispatch checks the first item — non-empty fast since
;; `(number? (first a))` is one tag-of compare. Empty coll → empty list.
;; Custom-comparator `(sort less? coll)` stays on the Brood-side `merge-sort`.
(defn sort (a & more)
  "Sort a collection (stable). `(sort coll)` is ascending by `<` for numbers, or by structural order (lexicographic on vectors/lists, text order on strings/symbols/keywords) for anything else. `(sort less? coll)` uses a strict less-than predicate."
  (cond
    (not (empty? more)) (merge-sort a (first more))
    (empty? a) nil
    (number? (first a)) (%sort-asc a)
    else (%sort-cmp a)))
(defn sort-by (key-fn coll)
  "Sort `coll` (stable, ascending) by comparing `(key-fn x)` of each item with the
structural order (`compare`), so numeric, string, keyword, and vector keys all work."
  (merge-sort (fn (x y) (< (compare (key-fn x) (key-fn y)) 0)) coll))
(defn merge-sort (less? coll)
  (if (or (empty? coll) (empty? (rest coll)))
    coll
    (let (n (quot (count coll) 2))
      (merge--runs less? (merge-sort less? (take n coll)) (merge-sort less? (drop n coll))))))
(defn merge--runs (less? a b) (merge--acc less? a b nil))
(defn merge--acc (less? a b acc)
  (cond
    (empty? a) (append (reverse acc) b)
    (empty? b) (append (reverse acc) a)
    ;; strict `<` on b-vs-a: equal elements take from `a` first, so it's stable.
    (less? (first b) (first a)) (merge--acc less? a (rest b) (cons (first b) acc))
    else (merge--acc less? (rest a) b (cons (first a) acc))))

(defn concat (& seqs)
  "Concatenate any number of sequences (lists, vectors, or maps read as `[k v]` pairs) into one list, left to right — the variadic sequence join. Alias of `append` (the name reflexively reached for). Returns a list; wrap in `(into [] …)` for a vector."
  (apply append seqs))

(defn mapcat (f coll)
  "Map `f` over `coll` and concatenate the resulting lists into one."
  (apply append (map f coll)))

(defn frequencies (coll)
  "A map from each distinct element of `coll` to how many times it occurs."
  (fold (fn (m x) (assoc m x (inc (get m x 0)))) {} coll))

(defn into (to from)
  "Pour each item of `from` into `to`. For a map, items are `[k v]` pairs (assoc'd, map result); for a vector, items are appended (vector result); otherwise items are appended (list result). Maps in `from` are read as their entries, so `(into [] some-map)` and `(into {} other-map)` both work."
  (cond
    (map? to) (reduce (fn (m p) (assoc m (first p) (second p))) to from)
    ;; `append to from` is always a list (fold-of-flip-cons), so we re-vectorise.
    ;; That's an extra O(n) pass — acceptable; the previous code silently
    ;; returned a list even when `to` was a vector.
    (vector? to) (apply vector (append to from))
    else (append to from)))

;; ---- more sequence operations -----------------------------------------------
;; The eager counterparts of the `x*` transducers, plus the common Clojure-ish
;; builders. All tail-recursive (reverse-accumulate, reverse once) so they stay
;; stack-safe on long inputs — see the sequence-library note above.

(defn remove (pred coll)
  "A list of the items of `coll` for which `(pred x)` is *falsy* — the complement of `filter`."
  (reverse (fold (fn (acc x) (if (pred x) acc (cons x acc))) nil coll)))

(defn keep (f coll)
  "A list of the non-nil results of `(f x)` over `coll` — map and filter fused (the eager counterpart of `xkeep`)."
  (reverse (fold (fn (acc x) (let (y (f x)) (if (nil? y) acc (cons y acc)))) nil coll)))

;; distinct: keep the first occurrence of each item. A map carried alongside the
;; result acts as the "seen" set, so membership is O(1)-ish, not the O(n²) a
;; `member?`-per-item scan would cost. State is the 2-vector [seen result-rev].
(defn distinct--step (state x)
  (if (contains? (nth state 0) x)
    state
    [(map-assoc (nth state 0) x true) (cons x (nth state 1))]))
(defn distinct (coll)
  "The items of `coll` with duplicates removed, keeping the first occurrence of each (order-preserving)."
  (reverse (nth (fold distinct--step [{} nil] coll) 1)))

;; dedupe: collapse only *consecutive* runs of equal items (no "seen" set needed).
(defn dedupe--acc (coll prev acc)
  (cond
    (empty? coll) acc
    (= (first coll) prev) (dedupe--acc (rest coll) prev acc)
    else (dedupe--acc (rest coll) (first coll) (cons (first coll) acc))))
(defn dedupe (coll)
  "The items of `coll` with *consecutive* runs of equal items collapsed to a single item."
  (if (empty? coll)
    nil
    (reverse (dedupe--acc (rest coll) (first coll) (list (first coll))))))

(defn group-by (f coll)
  "A map from each `(f x)` to the list of items of `coll` that produced it, each list in original order."
  ;; Prepend per group (O(1)) then reverse every group's list once at the end.
  (update-vals (fold (fn (m x) (let (k (f x)) (assoc m k (cons x (get m k))))) {} coll) reverse))

;; flatten: splice nested lists into one flat list. Descends through `pair?`/`nil`
;; (so empty sub-lists and nils vanish); vectors and maps are leaf items. The
;; outer walk is tail-recursive; the nested call recurses only as deep as the
;; nesting (bounded), not the length.
(defn flatten--acc (coll acc)
  (cond
    (empty? coll) acc
    (list? (first coll)) (flatten--acc (rest coll) (flatten--acc (first coll) acc))
    else (flatten--acc (rest coll) (cons (first coll) acc))))
(defn flatten (coll)
  "A single flat list of the leaf items of `coll`, descending into nested lists. Vectors and maps are treated as leaves."
  (reverse (flatten--acc coll nil)))

(defn interpose--acc (sep coll acc)
  (if (empty? coll) acc (interpose--acc sep (rest coll) (cons (first coll) (cons sep acc)))))
(defn interpose (sep coll)
  "A list with `sep` inserted between adjacent items of `coll`."
  (if (empty? coll) nil (reverse (interpose--acc sep (rest coll) (list (first coll))))))

(defn interleave--acc (a b acc)
  (if (or (empty? a) (empty? b))
    (reverse acc)
    (interleave--acc (rest a) (rest b) (cons (first b) (cons (first a) acc)))))
(defn interleave (a b)
  "A list alternating items from `a` and `b` — `(a0 b0 a1 b1 …)` — stopping at the shorter input."
  (interleave--acc a b nil))

(defn take-last (n coll)
  "The last `n` items of `coll`, as a list (the whole of `coll` if it is shorter, `()` if `n` <= 0)."
  (drop (- (count coll) n) coll))
(defn drop-last (n coll)
  "`coll` without its last `n` items (`()` if `n` >= its length)."
  (take (- (count coll) n) coll))

(defn repeat--acc (n x acc) (if (<= n 0) acc (repeat--acc (dec n) x (cons x acc))))
(defn repeat (n x)
  "A list of `x` repeated `n` times (empty if `n` <= 0)."
  (repeat--acc n x nil))

(defn repeatedly--acc (n f acc) (if (<= n 0) (reverse acc) (repeatedly--acc (dec n) f (cons (f) acc))))
(defn repeatedly (n f)
  "A list of `n` successive calls to the zero-argument function `f` (in call order)."
  (repeatedly--acc n f nil))

;; ---- transducers ------------------------------------------------------------
;; A *reducing function* has shape `(rf acc x) -> new-acc` — what `fold`
;; consumes. A *transducer* is a function `(xf rf) -> rf'` that wraps one
;; reducing function in another. Composing transducers is just function
;; composition (`comp`); the resulting transducer, applied to a reducer, fuses
;; the pipeline into a single per-step function — **no intermediate collections**.
;;
;; The eager pipeline `(reduce + 0 (filter even? (map sq xs)))` builds two
;; throwaway lists; the transducer form
;;
;;   (transduce (comp (xmap sq) (xfilter even?)) + 0 xs)
;;
;; walks `xs` once and never materialises the intermediates.
;;
;; v1 is *stateless* — `xtake`/`xdrop`/`xpartition` are deferred until we add an
;; early-termination protocol (the language has no mutable cells).

;; Composition (the glue for transducer chains, also generally useful).
(defn comp--compose (f g) (fn (x) (f (g x))))
(defn comp (& fns)
  "Right-to-left function composition. `((comp f g) x)` is `(f (g x))`; with no
arguments, `identity`. For transducers, the *leftmost* `xform`'s transformation
applies to each input first."
  (cond
    (empty? fns) identity
    (empty? (rest fns)) (first fns)
    else (fold comp--compose (first fns) (rest fns))))

;; Stateless transducer constructors. Named `x*` so the eager `map`/`filter`
;; keep their fixed-arity (no rest-list) fast path — see the perf devlog.
(defn xmap (f)
  "A transducer that applies `f` to each input. The fused counterpart of `(map f coll)`."
  (fn (rf) (fn (acc x) (rf acc (f x)))))

(defn xfilter (pred)
  "A transducer that keeps inputs for which `(pred x)` is truthy. The fused counterpart of `(filter pred coll)`."
  (fn (rf) (fn (acc x) (if (pred x) (rf acc x) acc))))

(defn xremove (pred)
  "A transducer that drops inputs for which `(pred x)` is truthy — the inverse of `xfilter`."
  (fn (rf) (fn (acc x) (if (pred x) acc (rf acc x)))))

(defn xkeep (f)
  "A transducer that keeps the non-nil results of `(f x)` — map and filter fused in one stage."
  (fn (rf) (fn (acc x) (let (y (f x)) (if (nil? y) acc (rf acc y))))))

(defn xmapcat (f)
  "A transducer that maps `f` over each input (expected to return a list or vector) and feeds the *items* of each result into the next stage — fused `mapcat`, no intermediate per-element lists."
  (fn (rf) (fn (acc x) (fold rf acc (f x)))))

(defn xtake-while (pred)
  "A transducer that lets each input through as long as `(pred x)` holds; the first input that fails the predicate ends the reduction (the failing item is *not* fed downstream). Stateless — predicate-driven via the `reduced` sentinel."
  (fn (rf) (fn (acc x) (if (pred x) (rf acc x) (reduced acc)))))

;; ---- early-termination sentinel ---------------------------------------------
;; A `reduced`-wrapped accumulator signals "stop the reduction now and unwrap
;; me." `xtake-while` returns one when its predicate fails; `transduce` (below)
;; sees it and halts. Count-based `xtake n` / `xdrop n` would need *internal*
;; mutable state per transducer, which Brood doesn't have (ADR-026), and are
;; deferred until either an accumulator-wrapping protocol or a mutable-cell
;; primitive lands.

(defn reduced (x)
  "Wrap `x` as a final, short-circuit reduced value. `transduce` sees this and stops walking the input, unwrapping `x` as the result."
  [:%reduced x])

(defn reduced? (x)
  "Is `x` a value wrapped by `reduced`?"
  ;; Hand-rolled nested-if — `reduced?` runs per-step on the transduce hot path,
  ;; so we skip `vector?`'s user-fn frame and `and`'s gensym/let dance.
  (if (%eq (type-of x) :vector)
    (if (%eq (vector-length x) 2) (%eq (vector-ref x 0) :%reduced) false)
    false))

(defn deref-reduced (x)
  "Unwrap a `reduced` value; otherwise return `x` unchanged."
  (if (reduced? x) (vector-ref x 1) x))

;; Driver — short-circuits on a `reduced` accumulator. The per-step `reduced?`
;; check is cheap for typical accumulators (it fails `vector?` immediately).
(defn transduce--step (rf acc coll)
  (cond
    (reduced? acc) (deref-reduced acc)
    (empty? coll) acc
    else (transduce--step rf (rf acc (first coll)) (rest coll))))

(defn transduce (xform rf init coll)
  "Reduce `coll` with `(xform rf)` from `init`. `xform` and `rf` fuse into a single pass; the equivalent eager pipeline (with intermediate collections) is `(reduce rf init (... xform-applied-to ... coll))`. If a step returns a `reduced` value (e.g. via `xtake-while`) the walk stops and that value is unwrapped as the result."
  (transduce--step (xform rf) init coll))

;; ---- iteration combinators --------------------------------------------------
;; Hide the hand-rolled counter/accumulator recursion behind names that read as
;; intent (the way `defprocess` hides a receive loop). All ordinary Brood.

(defn times (n f x)
  "Apply `f` to `x` `n` times — fⁿ(x). `(times 0 f x)` is `x`."
  (if (<= n 0) x (times (dec n) f (f x))))

(defn iterate-times--acc (f x n acc)
  (if (< n 0) acc (iterate-times--acc f (f x) (dec n) (cons x acc))))
(defn iterate-times (f x n)
  "The list (x f(x) f²(x) … fⁿ(x)) — `n`+1 successive states of applying `f`."
  (reverse (iterate-times--acc f x n nil)))

(defn enumerate (coll)
  "Pair each item with its 0-based index: ([0 x₀] [1 x₁] …)."
  (zip (range (count coll)) coll))

;; ---- comprehensions ---------------------------------------------------------
;; `for` builds a list by walking one or more bindings, with `:when` guards —
;; a macro over `mapcat`, so the map/filter/fold plumbing disappears from view.
;;   (for (x xs) expr)               -> a list of expr for each x
;;   (for (x xs :when p) expr)       -> … only where p holds
;;   (for (x xs y ys) [x y])         -> nested (y varies fastest)
;; Bindings may destructure: (for ([k v] (map-pairs m)) …). Build a map from the
;; result with `(into {} (for …))`. Bindings are a list — code is lists, vectors
;; are data (ADR-010); a vector is still accepted in binding position.

;; Compile the binding forms (a list: alternating pattern/coll, plus :when pred)
;; from the inside out, threading a single accumulator `acc` through. Each
;; binding becomes a `fold` over its collection that conses the body onto `acc`;
;; each :when an `if` that passes `acc` through unchanged when the guard fails;
;; the body a single `(cons body acc)`. The whole thing builds the result in
;; reverse with no intermediate per-element lists (the old `mapcat` lowering
;; allocated a one-element `(list body)` per item and concatenated them) — so a
;; final `reverse` restores order in one extra O(n) pass. `fold` is tail-
;; recursive, so deep comprehensions don't grow the stack.
(defn for--fold (acc binds body)
  (cond
    (empty? binds) `(cons ~body ~acc)
    (= (first binds) :when) `(if ~(second binds) ~(for--fold acc (rest (rest binds)) body) ~acc)
    else `(fold (fn (~acc ~(first binds)) ~(for--fold acc (rest (rest binds)) body)) ~acc ~(second binds))))

(defmacro for (binds body)
  "List comprehension: `(for (x xs) expr)` yields `expr` for each `x`; supports `:when guard` filters and multiple bindings (last varies fastest). Bindings may destructure."
  (let (acc (gensym "acc"))
    `(reverse (let (~acc nil) ~(for--fold acc (map identity binds) body)))))

;; (doseq (pat coll) body...) — run `body` for its side effects over each item,
;; returning nil. Just `for` run for effect (the result list is discarded). The
;; param is `bind`, not `binding` — the latter is the dynamic-variable form.
(defmacro doseq (bind & body)
  "Run `body` for its side effects over each item of the binding (like `for`, but discards the result and returns `nil`)."
  `(do (for ~bind (do ~@body)) nil))

;; (dotimes (i n) body...) — run `body` for `i` = 0, 1, …, n-1; returns nil. The
;; lean iteration primitive: a plain tail-recursive walker, no result list built
;; (unlike `doseq`, which routes through `for`/`mapcat`). For effects only.
(defn dotimes--loop (n f i) (when (< i n) (f i) (dotimes--loop n f (+ i 1))))
(defmacro dotimes (bind & body)
  "Run `body` with the bound name set to 0, 1, …, n-1 for side effect; returns `nil`. `bind` is `(var n)`."
  `(do (dotimes--loop ~(second bind) (fn (~(first bind)) ~@body) 0) nil))

;; (dolist (x xs) body...) — run `body` for each element of `xs`; returns nil.
;; The list-only counterpart to `dotimes`: lean and tail-recursive, no discard
;; list built. Use `doseq` when you need destructuring or `:when` filters; reach
;; for `dolist` for the common "do this for each item" loop.
(defn dolist--loop (xs f) (when (not (nil? xs)) (f (first xs)) (dolist--loop (rest xs) f)))
(defmacro dolist (bind & body)
  "Run `body` with the bound name set to each element of the collection for side effect; returns `nil`. `bind` is `(var coll)`."
  `(do (dolist--loop ~(second bind) (fn (~(first bind)) ~@body)) nil))

;; (bench label expr) — wall-clock timing, in milliseconds (the resolution of
;; `now`). The gensyms keep `label`/`expr` from capturing `t0`/`r` if the caller
;; happens to use those names.
(defmacro bench (label expr)
  "Evaluate `expr`, print `label: N ms`, and return `expr`'s value."
  (let (t0 (gensym "t0") r (gensym "r"))
    `(let (~t0 (now) ~r ~expr)
       (println (str ~label ": " (- (now) ~t0) " ms"))
       ~r)))

;; ---- symbol / keyword conversions -------------------------------------------
;; `symbol` and `keyword` (Rust) are lenient — they take string/symbol/keyword.
;; These are the strict named conversions: each errors on the wrong input shape,
;; matching the Scheme/Clojure tradition. Thin Brood wrappers, no new kernel.

(defn symbol->string (s)
  "The spelling of symbol `s` as a string. Errors if `s` isn't a symbol."
  (if (symbol? s) (name s) (error "symbol->string: expected a symbol, got " (type-of s))))

(defn string->symbol (s)
  "The symbol whose spelling is the string `s`. Errors if `s` isn't a string."
  (if (string? s) (symbol s) (error "string->symbol: expected a string, got " (type-of s))))

;; ---- strings ----------------------------------------------------------------
;; The string library, written over the kernel primitives `substring` /
;; `string-length` / `str` and `upper` / `lower` / `string->number`. Brood has no
;; distinct char type, so a "character" is a 1-char string; all indices are
;; char-based, matching `string-length`. The helpers below are tail-recursive
;; (stack-safe over long strings); `substring` is O(index), so a full scan is
;; O(n²) — fine for the short strings this targets (the rope/buffer engine in M2
;; is the home for large-text performance).

(defn char-at (s i)
  "The character (a 1-char string) at char index `i` of `s`."
  (substring s i (inc i)))

(defn number->string (n)
  "The textual form of number `n` — the inverse of `string->number`."
  (str n))

(defn string->list--acc (s i acc)
  (if (< i 0) acc (string->list--acc s (dec i) (cons (substring s i (inc i)) acc))))
(defn string->list (s)
  "The characters of `s` as a list of 1-char strings."
  (string->list--acc s (dec (string-length s)) nil))

(defn list->string (cs)
  "Concatenate a list of strings (e.g. from `string->list`) into one string."
  (apply str cs))

(defn index-of--str-from (s needle i)
  (let (nl (string-length needle))
    (cond
      (> (+ i nl) (string-length s)) -1
      (= (substring s i (+ i nl)) needle) i
      else (index-of--str-from s needle (inc i)))))
(defn index-of--seq-from (coll x i)
  (cond
    (empty? coll) -1
    (= (first coll) x) i
    else (index-of--seq-from (rest coll) x (inc i))))
(defn index-of (coll x)
  "The 0-based index of `x` in `coll`, or -1 if absent.
For a string, `x` is a substring (multi-char ok; the empty string matches at 0).
For a list or vector, `x` is an element compared structurally."
  (cond
    (string? coll) (index-of--str-from coll x 0)
    (vector? coll) (index-of--seq-from coll x 0)
    else (index-of--seq-from coll x 0)))

(defn string-contains? (s needle)
  "Does `s` contain `needle` as a substring?"
  (>= (index-of s needle) 0))

(defn includes? (coll x)
  "True if `coll` contains `x`. Works on lists, vectors, strings (substring), and maps (membership among values — use `contains?` for keys)."
  (cond
    (map? coll) (member? x (vals coll))
    (string? coll) (string-contains? coll x)
    else (>= (index-of coll x) 0)))

;; Collect `coll`'s elements interleaved with `sep` into a parts list (tail-
;; recursively, reversed), then build the string in one `apply str` pass.
(defn join--parts (sep coll acc)
  (if (empty? coll) acc (join--parts sep (rest coll) (cons (first coll) (cons sep acc)))))
(defn join (sep coll)
  "Concatenate the strings in `coll` with `sep` between adjacent elements."
  ;; One `apply str` over the assembled parts is O(total length); the previous
  ;; fold did `(str acc sep x)` each step, rebuilding the whole accumulator —
  ;; O(total length²).
  (if (empty? coll) "" (apply str (cons (first coll) (reverse (join--parts sep (rest coll) nil))))))

(defn string-split--acc (s sep acc)
  (let (i (index-of s sep))
    (if (< i 0)
      (reverse (cons s acc))
      (string-split--acc (substring s (+ i (string-length sep)) (string-length s))
        sep
        (cons (substring s 0 i) acc)))))
(defn string-split (s sep)
  "Split `s` into a list of substrings on each occurrence of `sep`. An empty
separator splits `s` into its individual characters."
  (if (= sep "") (string->list s) (string-split--acc s sep nil)))

(defn replace (s old new)
  "Return `s` with every occurrence of `old` replaced by `new`. An empty `old`
leaves `s` unchanged."
  (if (= old "") s (join new (string-split s old))))

(defn string--whitespace? (c) (or (= c " ") (= c "\t") (= c "\n") (= c "\r")))

(defn blank? (s)
  "Is `s` empty or made up only of whitespace?"
  (let (n (string-length s))
    (cond (= n 0) true (string--whitespace? (char-at s 0)) (blank? (substring s 1 n)) else false)))

(defn triml--from (s i n)
  (if (and (< i n) (string--whitespace? (char-at s i))) (triml--from s (inc i) n) (substring s i n)))
(defn triml (s) "Remove leading whitespace from `s`." (triml--from s 0 (string-length s)))

(defn trimr--to (s n)
  (if (and (> n 0) (string--whitespace? (char-at s (dec n))))
    (trimr--to s (dec n))
    (substring s 0 n)))
(defn trimr (s) "Remove trailing whitespace from `s`." (trimr--to s (string-length s)))

(defn trim (s) "Remove leading and trailing whitespace from `s`." (triml (trimr s)))

;; ---- string padding & repetition --------------------------------------------
;; Column formatting for tabular/console output. `pad-*` left unchanged when the
;; string already meets the width (they never truncate).
(defn string-repeat (s n)
  "The string `s` concatenated `n` times (the empty string if `n` <= 0)."
  (apply str (repeat n s)))

(defn pad-left (s w)
  "Right-justify `s` in a field of width `w`, padding with spaces on the left; `s` is returned unchanged if it is already at least `w` wide."
  (let (n (string-length s)) (if (>= n w) s (str (string-repeat " " (- w n)) s))))

(defn pad-right (s w)
  "Left-justify `s` in a field of width `w`, padding with spaces on the right; `s` is returned unchanged if it is already at least `w` wide."
  (let (n (string-length s)) (if (>= n w) s (str s (string-repeat " " (- w n))))))

;; ---- string formatting ------------------------------------------------------
;; A small `printf`-style helper for inline rendering. The supported specifiers
;; are a deliberate subset — the common cases for demos and tooling output:
;;   %s    any value, rendered via `str`
;;   %d    integer (any number; the type tag is a hint for the reader, not a
;;         converter — float in / float out, same as %s)
;;   %f    float with 6 fractional digits (matches the C/Java default)
;;   %.Nf  float with N fractional digits, rounded — uses `to-fixed`
;;   %%    a literal `%`
;; Width / justification aren't built in — `pad-left` / `pad-right` cover those
;; explicitly. Hex/octal/etc. aren't here; add them on demand. Errors on an
;; unknown spec or a format string that ends inside one; a missing arg renders
;; as `nil` (debuggable), extra args are ignored.
(defn format (fmt & args)
  "Render `fmt`, replacing each %-specifier with the next of `args`. Supports `%s` `%d` `%f` `%.Nf` `%%`; use `pad-left`/`pad-right` for width."
  (format--loop fmt 0 (string-length fmt) args ""))

(defn format--loop (fmt i n args acc)
  (cond
    (>= i n) acc
    (= (char-at fmt i) "%") (format--spec fmt (inc i) n args acc)
    else (format--loop fmt (inc i) n args (str acc (char-at fmt i)))))

(defn format--spec (fmt i n args acc)
  ;; called with `i` pointing one past the `%`
  (cond
    (>= i n) (error "format: unterminated specifier (lone '%' at end of format string)")
    (= (char-at fmt i) "%") (format--loop fmt (inc i) n args (str acc "%"))
    (= (char-at fmt i) "s") (format--loop fmt (inc i) n (rest args) (str acc (str (first args))))
    (= (char-at fmt i) "d") (format--loop fmt (inc i) n (rest args) (str acc (str (first args))))
    (= (char-at fmt i) "f") (format--loop fmt (inc i) n (rest args) (str acc (to-fixed (first args) 6)))
    (= (char-at fmt i) ".") (format--prec fmt (inc i) n args acc 0)
    else (error (str "format: unrecognized specifier '%" (char-at fmt i) "' at column " i))))

(defn format--prec (fmt i n args acc p)
  ;; called with `i` pointing one past the `.`, accumulating precision in `p`
  (cond
    (>= i n) (error "format: unterminated %.Nf specifier")
    (= (char-at fmt i) "f") (format--loop fmt (inc i) n (rest args) (str acc (to-fixed (first args) p)))
    else (let (d (string->number (char-at fmt i)))
           (if (and (int? d) (>= d 0) (<= d 9))
             (format--prec fmt (inc i) n args acc (+ (* p 10) d))
             (error (str "format: expected digit or 'f' after '.' in specifier, got '"
                      (char-at fmt i) "' at column " i))))))

;; ---- strings & paths --------------------------------------------------------
;; Helpers over `substring` (char-indexed, like `string-length`). Generic enough
;; to live in core; the module system and the project tooling build on them.
(defn starts-with? (s prefix)
  "Does string `s` begin with `prefix`?"
  (let (n (string-length prefix)) (and (>= (string-length s) n) (= (substring s 0 n) prefix))))

(defn ends-with? (s suffix)
  "Does string `s` end with `suffix`?"
  (let (sl (string-length s) ql (string-length suffix))
    (and (>= sl ql) (= (substring s (- sl ql) sl) suffix))))

;; Index of the last `/` in `s`, scanning down from `i`, or -1 if none. (Brood has
;; no char accessor yet; paths are short, so a substring scan is fine.)
(defn path--last-slash (s i)
  (cond (< i 0) -1 (= (substring s i (inc i)) "/") i else (path--last-slash s (dec i))))

;; The directory containing `path`: "/a/b/c" -> "/a/b", "/foo" -> "/", "rel" -> ".".
;; A path that is its own parent ("/" or ".") is the fixed point a walk-up stops at.
(defn parent-dir (path)
  "The directory containing `path` (\"/a/b/c\" -> \"/a/b\", \"/foo\" -> \"/\", \"rel\" -> \".\")."
  (let (i (path--last-slash path (dec (string-length path))))
    (cond (< i 0) "." (= i 0) "/" else (substring path 0 i))))

(defn path-join (a b)
  "Join path segments `a` and `b` with a single `/` separator."
  (if (ends-with? a "/") (str a b) (str a "/" b)))

(defn path-basename (path)
  "The final component of `path` (\"/a/b/c\" -> \"c\", \"/foo\" -> \"foo\",
\"foo\" -> \"foo\"). The empty string returns itself; a trailing slash isn't
stripped (`(cwd)` doesn't produce one, which is the primary caller)."
  (let (n (string-length path))
    (if (= n 0)
      ""
      (let (i (path--last-slash path (dec n)))
        (if (< i 0) path (substring path (inc i) n))))))

;; ---- pseudo-random numbers (xorshift32, pure & seedable) --------------------
;; Brood has no global mutable state, so randomness is *threaded*: every step
;; takes a seed and returns `[value next-seed]`. Pass `next-seed` to the next
;; call; thread the seed through your loop state exactly like any other value.
;; Seed a fresh stream from any integer (e.g. `(now)`) via `rand-seed`.
;;
;; The generator is Marsaglia's xorshift32 — fast and good enough for
;; simulations, sampling, shuffling, jitter, and ids; NOT for cryptography. Each
;; left shift can exceed 32 bits, so we mask back to 32 bits with `*rand-mask*`,
;; which also keeps every intermediate well within i64 (no overflow).

(def *rand-mask* 4294967295) ; 2^32 - 1

(defn rand-seed (n)
  "Normalize integer `n` into a valid nonzero 32-bit PRNG seed (xorshift32 cannot start from 0)."
  (let (m (bit-and n *rand-mask*))
    (if (= m 0) 2463534242 m)))

(defn rand--step (state)
  ;; One xorshift32 transition over a nonzero 32-bit `state`.
  (let (x (bit-and (bit-xor state (bit-shift-left state 13)) *rand-mask*)
        x (bit-xor x (bit-shift-right x 17))
        x (bit-and (bit-xor x (bit-shift-left x 5)) *rand-mask*))
    x))

(defn rng (seed)
  "Step the PRNG: returns `[value next-seed]`, where `value` is a pseudo-random non-negative 32-bit integer and `next-seed` feeds the next call. `seed` is any integer (normalized via `rand-seed`)."
  (let (s (rand--step (rand-seed seed)))
    [s s]))

(defn rand-int (seed n)
  "Returns `[i next-seed]` with `i` a pseudo-random integer in `[0, n)`. `n` must be positive."
  (if (<= n 0)
    (error "rand-int: bound must be positive: " n)
    (let (s (rand--step (rand-seed seed)))
      [(rem s n) s])))

(defn rand-float (seed)
  "Returns `[f next-seed]` with `f` a pseudo-random float in `[0.0, 1.0)`."
  (let (s (rand--step (rand-seed seed)))
    [(/ s 4294967296.0) s]))

(defn sample (seed coll)
  "Returns `[item next-seed]`: one uniformly random element of non-empty `coll` (list, vector, or a map read as its `[k v]` entries)."
  (let (items (into [] coll)
        n (count items))
    (if (= n 0)
      (error "sample: cannot sample from an empty collection")
      (let (s (rand--step (rand-seed seed)))
        [(nth items (rem s n)) s]))))

(defn shuffle--acc (state remaining acc)
  (if (= (count remaining) 0)
    [acc state]
    (let (s (rand--step state)
          i (rem s (count remaining)))
      (shuffle--acc s
        (append (take i remaining) (drop (inc i) remaining))
        (cons (nth remaining i) acc)))))

(defn shuffle (seed coll)
  "Returns `[shuffled next-seed]`: the items of `coll` as a list in uniformly random order (Fisher–Yates)."
  (shuffle--acc (rand-seed seed) (into [] coll) nil))

;; ---- discovery / introspection ----------------------------------------------
;; "What's in this image, and where?" — name- and doc-based search over the flat
;; global table, on top of the `global-names`/`doc` primitives. The first thing
;; to reach for when exploring rather than guessing names one at a time.

(defn all-globals ()
  "Every globally bound name, as a sorted list of symbols. Alias of `global-names`."
  (global-names))

(defn apropos (pattern)
  "Every global whose name contains `pattern` (a string, symbol, or keyword), as a sorted list of symbols — e.g. `(apropos \"rand\")`."
  ;; `name` (not `str`) so a keyword pattern drops its leading colon, matching
  ;; the bare global names; a string passes through unchanged.
  (let (needle (if (string? pattern) pattern (name pattern)))
    (filter (fn (s) (string-contains? (name s) needle)) (global-names))))

(defn doc-search (query)
  "Every global whose docstring contains `query` (a string), as a list of `[name doc]` pairs — searches behaviour, not just names, e.g. `(doc-search \"random\")`."
  (keep
    (fn (s)
      (let (d (try (doc (eval s)) (catch _ nil)))
        (when (and (string? d) (string-contains? d query))
          [s d])))
    (global-names)))

;; ---- modules: Emacs-flat provide / require (ADR-019) ------------------------
;; A flat module system over the one shared global table: `provide` records a
;; loaded feature, `require` loads one once. Embedded std modules (test, project)
;; are baked into the binary and found via `%builtin-module`; everything else is
;; searched for on `*load-path*` as `<name>.blsp`. This is policy — Rust supplies
;; only the filesystem + embedded-source mechanism (ADR-006/008).
(def *features* nil)
; names (strings) of features already loaded
(def *load-path* (list "."))
; directories searched for <name>.blsp

;; (provide 'foo) — mark a feature loaded (idempotent). Returns its name.
(defn provide (mod)
  "Mark feature `mod` (a symbol or string) as loaded (idempotent); returns its name."
  (let (key (name mod))
    (unless (member? key *features*) (def *features* (cons key *features*)))
    key))

;; A module declares itself at the top with `defmodule`: its name, an optional
;; docstring, and (implicitly) `provide`. The canonical module header — it replaces
;; the old bare-leading-string docstring *and* a trailing `(provide 'name)`.
(def *module-docs* {})
; module name (string) -> its docstring (or nil)

;; The `(require …)`+`(%refer …)` forms for one `(:use mod [:refer [a b]])` clause:
;; load the module, then import its names. `:refer [a b]` imports just those;
;; otherwise all of `mod`'s public (non-`--`) names. Used at `defmodule` expand time.
(defn defmodule--use-clause (clause)
  (let (mod (second clause)
         opts (rest (rest clause))
         subset (if (= (first opts) :refer) (second opts) nil))
    (list (list 'require (list 'quote mod))
          (list '%refer (list 'quote mod) (list 'quote subset)))))

;; All require/refer forms for the `(:use …)` clauses in a `defmodule` header
;; (skipping the optional docstring / any non-`:use` form), flattened for splicing.
(defn defmodule--use-forms (clauses)
  (apply concat
    (map defmodule--use-clause
      (filter (fn (c) (and (pair? c) (= (first c) :use))) clauses))))

;; A file declares itself a **module = namespace** at the top with `defmodule`
;; (ADR-065): each `def`/`defn`/`defmacro` defines `mod/name`, and a bare reference
;; resolves to `mod/name` if this namespace defines it, then through a `(:use …)`
;; import, then falls back to root (the prelude). It also records an optional
;; docstring and `provide`s the feature (the load-once key). A `(:use bar)` clause
;; refers `bar`'s public names bare; `(:use baz :refer [a b])` refers just `a`/`b`.
;; Put it first; one per file. e.g. (defmodule observer "process viewer" (:use display)).
(defmacro defmodule (mod & more)
  "Declare module/namespace `mod` and compile the rest of the file into it —
definitions become `mod/name`; bare references resolve there, then through
`(:use …)` imports, then root. Records an optional docstring and `provide`s the
feature. Put it first. e.g. (defmodule hatch \"A gen_server …\")."
  (let (key (name mod)
         doc (if (string? (first more)) (first more) nil)
         clauses (if (string? (first more)) (rest more) more))
    `(do (def *module-docs* (assoc *module-docs* ~key ~doc))
         (provide ~key)
         (%in-ns '~mod)
         ~@(defmodule--use-forms clauses))))

(defn module-doc (mod)
  "The docstring declared by `(defmodule mod …)` (a symbol or string), or nil."
  (get *module-docs* (name mod)))

;; First existing <filename> across the load-path dirs, or nil.
(defn require--find (filename dirs)
  (cond
    (empty? dirs) nil
    (file-exists? (path-join (first dirs) filename)) (path-join (first dirs) filename)
    else (require--find filename (rest dirs))))

;; Load one feature once: return immediately if already loaded, else evaluate its
;; embedded source (a baked-in std module) or the first <foo>.blsp found on
;; *load-path*, then record it. Errors if it can't be found.
(defn require-one (mod)
  "Load a single feature `mod` once (a no-op if already loaded); returns its name."
  (let (key (name mod))
    (if (member? key *features*)
      key
      (let (src (%builtin-module key))
        (if src
          (do (%load-string src) (provide key))
          (let (path (require--find (str key ".blsp") *load-path*))
            (if path (do (load path) (provide key)) (error "require: cannot find module '" key "'"))))))))

;; (require 'a 'b …) — load each feature once, left to right. Returns the names.
(defn require (& mods)
  "Load each feature once (a no-op for any already loaded); errors on one not
found. Returns the list of feature names. e.g. (require 'hatch 'test)."
  (map require-one mods))
