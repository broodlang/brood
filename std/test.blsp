;; std/test.blsp — a tiny test framework, written in Brood itself.
;;
;;   (require 'test)
;;   (describe "math"
;;     (test "adds"       (assert= (+ 1 2) 3))
;;     (test "multiplies" (assert= (* 2 3) 6) (assert-error (/ 1 0))))
;;   (run-tests)
;;
;; ExUnit / `mix test`-style: `describe` groups related cases, `test` names a
;; case with a string. `deftest` (one test named by a symbol, no group) is kept
;; for convenience and expands to `test`. See docs/testing.md for the full guide.
;;
;; ─────────────────────────────────────────────────────────────────────────────
;; EXECUTION MODEL — parallel by default, with opt-in serialisation
;; ─────────────────────────────────────────────────────────────────────────────
;; Every test runs concurrently, each in its own process (spawn/send/receive),
;; UNLESS its group opts out. Two opt-outs, given as a keyword right after the
;; group/name:
;;
;;   (describe "fast stuff" ...)            ; default: each test runs in parallel
;;   (describe "uses a shared file" :serial ...)   ; its tests run one-at-a-time,
;;                                          ;   in a single worker, but still
;;                                          ;   alongside *other* groups
;;   (describe "mutates a global" :isolated ...)   ; runs ALONE, against a PRIVATE
;;                                          ;   copy of the globals: no other test
;;                                          ;   runs at the same time, and its
;;                                          ;   defs roll back when it finishes
;;   (test "touches global state" :isolated ...)   ; a lone isolated test
;;
;; Why this matters here: a runtime's processes SHARE one global table (see
;; docs/shared-code.md), so two parallel tests that both redefine the same global
;; would race. Mark such a group `:serial` (serialise within the group) or
;; `:isolated` (run alone AND with a rolled-back private copy of the globals, so a
;; test's definitions can't leak to any other test). Tests that only read the
;; prelude and their own locals are safe to run in parallel — the default.
;;
;; Phases: the :isolated units run FIRST — one at a time on the runner itself,
;; each under `%isolate` (a private copy of the globals) — so each sees the clean
;; post-load baseline and nothing it defs survives. THEN all :parallel and :serial
;; units are spawned and run together.
;;
;; ─────────────────────────────────────────────────────────────────────────────
;; SHARE-SAFE TALLYING
;; ─────────────────────────────────────────────────────────────────────────────
;; Because processes share the global table, tests must NOT tally into shared
;; mutable globals (concurrent tests would clobber one another). Instead each test
;; collects its own failures into a PROCESS-LOCAL accumulator — `*fails*`, a `let`
;; binding the `test` macro establishes — and yields them as a value; the runner
;; aggregates results from returns / messages into its own local state. No shared
;; counters, no races. (Assertions are macros that push onto `*fails*`, so use
;; them lexically inside a test body, not from unrelated top-level helpers.)
;;
;; run-tests prints, once at the end, a structured `FILE:LINE:COL:` block per
;; failed assertion (the one format for humans, LLMs and editors — see
;; docs/tooling.md), then a one-line summary with timing and memory. It raises an
;; error if anything failed (non-zero exit — how `cargo test` notices). Flag:
;;   (run-tests :slow)    ; after the summary, list the slowest tests

;; --- registry ----------------------------------------------------------------
;; Built once, at load time, on the main process — so touching these globals here
;; is single-threaded and safe; workers never touch them.
;;
;; A *unit* is the thing scheduled together: (mode group tests), where mode is
;; :parallel | :serial | :isolated and tests is a list of (name thunk). A thunk
;; runs one test body and returns its list of failure-message strings (empty =
;; passed). A default `describe` emits one :parallel unit PER test (max
;; parallelism); a :serial/:isolated `describe` emits ONE unit holding all its
;; tests (so they run in sequence, in a single process).
(defmodule test
  "A tiny ExUnit-style test framework, written in Brood. `describe` groups related
cases and `test` names one; cases run concurrently by default, with `:serial` /
`:isolated` opt-outs. `run-tests` runs the registered suite once. See
docs/testing.md for the full guide.")

(def *units* nil)
; all registered units, newest first
(def *collecting* false)
; true while a describe body is being registered
(def *collected* nil)
; (name thunk) pairs gathered for the current describe

(defn add-unit! (mode group tests) (def *units* (cons (list mode group tests) *units*)))

;; Empty the registry. A `describe`/`test` form REGISTERS by consing onto
;; `*units*`; in a fresh process that starts at nil, so a one-shot `nest test`
;; never double-counts. But a long-lived image (the `nest mcp` session, ADR-013)
;; that `load`s the same test file twice would register every unit twice and
;; report inflated counts. The project test runner calls this right before it
;; (re)loads the test files, so each run owns a clean registry regardless of how
;; many times the image has loaded them before.
(defn reset-units! ()
  "Clear the test registry (drop every registered unit). The project test runner calls this before (re)loading test files so a long-lived image — e.g. a `nest mcp` hot-reload session — doesn't accumulate duplicate registrations across runs."
  (def *units* nil))

;; Full source location of a form as (file line col), or nil. Captured at
;; macro-expansion time (by the assertion macros), while the original read form
;; still carries its position — `current-file` / `form-pos` are Rust primitives
;; (docs/tooling.md). Each failing assertion is thus self-locating, which is what
;; lets the reporter emit a clickable `FILE:LINE:COL:` anchor per failure.
(defn fail-loc (form)
  (let (p (form-pos form))
    ; [line col] vector, or nil
    (if p (list (current-file) (vector-ref p 0) (vector-ref p 1)) nil)))

;; A failing assertion THROWS a tagged failure record rather than mutating shared
;; state — Brood data is immutable (no accumulator to push onto). The tag is a
;; `%`-internal keyword the body is exceedingly unlikely to throw itself. `loc` is
;; (file line col) or nil; `details` is a list of "label: value" strings.
;; test--record turns a caught throw back into the (loc detail-lines) record the
;; runner expects.
(defn test--fail (loc details) (throw (list :%test-fail loc details)))
(defn test--failure? (e) (and (pair? e) (= (first e) :%test-fail)))
(defn test--record (e) (list (second e) (third e)))

;; Run a test body that has been split into one thunk PER top-level form, in
;; order, each in its own `try` — so failures across the body's forms are all
;; collected, not just the first (a throw ends only its own form, then we move on).
;; A non-assertion (uncaught) error is recorded and STOPS the test, since later
;; forms may depend on the one that broke. Returns the failure list (empty = pass).
(defn test--run (thunks fails)
  (if (empty? thunks)
    (reverse fails)
    (let (outcome (try (do ((first thunks)) :%ok) (catch e (list :%caught e))))
      (cond
        (= outcome :%ok) (test--run (rest thunks) fails)
        (test--failure? (second outcome)) (test--run (rest thunks)
                                            (cons (test--record (second outcome)) fails))
        else (reverse (cons (list nil (list (str "uncaught error: " (second outcome)))) fails))))))

;; A test registers itself: collected into the enclosing describe if there is
;; one, otherwise emitted as its own standalone unit (:isolated if flagged).
(defn register-test! (name thunk isolated?)
  (if *collecting*
    (def *collected* (cons (list name thunk) *collected*))
    (add-unit! (if isolated? :isolated :parallel) "" (list (list name thunk)))))

;; Turn a finished describe's collected tests into units according to its mode:
;; default spreads them across one :parallel unit each; :serial/:isolated keep
;; them together in a single unit.
(defn emit-describe! (mode group tests)
  (if (= mode :parallel)
    (fold (fn (_ t) (add-unit! :parallel group (list t))) nil tests)
    (add-unit! mode group tests)))

(defmacro describe (group & forms)
  "Register a group of tests: `(describe \"name\" [:serial | :isolated] body...)`. Tests run in parallel by default; `:serial` runs them sequentially in one process, `:isolated` each against a private copy of the globals."
  (let (mode (cond
               (= (first forms) :isolated) :isolated
               (= (first forms) :serial) :serial
               else :parallel)
        body (if (= mode :parallel) forms (rest forms)))
    `(do
       (def *collecting* true)
       (def *collected* nil)
       (do ~@body)
       ; the (test ...) forms collect themselves
       (def *collecting* false)
       (emit-describe! ~mode ~group (reverse *collected*))
       nil)))

;; (test "name" [:isolated] body...) — register one test. Each top-level body form
;; becomes its own thunk; `test--run` runs them in order, each in its own `try`,
;; collecting a failure record from every form whose assertion fails (so a test
;; can report several failures). A non-assertion error is recorded and stops the
;; test, so a crashing test can't hang the runner (a dead worker never sends, and
;; `receive` would block forever). The thunk returns the failure list (empty = pass).
(defmacro test (name & forms)
  "Register one test: `(test \"name\" [:isolated] body...)`. Each body form is checked independently, so one test can report several assertion failures."
  (let (iso (= (first forms) :isolated)
        body (if iso (rest forms) forms)
        thunks (map (fn (f) (list 'fn nil f)) body))
    ; each form -> (fn () form)
    `(register-test! ~name (fn () (test--run (list ~@thunks) nil)) ~iso)))

(defmacro deftest (name & body)
  "Register a single test named by the (symbol) `name`, outside any `describe` group."
  `(test (str (quote ~name)) ~@body))

;; --- assertions --------------------------------------------------------------
;; Macros, not functions: on failure each THROWS a tagged failure record (via
;; `test--fail`); on success they do nothing. They evaluate their operands once.
;; A throw ends the *body form* it's in, not the whole test — `test--run` runs each
;; top-level form separately, so a test collects a failure from every form that
;; fails (several failures per test). Multiple assertions nested inside ONE form
;; stop at the first. Each failure carries its own source location.
;; Each assertion reports the FAILING SOURCE EXPRESSION (quoted at macro time) and
;; the actual value — so a failure line is self-identifying: you (or an LLM reading
;; the captured run) see exactly which expression failed and what it produced,
;; without opening the file or guessing among look-alike assertions.
;; A failure record is (loc detail-lines): `loc` is (file line col) or nil, and
;; `detail-lines` is a list of "label: value" strings. The reporter turns each
;; into a clickable anchor line plus its indented fields (docs/tooling.md).
(defmacro is (expr)
  "Assert that `expr` is truthy; on failure record the source expression and its actual value."
  (let (v (gensym "v") loc (fail-loc expr))
    `(let (~v ~expr)
       (unless ~v
         (test--fail (quote ~loc)
           (list (str "assert: " (pr-str (quote (is ~expr)))) (str "actual: " (pr-str ~v))))))))

(defmacro refute (expr)
  "Assert that `expr` is falsy — the negation of `is`."
  (let (v (gensym "v") loc (fail-loc expr))
    `(let (~v ~expr)
       (when ~v
         (test--fail (quote ~loc)
           (list (str "assert: " (pr-str (quote (refute ~expr))))
             (str "actual: " (pr-str ~v) "  (expected falsy)")))))))

(defmacro assert= (actual expected)
  "Assert that `actual` is structurally equal to `expected`; on failure record both values."
  (let (a (gensym "a") b (gensym "b") loc (fail-loc actual))
    `(let (~a ~actual ~b ~expected)
       (unless (= ~a ~b)
         (test--fail (quote ~loc)
           (list (str "assert: " (pr-str (quote (assert= ~actual ~expected))))
             (str "actual: " (pr-str ~a))
             (str "expect: " (pr-str ~b))))))))

(defmacro assert-error (& body)
  "Assert that evaluating `body` raises an error; fails if it completes normally."
  ;; Quote the body for the message: the lone form if there's one, else (do …).
  (let (form (if (= (count body) 1) (first body) (cons 'do body))
        loc (fail-loc (if (= (count body) 1) (first body) nil)))
    `(unless (try (do ~@body false) (catch e true))
       (test--fail (quote ~loc)
         (list (str "assert: " (pr-str (quote (assert-error ~form)))) "actual: no error was raised")))))

;; Pair it with assert= to pin exact failure output:
;;   (assert= (error-of (/ 1 0)) "runtime error: division by zero")
(defn error-of--render (e)
  ;; Built-in errors come through `catch` as a structured map (`{:kind :code
  ;; :message :hint}`); flatten to the legacy "kind error: message" string so
  ;; tests can pin exact text. A `(throw v)` lands here as the raw value `v` —
  ;; pass it through unchanged (matches the macro's stated contract).
  (cond
    (map? e) (str (name (get e :kind)) " error: " (get e :message))
    else e))
(defmacro error-of (& body)
  "Evaluate `body` and return the error it raised — a built-in error as its `\"kind error: message\"` string, a `(throw v)` as the value `v` — or nil if `body` completes without raising."
  `(try (do ~@body nil) (catch e (error-of--render e))))

;; --- property-based testing (over the seedable PRNG) -------------------------
;; `(check-property n gen pred)` draws `n` values from `gen` (a `seed -> [value
;; next-seed]` function, e.g. built on `rand-int`/`shuffle`/`sample`) and asserts
;; `(pred value)` for each. Deterministic (fixed start seed) so a failure
;; reproduces; on the first counterexample it fails the test with the value, the
;; trial number, and the seed that produced it. A loop tested by random sampling
;; catches edge cases a single hand-written example misses.
(defn check-property--loop (n gen pred loc seed i)
  (if (>= i n)
    nil ; all trials held
    (let ([val nxt] (gen seed))
      (if (pred val)
        (check-property--loop n gen pred loc nxt (inc i))
        (test--fail loc
          (list (str "property failed on trial " (inc i) "/" n)
            (str "counterexample: " (pr-str val))
            (str "reproduce with seed: " seed)))))))

(defmacro check-property (n gen pred)
  "Property test: run `n` trials, each drawing a value with `gen` (a `seed -> [value next-seed]` function over the PRNG) and asserting `(pred value)`. Deterministic; on the first counterexample fails with the value, trial, and seed. e.g. `(check-property 100 (fn (s) (rand-int s 1000)) (fn (x) (>= x 0)))`."
  (let (loc (fail-loc pred))
    `(check-property--loop ~n ~gen ~pred (quote ~loc) 1 0)))

;; --- small text/list helpers for the trace and slow-test output --------------
(defn opt? (flag opts)
  ; is flag present in the run-tests args?
  (cond (empty? opts) false (= flag (first opts)) true else (opt? flag (rest opts))))

(defn opt-val (key opts default)
  ; the value following `key` in the run-tests args (e.g. `:timeout 5000`), or default.
  (cond (empty? opts) default
        (= key (first opts)) (second opts)
        else (opt-val key (rest opts) default)))

;; (`pad-left` / `pad-right` are the prelude's, like `take` / `quot` — all formerly
;; redefined here, which clobbered the shared global with a worse version (the local
;; `spaces` helper was non-tail-recursive; `take` was non-tail), since the runtime
;; shares one global table across all loaded modules, so `require`-ing test would
;; re-bind them for the whole image. Use the prelude's stack-safe versions.)

;; Insertion sort of (name . ms) pairs, slowest first. O(n²), but there are only
;; ever a handful of tests, so simplicity wins.
(defn insert-by-ms (x sorted)
  (cond
    (empty? sorted) (list x)
    (>= (rest x) (rest (first sorted))) (cons x sorted)
    else (cons (first sorted) (insert-by-ms x (rest sorted)))))
(defn sort-by-ms (xs) (fold (fn (acc x) (insert-by-ms x acc)) nil xs))

;; A "N.N MB" formatter for the memory line (`quot` is the prelude's).
(defn mb-str (bytes)
  (let (tenths (quot (+ (* bytes 10) 524288) 1048576)
         ; round to nearest 0.1 MB
         whole
         (quot tenths 10)
         frac
         (rem tenths 10))
    (str whole "." frac " MB")))

;; --- results -----------------------------------------------------------------
;; A result is (group name fails ms): `fails` is the list of failure records for
;; that test (empty = passed). A failure record is (loc detail-lines); `loc` is
;; (file line col) or nil, captured per-assertion (see `fail-loc`).
(defn r-group (r) (first r))
(defn r-name (r) (second r))
(defn r-fails (r) (third r))
(defn r-ms (r) (nth r 3))
(defn r-failed? (r) (not (empty? (r-fails r))))
(defn label (group name)
  ; "group › name", or just name if ungrouped
  (if (= group "") (str name) (str group " › " name)))
(defn full-name (r) (label (r-group r) (r-name r)))

;; Live progress: announce a test as it starts, when `*test-trace*` is on. Runs in
;; the worker process (so it prints before the thunk runs); a no-op otherwise.
(defn trace-start (group name)
  (when *test-trace* (println (str "▶ " (label group name)))))

;; Run one (name thunk) and produce its result (group name fails ms). The thunk
;; returns its own failure list (it catches its first failing assertion), sharing
;; no mutable state — so running these concurrently is safe.
(defn run-test (group t)
  (trace-start group (first t))
  (let (start (now) fails ((second t)) ms (- (now) start)) (list group (first t) fails ms)))

;; Like run-test, but evaluate the body with a private copy of the global
;; bindings (`%isolate`): an :isolated test's `def`s are rolled back when it
;; finishes, so they can't leak to any other test. Used only in the isolated phase.
(defn run-test-fresh (group t)
  (trace-start group (first t))
  (let (start (now) fails (%isolate (second t)) ms (- (now) start)) (list group (first t) fails ms)))

;; Run every test in a unit, in order, returning the list of results. This is
;; what a worker does (for a :parallel/:serial unit) and what the runner does
;; directly for an :isolated unit.
(defn run-unit (unit) (let (group (second unit)) (map (fn (t) (run-test group t)) (third unit))))

;; --- the two phases ----------------------------------------------------------
;; Parallel phase: spawn one worker per non-isolated unit (each worker captures
;; its unit and reports the unit's results back as one message), then collect.
;; Output is emitted once at the end (a single structured report), so there is no
;; per-test progress to print here.
(defn spawn-units (units me)
  ;; Spawn one MONITORED worker per unit and return an assoc list of
  ;; `(pid unit)`. Each worker tags its message with its own pid (`(self)`),
  ;; which equals the pid `spawn` returns — so the collector can correlate a
  ;; result with the worker that produced it. `monitor` lets the collector
  ;; observe a worker that DIES before reporting (KI-2: a raced/crashed test
  ;; process throwing in `run-unit` itself, outside any per-form `try`) and turn
  ;; it into a failure instead of blocking forever in `receive`. The kernel fires
  ;; `[:down …]` immediately if the worker has already exited, so there is no
  ;; lost-death window between `spawn` and `monitor`.
  (fold
    (fn (acc unit)
      (let (pid (spawn (send me (list :unit-result (self) (run-unit unit)))))
        (monitor pid)
        (cons (list pid unit) acc)))
    nil
    units))

;; How many units run concurrently in the parallel phase. This BOUNDS MEMORY: the
;; GC is still a no-op (M1), so every *started* worker holds its entire allocation
;; until it exits — and reduction-preemption interleaves all started workers, so
;; spawning ALL units at once kept hundreds of heaps live simultaneously and made
;; the suite peak ~18 GiB (enough to OOM-freeze the host). The hibernating driver
;; (`run-driver`) instead spawns at most this many per group, collects them — each
;; then exits and its LOCAL heap is reclaimed wholesale — and only then spawns the
;; next group (and flips its own arena between groups), so the live set is
;; bounded by one group. The cap (`-j`) on OS threads does NOT bound this (it
;; limits threads, not started-and-suspended coroutines). Lower = less memory,
;; less parallelism; raise once the GC reclaims so a unit's transients don't pile
;; up. Within a group, a unit that itself spawns many workers still runs them
;; freely — this only bounds how many *units* are in flight at once.
(def *parallel-batch* 4)

;; Two per-test wall-clock thresholds, in milliseconds — distinct on purpose:
;;
;; - `*test-slow-ms*` (default 1s) — **informational**. A test that takes longer is
;;   listed (name + duration) under the summary. It still PASSES; this only surfaces
;;   where the time goes. Override: `(run-tests :slow-over MS)`.
;; - `*test-timeout-ms*` (default 30s) — **a hard ceiling**. A test that runs longer
;;   is hard-killed (`(exit worker :kill)`, ADR-063 — stops even a tight loop that
;;   never `receive`s) and reported as a "timed out" FAILURE, so a hung/runaway test
;;   fails the suite instead of dragging or wedging it. Override: `(run-tests :timeout
;;   MS)`. Workers in a batch start together, so the deadline (`collect-start + this`)
;;   is effectively per-test (per-unit for `:serial`/`:isolated`).
;;
;; So: slow ≤ duration < timeout → listed but passes; duration ≥ timeout → killed +
;; failed. Keep `*test-slow-ms*` < `*test-timeout-ms*` (a slow test you still want to
;; see before it's a hard failure).
(def *test-slow-ms* 1000)
(def *test-timeout-ms* 30000)

;; When set, print `▶ group › name` as each test STARTS — live progress so you can
;; see which test is running (and spot the slow/hung one) before it finishes. Off by
;; default, and never set by `run-tests-structured` / the `--test` path, so machine-
;; parsed and structured output stays clean. `(run-tests :trace)` turns it on, and
;; `nest test` passes `:trace`. Lines from parallel workers interleave (each is one
;; flushed `println`); they come in waves of `*parallel-batch*`.
(def *test-trace* false)

;; The parallel/serial units run in bounded groups (see `*parallel-batch*`) — the
;; loop that does so is the `run-driver` below, which also folds in the isolated
;; phase. (It used to be a plain `run-parallel`/`run-isolated` pair; they were
;; merged into the driver so the runner collects between groups at the safepoint.)

;; The unit a monitored worker `pid` was spawned for, or nil if `pid` isn't one
;; of ours (e.g. a stale `[:down …]` from a previous run still in the mailbox).
(defn unit-of-pid (pid workers)
  (cond (empty? workers) nil
        (= (first (first workers)) pid) (second (first workers))
        else (unit-of-pid pid (rest workers))))

;; A worker died before reporting (KI-2). Synthesize a failing result for every
;; test in its unit, carrying the exit reason — so a crashed/raced worker fails
;; fast as a visible failure instead of hanging the collector. A result tuple is
;; `(group name fails ms)`; a failure record is `(loc detail-lines)` with loc nil.
(defn dead-unit-results (unit reason)
  (map (fn (t)
         (list (second unit) (first t)
           (list (list nil (list (str "test process died: " (pr-str reason)))))
           0))
    (third unit)))

;; Account for each spawned worker exactly once — by its result if it reported,
;; otherwise by its death. A healthy worker sends `[:unit-result pid results]`
;; then exits `:normal` (its later `[:down …]` is ignored because its pid is in
;; `reported`); a crashed worker sends nothing but its monitor fires
;; `[:down mref pid reason]`, which we turn into failing results. `pending`
;; counts workers not yet accounted for. A `[:down …]` for an unknown pid (a
;; stale worker from a prior run in a long-lived session) is ignored WITHOUT
;; decrementing, so it can't corrupt the count.
;; Budget exhausted (`*test-timeout-ms*`): every worker that hasn't reported is
;; presumed hung. Hard-kill each — `(exit pid :kill)` stops even a tight non-receive
;; loop (ADR-063) — and synthesize a timeout failure for each of its tests, so a hung
;; test FAILS instead of wedging the collector. Returns the full result list.
(defn collect-timeout (workers reported acc)
  (fold (fn (a w)
          (if (member? (first w) reported)
            a
            (do (exit (first w) :kill)
                (append (timeout-unit-results (second w)) a))))
    acc
    workers))

;; A timeout failure per test in a hung unit — same shape as `dead-unit-results`:
;; `(group name fails ms)`, `fails` = `((loc detail-lines))`.
(defn timeout-unit-results (unit)
  (map (fn (t)
         (list (second unit) (first t)
           (list (list nil (list (str "test timed out after " (quot *test-timeout-ms* 1000)
                                    "s — hard-killed (raise *test-timeout-ms* if legitimately slow)"))))
           *test-timeout-ms*))
    (third unit)))

(defn collect-units (workers acc)
  ;; Fixed wall deadline for this batch — recomputed per collect, so each isolated
  ;; unit / parallel chunk gets its own full budget.
  (collect-loop (count workers) workers nil acc (+ (now) *test-timeout-ms*)))

(defn collect-loop (pending workers reported acc deadline)
  (if (= pending 0)
    acc
    ;; `(m m)` takes the next message; `(after …)` fires when the budget is spent.
    (let (msg (receive (m m) (after (max 0 (- deadline (now))) :%test-timeout)))
      (cond
        (= msg :%test-timeout)               ; budget spent — kill + fail the stragglers
        (collect-timeout workers reported acc)

        (= (first msg) :unit-result)         ; [:unit-result pid results]
        (let (pid (second msg))
          ;; Ignore a result from a pid that isn't one of THIS batch's workers, or
          ;; one already counted — a late message from a timed-out/killed worker of a
          ;; prior step must not corrupt this step's `pending` count.
          (if (or (member? pid reported) (nil? (unit-of-pid pid workers)))
            (collect-loop pending workers reported acc deadline)
            (collect-loop (- pending 1) workers (cons pid reported)
              (append (third msg) acc) deadline)))

        (= (first msg) :down)                ; [:down mref pid reason]
        (let (pid (third msg)
              unit (unit-of-pid pid workers))
          (cond
            (member? pid reported) (collect-loop pending workers reported acc deadline)
            (nil? unit)            (collect-loop pending workers reported acc deadline)
            else (collect-loop (- pending 1) workers reported
                   (append (dead-unit-results unit (nth msg 3)) acc) deadline)))

        ;; Anything else in the runner's mailbox isn't ours — skip it.
        else (collect-loop pending workers reported acc deadline)))))

;; Run a whole unit with each test under `%isolate` (global-def rollback). This
;; is what an isolated unit's *own* worker process evaluates.
(defn run-unit-fresh (unit)
  (let (group (second unit)) (map (fn (t) (run-test-fresh group t)) (third unit)))) ; -> results

;; ─── The test runner ────────────────────────────────────────────────────────
;; The runner is one long-lived process gathering every step's results. Its
;; per-step transients — worker-result copies, the `append` spine, spawn/monitor
;; machinery — are garbage that once climbed to the memory cap (the ~633-test
;; suite hit ~4 GiB) because automatic collection was off. It no longer does: the
;; driver loop is a SPAWNED process body, so it runs at the depth-1 eval safepoint
;; where **Stage B's automatic copying GC** (ADR-055) fires — each iteration's
;; garbage is reclaimed while the live `acc` is kept (it's rooted as a tail-call
;; argument). A plain tail call bounds the suite; the `(hibernate)` Stage A used
;; here is gone (and the primitive itself was removed — automatic GC made it
;; redundant, docs/memory-review.md §6).
;;
;; Each isolated unit still runs in its OWN awaited worker (so its heap is dropped
;; wholesale on exit, and its mailbox can't leak stragglers into another test);
;; the parallel units still run in `*parallel-batch*`-sized groups (so the live
;; set per collection stays bounded to one group). Isolated steps come first and
;; serially, so `%isolate`'s snapshot/restore of the shared globals table can't
;; race a concurrent unit and each sees the clean post-load baseline.

;; Chunk `coll` into ≤`n`-sized groups, KEEPING a short trailing group (`partition`
;; drops it — which here would silently skip tests).
(defn run--chunks (n coll acc)
  (if (empty? coll)
    (reverse acc)
    (run--chunks n (drop n coll) (cons (take n coll) acc))))

;; The driver's work list: each isolated unit as its own `(:iso unit)` step, then
;; the parallel/serial units as `(:par . units)` groups.
(defn run--steps (iso par)
  (append (map (fn (u) (list :iso u)) iso)
          (map (fn (b) (cons :par b)) (run--chunks *parallel-batch* par nil))))

;; Run one step in the current (driver) process, returning its unit results. An
;; `:iso` step spawns+awaits one unit under `%isolate`; a `:par` step spawns the
;; group and collects it. A crashed worker (KI-2) becomes failing results via the
;; `monitor` inside `spawn-units`/here, never a hang.
(defn run--step (step)
  (if (= (first step) :iso)
    (let (me (self)
          unit (second step)
          pid (spawn (send me (list :unit-result (self) (run-unit-fresh unit))))
          _ (monitor pid))
      (collect-units (list (list pid unit)) nil))
    (collect-units (spawn-units (rest step) (self)) nil)))

;; The driver loop: run a step, then tail-recurse into the next with its results
;; accumulated. Stage B collects the step's transients at the safepoint between
;; iterations (this is a depth-1 spawned-process body), keeping `acc` live. When
;; the work list is empty, hand the full result list to `parent` (the process
;; exits, so its heap drops too).
(defn run-driver (steps parent acc)
  (if (empty? steps)
    (send parent [:all-results acc])
    (run-driver (rest steps) parent
      (append (run--step (first steps)) acc))))

;; Spawn the driver and block until it reports every unit's results. Monitors it
;; so a driver crash surfaces as an error instead of hanging the suite.
(defn drain-runner (iso par)
  (let (me (self)
        d  (spawn (run-driver (run--steps iso par) me nil))
        mref (monitor d))
    (receive
      ([:all-results rs] rs)
      ([:down ~mref ~d reason] (error (str "test runner crashed: " reason))))))
;; ────────────────────────────────────────────────────────────────────────────

;; --- reporting ---------------------------------------------------------------
;; A failure record is (loc detail-lines): loc is (file line col) or nil.
(defn fail-loc-of (rec) (first rec))
(defn fail-lines-of (rec) (second rec))

;; The anchor line for a failed assertion. With a location it's the GNU
;; `FILE:LINE:COL: message` form that compilation-mode / flymake parse and make
;; clickable; without one, just the message. The labeled fields print indented
;; under it. See docs/tooling.md.
(defn fail-anchor (r rec)
  (let (loc (fail-loc-of rec))
    (if loc
      (str (first loc) ":" (second loc) ":" (third loc) ": test failed: " (full-name r))
      (str "test failed: " (full-name r)))))

;; Print every failure of a result as: an anchor line, then its fields indented.
(defn print-failure (indent r)
  (fold (fn (_ rec)
          (println (fail-anchor r rec))
          (fold (fn (_ line) (println (str indent line))) nil (fail-lines-of rec)))
    nil
    (r-fails r)))

;; Emit one editor-parseable block per failed assertion. There is a single
;; output format — structured — for humans, LLMs and Emacs alike (docs/tooling.md).
(defn report-failures (results)
  (let (failed (filter r-failed? results))
    (unless (empty? failed) (println "") (fold (fn (_ r) (print-failure "    " r)) nil failed))))

(defn report-slow (results)
  (println "")
  (println "Slowest tests:")
  (let (timings (map (fn (r) (cons (full-name r) (r-ms r))) results))
    (fold (fn (_ entry)
            (println (str "  "
                       (pad-right (str (first entry)) 28)
                       (pad-left (str (rest entry)) 6)
                       " ms")))
      nil
      (take 5 (sort-by-ms timings)))))

;; "1.3s" from milliseconds — one decimal, rounded to nearest 0.1s.
(defn secs-str (ms)
  (let (tenths (quot (+ ms 50) 100)) (str (quot tenths 10) "." (rem tenths 10) "s")))

;; Always-on slow-test surfacing: list every test slower than `over` ms (slowest
;; first), so a slow test is never hidden behind the one-line summary. Unlike
;; `report-slow` (the opt-in `:slow` top-5), this fires automatically. Prints
;; nothing when every test is under the threshold — the common, fast case stays
;; quiet.
(defn report-slow-over (results over)
  (let (slow (filter (fn (p) (> (rest p) over))
               (map (fn (r) (cons (full-name r) (r-ms r))) results)))
    (unless (empty? slow)
      (println "")
      (println (str "Slow tests (> " (secs-str over) "):"))
      (fold (fn (_ p)
              (println (str "  " (pad-right (str (first p)) 40) " " (secs-str (rest p)))))
        nil
        (sort-by-ms slow)))))

(defn count-failed (results)
  ; tests with at least one failed assertion
  (fold (fn (acc r) (if (r-failed? r) (+ acc 1) acc)) 0 results))
(defn count-failures (results)
  ; total failed assertions across tests
  (fold (fn (acc r) (+ acc (count (r-fails r)))) 0 results))

;; --- entry point -------------------------------------------------------------
(defn run-tests (& opts)
  "Run every registered test once (the isolated tests first, then the parallel/serial pool), print a summary, and raise if any failed. Each test has a 30s hard timeout (killed + failed if exceeded — `:timeout MS` to change). Any test over 1s is listed automatically (`:slow-over MS` to change that threshold); `:slow` also reports the slowest 5 regardless of duration."
  ;; `:timeout MS` / `:slow-over MS` override the budgets for this run (global rebind
  ;; — the spawned driver reads `*test-timeout-ms*` from the shared table).
  (def *test-timeout-ms* (opt-val :timeout opts *test-timeout-ms*))
  (def *test-slow-ms* (opt-val :slow-over opts *test-slow-ms*))
  (def *test-trace* (opt? :trace opts))
  (let (units (reverse *units*)
         par
         (filter (fn (u) (not= (first u) :isolated)) units)
         ; parallel + serial
         iso
         (filter (fn (u) (= (first u) :isolated)) units)
         start
         (now))
    ;; All result-gathering runs in the hibernating driver (isolated units first
    ;; and serially, then the parallel groups), so the runner's per-step transients
    ;; are reclaimed between steps. See the Stage-A block above.
    (let (results (drain-runner iso par)
          elapsed (- (now) start)
          total (count results)
          failed (count-failed results)
          fails (count-failures results))
      (report-failures results)
      (report-slow-over results *test-slow-ms*)
      (when (opt? :slow opts) (report-slow results))
      (println "")
      (println total
        "tests,"
        (- total failed)
        "passed,"
        failed
        "failed"
        (str "(" fails " failed assertions, " (count iso) " isolated)"))
      (println (str "  (" elapsed " ms wall, peak " (mb-str (mem-peak)) ")"))
      (if (> failed 0) (error (str failed " test(s) failed")) :ok))))

;; Structured analogue of `run-tests` — runs the same suite (isolated phase,
;; then parallel/serial), but **returns data** instead of printing + throwing.
;; Backs the `nest mcp` `run-tests` tool (step 1c-b). Shape:
;;   {:total :passed :failed :failed-assertions :ms
;;    :results [{:group :name :passed :ms :failures [{:loc :details} ...]}]}
;; `:loc` is `[file line col]` or nil; `:details` is a list of strings.
;; A test that uncaught-errored shows up as `:passed false` with a single
;; failure carrying the error text (consistent with the textual runner).
(defn run-tests-structured (& opts)
  "Like `run-tests`, but returns the result as data — `{:total :passed :failed :failed-assertions :ms :results [...]}` — instead of printing and raising. Backs the `nest mcp` `run-tests` tool."
  (let (units (reverse *units*)
        par   (filter (fn (u) (not= (first u) :isolated)) units)
        iso   (filter (fn (u) (= (first u) :isolated)) units)
        start (now))
    (let (results     (drain-runner iso par)
          elapsed     (- (now) start)
          total       (count results)
          failed      (count-failed results)
          fails       (count-failures results))
      {:total total
       :passed (- total failed)
       :failed failed
       :failed-assertions fails
       :ms elapsed
       ;; `(or … [])` on every list field so empty results render as JSON
       ;; `[]` rather than `null`. Matters when the suite has zero tests, or
       ;; a passing test has zero failures — agents branch on `length`, not
       ;; `(= null)`.
       :results (or (map (fn (r)
                       {:group (r-group r)
                        :name (r-name r)
                        :passed (not (r-failed? r))
                        :ms (r-ms r)
                        :failures (or (map (fn (f) {:loc (first f) :details (second f)})
                                       (r-fails r))
                                      [])})
                  results)
                 [])})))
