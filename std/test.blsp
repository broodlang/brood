;; std/test.blsp — a tiny test framework, written in Brood itself.
;;
;;   (require 'test)
;;   (describe "math"
;;     (test "adds"       (assert= (+ 1 2) 3))
;;     (test "multiplies" (assert= (* 2 3) 6) (assert-error (/ 1 0))))
;;   (run-tests)
;;
;; ExUnit / `mix test`-style: `describe` groups related cases, `test` names a
;; case with a string. `deftest` (one test named by a symbol, no group) is kept
;; for convenience and expands to `test`. See docs/testing.md for the full guide.
;;
;; ─────────────────────────────────────────────────────────────────────────────
;; EXECUTION MODEL — parallel by default, with opt-in serialisation
;; ─────────────────────────────────────────────────────────────────────────────
;; Every test runs concurrently, each in its own process (spawn/send/receive),
;; UNLESS its group opts out. Two opt-outs, given as a keyword right after the
;; group/name:
;;
;;   (describe "fast stuff" ...)            ; default: each test runs in parallel
;;   (describe "uses a shared file" :serial ...)   ; its tests run one-at-a-time,
;;                                          ;   in a single worker, but still
;;                                          ;   alongside *other* groups
;;   (describe "mutates a global" :isolated ...)   ; runs ALONE, against a PRIVATE
;;                                          ;   copy of the globals: no other test
;;                                          ;   runs at the same time, and its
;;                                          ;   defs roll back when it finishes
;;   (test "touches global state" :isolated ...)   ; a lone isolated test
;;
;; Why this matters here: a runtime's processes SHARE one global table (see
;; docs/shared-code.md), so two parallel tests that both redefine the same global
;; would race. Mark such a group `:serial` (serialise within the group) or
;; `:isolated` (run alone AND with a rolled-back private copy of the globals, so a
;; test's definitions can't leak to any other test). Tests that only read the
;; prelude and their own locals are safe to run in parallel — the default.
;;
;; Phases: the :isolated units run FIRST — one at a time on the runner itself,
;; each under `%isolate` (a private copy of the globals) — so each sees the clean
;; post-load baseline and nothing it defs survives. THEN all :parallel and :serial
;; units are spawned and run together.
;;
;; ─────────────────────────────────────────────────────────────────────────────
;; SHARE-SAFE TALLYING
;; ─────────────────────────────────────────────────────────────────────────────
;; Because processes share the global table, tests must NOT tally into shared
;; mutable globals (concurrent tests would clobber one another). Instead each test
;; collects its own failures into a PROCESS-LOCAL accumulator — `*fails*`, a `let`
;; binding the `test` macro establishes — and yields them as a value; the runner
;; aggregates results from returns / messages into its own local state. No shared
;; counters, no races. (Assertions are macros that push onto `*fails*`, so use
;; them lexically inside a test body, not from unrelated top-level helpers.)
;;
;; run-tests prints, once at the end, a structured `FILE:LINE:COL:` block per
;; failed assertion (the one format for humans, LLMs and editors — see
;; docs/tooling.md), then a one-line summary with timing and memory. It raises an
;; error if anything failed (non-zero exit — how `cargo test` notices). Flag:
;;   (run-tests :slow)    ; after the summary, list the slowest tests

;; --- registry ----------------------------------------------------------------
;; Built once, at load time, on the main process — so touching these globals here
;; is single-threaded and safe; workers never touch them.
;;
;; A *unit* is the thing scheduled together: (mode group tests), where mode is
;; :parallel | :serial | :isolated and tests is a list of (name thunk). A thunk
;; runs one test body and returns its list of failure-message strings (empty =
;; passed). A default `describe` emits one :parallel unit PER test (max
;; parallelism); a :serial/:isolated `describe` emits ONE unit holding all its
;; tests (so they run in sequence, in a single process).
(defmodule test
  "A tiny ExUnit-style test framework, written in Brood. `describe` groups related
cases and `test` names one; cases run concurrently by default, with `:serial` /
`:isolated` opt-outs. `run-tests` runs the registered suite once. See
docs/testing.md for the full guide.")

(def *units* nil)
; all registered units, newest first
(def *collecting* false)
; true while a describe body is being registered
(def *collected* nil)
; (name thunk) pairs gathered for the current describe

(defn add-unit! (mode group tests) (def *units* (cons (list mode group tests) *units*)))

;; Empty the registry. A `describe`/`test` form REGISTERS by consing onto
;; `*units*`; in a fresh process that starts at nil, so a one-shot `nest test`
;; never double-counts. But a long-lived image (the `nest mcp` session, ADR-013)
;; that `load`s the same test file twice would register every unit twice and
;; report inflated counts. The project test runner calls this right before it
;; (re)loads the test files, so each run owns a clean registry regardless of how
;; many times the image has loaded them before.
(defn reset-units! ()
  "Clear the test registry (drop every registered unit). The project test runner calls this before (re)loading test files so a long-lived image — e.g. a `nest mcp` hot-reload session — doesn't accumulate duplicate registrations across runs."
  (def *units* nil))

;; Full source location of a form as (file line col), or nil. Captured at
;; macro-expansion time (by the assertion macros), while the original read form
;; still carries its position — `current-file` / `form-pos` are Rust primitives
;; (docs/tooling.md). Each failing assertion is thus self-locating, which is what
;; lets the reporter emit a clickable `FILE:LINE:COL:` anchor per failure.
(defn fail-loc (form)
  (let (p (form-pos form))
    ; [line col] vector, or nil
    (if p (list (current-file) (vector-ref p 0) (vector-ref p 1)) nil)))

;; A failing assertion THROWS a tagged failure record rather than mutating shared
;; state — Brood data is immutable (no accumulator to push onto). The tag is a
;; `%`-internal keyword the body is exceedingly unlikely to throw itself. `loc` is
;; (file line col) or nil; `details` is a list of "label: value" strings.
;; test--record turns a caught throw back into the (loc detail-lines) record the
;; runner expects.
(defn test--fail (loc details) (throw (list :%test-fail loc details)))
(defn test--failure? (e) (and (pair? e) (= (first e) :%test-fail)))
(defn test--record (e) (list (second e) (third e)))

;; Run a test body that has been split into one thunk PER top-level form, in
;; order, each in its own `try` — so failures across the body's forms are all
;; collected, not just the first (a throw ends only its own form, then we move on).
;; A non-assertion (uncaught) error is recorded and STOPS the test, since later
;; forms may depend on the one that broke. Returns the failure list (empty = pass).
(defn test--run (thunks fails)
  (if (empty? thunks)
    (reverse fails)
    (let (outcome (try (do ((first thunks)) :%ok) (catch e (list :%caught e))))
      (cond
        (= outcome :%ok) (test--run (rest thunks) fails)
        (test--failure? (second outcome)) (test--run (rest thunks)
                                            (cons (test--record (second outcome)) fails))
        else (reverse (cons (list nil (list (str "uncaught error: " (second outcome)))) fails))))))

;; A test registers itself: collected into the enclosing describe if there is
;; one, otherwise emitted as its own standalone unit (:isolated if flagged).
(defn register-test! (name thunk isolated?)
  (if *collecting*
    (def *collected* (cons (list name thunk) *collected*))
    (add-unit! (if isolated? :isolated :parallel) "" (list (list name thunk)))))

;; Turn a finished describe's collected tests into units according to its mode:
;; default spreads them across one :parallel unit each; :serial/:isolated keep
;; them together in a single unit.
(defn emit-describe! (mode group tests)
  (if (= mode :parallel)
    (fold (fn (_ t) (add-unit! :parallel group (list t))) nil tests)
    (add-unit! mode group tests)))

(defmacro describe (group & forms)
  "Register a group of tests: `(describe \"name\" [:serial | :isolated] body...)`. Tests run in parallel by default; `:serial` runs them sequentially in one process, `:isolated` each against a private copy of the globals."
  (let (mode (cond
               (= (first forms) :isolated) :isolated
               (= (first forms) :serial) :serial
               else :parallel)
        body (if (= mode :parallel) forms (rest forms)))
    `(do
       (def *collecting* true)
       (def *collected* nil)
       (do ~@body)
       ; the (test ...) forms collect themselves
       (def *collecting* false)
       (emit-describe! ~mode ~group (reverse *collected*))
       nil)))

;; (test "name" [:isolated] body...) — register one test. Each top-level body form
;; becomes its own thunk; `test--run` runs them in order, each in its own `try`,
;; collecting a failure record from every form whose assertion fails (so a test
;; can report several failures). A non-assertion error is recorded and stops the
;; test, so a crashing test can't hang the runner (a dead worker never sends, and
;; `receive` would block forever). The thunk returns the failure list (empty = pass).
(defmacro test (name & forms)
  "Register one test: `(test \"name\" [:isolated] body...)`. Each body form is checked independently, so one test can report several assertion failures."
  (let (iso (= (first forms) :isolated)
        body (if iso (rest forms) forms)
        thunks (map (fn (f) (list 'fn nil f)) body))
    ; each form -> (fn () form)
    `(register-test! ~name (fn () (test--run (list ~@thunks) nil)) ~iso)))

(defmacro deftest (name & body)
  "Register a single test named by the (symbol) `name`, outside any `describe` group."
  `(test (str (quote ~name)) ~@body))

;; --- assertions --------------------------------------------------------------
;; Macros, not functions: on failure each THROWS a tagged failure record (via
;; `test--fail`); on success they do nothing. They evaluate their operands once.
;; A throw ends the *body form* it's in, not the whole test — `test--run` runs each
;; top-level form separately, so a test collects a failure from every form that
;; fails (several failures per test). Multiple assertions nested inside ONE form
;; stop at the first. Each failure carries its own source location.
;; Each assertion reports the FAILING SOURCE EXPRESSION (quoted at macro time) and
;; the actual value — so a failure line is self-identifying: you (or an LLM reading
;; the captured run) see exactly which expression failed and what it produced,
;; without opening the file or guessing among look-alike assertions.
;; A failure record is (loc detail-lines): `loc` is (file line col) or nil, and
;; `detail-lines` is a list of "label: value" strings. The reporter turns each
;; into a clickable anchor line plus its indented fields (docs/tooling.md).
(defmacro is (expr)
  "Assert that `expr` is truthy; on failure record the source expression and its actual value."
  (let (v (gensym "v") loc (fail-loc expr))
    `(let (~v ~expr)
       (unless ~v
         (test--fail (quote ~loc)
           (list (str "assert: " (pr-str (quote (is ~expr)))) (str "actual: " (pr-str ~v))))))))

(defmacro refute (expr)
  "Assert that `expr` is falsy — the negation of `is`."
  (let (v (gensym "v") loc (fail-loc expr))
    `(let (~v ~expr)
       (when ~v
         (test--fail (quote ~loc)
           (list (str "assert: " (pr-str (quote (refute ~expr))))
             (str "actual: " (pr-str ~v) "  (expected falsy)")))))))

(defmacro assert= (actual expected)
  "Assert that `actual` is structurally equal to `expected`; on failure record both values."
  (let (a (gensym "a") b (gensym "b") loc (fail-loc actual))
    `(let (~a ~actual ~b ~expected)
       (unless (= ~a ~b)
         (test--fail (quote ~loc)
           (list (str "assert: " (pr-str (quote (assert= ~actual ~expected))))
             (str "actual: " (pr-str ~a))
             (str "expect: " (pr-str ~b))))))))

(defmacro assert-error (& body)
  "Assert that evaluating `body` raises an error; fails if it completes normally."
  ;; Quote the body for the message: the lone form if there's one, else (do …).
  (let (form (if (= (count body) 1) (first body) (cons 'do body))
        loc (fail-loc (if (= (count body) 1) (first body) nil)))
    `(unless (try (do ~@body false) (catch e true))
       (test--fail (quote ~loc)
         (list (str "assert: " (pr-str (quote (assert-error ~form)))) "actual: no error was raised")))))

;; Pair it with assert= to pin exact failure output:
;;   (assert= (error-of (/ 1 0)) "runtime error: division by zero")
(defmacro error-of (& body)
  "Evaluate `body` and return the error it raised — a built-in error as its message string, a `(throw v)` as the value `v` — or nil if `body` completes without raising."
  `(try (do ~@body nil) (catch e e)))

;; --- small text/list helpers for the trace and slow-test output --------------
(defn opt? (flag opts)
  ; is flag present in the run-tests args?
  (cond (empty? opts) false (= flag (first opts)) true else (opt? flag (rest opts))))

(defn spaces (n) (if (<= n 0) "" (str " " (spaces (- n 1)))))
(defn pad-right (s w) (str s (spaces (- w (count s)))))
(defn pad-left (s w) (str (spaces (- w (count s))) s))

;; (`take` / `quot` are the prelude's — formerly redefined here, which clobbered
;; the shared global `take` with a non-tail version, since the runtime shares one
;; global table across all loaded modules. Use the prelude's stack-safe versions.)

;; Insertion sort of (name . ms) pairs, slowest first. O(n²), but there are only
;; ever a handful of tests, so simplicity wins.
(defn insert-by-ms (x sorted)
  (cond
    (empty? sorted) (list x)
    (>= (rest x) (rest (first sorted))) (cons x sorted)
    else (cons (first sorted) (insert-by-ms x (rest sorted)))))
(defn sort-by-ms (xs) (fold (fn (acc x) (insert-by-ms x acc)) nil xs))

;; A "N.N MB" formatter for the memory line (`quot` is the prelude's).
(defn mb-str (bytes)
  (let (tenths (quot (+ (* bytes 10) 524288) 1048576)
         ; round to nearest 0.1 MB
         whole
         (quot tenths 10)
         frac
         (rem tenths 10))
    (str whole "." frac " MB")))

;; --- results -----------------------------------------------------------------
;; A result is (group name fails ms): `fails` is the list of failure records for
;; that test (empty = passed). A failure record is (loc detail-lines); `loc` is
;; (file line col) or nil, captured per-assertion (see `fail-loc`).
(defn r-group (r) (first r))
(defn r-name (r) (second r))
(defn r-fails (r) (third r))
(defn r-ms (r) (nth r 3))
(defn r-failed? (r) (not (empty? (r-fails r))))
(defn label (group name)
  ; "group › name", or just name if ungrouped
  (if (= group "") (str name) (str group " › " name)))
(defn full-name (r) (label (r-group r) (r-name r)))

;; Run one (name thunk) and produce its result (group name fails ms). The thunk
;; returns its own failure list (it catches its first failing assertion), sharing
;; no mutable state — so running these concurrently is safe.
(defn run-test (group t)
  (let (start (now) fails ((second t)) ms (- (now) start)) (list group (first t) fails ms)))

;; Like run-test, but evaluate the body with a private copy of the global
;; bindings (`%isolate`): an :isolated test's `def`s are rolled back when it
;; finishes, so they can't leak to any other test. Used only in the isolated phase.
(defn run-test-fresh (group t)
  (let (start (now) fails (%isolate (second t)) ms (- (now) start)) (list group (first t) fails ms)))

;; Run every test in a unit, in order, returning the list of results. This is
;; what a worker does (for a :parallel/:serial unit) and what the runner does
;; directly for an :isolated unit.
(defn run-unit (unit) (let (group (second unit)) (map (fn (t) (run-test group t)) (third unit))))

;; --- the two phases ----------------------------------------------------------
;; Parallel phase: spawn one worker per non-isolated unit (each worker captures
;; its unit and reports the unit's results back as one message), then collect.
;; Output is emitted once at the end (a single structured report), so there is no
;; per-test progress to print here.
(defn spawn-units (units me)
  (fold
    (fn (_ unit)
      ;; capture `me` (the collector) and `unit` lexically; the thunk runs in
      ;; the child and reports this unit's results back.
      (spawn (send me (run-unit unit))))
    nil
    units))

(defn collect-units (remaining acc)
  ; remaining = messages still to receive
  (if (= remaining 0)
    acc
    (let (results (receive))
      ; one unit's worth of results
      (collect-units (- remaining 1) (append results acc)))))

;; Isolated phase: run each isolated unit on the runner itself, one at a time, so
;; nothing else is executing — and each test under `%isolate`, so its global defs
;; are rolled back and can't leak to another test.
(defn run-isolated (units acc)
  (if (empty? units)
    acc
    (let (unit (first units)
          group (second unit)
          results (map (fn (t) (run-test-fresh group t)) (third unit)))
      (run-isolated (rest units) (append results acc)))))

;; --- reporting ---------------------------------------------------------------
;; A failure record is (loc detail-lines): loc is (file line col) or nil.
(defn fail-loc-of (rec) (first rec))
(defn fail-lines-of (rec) (second rec))

;; The anchor line for a failed assertion. With a location it's the GNU
;; `FILE:LINE:COL: message` form that compilation-mode / flymake parse and make
;; clickable; without one, just the message. The labeled fields print indented
;; under it. See docs/tooling.md.
(defn fail-anchor (r rec)
  (let (loc (fail-loc-of rec))
    (if loc
      (str (first loc) ":" (second loc) ":" (third loc) ": test failed: " (full-name r))
      (str "test failed: " (full-name r)))))

;; Print every failure of a result as: an anchor line, then its fields indented.
(defn print-failure (indent r)
  (fold (fn (_ rec)
          (println (fail-anchor r rec))
          (fold (fn (_ line) (println (str indent line))) nil (fail-lines-of rec)))
    nil
    (r-fails r)))

;; Emit one editor-parseable block per failed assertion. There is a single
;; output format — structured — for humans, LLMs and Emacs alike (docs/tooling.md).
(defn report-failures (results)
  (let (failed (filter r-failed? results))
    (unless (empty? failed) (println "") (fold (fn (_ r) (print-failure "    " r)) nil failed))))

(defn report-slow (results)
  (println "")
  (println "Slowest tests:")
  (let (timings (map (fn (r) (cons (full-name r) (r-ms r))) results))
    (fold (fn (_ entry)
            (println (str "  "
                       (pad-right (str (first entry)) 28)
                       (pad-left (str (rest entry)) 6)
                       " ms")))
      nil
      (take 5 (sort-by-ms timings)))))

(defn count-failed (results)
  ; tests with at least one failed assertion
  (fold (fn (acc r) (if (r-failed? r) (+ acc 1) acc)) 0 results))
(defn count-failures (results)
  ; total failed assertions across tests
  (fold (fn (acc r) (+ acc (count (r-fails r)))) 0 results))

;; --- entry point -------------------------------------------------------------
(defn run-tests (& opts)
  "Run every registered test once (the isolated tests first, then the parallel/serial pool), print a summary, and raise if any failed. Pass `:slow` to also report the slowest tests."
  (let (units (reverse *units*)
         par
         (filter (fn (u) (not= (first u) :isolated)) units)
         ; parallel + serial
         iso
         (filter (fn (u) (= (first u) :isolated)) units)
         start
         (now)
         me
         (self))
    ;; Isolated phase first: each isolated test runs alone, against a private copy
    ;; of the globals, so it sees the clean post-load baseline (none of the
    ;; parallel/serial defs below) and its own defs roll back. Then launch the
    ;; parallel/serial workers and collect them.
    (let (iso-results (run-isolated iso nil)
          _ (spawn-units par me)
          par-results (collect-units (count par) nil)
          results (append iso-results par-results)
          elapsed (- (now) start)
          total (count results)
          failed (count-failed results)
          fails (count-failures results))
      (report-failures results)
      (when (opt? :slow opts) (report-slow results))
      (println "")
      (println total
        "tests,"
        (- total failed)
        "passed,"
        failed
        "failed"
        (str "(" fails " failed assertions, " (count iso) " isolated)"))
      (println (str "  (" elapsed " ms wall, peak " (mb-str (mem-peak)) ")"))
      (if (> failed 0) (error (str failed " test(s) failed")) :ok))))

;; Structured analogue of `run-tests` — runs the same suite (isolated phase,
;; then parallel/serial), but **returns data** instead of printing + throwing.
;; Backs the `nest mcp` `run-tests` tool (step 1c-b). Shape:
;;   {:total :passed :failed :failed-assertions :ms
;;    :results [{:group :name :passed :ms :failures [{:loc :details} ...]}]}
;; `:loc` is `[file line col]` or nil; `:details` is a list of strings.
;; A test that uncaught-errored shows up as `:passed false` with a single
;; failure carrying the error text (consistent with the textual runner).
(defn run-tests-structured (& opts)
  "Like `run-tests`, but returns the result as data — `{:total :passed :failed :failed-assertions :ms :results [...]}` — instead of printing and raising. Backs the `nest mcp` `run-tests` tool."
  (let (units (reverse *units*)
        par   (filter (fn (u) (not= (first u) :isolated)) units)
        iso   (filter (fn (u) (= (first u) :isolated)) units)
        start (now)
        me    (self))
    (let (iso-results (run-isolated iso nil)
          _           (spawn-units par me)
          par-results (collect-units (count par) nil)
          results     (append iso-results par-results)
          elapsed     (- (now) start)
          total       (count results)
          failed      (count-failed results)
          fails       (count-failures results))
      {:total total
       :passed (- total failed)
       :failed failed
       :failed-assertions fails
       :ms elapsed
       ;; `(or … [])` on every list field so empty results render as JSON
       ;; `[]` rather than `null`. Matters when the suite has zero tests, or
       ;; a passing test has zero failures — agents branch on `length`, not
       ;; `(= null)`.
       :results (or (map (fn (r)
                       {:group (r-group r)
                        :name (r-name r)
                        :passed (not (r-failed? r))
                        :ms (r-ms r)
                        :failures (or (map (fn (f) {:loc (first f) :details (second f)})
                                       (r-fails r))
                                      [])})
                  results)
                 [])})))
