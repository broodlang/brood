#!/bin/sh
# Thin ./configure for the Brood build, in the familiar autotools shape
# (./configure && make install). Brood is a Cargo workspace — this is just a
# convenience that records local build options into `config.mk`, which the
# Makefile includes. Re-run it any time to change options; it is not generated by
# autoconf and has no dependencies beyond a POSIX shell.

set -eu

prefix="$HOME/.local"
with_gui=0
with_gui_gpu=0
with_jit=1

usage() {
	cat <<'EOF'
Usage: ./configure [options]

Options:
  --with-gui        Build the native GUI window backend (winit/softbuffer/fontdue),
                    so `(observe)` can open a window. Off by default.
  --without-gui     Disable the GUI backend (the default).
  --with-gui-gpu    Build the EXPERIMENTAL GPU (OpenGL) render backend instead of the
                    CPU softbuffer one (implies --with-gui). Instanced quads + an
                    immediate swapchain; text is not yet drawn on the GPU. Off by default.
  --without-gui-gpu Use the CPU softbuffer backend (the default).
  --with-jit        Build the tier-1 JIT (ADR-101) into `brood`/`nest`. On by default;
                    hot compute loops run as native code. Needs a Cranelift-supported
                    host (x86_64 / aarch64).
  --without-jit     Disable the JIT (bytecode VM only) — for an unsupported host or a
                    minimal build.
  --prefix=DIR      Install root for `make install` (default: $HOME/.local).
                    Binaries go in DIR/bin.
  -h, --help        Show this help and exit.

Writes config.mk, then run `make install`. Example:
  ./configure --with-gui && make install
EOF
}

for arg in "$@"; do
	case "$arg" in
	--with-gui) with_gui=1 ;;
	--without-gui) with_gui=0 ;;
	--with-gui-gpu) with_gui_gpu=1; with_gui=1 ;;
	--without-gui-gpu) with_gui_gpu=0 ;;
	--with-jit) with_jit=1 ;;
	--without-jit) with_jit=0 ;;
	--prefix=*) prefix=${arg#--prefix=} ;;
	-h | --help)
		usage
		exit 0
		;;
	*)
		echo "configure: unknown option: $arg" >&2
		echo "Try './configure --help'." >&2
		exit 1
		;;
	esac
done

cat >config.mk <<EOF
# Generated by ./configure — do not edit by hand (re-run ./configure to change).
PREFIX   := $prefix
WITH_GUI := $with_gui
WITH_GUI_GPU := $with_gui_gpu
WITH_JIT := $with_jit
EOF

echo "configure: wrote config.mk"
echo "  prefix      = $prefix"
echo "  with-gui    = $with_gui"
echo "  with-gui-gpu = $with_gui_gpu"
echo "  with-jit    = $with_jit"
echo
echo "Next: make install"
