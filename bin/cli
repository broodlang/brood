#!/usr/bin/env bash
# Convenience launcher for the Brood CLI.
#
#   ./bin/cli                 # start the REPL
#   ./bin/cli file.blsp       # run a program file
#
# Builds via cargo as needed and forwards all arguments to the `brood` binary.
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec cargo run --quiet --manifest-path "$repo_root/Cargo.toml" -p cli -- "$@"
