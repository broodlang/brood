(defn bm (n s a)
  (if (= n 0) a
    (bm (- n 1) (second (rand-int s 1000000))
        (assoc a (first (rand-int s 1000000)) n))))
(def g1 (bm 3000 1 {}))
(def g2 (bm 3000 2 {}))
(def form (read-string "(reduce (fn (a x) (+ a x)) 0 (range 3000))"))
(defn bloop (n) (when (> n 0) (do (eval form) (count g1) (bloop (- n 1)))))
(defn bench-like (value) (do (bloop 5000) (+ value (count g1) (count g2))))
(println "result=" (bench-like (eval form)))
