;; Numeric-tower conformance — cases adapted from the Scheme (chibi r7rs-tests)
;; and Gabriel numeric suites to Brood's actual surface and semantics (added
;; 2026-06-29). Brood's tower is Int (i64) / BigInt / Decimal / Float, with
;; *structural* `=` (no cross-type coercion) but coercing *ordering*. Every result
;; is engine-independent; `make test` runs the suite through both the VM and the
;; tree-walker (ADR-076).
(defmodule numeric-conformance-test (:use test))

(describe "arithmetic identities"
  (test "additive/multiplicative identity and inverse"
    (assert= (+) 0) (assert= (*) 1)
    (assert= (+ 5 0) 5) (assert= (* 5 1) 5)
    (assert= (+ 7 (- 7)) 0))
  (test "commutativity and associativity (integers)"
    (assert= (+ 1 2 3) (+ 3 2 1))
    (assert= (* 2 3 4) (* 4 3 2))
    (assert= (+ (+ 1 2) 3) (+ 1 (+ 2 3))))
  (test "mixed int/float arithmetic yields a float (contagion)"
    (assert= (+ 1.5 2) 3.5)
    (assert= (* 2 0.5) 1.0)))

(describe "integers and bigint promotion (no silent wrap)"
  (test "i64 overflow promotes to bigint"
    (assert= (* 99999999999 99999999999) 9999999999800000000001)
    (assert= (+ 9223372036854775807 1) 9223372036854775808))
  (test "a 25! factorial is an exact bigint"
    (assert= (reduce * 1 (range 1 26)) 15511210043330985984000000)))

(describe "exponentiation (integer exponent) and roots"
  (test "pow with integer exponent, promoting past i64"
    (assert= (pow 2 0) 1) (assert= (pow 10 3) 1000)
    (assert= (pow 2 64) 18446744073709551616))
  (test "pow rejects a non-integer exponent (use sqrt for roots)"
    (assert-error (pow 2.0 0.5)))
  (test "sqrt of perfect squares is exact; irrationals are nearest-float"
    (assert= (sqrt 4.0) 2.0) (assert= (sqrt 9.0) 3.0)
    (is (< (abs (- (* (sqrt 2.0) (sqrt 2.0)) 2.0)) 1e-9))))

(describe "rounding family"
  (test "floor / ceil round toward -inf / +inf"
    (assert= (floor 2.7) 2) (assert= (ceil 2.1) 3)
    (assert= (floor -2.5) -3) (assert= (ceil -2.5) -2))
  (test "round is half-away-from-zero (2.5 -> 3, -2.5 -> -3)"
    (assert= (round 2.5) 3) (assert= (round 3.5) 4)
    (assert= (round -2.5) -3) (assert= (round 2.4) 2)))

(describe "predicates"
  (test "even? / odd?"
    (is (even? 0)) (is (even? 4)) (is (odd? 3)) (is (not (even? 3))))
  (test "zero? is structural — true for the int 0, false for the float 0.0"
    (is (zero? 0)) (is (not (zero? 0.0))))
  (test "sign via comparison (no pos?/neg? builtins)"
    (is (> 5 0)) (is (< -5 0)) (is (not (> 0 0)))))

(describe "abs across the tower"
  (test "abs of int / float / bigint"
    (assert= (abs -5) 5) (assert= (abs -5.0) 5.0)
    (assert= (abs -100000000000000000000) 100000000000000000000)))

(describe "ordering coerces across the tower, but = does NOT"
  (test "ordering compares numeric value across types"
    (is (< 1 1.5)) (is (< 1M 2)) (is (<= 2 2.0)) (is (< 2 100000000000000000000)))
  (test "= is structural: numerically-equal-but-different-type is not ="
    (is (not (= 1 1.0))) (is (not (= 1 1M))) (is (not (= 2.0 2)))
    (is (= 2 2)) (is (= 2.0 2.0))))

(describe "number <-> string"
  (test "number->string then string->number round-trips int / float / bigint"
    (is (= 42 (string->number (number->string 42))))
    (is (= 1.5 (string->number (number->string 1.5))))
    (is (= 100000000000000000000 (string->number (number->string 100000000000000000000)))))
  (test "string->number parses valid forms and returns nil on garbage"
    (assert= (string->number "42") 42)
    (assert= (string->number "1.5") 1.5)
    (assert= (string->number "1e3") 1000.0)
    (assert= (string->number "nope") nil)
    (assert= (string->number "1.5.6") nil)
    (assert= (string->number "0x10") nil)))
