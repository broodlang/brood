;; Package manager — Slice 1: :path deps end-to-end (std/package.blsp, ADR-037).
;; Covers the canonical tree hash, reading a dep's manifest, transitive
;; resolution + conflict detection, the lock-file round-trip, and `ensure-deps`'s
;; load-path output. Fixtures are real directories built under /tmp with a unique
;; gensym'd root per test, so the cases don't collide and need no network/git.
;;
;; Register-only — discovered and run by `nest test` (and cargo test).

(defmodule package-test (:use test) (:use package) (:use project))

;; Build a throwaway project dir `<tmp>/<name>` with a manifest + one src module.
;; `deps-vec` is a literal :dependencies vector string (or nil for none).
;; A fresh, unique fixture dir. Must use `random-token` (entropy-seeded), NOT
;; `gensym`: gensym's counter resets to 0 each `nest test` process, so its
;; `/tmp` paths are *reused* across runs — and since fixtures aren't torn down,
;; a path written by one test in run A is reused by a *different* test in run B
;; (the counter a test draws shifts run-to-run under concurrent scheduling),
;; accumulating both tests' files and contaminating `provided-modules`. A random
;; token is unique across processes and runs, so a dir is never reused.
(defn pkg-fixture-root () (path-join "/tmp" (str "brood-pkg-" (random-token 8))))

;; Turn a fixture dir into a one-commit git repo (so :git deps can be exercised
;; offline via a file:// URL — no network). Returns the file:// URL.
(defn pkg-git-init (dir)
  (run-process "git" (list "-C" dir "init" "-q"))
  (run-process "git" (list "-C" dir "config" "user.email" "t@example.com"))
  (run-process "git" (list "-C" dir "config" "user.name" "Test"))
  (run-process "git" (list "-C" dir "add" "-A"))
  (run-process "git" (list "-C" dir "commit" "-q" "-m" "init"))
  (str "file://" dir))
(defn pkg-git-tag (dir tag) (run-process "git" (list "-C" dir "tag" tag)))

(defn pkg-write-project (root nm src-module body deps-line)
  (make-dir (path-join root "src"))
  (spit (path-join root "project.blsp")
    (str "(project :name \"" nm "\" :version \"0.1.0\"" deps-line ")\n"))
  (spit (path-join (path-join root "src") (str src-module ".blsp"))
    (str "(defmodule " src-module " \"fixture\")\n" body "\n")))

(describe "package: canonical tree hash"
  (test "is deterministic for the same content"
    (let (root (pkg-fixture-root))
      (pkg-write-project root "a" "a" "(defn f () 1)" "")
      (assert= (package-tree-hash root) (package-tree-hash root))))
  (test "changes when a file's content changes"
    (let (root (pkg-fixture-root))
      (pkg-write-project root "a" "a" "(defn f () 1)" "")
      (let (h1 (package-tree-hash root))
        (spit (path-join (path-join root "src") "a.blsp") "(defmodule a \"fixture\")\n(defn f () 2)\n")
        (refute (= h1 (package-tree-hash root))))))
  (test "skips _deps/ so a nested cache doesn't perturb the hash"
    (let (root (pkg-fixture-root))
      (pkg-write-project root "a" "a" "(defn f () 1)" "")
      (let (h1 (package-tree-hash root))
        (make-dir (path-join root "_deps"))
        (spit (path-join (path-join root "_deps") "junk.blsp") "(def x 1)")
        (assert= h1 (package-tree-hash root))))))

(describe "package: reading a dependency's manifest"
  (test "extracts a dep's own :dependencies"
    (let (root (pkg-fixture-root))
      (pkg-write-project root "a" "a" "(defn f () 1)"
        " :dependencies [[b :path \"../b\"]]")
      (assert= (package/package--manifest-deps (path-join root "project.blsp"))
        (list {:name 'b :kind :path :path "../b"}))))
  (test "a manifest without :dependencies yields nil"
    (let (root (pkg-fixture-root))
      (pkg-write-project root "a" "a" "(defn f () 1)" "")
      (assert= (package/package--manifest-deps (path-join root "project.blsp")) nil)))
  (test "a missing manifest yields nil"
    (assert= (package/package--manifest-deps "/tmp/does-not-exist-xyz/project.blsp") nil)))

(describe "package: resolving :path deps"
  (test "a single path dep resolves to an entry with name/kind/path/sha/deps"
    (let (parent (pkg-fixture-root)
          dep-dir (path-join parent "greeter")
          app-dir (path-join parent "app"))
      (pkg-write-project dep-dir "greeter" "greeter" "(defn greet (w) (str \"hi \" w))" "")
      (pkg-write-project app-dir "app" "main" "(defn main () 1)"
        " :dependencies [[greeter :path \"../greeter\"]]")
      (let (entries (resolve-deps app-dir (list {:name 'greeter :kind :path :path "../greeter"}) nil))
        (assert= (count entries) 1)
        (let (e (first entries))
          (assert= (get e :name) 'greeter)
          (assert= (get e :kind) :path)
          (assert= (get e :path) "../greeter")
          (is (string? (get e :sha256)))
          (assert= (get e :deps) nil)))))
  (test "transitive path deps are resolved depth-first into a flat list"
    (let (parent (pkg-fixture-root)
          a (path-join parent "a")
          b (path-join parent "b")
          app (path-join parent "app"))
      (pkg-write-project b "b" "b" "(defn bf () 1)" "")
      (pkg-write-project a "a" "a" "(defn af () 1)" " :dependencies [[b :path \"../b\"]]")
      (pkg-write-project app "app" "main" "(defn main () 1)" " :dependencies [[a :path \"../a\"]]")
      (let (entries (resolve-deps app (list {:name 'a :kind :path :path "../a"}) nil))
        (assert= (map (fn (e) (get e :name)) entries) (list 'a 'b)))))
  (test "a missing path dep is a clear error"
    (let (app (pkg-fixture-root))
      (pkg-write-project app "app" "main" "(defn main () 1)" "")
      (is (string-contains?
            (try (resolve-deps app (list {:name 'gone :kind :path :path "../gone"}) nil) (catch e e))
            "not found")))))

;; :git deps (Slice 2) — exercised against a local git repo over a file:// URL, so
;; the suite stays offline. Covers cloning into _deps/, commit pinning, the lock
;; fields, transitive resolution, the direct-beats-transitive rule, and the loud
;; conflict error.
(describe "package: resolving :git deps"
  (test "a :git dep clones into _deps/, pins a commit, and records a sha"
    (let (parent (pkg-fixture-root)
          dep-dir (path-join parent "greeter")
          app-dir (path-join parent "app"))
      (pkg-write-project dep-dir "greeter" "greeter" "(defn greet (w) w)" "")
      (let (url (pkg-git-init dep-dir))
        (pkg-git-tag dep-dir "v1.0.0")
        (pkg-write-project app-dir "app" "main" "(defn main () 1)" "")
        (let (entries (resolve-deps app-dir (list {:name 'greeter :kind :git :url url :ref "v1.0.0"}) nil))
          (assert= (count entries) 1)
          (let (e (first entries))
            (assert= (get e :kind) :git)
            (assert= (get e :url) url)
            (assert= (get e :ref) "v1.0.0")
            (is (string? (get e :commit)))
            (is (string? (get e :sha256)))
            (is (dir? (path-join (path-join app-dir "_deps") "greeter")))
            (is (file-exists? (path-join (path-join (path-join app-dir "_deps") "greeter") ".brood-pkg.blsp"))))))))
  (test "a second resolve reuses the locked commit (cache hit, no re-clone)"
    (let (parent (pkg-fixture-root)
          dep-dir (path-join parent "greeter")
          app-dir (path-join parent "app"))
      (pkg-write-project dep-dir "greeter" "greeter" "(defn greet (w) w)" "")
      (let (url (pkg-git-init dep-dir))
        (pkg-git-tag dep-dir "v1.0.0")
        (pkg-write-project app-dir "app" "main" "(defn main () 1)" "")
        (let (dep (list {:name 'greeter :kind :git :url url :ref "v1.0.0"})
              e1 (first (resolve-deps app-dir dep nil)))
          (write-lockfile app-dir (list e1))
          ;; re-resolve with the lock present: same commit + sha, cache untouched
          (let (e2 (first (resolve-deps app-dir dep (read-lockfile app-dir))))
            (assert= (get e2 :commit) (get e1 :commit))
            (assert= (get e2 :sha256) (get e1 :sha256)))))))
  (test "transitive :git deps are flattened; a direct pin beats a transitive one"
    (let (parent (pkg-fixture-root)
          ansi (path-join parent "ansi")
          greeter (path-join parent "greeter")
          app (path-join parent "app"))
      (pkg-write-project ansi "ansi" "ansi" "(defn bold (s) s)" "")
      (let (ansi-url (pkg-git-init ansi))
        (pkg-git-tag ansi "v1.0.0")
        (pkg-git-tag ansi "v2.0.0")
        ;; greeter (transitively) wants ansi v1.0.0
        (pkg-write-project greeter "greeter" "greeter" "(defn g () 1)"
          (str " :dependencies [[ansi :git \"" ansi-url "\" :ref \"v1.0.0\"]]"))
        (let (greeter-url (pkg-git-init greeter))
          (pkg-git-tag greeter "v1.0.0")
          (pkg-write-project app "app" "main" "(defn main () 1)" "")
          ;; app pins ansi v2.0.0 directly + depends on greeter → v2 wins, no error
          (let (entries (resolve-deps app
                          (list {:name 'ansi :kind :git :url ansi-url :ref "v2.0.0"}
                                {:name 'greeter :kind :git :url greeter-url :ref "v1.0.0"})
                          nil)
                idx (package/package--index-by-name entries))
            (assert= (sort (map (fn (e) (get e :name)) entries)) (list 'ansi 'greeter))
            (assert= (get (get idx 'ansi) :ref) "v2.0.0"))))))
  (test "two transitive :git deps at different refs, with no direct pin, error loudly"
    (let (parent (pkg-fixture-root)
          ansi (path-join parent "ansi")
          greeter (path-join parent "greeter")
          pretty (path-join parent "pretty")
          app (path-join parent "app"))
      (pkg-write-project ansi "ansi" "ansi" "(defn bold (s) s)" "")
      (let (ansi-url (pkg-git-init ansi))
        (pkg-git-tag ansi "v1.0.0")
        (pkg-git-tag ansi "v2.0.0")
        (pkg-write-project greeter "greeter" "greeter" "(defn g () 1)"
          (str " :dependencies [[ansi :git \"" ansi-url "\" :ref \"v1.0.0\"]]"))
        (pkg-write-project pretty "pretty" "pretty" "(defn p () 1)"
          (str " :dependencies [[ansi :git \"" ansi-url "\" :ref \"v2.0.0\"]]"))
        (let (greeter-url (pkg-git-init greeter)
              pretty-url (pkg-git-init pretty))
          (pkg-write-project app "app" "main" "(defn main () 1)" "")
          (is (string-contains?
                (try (resolve-deps app
                       (list {:name 'greeter :kind :git :url greeter-url :ref "main"}
                             {:name 'pretty :kind :git :url pretty-url :ref "main"})
                       nil)
                  (catch e e))
                "conflicting dependency")))))))

;; Namespace-collision detection (ADR-070). We test the cwd-free helpers
;; (`package--provided-modules` / `package--check-namespace-collisions`) directly,
;; the way slice 1 tests the verbs' helpers rather than the cwd-driven verbs.
(describe "package: namespace-collision detection (ADR-070)"
  (test "provided-modules reports each file's (defmodule …) name"
    (let (root (pkg-fixture-root))
      (pkg-write-project root "x" "alpha" "(defn f () 1)" "")
      (assert= (package/package--provided-modules (path-join root "src")) (list 'alpha))))
  (test "provided-modules reads the defmodule name, not the filename"
    (let (root (pkg-fixture-root))
      (make-dir (path-join root "src"))
      ;; file is helpers.blsp but it declares (defmodule json) — json is the
      ;; namespace that would clobber, so that's what we must report.
      (spit (path-join (path-join root "src") "helpers.blsp") "(defmodule json \"x\")\n(defn p () 1)\n")
      (assert= (package/package--provided-modules (path-join root "src")) (list 'json))))
  (test "two providers of the same module name collide loudly"
    (let (parent (pkg-fixture-root)
          a (path-join parent "a")
          b (path-join parent "b"))
      (pkg-write-project a "a" "util" "(defn f () 1)" "")
      (pkg-write-project b "b" "util" "(defn g () 2)" "")
      (is (string-contains?
            (try (package/package--check-namespace-collisions
                   (list (list "dependency 'a'" (path-join a "src"))
                         (list "dependency 'b'" (path-join b "src"))))
              (catch e e))
            "collision"))))
  (test "distinct module names across providers are fine"
    (let (parent (pkg-fixture-root)
          a (path-join parent "a")
          b (path-join parent "b"))
      (pkg-write-project a "a" "alpha" "(defn f () 1)" "")
      (pkg-write-project b "b" "beta" "(defn g () 2)" "")
      (assert= (package/package--check-namespace-collisions
                 (list (list "dependency 'a'" (path-join a "src"))
                       (list "dependency 'b'" (path-join b "src"))))
        nil))))

(describe "package: the lock file round-trips"
  (test "write-lockfile then read-lockfile recovers the dep vector"
    (let (parent (pkg-fixture-root)
          dep-dir (path-join parent "greeter")
          app-dir (path-join parent "app"))
      (pkg-write-project dep-dir "greeter" "greeter" "(defn greet (w) w)" "")
      (pkg-write-project app-dir "app" "main" "(defn main () 1)"
        " :dependencies [[greeter :path \"../greeter\"]]")
      (let (entries (resolve-deps app-dir (list {:name 'greeter :kind :path :path "../greeter"}) nil))
        (write-lockfile app-dir entries)
        (let (locked (read-lockfile app-dir))
          (is (vector? locked))
          (assert= (vector-length locked) 1)
          ;; entry vector: [greeter :path "../greeter" :sha256 H :deps []]
          (let (row (vector-ref locked 0))
            (assert= (vector-ref row 0) 'greeter)
            (assert= (vector-ref row 1) :path)
            (assert= (vector-ref row 2) "../greeter"))))))
  (test "read-lockfile is nil when there is no lock file"
    (assert= (read-lockfile (pkg-fixture-root)) nil)))

(describe "package: ensure-deps yields load-path entries"
  (test "returns each dep's src dir and writes the lock file"
    (let (parent (pkg-fixture-root)
          dep-dir (path-join parent "greeter")
          app-dir (path-join parent "app"))
      (pkg-write-project dep-dir "greeter" "greeter" "(defn greet (w) w)" "")
      (pkg-write-project app-dir "app" "main" "(defn main () 1)"
        " :dependencies [[greeter :path \"../greeter\"]]")
      (let (dirs (ensure-deps app-dir (list {:name 'greeter :kind :path :path "../greeter"})))
        (assert= (count dirs) 1)
        ;; the dir is the dep's src/ (relative ".." is left unnormalised — the OS
        ;; resolves it; normalisation is a deferred nicety)
        (is (string-contains? (first dirs) "greeter/src"))
        (is (file-exists? (path-join app-dir "project.lock.blsp"))))))
  (test "no deps means no load-path entries and no lock file"
    (let (app (pkg-fixture-root))
      (make-dir app)
      (assert= (ensure-deps app nil) nil)
      (refute (file-exists? (path-join app "project.lock.blsp"))))))

;; Editing the manifest — pure string→string transforms (comment-preserving),
;; so they test without the filesystem. The add/remove *verbs* are cwd-driven
;; (covered by the hand check `nest add`/`nest remove` in a scaffolded project).
(describe "package: editing the manifest"
  (test "add creates a :dependencies clause and preserves comments"
    (let (src "(project :name \"app\" :version \"0.1.0\")\n\n;; a keeper comment\n"
          out (package/package--manifest-add src
                (package/package--dep->entry-node {:name 'greeter :kind :path :path "../greeter"})))
      (is (string-contains? out "a keeper comment"))
      (let (form (read-string out))
        (assert= (project/project--parse-deps (plist-get (rest form) :dependencies))
          (list {:name 'greeter :kind :path :path "../greeter"})))))
  (test "add appends to an existing :dependencies"
    (let (src "(project :name \"app\" :dependencies [[a :path \"../a\"]])\n"
          out (package/package--manifest-add src
                (package/package--dep->entry-node {:name 'b :kind :path :path "../b"})))
      (let (form (read-string out))
        (assert= (map (fn (d) (get d :name)) (project/project--parse-deps (plist-get (rest form) :dependencies)))
          (list 'a 'b)))))
  (test "remove drops the named dep, keeps the rest and comments"
    (let (src "(project :name \"app\"\n  :dependencies [[a :path \"../a\"] [b :path \"../b\"]])\n;; keep me\n"
          out (package/package--manifest-remove src 'a))
      (is (string-contains? out "keep me"))
      (let (form (read-string out))
        (assert= (map (fn (d) (get d :name)) (project/project--parse-deps (plist-get (rest form) :dependencies)))
          (list 'b)))))
  (test "remove of the only dep leaves an empty :dependencies"
    (let (src "(project :name \"app\" :dependencies [[a :path \"../a\"]])\n"
          out (package/package--manifest-remove src 'a))
      (assert= (project/project--parse-deps (plist-get (rest (read-string out)) :dependencies)) nil))))

;; The `fetch`/`tree` verbs themselves are cwd-driven (they walk from `(cwd)` to a
;; project root), so — like `run-project` — they can't be isolated from the brood
;; repo the suite runs inside. The hand check is `nest fetch`/`nest tree` in a
;; scaffolded project. Here we cover their pure, cwd-free helpers.
(describe "package: tree helpers"
  (test "dep-label renders a path dep"
    (assert= (package/package--dep-label {:name 'shared :kind :path :path "../shared"})
      "shared  (path \"../shared\")"))
  (test "dep-label renders a git dep"
    (assert= (package/package--dep-label {:name 'p :kind :git :url "https://x.git" :ref "v1"})
      "p  (git https://x.git @ v1)"))
  (test "index-by-name keys resolved entries by their name"
    (let (idx (package/package--index-by-name
                (list {:name 'a :kind :path :path "../a" :deps nil}
                      {:name 'b :kind :path :path "../b" :deps nil})))
      (assert= (get (get idx 'a) :path) "../a")
      (assert= (get (get idx 'b) :path) "../b"))))

;; End-to-end: a path dep's module becomes require-able once its src dir is on
;; *load-path* — the whole point of the slice. :isolated because it mutates
;; *load-path* and loads a module (ADR-017 rolls both back).
(describe "package: a resolved :path dep is require-able" :isolated
  (test "require finds the dep's module after ensure-deps extends *load-path*"
    (let (parent (pkg-fixture-root)
          dep-dir (path-join parent "greeter")
          app-dir (path-join parent "app"))
      (pkg-write-project dep-dir "greeter" "greeter" "(defn greet (w) (str \"hi \" w))" "")
      (pkg-write-project app-dir "app" "main" "(defn main () 1)"
        " :dependencies [[greeter :path \"../greeter\"]]")
      (let (dirs (ensure-deps app-dir (list {:name 'greeter :kind :path :path "../greeter"})))
        (def *load-path* (append *load-path* dirs))
        (require 'greeter)
        ;; greeter is a `(defmodule greeter)`, so its `greet` is `greeter/greet`
        (assert= (greeter/greet "you") "hi you")))))

;; The git equivalent: a :git dep is cloned into _deps/, its src/ joins *load-path*,
;; and its module becomes require-able. :isolated for the same load-path reason.
(describe "package: a resolved :git dep is require-able" :isolated
  (test "require finds a cloned git dep's module after ensure-deps"
    (let (parent (pkg-fixture-root)
          dep-dir (path-join parent "salutation")
          app-dir (path-join parent "app"))
      (pkg-write-project dep-dir "salutation" "salutation" "(defn hi (w) (str \"yo \" w))" "")
      (let (url (pkg-git-init dep-dir))
        (pkg-git-tag dep-dir "v1.0.0")
        (pkg-write-project app-dir "app" "main" "(defn main () 1)" "")
        (let (dirs (ensure-deps app-dir (list {:name 'salutation :kind :git :url url :ref "v1.0.0"})))
          (def *load-path* (append *load-path* dirs))
          (require 'salutation)
          (assert= (salutation/hi "you") "yo you")
          ;; and the clone + lock landed under the app
          (is (dir? (path-join (path-join app-dir "_deps") "salutation")))
          (is (file-exists? (path-join app-dir "project.lock.blsp"))))))))
