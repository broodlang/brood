;; `read-all` (kernel) + `std/eval-command` (the C-x C-e family). Register-only —
;; discovered and run by `nest test` (and cargo test, via crates/lisp/tests/suite.rs).

(defmodule eval-command-test
  (:use test)
  (:use buffer)
  (:use eval-command))

(require 'buffer)
(require 'eval-command)

(describe "read-all"
  (test "returns every form in source order"
    (assert= (read-all "(+ 1 2) :x 3") (list '(+ 1 2) :x 3)))
  (test "single form"
    (assert= (read-all "hello") (list 'hello)))
  (test "blank / comment-only source is the empty list"
    (is (empty? (read-all "")))
    (is (empty? (read-all "   \n  ;; just a comment\n"))))
  (test "the all-forms sibling of read-string (first only)"
    (let (src "(a) (b) (c)")
      (assert= (read-string src) '(a))
      (assert= (last (read-all src)) '(c))))
  (test "raises on an incomplete form (like read-string)"
    (assert= (try (do (read-all "(+ 1 2") :no-throw) (catch e :threw)) :threw)))

;; ---- the eval commands ------------------------------------------------------
(describe "eval-last-sexp"
  (test "evaluates the last complete form ending at point"
    (assert= (eval-last-sexp (end-of-buffer (make-buffer "(+ 1 2)"))) "=> 3"))

  (test "only the last form runs — earlier forms are not re-evaluated"
    ;; the `(println …)` in the first form must NOT print: it isn't evaluated.
    (assert= (eval-last-sexp (end-of-buffer (make-buffer "(println \"nope\") (* 6 7)")))
      "=> 42"))

  (test "captured output from the evaluated form is prefixed before the value"
    (assert= (eval-last-sexp (end-of-buffer (make-buffer "(do (print \"hi\") 7)")))
      "hi\n=> 7"))

  (test "respects point — evaluates the last form before point, not after it"
    ;; point 7 sits just after the first form; the second is past point.
    (assert= (eval-last-sexp (goto-char (make-buffer "(+ 1 2) (* 9 9)") 7)) "=> 3"))

  (test "no form before point comes back as a clean error message"
    (assert= (eval-last-sexp (make-buffer "")) "error: no complete form before point"))

  (test "an unbalanced form is reported, not raised"
    (let (msg (eval-last-sexp (end-of-buffer (make-buffer "(+ 1 "))))
      (is (starts-with? msg "error:")))))

(describe "eval-region"
  (test "evaluates the region between mark and point, last value wins"
    ;; region [0,7) is "(+ 2 3)"; the trailing "garbage" is outside it.
    (assert= (eval-region (assoc (make-buffer "(+ 2 3)garbage") :mark 0 :point 7))
      "=> 5"))
  (test "no mark set → a note, not an error or a crash"
    (assert= (eval-region (make-buffer "(+ 1 1)")) "; no region (set the mark first)")))

(describe "eval-buffer"
  (test "evaluates every top-level form, returning the last value"
    (assert= (eval-buffer (make-buffer "(+ 1 1) (* 5 5)")) "=> 25"))
  (test "output across the buffer is captured"
    (assert= (eval-buffer (make-buffer "(print \"a\") (print \"b\") 0")) "ab\n=> 0")))

;; ---- across processes -------------------------------------------------------
;; A buffer is process-local (its rope can't cross a process), so a worker builds
;; its own buffer, evaluates, and sends back only the message *string*. This proves
;; the commands — and the inherited output capture — work off the root process.
(defn ec-worker (parent src) (send parent (eval-last-sexp (end-of-buffer (make-buffer src)))))

(describe "eval-command across processes"
  :isolated
  (test "a spawned evaluator's message string crosses back unchanged"
    (let (me (self))
      (spawn (ec-worker me "(* 7 8)"))
      (assert= (receive) "=> 56")))
  (test "output captured in a spawned evaluator rides along"
    (let (me (self))
      (spawn (ec-worker me "(do (print \"P\") 1)"))
      (assert= (receive) "P\n=> 1"))))
