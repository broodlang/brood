;; The editor framework's buffer model (M2 Phase 1, ADR-045): the immutable
;; buffer value + pure point/mark/region/movement/editing ops, plus the thin
;; `spawn-buffer` actor shell. Pure Brood over the rope primitives — opt-in
;; (`require 'buffer`), never in the prelude.
;;
;; Register-only — discovered and run by `nest test` (and cargo test, via
;; crates/lisp/tests/suite.rs). The whole suite runs in parallel (each test a
;; process); the final :isolated block adds explicit spawn/send/receive coverage
;; of the actor shell — and proves a buffer's rope stays inside its process.

(defmodule buffer-test (:use test) (:use editor/buffer))

(require 'log)    ; the buffer-as-log-sink integration test drives a real logger
(require 'proc/hatch)  ; gen-call — to flush the logger's casts before asserting

;; Drop any fixtures a prior run left in /tmp (at load, before any test runs).
(purge-stale-temp "brood-buf-")

(describe "buffer construction & reads"
  (test "make-buffer"
    (let (b (make-buffer "hello world"))
      (is (buffer? b))
      (assert= (buffer-text b) "hello world")
      (assert= (buffer-point b) 0)
      (assert= (buffer-mark b) nil)
      (assert= (buffer-name b) "*scratch*")
      (assert= (buffer-file b) nil)
      (assert= (buffer-length b) 11)))
  (test "make-buffer with name and file"
    (let (b (make-buffer "x" "notes" "/tmp/notes.txt"))
      (assert= (buffer-name b) "notes")
      (assert= (buffer-file b) "/tmp/notes.txt")))
  (test "buffer? rejects non-buffers"
    (refute (buffer? "hello"))
    (refute (buffer? {:rope "not-a-rope"}))
    (refute (buffer? 3)))
  (test "line reads"
    (let (b (make-buffer "alpha\nbeta\ngamma"))
      (assert= (buffer-line-count b) 3)
      (assert= (buffer-line-at b 0) "alpha\n")
      (assert= (buffer-line-at b 2) "gamma")))
  (test "char-after / char-before at the edges"
    (let (b (goto-char (make-buffer "abc") 1))
      (assert= (buffer-char-after b) "b")
      (assert= (buffer-char-before b) "a"))
    (assert= (buffer-char-before (make-buffer "abc")) nil)  ; point 0
    (assert= (buffer-char-after (end-of-buffer (make-buffer "abc"))) nil)))

(describe "buffer movement"
  (test "goto-char clamps to [0, length]"
    (let (b (make-buffer "abc"))
      (assert= (buffer-point (goto-char b 2)) 2)
      (assert= (buffer-point (goto-char b 99)) 3)
      (assert= (buffer-point (goto-char b -5)) 0)))
  (test "forward/backward-char clamp"
    (let (b (goto-char (make-buffer "abcde") 2))
      (assert= (buffer-point (forward-char b)) 3)
      (assert= (buffer-point (forward-char b 10)) 5)
      (assert= (buffer-point (backward-char b)) 1)
      (assert= (buffer-point (backward-char b 10)) 0)))
  (test "beginning/end-of-line"
    (let (b (goto-char (make-buffer "ab\ncde\nf") 4))
      ; on 'd' in line 1
      (assert= (buffer-point (beginning-of-line b)) 3)
      (assert= (buffer-point (end-of-line b)) 6)))  ; just before the newline
  (test "beginning/end-of-buffer"
    (let (b (make-buffer "abcde"))
      (assert= (buffer-point (end-of-buffer b)) 5)
      (assert= (buffer-point (beginning-of-buffer (end-of-buffer b))) 0)))
  (test "current-line and column"
    (let (b (goto-char (make-buffer "line0\nline1\nline2") 14))
      ; line 2, col 2
      (assert= (buffer-current-line b) 2)
      (assert= (buffer-column b) 2)))
  (test "forward-line preserves the column when the line is long enough"
    (let (b (-> (make-buffer "hello\nworld\nhi") (goto-char 2) (forward-line 1)))
      (assert= (buffer-current-line b) 1)
      (assert= (buffer-column b) 2)))  ; col 2 of "world" = 'r'
  (test "forward-line clamps the column to a short target line"
    (let (b (-> (make-buffer "hello\nhi") (goto-char 4) (forward-line 1)))
      (assert= (buffer-current-line b) 1)
      (assert= (buffer-column b) 2)))  ; "hi" is only 2 long → column 2 (end)
  (test "forward/backward-line clamp to the line range"
    (let (b (make-buffer "a\nb\nc"))
      (assert= (buffer-current-line (forward-line b 99)) 2)
      (assert= (buffer-current-line (backward-line (end-of-buffer b) 99)) 0)))
  (test "forward-word moves to the end of the next word"
    (let (b (make-buffer "foo bar  baz"))
      (assert= (buffer-point (forward-word b)) 3)  ; end of "foo"
      (assert= (buffer-point (forward-word (forward-word b))) 7)  ; end of "bar"
      (assert= (buffer-point (forward-word (goto-char b 12))) 12)))  ; at end, stays
  (test "backward-word moves to the start of the previous word"
    (let (b (goto-char (make-buffer "foo bar  baz") 12))
      ; end of "baz"
      (assert= (buffer-point (backward-word b)) 9)  ; start of "baz"
      (assert= (buffer-point (backward-word (backward-word b))) 4)  ; start of "bar"
      (assert= (buffer-point (backward-word (goto-char b 0))) 0)))  ; at start, stays
  (test "word motion crosses lines and delimiters"
    (let (b (make-buffer "(foo\n bar)"))
      (assert= (buffer-point (forward-word b)) 4)  ; skips '(', ends "foo"
      (assert= (buffer-point (forward-word (forward-word b))) 9))))  ; ends "bar" before ')'

;; paragraphs {a,b} {c,d} {e}, blank-line separated.
;;  offsets: a0 b2  blank4  c5 d7  blank9  e10  (len 11)
(describe "buffer paragraph motion (M-{ / M-})"
  (test "forward-paragraph stops at the start of the next blank line"
    (let (txt "a\nb\n\nc\nd\n\ne")
      (assert= (buffer-point (forward-paragraph (make-buffer txt))) 4)               ; from line 0
      (assert= (buffer-point (forward-paragraph (goto-char (make-buffer txt) 8))) 9)))  ; from inside {c,d}
  (test "forward-paragraph in the last paragraph lands at end of buffer"
    (assert= (buffer-point (forward-paragraph (goto-char (make-buffer "a\nb\n\nc\nd\n\ne") 10))) 11))
  (test "backward-paragraph goes to the current paragraph's start, then the previous"
    (let (txt "a\nb\n\nc\nd\n\ne")
      (assert= (buffer-point (backward-paragraph (goto-char (make-buffer txt) 8))) 5)   ; from inside {c,d}
      (assert= (buffer-point (backward-paragraph (goto-char (make-buffer txt) 5))) 0)))  ; from {c,d} start → {a,b}
  (test "backward-paragraph at buffer start stays at 0"
    (assert= (buffer-point (backward-paragraph (make-buffer "a\nb\n\nc"))) 0)))

(describe "buffer editing is immutable"
  (test "insert advances point; the original is untouched"
    (let (b (goto-char (make-buffer "hello world") 5))
      (let (b2 (insert b ","))
        (assert= (buffer-text b2) "hello, world")
        (assert= (buffer-point b2) 6)
        ; original unchanged
        (assert= (buffer-text b) "hello world")
        (assert= (buffer-point b) 5))))
  (test "delete-char removes after point; point stays"
    (let (b (goto-char (make-buffer "hello") 1))
      (assert= (buffer-text (delete-char b)) "hllo")
      (assert= (buffer-point (delete-char b)) 1)
      (assert= (buffer-text (delete-char b 3)) "ho")))
  (test "delete-backward-char removes before point; point moves back"
    (let (b (goto-char (make-buffer "hello") 3))
      (assert= (buffer-text (delete-backward-char b)) "helo")
      (assert= (buffer-point (delete-backward-char b)) 2)
      (assert= (buffer-text (delete-backward-char b 2)) "hlo")))
  (test "edits at the buffer edges clamp safely"
    (assert= (buffer-text (delete-char (end-of-buffer (make-buffer "ab")))) "ab")
    (assert= (buffer-text (delete-backward-char (make-buffer "ab"))) "ab")))

(describe "read-only buffers"
  (test "fresh buffers are writable; set-read-only / read-only? round-trip"
    (let (b (make-buffer "hi"))
      (refute (read-only? b))
      (is (read-only? (set-read-only b true)))
      (refute (read-only? (set-read-only (set-read-only b true) false)))))
  (test "every text mutator refuses a read-only buffer"
    (let (b (set-read-only (goto-char (set-mark (make-buffer "hello")) 5) true))
      ;; mark at 0, point at 5 → a non-empty region for delete-region
      (assert-error (insert b "x"))
      (assert-error (delete-char b))
      (assert-error (delete-backward-char b))
      (assert-error (delete-region b))
      (assert-error (replace-region b 0 1 "X"))))
  (test "construction and movement still work while read-only"
    (let (b (set-read-only (make-buffer "hello world") true))
      ;; make-buffer built the text before the flag; navigation never checks it
      (assert= (buffer-text b) "hello world")
      (assert= (buffer-point (forward-word b)) 5)
      (assert= (buffer-point (end-of-buffer b)) 11)))
  (test "clearing read-only restores editing"
    (let (b (set-read-only (make-buffer "ab") true))
      (assert= (buffer-text (insert (set-read-only b false) "!")) "!ab"))))

(describe "buffer mark & region"
  (test "set-mark / region / clear-mark"
    (let (b (-> (make-buffer "abcdef") (goto-char 1) set-mark (goto-char 4)))
      (assert= (buffer-mark b) 1)
      (assert= (buffer-region b) "bcd")
      (assert= (buffer-mark (clear-mark b)) nil)))
  (test "region works regardless of point/mark order"
    (let (b (-> (make-buffer "abcdef") (goto-char 4) set-mark (goto-char 1)))
      (assert= (buffer-region b) "bcd")))
  (test "no region without a mark"
    (assert= (buffer-region (make-buffer "abc")) nil))
  (test "delete-region removes between point and mark, clears mark, point to start"
    (let (b (-> (make-buffer "abcdef") (goto-char 1) set-mark (goto-char 4) delete-region))
      (assert= (buffer-text b) "aef")
      (assert= (buffer-point b) 1)
      (assert= (buffer-mark b) nil)))
  (test "delete-region is a no-op without a mark"
    (assert= (buffer-text (delete-region (make-buffer "abc"))) "abc"))
  (test "buffer-region-bounds gives [lo hi], order-independent, nil without a mark"
    (assert= (buffer-region-bounds (make-buffer "abc")) nil)
    (assert= (buffer-region-bounds (-> (make-buffer "abcdef") (goto-char 1) set-mark (goto-char 4)))
      [1 4])
    (assert= (buffer-region-bounds (-> (make-buffer "abcdef") (goto-char 4) set-mark (goto-char 1)))
      [1 4]))
  (test "buffer-region-bounds matches the buffer-region span"
    (let (b (-> (make-buffer "abcdef") (goto-char 1) set-mark (goto-char 4))
          [lo hi] (buffer-region-bounds b))
      (assert= (substring (buffer-text b) lo hi) (buffer-region b)))))

(describe "replace-region (the splice primitive)"
  (test "replaces [start,end) with the string, point after the insert"
    (let (b (replace-region (make-buffer "hello world") 6 11 "there"))
      (assert= (buffer-text b) "hello there")
      (assert= (buffer-point b) 11)))   ; 6 + len("there")
  (test "an empty replacement deletes the range"
    (assert= (buffer-text (replace-region (make-buffer "abcdef") 1 4 "")) "aef"))
  (test "an empty range inserts at the point"
    (assert= (buffer-text (replace-region (make-buffer "abc") 1 1 "XY")) "aXYbc")))

(describe "line-wise region ops"
  (test "region-line-range is the current line when there's no mark"
    (assert= (region-line-range (-> (make-buffer "a\nb\nc") (goto-char 2))) [1 1]))
  (test "region-line-range spans the region's lines"
    (assert= (region-line-range (-> (make-buffer "a\nb\nc\nd") (goto-char 0) set-mark (goto-char 4)))
      [0 1]))   ; covers lines 0–1
  (test "a region ending at a line start doesn't pull that trailing line in"
    ;; "a\nb\nc": mark 0, point 4 = start of line 2 → range is lines 0–1, not 0–2
    (assert= (region-line-range (-> (make-buffer "a\nb\nc") (goto-char 0) set-mark (goto-char 4)))
      [0 1]))
  (test "map-region-lines threads the buffer over each line in range"
    ;; prefix every line of the region with '> '
    (let (b (-> (make-buffer "a\nb\nc") (goto-char 0) set-mark (goto-char 3))  ; lines 0–1
          out (map-region-lines b
                (fn (bb l) (insert (goto-char bb (rope-line->char (buffer-rope bb) l)) "> "))))
      (assert= (buffer-text out) "> a\n> b\nc"))))

(describe "buffer mark ring"
  (test "push-mark sets the mark and pushes point onto the ring"
    (let (b (-> (make-buffer "abcdef") (goto-char 3) push-mark))
      (assert= (buffer-mark b) 3)
      (assert= (get b :mark-ring) (list 3))))
  (test "pop-mark moves point to the newest ring entry, rotating it to the back"
    (let (b (-> (make-buffer "abcdef") (goto-char 2) push-mark (goto-char 5) push-mark (goto-char 0))
          p1 (pop-mark b))
      (assert= (buffer-point p1) 5)                 ; newest mark first
      (assert= (buffer-point (pop-mark p1)) 2)      ; then the older one
      (assert= (buffer-point (pop-mark (pop-mark p1))) 5)))  ; ring cycles
  (test "pop-mark is a no-op on an empty ring"
    (assert= (buffer-point (pop-mark (goto-char (make-buffer "abc") 1))) 1)))

(describe "buffer search"
  (test "buffer-search-forward finds the first match at or after `from`"
    (let (b (make-buffer "abc abc"))
      (assert= (buffer-search-forward b "abc" 0) 0)
      (assert= (buffer-search-forward b "abc" 1) 4)
      (assert= (buffer-search-forward b "zzz" 0) nil)))
  (test "buffer-search-backward finds the last match before `before`"
    (let (b (make-buffer "abc abc"))
      (assert= (buffer-search-backward b "abc" 7) 4)
      (assert= (buffer-search-backward b "abc" 4) 0)
      (assert= (buffer-search-backward b "abc" 0) nil)
      (assert= (buffer-search-backward b "zzz" 7) nil))))

(describe "buffer undo / redo"
  (test "undo restores the text and point before the last edit"
    (let (b (-> (make-buffer "hello") (goto-char 5) (insert "!"))
          u (undo b))
      (assert= (buffer-text b) "hello!")
      (assert= (buffer-text u) "hello")
      (assert= (buffer-point u) 5)))
  (test "redo re-applies an undone edit"
    (let (b (-> (make-buffer "hi") end-of-buffer (insert "!"))
          r (-> b undo redo))
      (assert= (buffer-text r) "hi!")
      (assert= (buffer-point r) 3)))
  (test "a fresh edit clears the redo stack"
    (let (b (-> (make-buffer "") (insert "a") (insert "b"))
           ; "ab"
           back
           (undo b)  ; "a", redo has "ab"
           edited
           (insert back "z"))
      ; "az", redo cleared
      (assert= (buffer-text edited) "az")
      (assert= (buffer-text (redo edited)) "az")))  ; redo is now a no-op
  (test "undo with no history is a no-op"
    (let (b (make-buffer "abc"))
      (assert= (buffer-text (undo b)) "abc")
      (assert= (buffer-text (redo b)) "abc")))
  (test "a no-op edit records nothing (undo skips past it)"
    (let (b (-> (make-buffer "ab") (insert "X"))
           ; "Xab", one undo step
           noop
           (delete-char (end-of-buffer b)))
      ; delete at end → unchanged
      (assert= (buffer-text noop) "Xab")
      (assert= (buffer-text (undo noop)) "ab")))  ; undo reaches the real edit
  (test "undoing a region delete restores the text and the mark"
    (let (b (-> (make-buffer "abcdef") (goto-char 1) set-mark (goto-char 4) delete-region)
          u (undo b))
      (assert= (buffer-text b) "aef")
      (assert= (buffer-text u) "abcdef")
      (assert= (buffer-mark u) 1)
      (assert= (buffer-point u) 4)))
  (test "two buffers keep independent histories"
    (let (a (-> (make-buffer "") (insert "a"))
          c (-> (make-buffer "") (insert "c")))
      (assert= (buffer-text (undo a)) "")
      (assert= (buffer-text c) "c")))  ; undoing `a` left `c` untouched
  (test "disable-undo stops recording (a log buffer), so undo is a no-op"
    (let (b (-> (disable-undo (make-buffer "")) (insert "a") (insert "b")))
      (assert= (buffer-text b) "ab")
      (assert= (get b :undo) ())  ; nothing recorded
      (assert= (buffer-text (undo b)) "ab"))))

(describe "buffer file round-trip"
  (test "buffer-from-file reads, save-buffer writes back"
    (let (path (str (temp-dir "brood-buf-") ".txt"))
      (spit path "first line\nsecond line\n")
      (let (b (buffer-from-file path))
        (assert= (buffer-text b) "first line\nsecond line\n")
        (assert= (buffer-file b) path)
        ; edit and save, then re-read to confirm it persisted
        (save-buffer (-> b end-of-buffer (insert "third line\n")))
        (assert= (buffer-text (buffer-from-file path))
          "first line\nsecond line\nthird line\n"))))
  (test "save-buffer with no file raises"
    (assert-error (save-buffer (make-buffer "x"))))
  ;; find-file-buffer: vim/emacs `find-file` — read an existing file, else a fresh
  ;; empty buffer backed by the path (so the first save creates the file).
  (test "find-file-buffer reads an existing file"
    (let (path (str (temp-dir "brood-buf-") ".txt"))
      (spit path "hi\n")
      (let (b (find-file-buffer path))
        (assert= (buffer-text b) "hi\n")
        (assert= (buffer-file b) path))))
  (test "find-file-buffer on a missing path is an empty buffer backed by it"
    (let (path (str (temp-dir "brood-buf-") "-new.txt")  ; temp-dir creates the file…
          gone (str path ".absent"))                      ; …so use a path that doesn't exist
      (let (b (find-file-buffer gone))
        (assert= (buffer-text b) "")          ; empty — not an error
        (assert= (buffer-file b) gone)        ; backed by the path, so save creates it
        (save-buffer (insert b "made"))
        (assert= (buffer-text (find-file-buffer gone)) "made")))))

;; The actor shell: a buffer process owns its buffer (and process-local rope) and
;; replies only with derived views. Edits/reads cross as closures (ADR-033).
(describe "buffer actor shell"
  :isolated

  (test "spawn-buffer + edit + query"
    (let (bp (spawn-buffer (make-buffer "hello")))
      (buffer-edit bp (fn (b) (-> b end-of-buffer (insert " world"))))
      (assert= (buffer-query bp buffer-text) "hello world")
      (assert= (buffer-query bp buffer-length) 11)
      (assert= (stop-buffer bp) :stopped)))

  (test "a query returns a derived view (a line string), not the buffer"
    (let (bp (spawn-buffer (make-buffer "line0\nline1")))
      (assert= (buffer-query bp (fn (b) (buffer-line-at b 1))) "line1")
      (stop-buffer bp)))

  (test "spawning preserves point and mark (ships text, rebuilds the rope)"
    (let (src (-> (make-buffer "abcdef") (goto-char 1) set-mark (goto-char 4))
          bp (spawn-buffer src))
      (assert= (buffer-query bp buffer-point) 4)
      (assert= (buffer-query bp buffer-mark) 1)
      (assert= (buffer-query bp buffer-region) "bcd")
      (stop-buffer bp)))

  (test "two buffer processes are independent"
    (let (a (spawn-buffer (make-buffer "aaa"))
          b (spawn-buffer (make-buffer "bbb")))
      (buffer-edit a (fn (buf) (insert buf "!")))
      (assert= (buffer-query a buffer-text) "!aaa")
      (assert= (buffer-query b buffer-text) "bbb")
      (stop-buffer a)
      (stop-buffer b)))

  ;; A buffer process is an `io` sink: `[:io-write s]` appends. create-buffer /
  ;; delete-buffer are the lifecycle pair. Same-sender ordering makes this exact.
  (test "create-buffer + [:io-write] appends; delete-buffer stops it"
    (let (bp (create-buffer "*log*"))
      (send bp [:io-write "hello\n"])
      (send bp [:io-write "world\n"])
      (assert= (buffer-query bp buffer-text) "hello\nworld\n")
      (assert= (delete-buffer bp) :stopped)))

  ;; The point of it all: a std/log process-backend streams log lines into a buffer
  ;; process, no glue. Flush the logger (a query after the casts) before asserting,
  ;; since logging is fire-and-forget.
  (test "a logger process-backend streams log lines into a buffer process"
    (let (bp (create-buffer "*app-log*")
          lg (log/start-logger {:level :info :backends [(log/process-backend bp)]}))
      (log/log-info "server up")
      (log/log-warn "disk low")
      (proc/hatch/gen-call lg :config)   ; the logger has now dispatched both casts → bp
      (let (txt (buffer-query bp buffer-text))
        (is (string-contains? txt "server up"))
        (is (string-contains? txt "disk low")))
      (log/stop-logger)
      (delete-buffer bp))))
