;; std/proctree.blsp — ordering a flat process-info list as a parent→child forest.
;; Pure over synthetic `{:id :parent}` maps (no spawning needed): the lineage walk
;; the observer's tree sort and myedit's *Process List* both share.

(defmodule proctree-test (:use test) (:use proctree))

(require 'proctree)

(describe "proctree/by-id"
  (test "sorts ascending by id (the flat view)"
    (assert= (map (fn (p) (get p :id)) (by-id [{:id 3} {:id 1} {:id 2}])) '(1 2 3))))

(describe "proctree/tree-order"
  (test "roots first, each followed by its DFS descendants, depth-tagged"
    (let (ps [{:id 1 :parent nil} {:id 2 :parent 1} {:id 3 :parent 1} {:id 4 :parent 2}]
          o (tree-order ps))
      (assert= (map (fn (p) (get p :id)) o) '(1 2 4 3))        ; 1 → (2 → 4) → 3
      (assert= (map (fn (p) (get p :depth)) o) '(0 1 2 1))))
  (test "an orphan (parent not in the set) is treated as a root"
    (let (o (tree-order [{:id 5 :parent 99} {:id 6 :parent 5}]))
      (assert= (map (fn (p) (get p :id)) o) '(5 6))
      (assert= (map (fn (p) (get p :depth)) o) '(0 1))))
  (test "multiple roots are ordered by id; siblings too"
    (assert= (map (fn (p) (get p :id))
               (tree-order [{:id 2 :parent nil} {:id 1 :parent nil} {:id 3 :parent 2}]))
      '(1 2 3)))
  (test "a snapshot with no root (mutual parents) is bounded to empty, not a hang"
    ;; impossible from real process-info, but a malformed snapshot must terminate
    (is (empty? (tree-order [{:id 1 :parent 2} {:id 2 :parent 1}])))))
