;; std/supervisor.blsp — OTP-style supervision built in Brood on
;; spawn/monitor/receive/exit. :isolated because each test spawns processes (and
;; supervisors) and observes restarts via messages to the test process.
;;
;; The idiom throughout: a child reports `[:up …]` to the test process when it
;; starts, then parks on `receive`. The test crashes it with `:die`; if the
;; supervisor restarts it, a *new* incarnation reports `[:up …]` with a fresh
;; pid. A `(receive … (after ms :none))` proves the *absence* of a restart.

(defmodule supervisor-test (:use test) (:use proc/supervisor))

;; A child spec whose worker announces itself to `to`, then waits. `:die` makes
;; it crash (abnormal exit); `:done` makes it return cleanly (`:normal` exit).
;; `spawn-link` (not `spawn`): the child is linked to the supervisor *atomically*, so a
;; fast `:normal` exit (e.g. right after `:done`) reaches it as `[:EXIT … :normal]`, never
;; a racy `:noproc` that would spuriously restart a `:transient` child. This is the
;; Erlang convention for supervised children (spawn_link).
(defn watched-spec (to restart)
  {:id :w
   :restart restart
   :start (fn () (spawn-link (do (send to [:up (self)]) (receive (:die (error "boom")) (:done :ok)))))})

;; Like `watched-spec` but tags its announcement `[:up tag (self)]`, so a test
;; supervising several children can tell their incarnations apart.
(defn tagged-spec (to tag restart)
  {:id tag
   :restart restart
   :start (fn ()
            (spawn-link (do (send to [:up tag (self)]) (receive (:die (error "boom")) (:done :ok)))))})

;; Collect `n` tagged `[:up tag pid]` announcements into a `{tag pid}` map.
;; Tail-recursive via the receive trampoline (a test runs in a small-stack proc).
(defn collect-ups (n acc)
  (if (= n 0)
    acc
    (receive ([:up tag pid] (collect-ups (- n 1) (assoc acc tag pid))))))

;; A child that announces `[:up tag pid]` on start and `[:stopped tag]` when it
;; receives `[:$stop]` — with `:shutdown :infinity` so we can observe teardown
;; ORDER (the supervisor stops children one at a time, waiting for each).
(defn stop-announce-spec (to tag)
  {:id tag
   :restart :permanent
   :shutdown :infinity
   :start (fn ()
            (spawn (do (send to [:up tag (self)]) (receive ([:$stop] (send to [:stopped tag]))))))})

(defn collect-stops (n acc)
  (if (= n 0)
    (reverse acc)
    (receive ([:stopped t] (collect-stops (- n 1) (cons t acc))))))

;; Registration races the child's own `[:up]`, so a holder may briefly see the
;; old/nil value after a (re)start — poll `whereis` until it settles (or give up).
(defn wait-name (name expected tries)
  (cond
    (= (whereis name) expected) expected
    (= tries 0) (whereis name)
    else (do (sleep 5) (wait-name name expected (- tries 1)))))

(describe "supervisor: one-for-one restart"
  :isolated

  ;; Each test tags its child (`tagged-spec`) with a unique key so its `[:up …]`
  ;; stream is isolated: this `:isolated` describe runs as ONE unit (shared process +
  ;; mailbox, see test.blsp), so an untagged `[:up]` from a sibling test could, under
  ;; load, arrive late and be miscounted by a later test's `receive` — flaking the
  ;; absence checks below. A real restart of *this* test's child still sends
  ;; `[:up <tag> newpid]` and is caught, so tagging fixes the cross-test race without
  ;; masking a real restart bug.
  (test "a permanent child is restarted with a fresh pid after it crashes"
    (let (me (self)
          sup (start-supervisor (list (tagged-spec me :perm-r :permanent))
                {:max-restarts 5 :max-seconds 5})
          p1 (receive ([:up :perm-r p] p)))
      (send p1 :die)  ; crash the first incarnation
      (let (p2 (receive ([:up :perm-r p] p)))
        ; the restart announces itself
        (is (not (= p1 p2)))  ; genuinely a new process
        (stop-supervisor sup))))

  (test "a transient child IS restarted after an abnormal exit"
    (let (me (self)
          sup (start-supervisor (list (tagged-spec me :tr-abn :transient)))
          p1 (receive ([:up :tr-abn p] p)))
      (send p1 :die)
      (let (p2 (receive ([:up :tr-abn p] p)))
        (is (not (= p1 p2)))
        (stop-supervisor sup))))

  (test "a transient child is NOT restarted after a clean :normal exit"
    (let (me (self)
          sup (start-supervisor (list (tagged-spec me :tr-norm :transient)))
          p1 (receive ([:up :tr-norm p] p)))
      (send p1 :done)  ; returns normally
      (assert= :none (receive ([:up :tr-norm _] :restarted) (after 150 :none)))
      (stop-supervisor sup)))

  (test "a temporary child is never restarted"
    (let (me (self)
          sup (start-supervisor (list (tagged-spec me :temp-n :temporary)))
          p1 (receive ([:up :temp-n p] p)))
      (send p1 :die)
      (assert= :none (receive ([:up :temp-n _] :restarted) (after 150 :none)))
      (stop-supervisor sup))))

(describe "supervisor: one-for-all"
  :isolated

  (test "a crash restarts every child with a fresh pid"
    (let (me (self)
          sup (start-supervisor (list (tagged-spec me :a :permanent)
                                  (tagged-spec me :b :permanent))
                {:strategy :one-for-all :max-restarts 5 :max-seconds 5})
          gen1 (collect-ups 2 {}))
      (send (get gen1 :a) :die)  ; crash a → kills + restarts both
      (let (gen2 (collect-ups 2 {}))
        ; both announce fresh incarnations
        (is (not (= (get gen1 :a) (get gen2 :a))))
        (is (not (= (get gen1 :b) (get gen2 :b))))  ; the healthy sibling restarted too
        (stop-supervisor sup))))

  (test "a :temporary sibling is terminated but not revived"
    (let (me (self)
          sup (start-supervisor (list (tagged-spec me :a :permanent)
                                  (tagged-spec me :b :temporary))
                {:strategy :one-for-all})
          gen1 (collect-ups 2 {})
          mb (monitor (get gen1 :b)))
      ; watch the temporary sibling
      (send (get gen1 :a) :die)
      ;; b is force-killed as part of the group restart (our monitor sees it)…
      (assert= :down (receive ([:down ~mb _ _] :down)))
      ;; …only a comes back (one fresh :up); b is dropped, so no second :up.
      (let (g2a (receive ([:up :a p] p)))
        (is (not (= (get gen1 :a) g2a)))
        (assert= :none (receive ([:up :b _] :revived) (after 150 :none))))
      (stop-supervisor sup))))

(describe "supervisor: rest-for-one"
  :isolated

  (test "restarts the crashed child and those started after it, not before"
    (let (me (self)
          sup (start-supervisor (list (tagged-spec me :a :permanent)
                                  (tagged-spec me :b :permanent)
                                  (tagged-spec me :c :permanent))
                {:strategy :rest-for-one})
          gen1 (collect-ups 3 {}))
      (send (get gen1 :b) :die)  ; crash b → restart b and c, leave a
      (let (gen2 (collect-ups 2 {}))
        ; exactly two restarts announce
        (is (not (= (get gen1 :b) (get gen2 :b))))
        (is (not (= (get gen1 :c) (get gen2 :c))))
        (is (nil? (get gen2 :a)))  ; a was not restarted…
        (assert= :none (receive ([:up _ _] :more) (after 150 :none)))  ; …and nothing else did
        (stop-supervisor sup)))))

(describe "supervisor: restart intensity"
  :isolated

  (test "exceeding the restart limit shuts the supervisor down abnormally"
    ;; A child that crashes immediately on every start. With max-restarts 2,
    ;; the 3rd restart trips the intensity window and the supervisor throws,
    ;; so a monitor on the supervisor sees `[:down … [:error …]]`.
    ;; (Each crash prints a "process … died" line to stderr — expected here.)
    (let (sup (start-supervisor (list {:id :crashy
                                       :restart :permanent
                                       :start (fn () (spawn (error "always")))})
                {:max-restarts 2 :max-seconds 5})
          mref (monitor sup))
      (assert= :gaveup
        (receive ([:down ~mref ~sup [:error _]] :gaveup)
         )))))

(describe "supervisor: shutdown terminates children"
  :isolated

  (test "stop-supervisor kills its children (no orphans)"
    (let (me (self)
          sup (start-supervisor (list (watched-spec me :permanent)))
          p1 (receive ([:up p] p))
          mp (monitor p1))
      ; watch the child directly
      (stop-supervisor sup)
      ;; the supervisor exits *and* hard-kills the child → our monitor fires.
      (assert= :down (receive ([:down ~mp ~p1 _] :down))))))

(describe "supervisor: nested trees + graceful shutdown"
  :isolated

  (test "stop-supervisor cascades through a :shutdown :infinity sub-supervisor"
    ;; parent → (sub-supervisor child, :shutdown :infinity) → announcing worker.
    ;; Stopping the parent must tear the *grandchild* down too, not orphan it.
    (let (me (self)
           subtree
           {:id :sub
            :restart :permanent
            :shutdown :infinity
            :start (fn ()
                     (start-supervisor (list (watched-spec me :permanent))
                       {:max-restarts 5 :max-seconds 5}))}
           parent
           (start-supervisor (list subtree) {:strategy :one-for-one})
           gc
           (receive ([:up p] p))  ; the grandchild announced itself
           gm
           (monitor gc))
      (stop-supervisor parent)
      (assert= :torn-down
        (receive ([:down ~gm ~gc _] :torn-down)))))

  (test "a :shutdown <ms> child that ignores [:$stop] is hard-killed after the timeout"
    ;; The worker's receive only matches :die — it never consumes [:$stop], so the
    ;; supervisor's graceful attempt times out and falls back to (exit :kill).
    (let (me (self)
          spec {:id :w
                :restart :permanent
                :shutdown 100
                :start (fn () (spawn (do (send me [:up (self)]) (receive (:die :ok)))))}
          sup (start-supervisor (list spec))
          p (receive ([:up x] x))
          pm (monitor p))
      (stop-supervisor sup)
      (assert= :killed
        (receive ([:down ~pm ~p _] :killed))))))

(describe "supervisor: shutdown order + named children"
  :isolated

  (test "stop-supervisor terminates children in reverse start order"
    (let (me (self)
          sup (start-supervisor (list (stop-announce-spec me :a)
                                  (stop-announce-spec me :b)
                                  (stop-announce-spec me :c)))
          _ (collect-ups 3 {}))
      ; wait until all three are up
      (stop-supervisor sup)
      ;; started a, b, c → torn down c, b, a
      (assert= (list :c :b :a) (collect-stops 3 ()))))

  (test "a named child is addressable by name, and the name follows a restart"
    (let (me (self)
          sup (start-supervisor (list {:id :svc
                                       :name :sup-test-svc
                                       :restart :permanent
                                       :start (fn ()
                                                (spawn (do
                                                         (send me [:up (self)])
                                                         (receive (:die (error "boom"))))))}))
          p1 (receive ([:up p] p)))
      (assert= p1 (wait-name :sup-test-svc p1 50))  ; reachable by its name
      (send p1 :die)  ; crash it
      (let (p2 (receive ([:up p] p)))
        ; restarted with a fresh pid
        (is (not (= p1 p2)))
        (assert= p2 (wait-name :sup-test-svc p2 50))  ; the name now points at the new pid
        (stop-supervisor sup)))))

(describe "supervisor: crash teardown (link propagation, ADR-067)"
  :isolated

  (test "killing a supervisor tears its child down too (no orphan)"
    ;; The supervisor links its children; when the *supervisor itself* dies, the
    ;; kernel propagates the exit down the links and the child dies. Monitors
    ;; couldn't do this — the whole reason for the link rewrite.
    (let (me (self)
          sup (start-supervisor (list (watched-spec me :permanent)))
          w (receive ([:up p] p))
          wm (monitor w))
      (exit sup :kill)  ; the supervisor dies abnormally
      (assert= :torn-down
        (receive ([:down ~wm ~w _] :torn-down)))))

  (test "killing a supervisor cascades through a nested sub-supervisor"
    ;; parent → (sub-supervisor child) → grandchild. Killing the *parent* must
    ;; reach the grandchild: the sub-supervisor (linked + trapping) sees its
    ;; parent's [:EXIT] and tears its own subtree down.
    (let (me (self)
          subtree {:id :sub
                   :restart :permanent
                   :shutdown :infinity
                   :start (fn ()
                            (start-supervisor (list (watched-spec me :permanent))
                              {:max-restarts 5 :max-seconds 5}))}
          parent (start-supervisor (list subtree) {:strategy :one-for-one})
          gc (receive ([:up p] p))
          gm (monitor gc))
      (exit parent :kill)  ; parent dies abnormally
      (assert= :torn-down
        (receive ([:down ~gm ~gc _] :torn-down))))))

(describe "supervisor: runtime child API (DynamicSupervisor)"
  :isolated

  (test "start-child adds and supervises a child at runtime"
    (let (me (self)
           sup
           (start-supervisor (list))  ; empty — a dynamic supervisor
           _
           (assert= 0 (count-children sup))
           pid
           (start-child sup (watched-spec me :permanent))
           p1
           (receive ([:up p] p)))
      (is (= pid p1))  ; start-child returned the live pid
      (assert= 1 (count-children sup))
      ;; it's fully supervised: crash it, it restarts with a fresh pid
      (send p1 :die)
      (let (p2 (receive ([:up p] p)))
        (is (not (= p1 p2)))
        (assert= 1 (count-children sup)))
      (stop-supervisor sup)))

  (test "terminate-child stops a child and removes it (no restart)"
    (let (me (self)
          sup (start-supervisor (list))
          pid (start-child sup (tagged-spec me :w :permanent))
          _ (receive ([:up :w _] :ok))
          wm (monitor pid))
      (assert= :ok (terminate-child sup :w))  ; by :id
      (assert= :down (receive ([:down ~wm ~pid _] :down)))
      (assert= 0 (count-children sup))  ; dropped, not restarted
      (assert= :none (receive ([:up :w _] :restarted) (after 150 :none)))
      (assert= :not-found (terminate-child sup :w))  ; already gone
      (stop-supervisor sup)))

  (test "restart-child replaces a child with a fresh incarnation"
    (let (me (self)
          sup (start-supervisor (list))
          p1 (start-child sup (tagged-spec me :w :permanent))
          _ (receive ([:up :w _] :ok))
          p2 (restart-child sup :w))
      ; by :id
      (receive ([:up :w _] :ok))  ; the fresh incarnation announces
      (is (not (= p1 p2)))
      (assert= 1 (count-children sup))
      (assert= :not-found (restart-child sup :nope))
      (stop-supervisor sup))))

(describe "supervisor: introspection and validation"
  :isolated

  (test "which-children reports a summary per live child"
    (let (me (self)
           sup
           (start-supervisor (list (watched-spec me :permanent)))
           _
           (receive ([:up _] :ok))  ; wait until the child is up
           kids
           (which-children sup))
      (assert= 1 (count kids))
      (assert= :w (get (first kids) :id))
      (is (not (nil? (get (first kids) :pid))))
      (stop-supervisor sup)))

  (test "an unknown strategy is rejected up front"
    (assert-error (start-supervisor (list) {:strategy :every-which-way}))))
