;; std/supervisor.blsp — OTP-style supervision built in Brood on
;; spawn/monitor/receive/exit. :isolated because each test spawns processes (and
;; supervisors) and observes restarts via messages to the test process.
;;
;; The idiom throughout: a child reports `[:up …]` to the test process when it
;; starts, then parks on `receive`. The test crashes it with `:die`; if the
;; supervisor restarts it, a *new* incarnation reports `[:up …]` with a fresh
;; pid. A `(receive … (after ms :none))` proves the *absence* of a restart.

(require 'test)
(require 'supervisor)

;; A child spec whose worker announces itself to `to`, then waits. `:die` makes
;; it crash (abnormal exit); `:done` makes it return cleanly (`:normal` exit).
(defn watched-spec (to restart)
  {:id :w
   :restart restart
   :start (fn () (spawn (do (send to [:up (self)])
                            (receive (:die (error "boom"))
                                     (:done :ok)))))})

;; Like `watched-spec` but tags its announcement `[:up tag (self)]`, so a test
;; supervising several children can tell their incarnations apart.
(defn tagged-spec (to tag restart)
  {:id tag
   :restart restart
   :start (fn () (spawn (do (send to [:up tag (self)])
                            (receive (:die (error "boom"))
                                     (:done :ok)))))})

;; Collect `n` tagged `[:up tag pid]` announcements into a `{tag pid}` map.
;; Tail-recursive via the receive trampoline (a test runs in a small-stack proc).
(defn collect-ups (n acc)
  (if (= n 0) acc
    (receive ([:up tag pid] (collect-ups (- n 1) (assoc acc tag pid))))))

(describe "supervisor: one-for-one restart"
  :isolated

  (test "a permanent child is restarted with a fresh pid after it crashes"
    (let (me  (self)
          sup (start-supervisor (list (watched-spec me :permanent))
                                {:max-restarts 5 :max-seconds 5})
          p1  (receive ([:up p] p)))
      (send p1 :die)                          ; crash the first incarnation
      (let (p2 (receive ([:up p] p)))         ; the restart announces itself
        (is (not (= p1 p2)))                  ; genuinely a new process
        (stop-supervisor sup))))

  (test "a transient child IS restarted after an abnormal exit"
    (let (me  (self)
          sup (start-supervisor (list (watched-spec me :transient)))
          p1  (receive ([:up p] p)))
      (send p1 :die)
      (let (p2 (receive ([:up p] p)))
        (is (not (= p1 p2)))
        (stop-supervisor sup))))

  (test "a transient child is NOT restarted after a clean :normal exit"
    (let (me  (self)
          sup (start-supervisor (list (watched-spec me :transient)))
          p1  (receive ([:up p] p)))
      (send p1 :done)                         ; returns normally
      (assert= :none (receive ([:up _] :restarted) (after 150 :none)))
      (stop-supervisor sup)))

  (test "a temporary child is never restarted"
    (let (me  (self)
          sup (start-supervisor (list (watched-spec me :temporary)))
          p1  (receive ([:up p] p)))
      (send p1 :die)
      (assert= :none (receive ([:up _] :restarted) (after 150 :none)))
      (stop-supervisor sup))))

(describe "supervisor: one-for-all"
  :isolated

  (test "a crash restarts every child with a fresh pid"
    (let (me   (self)
          sup  (start-supervisor (list (tagged-spec me :a :permanent)
                                       (tagged-spec me :b :permanent))
                                 {:strategy :one-for-all :max-restarts 5 :max-seconds 5})
          gen1 (collect-ups 2 {}))
      (send (get gen1 :a) :die)               ; crash a → kills + restarts both
      (let (gen2 (collect-ups 2 {}))          ; both announce fresh incarnations
        (is (not (= (get gen1 :a) (get gen2 :a))))
        (is (not (= (get gen1 :b) (get gen2 :b))))   ; the healthy sibling restarted too
        (stop-supervisor sup))))

  (test "a :temporary sibling is terminated but not revived"
    (let (me   (self)
          sup  (start-supervisor (list (tagged-spec me :a :permanent)
                                       (tagged-spec me :b :temporary))
                                 {:strategy :one-for-all})
          gen1 (collect-ups 2 {})
          mb   (monitor (get gen1 :b)))        ; watch the temporary sibling
      (send (get gen1 :a) :die)
      ;; b is force-killed as part of the group restart (our monitor sees it)…
      (assert= :down (receive ([:down ~mb _ _] :down) (after 1000 :alive)))
      ;; …only a comes back (one fresh :up); b is dropped, so no second :up.
      (let (g2a (receive ([:up :a p] p)))
        (is (not (= (get gen1 :a) g2a)))
        (assert= :none (receive ([:up :b _] :revived) (after 150 :none))))
      (stop-supervisor sup))))

(describe "supervisor: rest-for-one"
  :isolated

  (test "restarts the crashed child and those started after it, not before"
    (let (me   (self)
          sup  (start-supervisor (list (tagged-spec me :a :permanent)
                                       (tagged-spec me :b :permanent)
                                       (tagged-spec me :c :permanent))
                                 {:strategy :rest-for-one})
          gen1 (collect-ups 3 {}))
      (send (get gen1 :b) :die)               ; crash b → restart b and c, leave a
      (let (gen2 (collect-ups 2 {}))          ; exactly two restarts announce
        (is (not (= (get gen1 :b) (get gen2 :b))))
        (is (not (= (get gen1 :c) (get gen2 :c))))
        (is (nil? (get gen2 :a)))             ; a was not restarted…
        (assert= :none (receive ([:up _ _] :more) (after 150 :none)))  ; …and nothing else did
        (stop-supervisor sup)))))

(describe "supervisor: restart intensity"
  :isolated

  (test "exceeding the restart limit shuts the supervisor down abnormally"
    ;; A child that crashes immediately on every start. With max-restarts 2,
    ;; the 3rd restart trips the intensity window and the supervisor throws,
    ;; so a monitor on the supervisor sees `[:down … [:error …]]`.
    ;; (Each crash prints a "process … died" line to stderr — expected here.)
    (let (sup  (start-supervisor (list {:id :crashy
                                        :restart :permanent
                                        :start (fn () (spawn (error "always")))})
                                 {:max-restarts 2 :max-seconds 5})
          mref (monitor sup))
      (assert= :gaveup
        (receive ([:down ~mref ~sup [:error _]] :gaveup)
                 (after 2000 :still-up))))))

(describe "supervisor: shutdown terminates children"
  :isolated

  (test "stop-supervisor kills its children (no orphans)"
    (let (me   (self)
          sup  (start-supervisor (list (watched-spec me :permanent)))
          p1   (receive ([:up p] p))
          mp   (monitor p1))                  ; watch the child directly
      (stop-supervisor sup)
      ;; the supervisor exits *and* hard-kills the child → our monitor fires.
      (assert= :down (receive ([:down ~mp ~p1 _] :down) (after 1000 :orphaned))))))

(describe "supervisor: introspection and validation"
  :isolated

  (test "which-children reports a summary per live child"
    (let (me   (self)
          sup  (start-supervisor (list (watched-spec me :permanent)))
          _    (receive ([:up _] :ok))        ; wait until the child is up
          kids (which-children sup))
      (assert= 1 (count kids))
      (assert= :w (get (first kids) :id))
      (is (not (nil? (get (first kids) :pid))))
      (stop-supervisor sup)))

  (test "an unknown strategy is rejected up front"
    (assert-error (start-supervisor (list) {:strategy :every-which-way}))))
