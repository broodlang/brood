;; Reader hardening — malformed / "silly syntax" must produce a clean parse error,
;; never a panic or segfault (added 2026-06-29, after a 500-input syntax fuzz run
;; found 0 crashes). `read-string` surfaces the reader directly; `assert-error`
;; confirms a clean error. Also pins a few valid-but-weird forms that MUST parse.
(defmodule reader-malformed-test (:use test))

;; one arg, fully balanced per line: (assert-error (read-string "S"))
(describe "malformed input errors cleanly (no crash)"
  (test "unbalanced / stray delimiters"
    (assert-error (read-string "(((("))
    (assert-error (read-string ")"))
    (assert-error (read-string "[1 2"))
    (assert-error (read-string "{:a"))
    (assert-error (read-string "([)]")))
  (test "unterminated / bad-escape strings"
    (assert-error (read-string "\"no end"))
    (assert-error (read-string "\"\\x\""))
    (assert-error (read-string "\"\\u{110000}\"")))
  (test "number-shaped tokens that don't parse are a parse error, not a silent symbol"
    ;; a token whose intent is numeric (leads with a digit/sign/dot, holds only
    ;; number chars) but doesn't parse must fail loudly — it is NOT a symbol.
    (assert= (read-string "1e7") 10000000.0)   ; valid float still parses
    (assert-error (read-string "1e"))          ; float-shaped, malformed
    (assert-error (read-string "1.2.3"))       ; float-shaped, malformed
    (assert-error (read-string "1e+"))         ; float-shaped, malformed
    (assert-error (read-string "--5")))        ; int-shaped, malformed
  (test "dangling reader sugar"
    (assert-error (read-string "'"))
    (assert-error (read-string "`"))
    (assert-error (read-string "~"))
    (assert-error (read-string "~@")))
  (test "pathologically deep nesting errors (depth cap), does not overflow"
    (assert-error (read-string (string-repeat "(" 100000)))
    (assert-error (read-string (string-repeat "[" 100000)))))

(describe "valid but unusual forms still parse correctly"
  (test "non-finite float literals read as floats"
    (assert= (type-of (read-string "inf")) :float)
    (assert= (type-of (read-string "nan")) :float))
  (test "dotted pair and empty containers"
    (assert= (read-string "(1 2 . 3)") (cons 1 (cons 2 3)))
    (assert= (read-string "[]") [])
    (assert= (read-string "()") '()))
  (test "nested form parses to the right structure"
    (assert= (read-string "(1 (2 (3)))") (list 1 (list 2 (list 3))))))
