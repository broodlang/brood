;; Project manifest + entry-point resolution (std/project.blsp). Covers the
;; `:main` parser and the default entry. Register-only — discovered and run by
;; `nest test` (and cargo test, via crates/lisp/tests/suite.rs).
;;
;; `run-project` itself is not exercised in-language: it walks from `cwd` to a
;; project.blsp, which the brood-repo suite already sits inside, so we can't
;; isolate it from here without changing the working directory. The hand-run
;; equivalent — `nest new foo && cd foo && nest run` — is the integration check.

(defmodule project-test (:use test) (:use project))

;; Drop any fixtures a prior run left in /tmp (at load, before any test runs).
(purge-stale-temp "brood-dup-")

(describe "project: :main parsing"
  (test "a bare symbol defaults the fn name to `main`"
    (assert= (project/project--parse-main 'foo) '(foo main)))
  (test "a 2-list of symbols is taken as (module fn)"
    (assert= (project/project--parse-main '(foo bar)) '(foo bar)))
  (test "a 1-list is rejected"
    (assert= "project: :main must be a module symbol or '(module fn), got (foo)"
      (try (project/project--parse-main '(foo)) (catch e e))))
  (test "a 3-list is rejected"
    (assert= "project: :main must be a module symbol or '(module fn), got (foo bar baz)"
      (try (project/project--parse-main '(foo bar baz)) (catch e e))))
  (test "a non-symbol head is rejected"
    (is (string? (try (project/project--parse-main '("foo" main)) (catch e e)))))
  (test "a non-symbol fn is rejected"
    (is (string? (try (project/project--parse-main '(foo "main")) (catch e e)))))
  (test "a string is rejected"
    (is (string? (try (project/project--parse-main "main") (catch e e)))))
  ;; `:main 'app` reads as `(quote app)` (the manifest is data, never evaluated),
  ;; which would silently misparse to module `quote` — guard it with a fix-it.
  (test "a quoted symbol is rejected with a drop-the-quote fix-it"
    (let (msg (try (project/project--parse-main '(quote app)) (catch e e)))
      (and (is (string-contains? msg "drop the leading quote"))
        (is (string-contains? msg "`:main app`")))))
  (test "a quoted list is rejected with a drop-the-quote fix-it"
    (is (string-contains? (try (project/project--parse-main '(quote (app start))) (catch e e))
          "drop the leading quote"))))

(describe "project: default entry"
  (test "*project-main* defaults to (main main)"
    ;; A manifest with no :main key never assigns *project-main*, so the default
    ;; stays in place. The brood repo's own project.blsp omits :main, so this
    ;; reflects the live value the runner would use.
    (assert= *project-main* '(main main))))

(describe "project: :dependencies parsing (ADR-037)"
  (test "a :git entry normalises to a dep map"
    (assert= (project/project--parse-dep '[parser :git "https://example.com/p.git" :ref "v1.2.0"])
      {:name 'parser :kind :git :url "https://example.com/p.git" :ref "v1.2.0"}))
  (test "a :path entry normalises to a dep map"
    (assert= (project/project--parse-dep '[shared :path "../shared"])
      {:name 'shared :kind :path :path "../shared"}))
  (test "parse-deps maps over the whole vector"
    (assert= (project/project--parse-deps '[[a :path "../a"] [b :path "../b"]])
      (list {:name 'a :kind :path :path "../a"} {:name 'b :kind :path :path "../b"})))
  (test "nil dependencies parse to nil"
    (assert= (project/project--parse-deps nil) nil))
  (test "a non-vector :dependencies value is rejected"
    (is (string-contains? (try (project/project--parse-deps '(a b)) (catch e e)) "must be a vector")))
  (test "a non-symbol dep name is rejected"
    (is (string-contains? (try (project/project--parse-dep '["parser" :path "../p"]) (catch e e))
          "must be a symbol")))
  (test "an unknown source kind is rejected"
    (is (string-contains? (try (project/project--parse-dep '[parser :svn "../p"]) (catch e e))
          "must be :git or :path")))
  (test "a :git dep without a :ref is rejected"
    (is (string-contains? (try
                            (project/project--parse-dep '[parser :git "https://x.git"])
                            (catch e e))
          "needs a :ref")))
  (test "a reserved opt is rejected so the manifest stays forward-compatible"
    (is (string-contains? (try
                            (project/project--parse-dep '[parser :git
                                                           "https://x.git"
                                                           :ref
                                                           "v1"
                                                           :branch
                                                           "main"])
                            (catch e e))
          "reserved for a future version")))
  (test "an entry that is too short is rejected"
    (is (string-contains? (try (project/project--parse-dep '[parser :path]) (catch e e))
          "too short"))))

;; `:isolated` runs against a rolled-back private copy of the globals (ADR-017),
;; so the *project-* globals this clobbers via `(project ...)` don't leak.
(describe "project: the (project ...) manifest macro treats its args as data"
  :isolated
  (test "bare dep-name symbols survive without quoting; :dependencies populates *project-dependencies*"
    (project :name
      "demo"
      :version
      "0.0.1"
      :dependencies
      [[parser :git "https://example.com/p.git" :ref "v1"] [shared :path "../shared"]])
    (assert= *project-dependencies*
      (list {:name 'parser :kind :git :url "https://example.com/p.git" :ref "v1"}
        {:name 'shared :kind :path :path "../shared"}))))

(describe "project: scaffold templates (ADR-037)"
  (test "the .gitignore template ignores the package cache"
    (is (string-contains? (project/project--gitignore-template) "_deps/")))
  (test "the manifest template documents how to add :dependencies"
    (let (m (project/project--manifest-template "demo"))
      (is (string-contains? m ":dependencies"))
      ;; still a valid manifest: the first form is the (project …) call
      (let (form (read-string m))
        (assert= (first form) 'project)
        (assert= (plist-get (rest form) :name) "demo")))))

(describe "project: namespace-aware duplicate global detection (ADR-065)"
  (test "project/project--file-def-names resolves names to ns/name (ambient earmuffs stay root; defmodule skipped)"
    (let (dir (temp-dir "brood-dup-"))
      (make-dir dir)
      (let (f (path-join dir "a.blsp"))
        (spit f
          "(defmodule a \"x\")\n(defn main () 1)\n(def k 2)\n(defmacro m (x) x)\n(defdyn *d* 0)\n(defn helper (y) y)\n")
        ;; Under `(defmodule a)` every binding resolves to `a/…`, except the
        ;; ambient `*d*` earmuff which stays root (mirrors the kernel resolver).
        (assert= (sort (project/project--file-def-names f))
          (sort ["*d*" "a/helper" "a/k" "a/m" "a/main"])))))
  (test "the same short name in two DIFFERENT namespaces is not a collision"
    (let (dir (temp-dir "brood-dup-"))
      (make-dir dir)
      (let (fa (path-join dir "a.blsp") fb (path-join dir "b.blsp"))
        (spit fa "(defmodule alpha)\n(defn main () 1)\n")
        (spit fb "(defmodule beta)\n(defn main () 2)\n")
        ;; alpha/main vs beta/main — distinct keys, no warning.
        (assert= (project/project--duplicate-def-warnings [fa fb]) nil))))
  (test "the same name in the SAME namespace IS flagged (qualified)"
    (let (dir (temp-dir "brood-dup-"))
      (make-dir dir)
      (let (fa (path-join dir "a.blsp") fb (path-join dir "b.blsp"))
        (spit fa "(defmodule shared)\n(defn main () 1)\n(defn only-a () 1)\n")
        (spit fb "(defmodule shared)\n(defn main () 2)\n(defn only-b () 2)\n")
        (let (warns (project/project--duplicate-def-warnings [fa fb]))
          (assert= (count warns) 1)
          (is (string-contains? (first warns) "shared/main"))
          (refute (string-contains? (first warns) "only-a"))))))
  (test "an ambient *earmuff* name collides across namespaces (it stays root)"
    (let (dir (temp-dir "brood-dup-"))
      (make-dir dir)
      (let (fa (path-join dir "a.blsp") fb (path-join dir "b.blsp"))
        (spit fa "(defmodule alpha)\n(defdyn *cfg* 1)\n")
        (spit fb "(defmodule beta)\n(defdyn *cfg* 2)\n")
        (let (warns (project/project--duplicate-def-warnings [fa fb]))
          (assert= (count warns) 1)
          (is (string-contains? (first warns) "*cfg*"))))))
  (test "files with no defmodule share the root namespace — same name still collides"
    (let (dir (temp-dir "brood-dup-"))
      (make-dir dir)
      (let (fa (path-join dir "a.blsp") fb (path-join dir "b.blsp"))
        (spit fa "(defn main () 1)\n(defn only-a () 1)\n")
        (spit fb "(defn main () 2)\n(defn only-b () 2)\n")
        (let (warns (project/project--duplicate-def-warnings [fa fb]))
          (assert= (count warns) 1)
          (is (string-contains? (first warns) "main"))
          (refute (string-contains? (first warns) "only-a"))))))
  (test "no duplicates yields no warnings"
    (let (dir (temp-dir "brood-dup-"))
      (make-dir dir)
      (let (fa (path-join dir "a.blsp") fb (path-join dir "b.blsp"))
        (spit fa "(defmodule alpha)\n(defn alpha-fn () 1)\n")
        (spit fb "(defmodule beta)\n(defn beta-fn () 2)\n")
        (assert= (project/project--duplicate-def-warnings [fa fb]) nil)))))
