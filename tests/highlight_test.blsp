;; tests/highlight_test.blsp — the lexical highlighter / analysis (std/highlight.blsp).
;;
;; The module is pure (source string -> spans / chunks / positions), so it's fully
;; testable without a terminal — the live `term-*` rendering lives in
;; std/lineedit.blsp and is exercised manually. These cover the lexer's token
;; classification, the bracket matcher (incl. brackets ignored inside strings),
;; the signature scanner's callee + arg-index, and the completion helpers. The
;; closing :isolated block tokenizes inside a spawned process to prove the spans
;; (vectors of face maps) round-trip the copy-on-send heap boundary.

(defmodule highlight-test (:use test) (:use editor/highlight))

;; `highlight-spans` walks the native `scan-tokens` stream; pin that lexer's shape too.
(describe "scan-tokens — the native lexical token stream"
  ;; scan-tokens returns a VECTOR of [start end kind text] (like parse-source).
  (test "tokens carry [start end kind text], whitespace skipped"
    (assert= (scan-tokens "(map 42 :k)")
      [[0 1 :open "("] [1 4 :symbol "map"] [5 7 :number "42"]
       [8 10 :keyword ":k"] [10 11 :close ")"]]))
  (test "strings honour escapes; comments run to end of input"
    (assert= (scan-tokens "\"a\\\"b\" ; c")
      [[0 6 :string "\"a\\\"b\""] [7 10 :comment "; c"]]))
  (test "nil/true/false classify as keyword (constants)"
    (assert= (scan-tokens "nil") [[0 3 :keyword "nil"]]))
  (test "empty source yields no tokens"
    (assert= (scan-tokens "") [])))

(describe "highlight-spans — token classification"
  (test "special form vs call vs number"
    (assert= (highlight-spans "(+ 1)")
      (list [1 2 hl-face-function] [3 4 hl-face-number]))
    (assert= (highlight-spans "(if x)")
      (list [1 3 hl-face-special])))
  (test "strings and comments"
    (assert= (highlight-spans "\"hi\" ; c")
      (list [0 4 hl-face-string] [5 8 hl-face-comment])))
  (test "keywords colour as keywords"
    (assert= (highlight-spans ":foo") (list [0 4 hl-face-keyword])))
  (test "nil / true / false colour as constants, even in head position"
    (assert= (highlight-spans "nil") (list [0 3 hl-face-keyword]))
    (assert= (highlight-spans "(true)") (list [1 5 hl-face-keyword])))
  (test "a plain variable reference carries no span"
    (assert= (highlight-spans "x") '())))

(describe "highlight-window — spans shifted into absolute coordinates"
  (test "base 0 equals highlight-spans"
    (assert= (highlight-window "(+ 1)" 0) (highlight-spans "(+ 1)")))
  (test "every span start/end is shifted by base"
    (assert= (highlight-window "(+ 1)" 10)
      (list [11 12 hl-face-function] [13 14 hl-face-number]))))

(describe "safe-restart — a column-0 form start to lex from"
  (test "backs up to the start of the enclosing top-level form"
    ;; pos 18 sits inside the second form, whose `(` is at offset 11 (after the \n at 10)
    (assert= (safe-restart "(defn a ()\n(defn b ()" 18) 11))
  (test "a column-0 open bracket at pos is itself the restart"
    (assert= (safe-restart "(a)\n(b)" 4) 4))
  (test "no column-0 form start yields 0"
    (assert= (safe-restart "   (indented)" 8) 0)
    (assert= (safe-restart "" 0) 0))
  (test "an indented form falls back to the column-0 form above it"
    (assert= (safe-restart "(let (x 1)\n  (f x))" 15) 0)))

(describe "highlight-chunks — tiling a visible line"
  (test "chunks cover the whole line, coalescing default runs"
    (assert= (highlight-chunks "(+ 1)" 0 "(+ 1)" '())
      (list ["(" nil]
        ["+" hl-face-function]
        [" " nil]
        ["1" hl-face-number]
        [")" nil])))
  (test "an empty line yields no chunks"
    (assert= (highlight-chunks "" 0 "" '()) '())))

(describe "face-at — the span covering an offset"
  (test "a hit inside a span returns its face"
    (assert= (face-at (list [1 2 hl-face-function] [3 4 hl-face-number]) 3) hl-face-number))
  (test "a gap between spans has no face"
    (assert= (face-at (list [1 2 hl-face-function] [3 4 hl-face-number]) 2) nil))
  (test "the end offset is exclusive"
    (assert= (face-at (list [1 4 hl-face-string]) 4) nil)))

(describe "ranges-face — merged overlay faces at an offset"
  (test "no covering range yields nil"
    (assert= (ranges-face (list [0 2 {:reverse true}]) 5) nil))
  (test "overlapping ranges merge, later winning on key conflict"
    (assert= (ranges-face (list [0 5 {:fg :red :bold true}] [0 5 {:fg :blue}]) 2)
      {:fg :blue :bold true})))

(describe "fontify-runs — span + range tiling into runs"
  (test "plain text is one nil-faced run"
    (assert= (fontify-runs "abc" 0 '() '()) (list ["abc" nil])))
  (test "adjacent equal-face chars coalesce into one run"
    (assert= (fontify-runs "abc" 0 (list [0 3 hl-face-string]) '())
      (list ["abc" hl-face-string])))
  (test "a covering range splits a run and merges on top of the span face"
    (assert= (fontify-runs "abc" 0 (list [0 3 {:fg :green}]) (list [1 2 {:reverse true}]))
      (list ["a" {:fg :green}]
        ["b" {:fg :green :reverse true}]
        ["c" {:fg :green}])))
  (test "base offsets span / range lookups into buffer coordinates"
    ;; text "bc" begins at buffer offset 1, so the [1 2 …] span faces only "b"
    (assert= (fontify-runs "bc" 1 (list [1 2 hl-face-number]) '())
      (list ["b" hl-face-number] ["c" nil])))
  (test "empty text yields no runs"
    (assert= (fontify-runs "" 0 '() '()) '())))

;; span-runs is the native no-overlay tiler `fontify-runs` calls when no range crosses
;; the line (the common per-frame case). The fontify-runs cases above exercise it through
;; that path; these pin its contract directly.
(describe "span-runs (native no-overlay tiler)"
  (test "a gap before and after a span are nil-faced runs"
    (assert= (span-runs "a b" 0 (list [2 3 {:fg :green}]))
      (list ["a " nil] ["b" {:fg :green}])))
  (test "touching same-face spans coalesce; a base offsets into buffer coords"
    (assert= (span-runs "abc" 0 (list [0 1 {:fg :red}] [1 2 {:fg :red}]))
      (list ["ab" {:fg :red}] ["c" nil]))
    (assert= (span-runs "bc" 1 (list [1 2 {:fg :yellow}])) (list ["b" {:fg :yellow}] ["c" nil])))
  (test "no spans → one nil run; empty text → no runs"
    (assert= (span-runs "abc" 0 '()) (list ["abc" nil]))
    (assert= (span-runs "" 0 '()) '()))
  ;; `base` is caller-controlled; a huge base must not panic the host (kernel
  ;; audit #3 — `base + text-length` overflowed i64 -> SIGABRT / OOB char slice).
  (test "a base that overflows i64 raises a clean error, never panics the host"
    (assert-error (span-runs "a" 9223372036854775807 '()))
    (assert-error (span-runs "abc" 9223372036854775807 (list [0 1 {:fg :red}]))))
  (test "a large-but-non-overflowing base still tiles correctly"
    (assert= (span-runs "abc" 9223372036854775800
               (list [9223372036854775801 9223372036854775806 {:fg :red}]))
      (list ["a" nil] ["bc" {:fg :red}]))))

(describe "special-form?"
  (test "core forms / macros are special"
    (is (special-form? "defn"))
    (is (special-form? "cond"))
    (is (special-form? "->")))
  (test "ordinary functions are not"
    (refute (special-form? "map"))
    (refute (special-form? "reduce"))))

(describe "bracket-match — the pair adjacent to the cursor"
  (test "matches an opener forward and a closer backward"
    (assert= (bracket-match "(+ 1)" 1) [0 4])
    (assert= (bracket-match "(+ 1)" 5) [0 4]))
  (test "an unclosed opener is unmatched"
    (assert= (bracket-match "(+ 1" 1) [0 :unmatched]))
  (test "no bracket adjacent to the cursor"
    (assert= (bracket-match "abc" 1) nil))
  (test "brackets inside a string are ignored"
    ;; (str ")" 1) — the ) inside the string must not match the leading (
    (assert= (bracket-match "(str \")\" 1)" 1) [0 10])))

(describe "enclosing-call — the call around the cursor"
  (test "callee and arg index"
    (assert= (enclosing-call "(map f " 7) ["map" 1])
    (assert= (enclosing-call "(map f xs" 9) ["map" 1]))
  (test "the innermost call wins"
    (assert= (enclosing-call "(+ (* 2 3) " 11) ["+" 1]))
  (test "outside any call there is no hint"
    (assert= (enclosing-call "abc " 4) nil))
  (test "a call deep below many top-level forms is found (scan starts at the defun, not 0)"
    ;; the enclosing-bracket scan begins at the nearest column-0 form start (safe-restart),
    ;; so cost is O(enclosing form), not O(pos) — but the answer must still be exact.
    (let (lead (join "" (map (fn (i) "(defn f ())\n") (range 500)))
          src (str lead "(map g "))
      (assert= (enclosing-call src (+ (string-length lead) 7)) ["map" 1]))))

(describe "completion helpers"
  (test "symbol-prefix-at returns the token start and text"
    (assert= (symbol-prefix-at "(map fo" 7) [5 "fo"])
    (assert= (symbol-prefix-at "(+ " 3) [3 ""]))
  (test "common-prefix of candidates"
    (assert= (common-prefix ["map" "mapcat" "max"]) "ma")
    (assert= (common-prefix ["reduce"]) "reduce")
    (assert= (common-prefix []) "")))

;; Cross-process: spans (vectors carrying face *maps*) cross a heap boundary via
;; send (a deep copy) before being compared, proving the analysis output survives
;; the copy-on-send round-trip under the scheduler — not just same-heap building.
(describe "highlight-spans across processes"
  :isolated

  (test "spans built in another process round-trip intact"
    (let (w (spawn (receive ([:lex src from] (send from (highlight-spans src))))))
      (send w [:lex "(+ 1)" (self)])
      (assert= (receive (r r))
        (list [1 2 hl-face-function] [3 4 hl-face-number])))))
