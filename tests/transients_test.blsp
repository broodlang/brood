;; Transient map-build spike (docs/transients.md) — adversarial coverage.
;;
;; The kernel now builds maps with an *internal* transient: `map_from_pairs` and
;; `%map-into` (behind `hash-map`, `{}` literals, and the prelude's `into`/`zipmap`)
;; mutate build-local CHAMP nodes in place. The whole point of these tests is to
;; try to OBSERVE that mutation — i.e. to break immutability — and to prove the
;; transient result is byte-identical to the copy-on-write fold it replaces.
;;
;; Each `test` runs in its own green process on the worker pool, so all of this is
;; already exercised concurrently; the :isolated block adds explicit spawn/send and
;; a hot-reload (def-rebinding) scenario on top.

(defmodule transients-test (:use test))

;; ---- file-local helpers (defined once at load) ------------------------------

;; The copy-on-write reference: fold the immutable `assoc` (no transient).
(defn tr-cow (pairs) (reduce (fn (m p) (assoc m (first p) (second p))) {} pairs))

;; `n` `[k v]` pairs. `spread` controls the key modulus, so a small spread forces
;; many duplicate keys (last-wins overwrite path) while a large one fills the trie.
(defn tr-pairs (n spread)
  (map (fn (i) [(rem (* i 2654435761) spread) (* i i)]) (range n)))

;; Build the same map both ways and assert full structural identity, not just
;; entry-set equality: `=` on maps is structural (canonical CHAMP shape), and
;; `map-pairs` order is shape-derived, so equal order proves identical tries.
(defn tr-same? (pairs)
  (let (t (into {} pairs) c (tr-cow pairs))
    (and (= t c)
         (= (count t) (count c))
         (= (map-pairs t) (map-pairs c)))))

(describe "transient build equals copy-on-write build"

  (test "matches CoW across sizes (unique-ish keys: trie fills and branches)"
    (is (tr-same? (tr-pairs 0 1000000)))
    (is (tr-same? (tr-pairs 1 1000000)))
    (is (tr-same? (tr-pairs 50 1000000)))
    (is (tr-same? (tr-pairs 1000 1000000)))
    (is (tr-same? (tr-pairs 5000 1000000))))

  (test "matches CoW with heavy duplicate keys (overwrite path, last-wins)"
    ;; 5000 entries into only 7 / 64 distinct keys — hammers in-place overwrite.
    (is (tr-same? (tr-pairs 5000 7)))
    (is (tr-same? (tr-pairs 5000 64)))
    ;; explicit last-wins: later value for a repeated key must win, both ways.
    (assert= (into {} [[:k 1] [:k 2] [:k 3]]) {:k 3})
    (assert= (into {} [[:k 1] [:k 2] [:k 3]]) (tr-cow [[:k 1] [:k 2] [:k 3]])))

  (test "matches CoW with structural (vector / nested) keys"
    (let (ps (map (fn (i) [[i (rem i 5)] {:i i}]) (range 800)))
      (is (= (into {} ps) (tr-cow ps)))
      (is (= (map-pairs (into {} ps)) (map-pairs (tr-cow ps))))))

  (test "hash-map / {} literal (map_from_pairs transient path) is correct"
    (assert= (hash-map :a 1 :b 2 :c 3) {:a 1 :b 2 :c 3})
    (assert= (hash-map 1 1 2 4 3 9 1 100) {1 100 2 4 3 9})  ;; dup key last-wins
    (assert= (count (into {} (tr-pairs 2000 1000000))) 2000)))

(describe "the transient never leaks — inputs stay immutable"

  (test "into an EXISTING map leaves the original byte-identical"
    (let (base {:a 1 :b 2 :c 3} snap {:a 1 :b 2 :c 3})
      (let (grown (into base (map (fn (i) [i (* i i)]) (range 2000))))
        (assert= base snap)                    ;; original untouched
        (assert= (get grown :a) 1)             ;; carried the base entries
        (assert= (get grown 1999) (* 1999 1999))
        (assert= (count grown) 2003))))

  (test "many derived builds from one held map never disturb it"
    (let (m (into {} (tr-pairs 1500 1000000)) snap (into {} (tr-pairs 1500 1000000)))
      ;; derive a pile of maps from `m`; `m` must equal its snapshot afterwards.
      (let (_ (map (fn (i) (into m [[(- 0 i) i]])) (range 200)))
        (assert= m snap)
        (assert= (count m) 1500))))

  (test "a map FROM-source is read, not consumed"
    (let (src {:x 1 :y 2})
      (assert= (into {} src) {:x 1 :y 2})       ;; into {} from a map = its entries
      (assert= src {:x 1 :y 2}))))               ;; source untouched

;; ---- explicit concurrency + hot reload (own globals copy) -------------------

(defn tr-build-worker (parent n)
  (send parent (into {} (map (fn (i) [i (* i i)]) (range n)))))

;; a shared GLOBAL map, built via the transient path at load, read by many procs.
(def tr-global (into {} (map (fn (i) [i (* i 10)]) (range 100))))

;; each reader DERIVES a fresh map from the shared global (transient build off a
;; not-owned input) and reports a value that must match the untouched global.
(defn tr-deriver (parent i)
  (send parent [:d (get (into tr-global [[:tag i]]) i)]))
(defn tr-spawn-derivers (parent n)
  (when (> n 0) (spawn (tr-deriver parent n)) (tr-spawn-derivers parent (- n 1))))
(defn tr-collect (got total acc)
  (if (= got total) acc (tr-collect (+ got 1) total (receive ([:d v] (+ acc v))))))

(describe "transient build across processes + hot reload"
  :isolated

  (test "a worker builds a map via the transient path; it round-trips unchanged"
    (let (me (self) w (spawn (tr-build-worker me 1000)))
      (let (got (receive))
        (assert= (count got) 1000)
        (assert= (get got 0) 0)
        (assert= (get got 999) (* 999 999))
        ;; deep-copied across heaps AND equal to the CoW reference
        (assert= got (tr-cow (map (fn (i) [i (* i i)]) (range 1000)))))))

  (test "50 processes derive from a shared GLOBAL map; the global is untouched"
    ;; each deriver returns (get derived i) == (get tr-global i) == i*10.
    ;; Σ 10i for i in 1..50 = 10 * 1275 = 12750.
    (tr-spawn-derivers (self) 50)
    (assert= (tr-collect 0 50 0) 12750)
    (assert= (count tr-global) 100)             ;; no deriver mutated the shared global
    (assert= (get tr-global 50) 500))

  (test "redefining the builder mid-stream leaves shared maps intact (hot reload)"
    ;; `def` rebinds a global (the only mutation in the language, ADR-013); a
    ;; transient build reading a shared/promoted map across that rebinding must
    ;; never corrupt it. v1 keys by i; v2 (late-bound) keys by i+1000.
    (let (snapshot tr-global)
      (def tr-make (fn (n) (into tr-global (map (fn (i) [i i]) (range n)))))
      (let (r1 (tr-make 60))
        (def tr-make (fn (n) (into tr-global (map (fn (i) [(+ i 1000) i]) (range n)))))
        (let (r2 (tr-make 60))
          (assert= tr-global snapshot)          ;; shared global identical after both builds + redef
          (assert= (get r1 10) 10)              ;; v1 overwrote the global's key 10 (was 100)
          (assert= (get r1 80) 800)             ;; v1 left key 80 (>=60) — carried from the global
          (assert= (get r2 1010) 10)            ;; v2 result (new key scheme, late-bound)
          (assert= (get r2 50) 500))))))         ;; v2's keys are 1000+, so global's key 50 survives

;; ===========================================================================
;; The EXPOSED transient surface: (transient m) / (assoc! t k v) /
;; (dissoc! t k) / (persistent! t), plus transient? and live get/count/
;; contains?. The build above tested the kernel's *internal* transient
;; (map_from_pairs). These tests drive the user-facing identity-mutable handle
;; across multiple ops — which means a GC safepoint can fire BETWEEN ops, the
;; hazard the epoch guard defends against.
;; ===========================================================================

;; Build {0->0 … (n-1)->(n-1)} persistently (immutable assoc fold).
(defn ts-persistent (n) (fold (fn (m i) (assoc m i i)) {} (range n)))
;; Build the same map with the transient surface API. The recursion makes
;; `assoc!` the per-step op, so under BROOD_GC_STRESS=1 a collection fires
;; between every call — relocating the maps slab the watermark indexes.
(defn ts-fill! (t i n) (if (>= i n) t (ts-fill! (assoc! t i i) (+ i 1) n)))
(defn ts-transient (n) (persistent! (ts-fill! (transient {}) 0 n)))

(describe "transient surface API: basics"
  (test "transient? / type-of / not a map"
    (is (transient? (transient {})))
    (refute (transient? {}))
    (refute (transient? 1))
    (assert= (type-of (transient {})) :transient)
    (refute (map? (transient {})))
    (is (map? (persistent! (transient {})))))
  (test "assoc! then persistent! yields the canonical map"
    (assert= (persistent! (assoc! (assoc! (transient {}) :a 1) :b 2)) {:a 1 :b 2}))
  (test "assoc! is identity-mutable — returns the same handle"
    (let (t (transient {})) (is (= t (assoc! t :a 1)))))
  (test "dissoc! removes in place"
    (assert= (persistent! (dissoc! (assoc! (assoc! (transient {}) :a 1) :b 2) :a)) {:b 2}))
  (test "seeding from an existing map leaves the original untouched"
    (let (m {:a 1} t (transient m))
      (assoc! t :b 2)
      (assert= (persistent! t) {:a 1 :b 2})
      (assert= m {:a 1}))))

(describe "transient surface API: live lookups (Clojure-style)"
  (test "get / count / contains? read a live transient"
    (let (t (assoc! (assoc! (transient {}) :a 1) :b 2))
      (assert= (get t :a) 1)
      (assert= (get t :missing :dflt) :dflt)
      (assert= (count t) 2)
      (is (contains? t :a))
      (refute (contains? t :missing)))))

(describe "transient surface API: use-after-persistent! errors"
  (test "assoc! / dissoc! / persistent! after persistent! all error"
    (let (t (transient {}))
      (persistent! t)
      (assert-error (assoc! t :a 1))
      (assert-error (dissoc! t :a))
      (assert-error (persistent! t)))))

(describe "transient surface API: GC safety (watermark survives relocation)"
  ;; The crux: under BROOD_GC_STRESS=1 a collect fires between every `assoc!`,
  ;; moving the maps slab; the epoch guard re-anchors the watermark each time.
  ;; A 2000-entry build must still equal the persistent fold, no flush_oob/poison.
  (test "a 2000-entry transient build equals the persistent fold"
    (assert= (ts-transient 2000) (ts-persistent 2000)))
  (test "transient builds equal persistent maps at several sizes"
    (is (= (ts-transient 0) (ts-persistent 0)))
    (is (= (ts-transient 1) (ts-persistent 1)))
    (is (= (ts-transient 64) (ts-persistent 64)))
    (is (= (ts-transient 257) (ts-persistent 257)))
    (is (= (ts-transient 1000) (ts-persistent 1000))))
  (test "count matches after a stress build"
    (assert= (count (ts-transient 500)) 500)))
