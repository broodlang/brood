;; std/sexp — structural (s-expression) navigation over Brood's parse-source CST.
;; Reusable Brood-code tooling (the editor's brood-mode binds these, but they're not
;; editor-specific). Register-only — run by `nest test` (and cargo test, via suite.rs).

(defmodule sexp-test (:use test) (:use sexp) (:use editor/buffer))
(require 'sexp)
(require 'editor/buffer)

;; (defn f (x)\n  (+ x 1))   — outer list [0,22); 'defn' [1,5); 'f' [6,7);
;; (x) [8,11); inner (+ x 1) [14,21).
(def src "(defn f (x)\n  (+ x 1))")

(describe "sexp navigation (pure, over the parse-source CST)"
  (test "forward over the whole top form, and over inner atoms"
    (assert= (point-forward src 0) 22)  ; before outer → end of the whole form
    (assert= (point-forward src 1) 5)  ; → end of 'defn'
    (assert= (point-forward src 5) 7))  ; from the space → end of 'f'
  (test "backward"
    (assert= (point-backward src 22) 0)  ; before close → start of the top form
    (assert= (point-backward src 5) 1))  ; end of 'defn' → its start
  (test "down-list enters, up-list leaves"
    (assert= (point-down src 0) 1)  ; just inside the outer list
    (assert= (point-up src 15) 14)  ; inside (+ x 1) → its open paren
    (assert= (point-up src 1) 0)  ; inside outer → its open paren
    (assert= (point-up src 0) 0))  ; at top level → unchanged
  (test "beginning-of-defun finds the enclosing top-level form"
    (assert= (point-defun-start src 15) 0)
    (assert= (point-defun-start src 8) 0))
  (test "positions account for delimiters & reader-macro prefixes"
    ;; "'(a) [b]"  → quoted list [0,4), vector [5,8)
    (assert= (point-forward "'(a) [b]" 0) 4)
    (assert= (point-forward "'(a) [b]" 4) 8)))

;; Structural motion narrows to the forms around point (`sexp/narrow`) so it's
;; O(neighbouring forms), not O(buffer). These pin that the narrowed answer equals the
;; whole-buffer one, including deep in a file with many preceding top-level forms (where
;; the un-narrowed walk is what made `forward-sexp` stall for a second).
(describe "sexp navigation narrows without changing the answer"
  ;; brute-force references: the same queries over the WHOLE-buffer CST, un-narrowed.
  (defn bf-enc (text point) (enclosing (tree text) point))
  (defn bf-forward (text point)
    (let (nxt (first (filter (fn (f) (>= (get f :start) point)) (forms-of (bf-enc text point)))))
      (if (nil? nxt) point (get nxt :end))))
  (defn bf-backward (text point)
    (let (prev (last (filter (fn (f) (<= (get f :end) point)) (forms-of (bf-enc text point)))))
      (if (nil? prev) point (get prev :start))))
  (def many (str (join "" (map (fn (i) (str "(defn f" i " () " i ")\n")) (range 300)))
                 "(map g (h x))"))
  (def n (string-length many))
  (test "narrowed motion matches the whole-buffer walk at many points (incl. deep + boundaries)"
    (doseq (p [0 1 25 (- n 13) (- n 12) (- n 7) (- n 6) (- n 1)])
      (assert= (point-forward many p) (bf-forward many p))
      (assert= (point-backward many p) (bf-backward many p))))
  (test "narrow genuinely slices (base ≤ point, slice shorter than the whole text)"
    (let ([base sub] (narrow many (- n 6)))
      (is (<= base (- n 6)))
      (is (> (string-length sub) 0))
      (is (< (string-length sub) n)))))

(describe "sexp buffer commands"
  (test "forward moves point to the end of the next sexp"
    (assert= (get (forward (make-buffer "(+ 1 2)") nil) :point) 7))
  (test "down enters the next list, up leaves it"
    (let (b (down (make-buffer "(a b)") nil))
      (assert= (get b :point) 1)
      (assert= (get (up b nil) :point) 0))))

;; `tree` is the kernel's `parse-source-positioned` — the position-annotated CST the
;; navigation runs over. These pin the node shape the queries above depend on.
(describe "parse-source-positioned (the kernel CST behind sexp/tree)"
  (test "the root is a positioned container node spanning the whole text"
    (let (r (tree "(a b)"))
      (assert= (get r :kind) :root)
      (assert= (get r :start) 0)
      (assert= (get r :end) 5)
      (assert= (count (get r :kids)) 1)))   ; one top-level form, no trivia
  (test "a leaf carries its raw :text and half-open positions"
    (let (lst (first (forms-of (tree "(ab cd)")))
          ab (first (forms-of lst)))
      (assert= (get ab :kind) :symbol)
      (assert= (get ab :text) "ab")
      (assert= (get ab :start) 1)
      (assert= (get ab :end) 3)))
  (test "positions are CHARACTER offsets, not bytes (multibyte leading content)"
    ;; "é" is two UTF-8 bytes but one character; the symbol after it starts at char 2.
    (let (x (first (forms-of (tree "é x"))))
      (assert= (get x :start) 0))           ; the "é" symbol at char 0
    (let (forms (forms-of (tree "é x"))
          x (first (rest forms)))
      (assert= (get x :start) 2)             ; "x" at char 2 (byte 3) — char offset
      (assert= (get x :end) 3))))

;; The paredit family: pure structural edits returning [new-text new-point], nil when
;; the op doesn't apply. Slurp/barf are inverses; raise/splice collapse a level.
(describe "sexp structural edits (paredit, pure over the CST)"
  (test "slurp-forward pulls the next sibling in; barf-forward expels the last"
    (assert= (point-slurp-forward "(foo) bar" 2) ["(foo bar)" 2])
    (assert= (point-barf-forward "(foo bar)" 2) ["(foo) bar" 2]))
  (test "slurp-backward pulls the previous sibling in; barf-backward expels the first"
    (assert= (point-slurp-backward "foo (bar)" 6) ["(foo bar)" 6])
    (assert= (point-barf-backward "(foo bar)" 6) ["foo (bar)" 6]))
  (test "raise replaces the enclosing list with the child at point"
    (assert= (point-raise "(a (b c) d)" 6) ["(a c d)" 3]))   ; point on c
  (test "splice drops the enclosing delimiters, keeping the contents"
    (assert= (point-splice "(a (b) c)" 4) ["(a b c)" 3]))
  (test "wrap-round wraps the form at point, point landing just inside"
    (assert= (point-wrap-round "foo bar" 0) ["(foo) bar" 1]))
  (test "ops return nil when inapplicable (no sibling, top level)"
    (assert= (point-slurp-forward "(foo)" 2) nil)   ; nothing after to slurp
    (assert= (point-splice "foo" 1) nil))           ; not inside any list
  (test "point-kill-end caps at the enclosing close, never breaking parens"
    (assert= (point-kill-end "(foo bar)" 1) 8)      ; kill foo bar, keep the )
    (assert= (point-kill-end "(foo\n bar)" 1) 4)))  ; multi-line → only to end of line
