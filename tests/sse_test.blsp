;; std/sse.blsp — a Server-Sent Events client. The wire grammar is parsed by pure
;; functions (unit-tested directly); `with-events` (std/ui.blsp) merges pushed events
;; into a ui-run loop; and one end-to-end test streams frames from a loopback server.

(defmodule sse-test (:use test) (:use net/sse) (:use editor/ui))

(describe "sse — pure event-field parsing"
  (test "parses event / data / id, stripping one space after the colon"
    (let (ev (net/sse/sse--parse-event "event: run_started\ndata: {\"id\":42}\nid: 7"))
      (assert= (get ev :event) "run_started")
      (assert= (get ev :data) "{\"id\":42}")
      (assert= (get ev :id) "7")))
  (test "multiple data lines join with a newline"
    (assert= (get (net/sse/sse--parse-event "data: a\ndata: b\ndata: c") :data) "a\nb\nc"))
  (test "missing type defaults to \"message\"; missing data to \"\""
    (assert= (get (net/sse/sse--parse-event "data: x") :event) "message")
    (assert= (get (net/sse/sse--parse-event "event: ping") :data) ""))
  (test "comment lines (:-prefixed) are ignored"
    (assert= (get (net/sse/sse--parse-event ": keep-alive\ndata: y") :data) "y"))
  (test "a value with no leading space is kept verbatim"
    (assert= (get (net/sse/sse--parse-event "data:tight") :data) "tight")))

(describe "sse — frame splitting + line endings"
  (test "frames splits complete blocks from a trailing remainder"
    (let ([blocks rest] (net/sse/sse--frames "x: 1\n\ny: 2\n\nrest"))
      (assert= blocks (list "x: 1" "y: 2"))
      (assert= rest "rest")))
  (test "no complete frame yet → no blocks, all remainder"
    (let ([blocks rest] (net/sse/sse--frames "partial data"))
      (assert= blocks '())
      (assert= rest "partial data")))
  (test "normalise turns \\r\\n and \\r into \\n"
    (assert= (net/sse/sse--normalize "a\r\nb\rc\nd") "a\nb\nc\nd"))
  (test "status reads the numeric code from a response head"
    (assert= (net/sse/sse--status "HTTP/1.1 200 OK\nContent-Type: text/event-stream") 200)
    (assert= (net/sse/sse--status "HTTP/1.1 404 Not Found") 404)))

(describe "sse — server-side frame building"
  (test "a single-line payload becomes one data: line + the blank line"
    (assert= (net/sse/sse-frame "hello") "data: hello\n\n"))
  (test "a multi-line payload prefixes every line with data:"
    (assert= (net/sse/sse-frame "a\nb\nc") "data: a\ndata: b\ndata: c\n\n"))
  (test "an event type adds the leading event: line"
    (assert= (net/sse/sse-frame "x" "tick") "event: tick\ndata: x\n\n"))
  (test "sse-headers declares text/event-stream and disables caching"
    (let (h (net/sse/sse-headers))
      (assert= (get h "Content-Type") "text/event-stream")
      (assert= (get h "Cache-Control") "no-cache")))
  (test "sse-frame is the inverse of sse--parse-event (round-trip)"
    (let ([blocks _] (net/sse/sse--frames (net/sse/sse-frame "a\nb" "tick"))
          ev (net/sse/sse--parse-event (first blocks)))
      (assert= (get ev :event) "tick")
      (assert= (get ev :data) "a\nb"))))

(describe "with-events — merges [:sse …] into ui-run input"
  (test "a queued sse message is returned by :poll before the underlying display"
    (let (fake {:poll (fn (ms) :keyboard) :size (fn () [80 24])}
          wrapped (with-events fake))
      ;; empty mailbox → delegate to the wrapped display's poll
      (assert= ((get wrapped :poll) 0) :keyboard)
      ;; a queued [:sse …] comes out first
      (send (self) [:sse {:event "x" :data "1"}])
      (assert= ((get wrapped :poll) 0) [:sse {:event "x" :data "1"}])
      ;; …and [:sse-closed …] too
      (send (self) [:sse-closed :closed])
      (assert= ((get wrapped :poll) 0) [:sse-closed :closed])
      ;; mailbox drained → back to delegating
      (assert= ((get wrapped :poll) 0) :keyboard)))
  (test "non-poll ops pass through unchanged"
    (let (wrapped (with-events {:poll (fn (ms) nil) :size (fn () [120 40])}))
      (assert= ((get wrapped :size)) [120 40]))))

(describe "sse — end-to-end over a loopback event-stream server"
  (test "connect yields :sse-open, the pushed events, then :sse-closed"
    (let (me (self))
      ;; a tiny server: accept, read the request, stream the head + two frames, close.
      (spawn (do
               (let (ls (tcp-listen "127.0.0.1" 0))
                 (send me [:port (tcp-local-port ls)])
                 (receive ([:tcp-accept ~ls c] (do
                                                 (tcp-controlling-process c (self))
                                                 (receive ([:tcp ~c _] (do
                                                                         (tcp-send c
                                                                           "HTTP/1.1 200 OK\r\nContent-Type: text/event-stream\r\n\r\n")
                                                                         (tcp-send c
                                                                           "event: hello\r\ndata: world\r\n\r\n")
                                                                         (tcp-send c
                                                                           "data: {\"n\":1}\r\n\r\n")
                                                                         (tcp-close c)))
                                                   (after 5000 nil))))
                   (after 5000 nil)))))
      (let (port (receive ([:port p] p) (after 5000 :timeout)))
        (sse-connect (str "http://127.0.0.1:" port "/events") me)
        (let (open (receive ([:sse-open s] s) (after 5000 :timeout))
              e1 (receive ([:sse e] e) (after 5000 :timeout))
              e2 (receive ([:sse e] e) (after 5000 :timeout))
              closed (receive ([:sse-closed r] r) (after 5000 :timeout)))
          (assert= open 200)
          (assert= (get e1 :event) "hello")
          (assert= (get e1 :data) "world")
          (assert= (get e2 :event) "message")
          (assert= (get e2 :data) "{\"n\":1}")
          (is (not (= closed :timeout))))))))
