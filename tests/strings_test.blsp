;; The string library: kernel primitives `upper`/`lower`/`string->number` (Rust)
;; plus the Brood layer over `substring`/`str` (char-at, string->list, index-of,
;; join, string-split, replace, trim, …). Register-only — discovered and run by
;; `nest test` (and cargo test, via crates/lisp/tests/suite.rs).

(require 'test)

(describe "case folding"
  (test "upper / lower"
    (assert= (upper "Hello, World!") "HELLO, WORLD!")
    (assert= (lower "Hello, World!") "hello, world!"))
  (test "idempotent on already-cased / non-alpha"
    (assert= (upper "ABC 123") "ABC 123")
    (assert= (lower "abc 123") "abc 123"))
  (test "Unicode-aware" (assert= (upper "ß") "SS") (assert= (upper "naïve") "NAÏVE")))

(describe "string <-> number"
  (test "integers parse to ints"
    (assert= (string->number "42") 42)
    (assert= (string->number "-7") -7))
  (test "floats parse to floats"
    (assert= (string->number "3.5") 3.5)
    (assert= (string->number "-0.25") -0.25))
  (test "non-numbers and partial matches are nil"
    (assert= (string->number "x") nil)
    (assert= (string->number "3abc") nil)
    (assert= (string->number "") nil)
    (assert= (string->number " 5") nil))
  (test "number->string is the inverse"
    (assert= (number->string 42) "42")
    (assert= (number->string 3.5) "3.5")
    (assert= (string->number (number->string 99)) 99)))

(describe "characters & lists"
  (test "char-at is char-indexed"
    (assert= (char-at "hello" 0) "h")
    (assert= (char-at "hello" 4) "o"))
  (test "string->list yields 1-char strings"
    (assert= (string->list "abc") (list "a" "b" "c"))
    (assert= (string->list "") nil))
  (test "list->string reassembles"
    (assert= (list->string (list "a" "b" "c")) "abc")
    (assert= (list->string (string->list "round-trip")) "round-trip")))

(describe "escapes"
  ;; Beyond the named `\e` / `\n` / `\t` / `\r` / `\0` / `\\` / `\"`, Brood
  ;; strings also support `\xHH` (two-hex-digit byte) and `\u{H..H}` (Unicode
  ;; codepoint). `\e` and `\x1b` and `\u{1b}` all produce ESC.
  (test "\\xHH decodes a two-hex-digit byte"
    (assert= "\x1b" "\e")
    (assert= "\x41" "A"))
  (test "\\u{H..H} decodes a Unicode codepoint"
    (assert= "\u{1b}" "\e")
    (assert= "\u{41}" "A")
    ;; 😀 is U+1F600; the literal char round-trips through the string too.
    (assert= "\u{1F600}" "😀"))
  (test "malformed escapes pass through as literal chars"
    (assert= "\xZZ" "xZZ")
    (assert= "\u{}" "u{}")
    (assert= "\u{nothex}" "u{nothex}")))

(describe "search"
  (test "index-of finds the first occurrence"
    (assert= (index-of "hello world" "o") 4)
    (assert= (index-of "hello world" "world") 6))
  (test "index-of is -1 when absent" (assert= (index-of "hello" "z") -1))
  (test "the empty needle is found at 0" (assert= (index-of "hello" "") 0))
  (test "string-contains?"
    (is (string-contains? "hello" "ell"))
    (refute (string-contains? "hello" "xyz")))
  ;; index-of also works on lists and vectors (linear scan; structural `=`).
  (test "index-of on a list/vector finds the element index"
    (assert= (index-of (list 10 20 30) 20) 1)
    (assert= (index-of [10 20 30] 30) 2)
    (assert= (index-of (list :a :b :c) :b) 1))
  (test "index-of is -1 for a missing element on lists/vectors"
    (assert= (index-of (list 1 2 3) 99) -1)
    (assert= (index-of [] :anything) -1))
  ;; includes? wraps the common membership test for any collection.
  (test "includes? works on lists, vectors, strings, and maps"
    (is (includes? (list 1 2 3) 2))
    (refute (includes? (list 1 2 3) 9))
    (is (includes? [10 20] 20))
    (is (includes? "hello" "ell"))
    (is (includes? {:a 1 :b 2} 2))
    (refute (includes? {:a 1} 99))))

(describe "join"
  (test "places the separator between elements" (assert= (join ", " (list "a" "b" "c")) "a, b, c"))
  (test "single element has no separator" (assert= (join ", " (list "solo")) "solo"))
  (test "empty collection is the empty string" (assert= (join ", " nil) "")))

(describe "split"
  (test "splits on each occurrence" (assert= (string-split "a,b,c" ",") (list "a" "b" "c")))
  (test "keeps empty fields" (assert= (string-split "a,,b" ",") (list "a" "" "b")))
  (test "no separator present yields the whole string"
    (assert= (string-split "abc" ",") (list "abc")))
  (test "multi-char separator" (assert= (string-split "a::b::c" "::") (list "a" "b" "c")))
  (test "empty separator splits into characters"
    (assert= (string-split "abc" "") (list "a" "b" "c")))
  (test "split then join round-trips" (assert= (join "," (string-split "x,y,z" ",")) "x,y,z")))

(describe "replace"
  (test "replaces every occurrence" (assert= (replace "a-b-c" "-" "+") "a+b+c"))
  (test "multi-char old / new"
    (assert= (replace "one fish two fish" "fish" "cat") "one cat two cat"))
  (test "absent pattern is unchanged" (assert= (replace "hello" "z" "!") "hello"))
  (test "empty old leaves the string unchanged" (assert= (replace "hello" "" "!") "hello")))

(describe "whitespace"
  (test "blank?" (is (blank? "")) (is (blank? "   ")) (is (blank? "\t\n ")) (refute (blank? " x ")))
  (test "trim removes both ends"
    (assert= (trim "  hi there  ") "hi there")
    (assert= (trim "\n\thi\n") "hi")
    (assert= (trim "no-padding") "no-padding"))
  (test "triml / trimr remove one end"
    (assert= (triml "  hi  ") "hi  ")
    (assert= (trimr "  hi  ") "  hi"))
  (test "all-whitespace trims to empty" (assert= (trim "    ") "")))

(describe "padding & repetition"
  (test "string-repeat concatenates n copies"
    (assert= (string-repeat "=" 5) "=====")
    (assert= (string-repeat "ab" 3) "ababab"))
  (test "string-repeat with n <= 0 is empty"
    (assert= (string-repeat "x" 0) "")
    (assert= (string-repeat "x" -2) ""))
  (test "pad-left right-justifies with spaces"
    (assert= (pad-left "42" 6) "    42")
    (assert= (pad-left "" 3) "   "))
  (test "pad-right left-justifies with spaces"
    (assert= (pad-right "hi" 6) "hi    ")
    (assert= (pad-right "" 3) "   "))
  (test "pad-* never truncate an over-wide string"
    (assert= (pad-left "toolong" 3) "toolong")
    (assert= (pad-right "toolong" 3) "toolong"))
  (test "pad-* are exact-width at the boundary"
    (assert= (string-length (pad-left "ab" 2)) 2)
    (assert= (string-length (pad-right "ab" 5)) 5)))

(describe "to-fixed (fixed-decimal rendering)"
  (test "renders exactly n decimal places"
    (assert= (to-fixed 3.14159 2) "3.14")
    (assert= (to-fixed 0.015873015873 4) "0.0159"))
  (test "pads short fractions with trailing zeros"
    (assert= (to-fixed 1.5 3) "1.500")
    (assert= (to-fixed 2 2) "2.00"))
  (test "n = 0 gives an integer-looking string (no point)"
    (assert= (to-fixed 3.7 0) "4")
    (assert= (to-fixed 3.2 0) "3"))
  (test "rejects a negative decimal count" (assert-error (to-fixed 1.0 -1)))
  (test "lines up in a fixed-width column via pad-left"
    (assert= (pad-left (to-fixed 1.5 2) 7) "   1.50")))

(describe "format (printf-style)"
  (test "a format string with no specifiers is returned unchanged"
    (assert= (format "") "")
    (assert= (format "hello, world") "hello, world"))
  (test "%% renders a literal %"
    (assert= (format "100%%") "100%")
    (assert= (format "%%done") "%done"))
  (test "%s renders any value via str"
    (assert= (format "got: %s" "x") "got: x")
    (assert= (format "got: %s" 42) "got: 42")
    (assert= (format "got: %s" :foo) "got: :foo")
    (assert= (format "got: %s" nil) "got: nil")
    (assert= (format "got: %s" [1 2 3]) "got: [1 2 3]"))
  (test "%d renders a number"
    (assert= (format "n=%d" 42) "n=42")
    (assert= (format "n=%d" -7) "n=-7"))
  (test "%f renders a float with 6 fractional digits (C default)"
    (assert= (format "pi=%f" 3.141592653589793) "pi=3.141593"))
  (test "%.Nf renders a float with N fractional digits"
    (assert= (format "pi=%.2f" 3.14159) "pi=3.14")
    (assert= (format "%.0f" 3.7) "4")
    (assert= (format "%.4f" 0.015873015873) "0.0159"))
  (test "mixed specifiers consume args left-to-right"
    (assert= (format "x = %d, y = %.2f" 42 3.14159) "x = 42, y = 3.14")
    (assert= (format "%s/%s" "a" "b") "a/b"))
  (test "extra args are ignored; missing args render as nil"
    (assert= (format "one") "one")
    (assert= (format "%s" "a" "b" "c") "a")
    (assert= (format "%s %s" "a") "a nil"))
  (test "rejects an unknown specifier or a truncated one"
    (assert-error (format "what is %q" 1))
    (assert-error (format "ends in %"))
    (assert-error (format "ends in %.2"))
    (assert-error (format "%.xf" 1.0))))

;; ---- across processes -------------------------------------------------------
;; Each worker builds a padded string from data and sends it back (deep copy
;; across per-process heaps); the parent fans in and checks the strings survived
;; the round-trip intact. :isolated so it doesn't contend for the runner's
;; mailbox with the parallel suite.
(defn str-pad-worker (parent i) (send parent [:p i (pad-left (number->string i) 4)]))
(defn str-spawn-padders (parent n)
  (when (> n 0) (spawn (str-pad-worker parent n)) (str-spawn-padders parent (- n 1))))
(defn str-collect (got total acc)
  (if (= got total) acc (str-collect (+ got 1) total (receive ([:p i s] (assoc acc i s))))))

(describe "string formatting across processes"
  :isolated
  (test "padded strings round-trip through 20 workers unchanged"
    (str-spawn-padders (self) 20)
    (let (merged (str-collect 0 20 {}))
      (assert= (count merged) 20)
      (assert= (get merged 1) "   1")
      (assert= (get merged 20) "  20")))
  (test "string-repeat result survives a send"
    (let (me (self))
      (spawn (send me (string-repeat "-" 8)))
      (assert= (receive) "--------"))))
