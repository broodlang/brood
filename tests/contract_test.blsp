;; Runtime type contracts — `(sig! …)` (docs/type-annotations.md).
;;
;; `(sig …)` informs the advisory checker only; `(sig! …)` *also* installs a
;; runtime contract (the opt-in "strong arrow"): every argument and the result
;; are checked at call time and a mismatch throws. This is the *sound* half — a
;; value the static checker trusted can never silently slip through. Place a
;; `sig!` after the function's definition (it rebinds the name, preserving arity).
(defmodule contract-test
  (:use test))

(defn c-add (a b) (+ a b))
(sig! c-add (int int -> int))

;; A function that lies about its return type — the body returns a string.
(defn c-bad-ret (x) "not an int")
(sig! c-bad-ret (int -> int))

(defn c-id (x) x)
(sig! c-id ((or int nil) -> (or int nil)))

(describe "runtime contracts (sig!)"
  (test "a correct call passes through unchanged"
    (assert= (c-add 2 3) 5))
  (test "a bad first argument throws"
    (assert-error (c-add "x" 3)))
  (test "a bad second argument throws too"
    (assert-error (c-add 1 :k)))
  (test "a bad *result* throws — the fn can't lie about its return type"
    (assert-error (c-bad-ret 1)))
  (test "a union type accepts either member"
    (assert= (c-id 7) 7)
    (assert= (c-id nil) nil))
  (test "a union type still rejects a non-member"
    (assert-error (c-id "s"))))

;; --- element-level (list E) / (vector E) checks --------------------------------

(defn c-sum-list (xs) (reduce + 0 xs))
(sig! c-sum-list ((list int) -> int))

(defn c-first-vec (v) (first v))
(sig! c-first-vec ((vector string) -> string))

(describe "element-level sequence type checks"
  (test "(list int) accepts a list of ints"
    (assert= (c-sum-list (list 1 2 3)) 6))
  (test "(list int) rejects a list containing a non-int"
    (assert-error (c-sum-list (list 1 "two" 3))))
  (test "(list int) accepts an empty list"
    (assert= (c-sum-list nil) 0))
  (test "(vector string) accepts a vector of strings"
    (assert= (c-first-vec ["a" "b"]) "a"))
  (test "(vector string) rejects a vector containing a non-string"
    (assert-error (c-first-vec [1 "b"]))))

;; --- rest params in sig! -------------------------------------------------------

(defn c-sum (& xs) (reduce + 0 xs))
(sig! c-sum (& int -> int))

(defn c-join-strs (sep & parts) (join sep parts))
(sig! c-join-strs (string & string -> string))

(describe "rest param contracts (sig! with &)"
  (test "pure variadic: correct rest args pass"
    (assert= (c-sum 1 2 3 4) 10))
  (test "pure variadic: a non-int rest arg throws"
    (assert-error (c-sum 1 2 "oops")))
  (test "pure variadic: zero rest args pass"
    (assert= (c-sum) 0))
  (test "fixed + rest: correct args pass"
    (assert= (c-join-strs ", " "a" "b" "c") "a, b, c"))
  (test "fixed + rest: bad fixed arg throws"
    (assert-error (c-join-strs 42 "a" "b")))
  (test "fixed + rest: bad rest arg throws"
    (assert-error (c-join-strs ", " "a" 99 "c"))))

;; --- intersection types (and A B …) --------------------------------------------

(defn c-head (xs) (first xs))
(sig! c-head ((and pair (list int)) -> int))

(defn c-never (x) x)
(sig! c-never ((and int string) -> int))  ; NEVER — nothing satisfies both

(describe "intersection type checks (and)"
  (test "(and pair (list int)) accepts a non-empty list of ints"
    (assert= (c-head (list 1 2 3)) 1))
  (test "(and pair (list int)) rejects nil (not pair?)"
    (assert-error (c-head nil)))
  (test "(and pair (list int)) rejects a list with a non-int element"
    (assert-error (c-head (list "a" "b"))))
  (test "(and int string) is NEVER — even an int is rejected"
    (assert-error (c-never 1)))
  (test "(and int string) is NEVER — even a string is rejected"
    (assert-error (c-never "a"))))

;; --- map key/value types (map K V) ---------------------------------------------

(defn c-lookup (m k) (get m k 0))
(sig! c-lookup ((map keyword int) keyword -> int))

(describe "map key/value type checks (map K V)"
  (test "(map keyword int) accepts a keyword-int map"
    (assert= (c-lookup {:a 1 :b 2} :a) 1))
  (test "(map keyword int) rejects a map with a string key"
    (assert-error (c-lookup {"a" 1} :a)))
  (test "(map keyword int) rejects a map with a non-int value"
    (assert-error (c-lookup {:a "one"} :a)))
  (test "(map keyword int) rejects a non-map argument"
    (assert-error (c-lookup (list 1 2) :a)))
  (test "(map keyword int) accepts an empty map"
    (assert= (c-lookup {} :x) 0)))

;; --- type variables (?A) --------------------------------------------------------
;; Type variables are static-only constraints — `?A` is unknown to `type-matches?`
;; so it accepts any value (correct: the static checker handles the precision).
;; The sig! wrapper still enforces the non-variable parts (base types, shape).

(defn c-identity (x) x)
(sig! c-identity (?A -> ?A))

(defn c-my-first (xs) (first xs))
(sig! c-my-first ((list ?A) -> ?A))

(defn c-const (x y) x)
(sig! c-const (?A ?B -> ?A))

(describe "type variable annotations (?A)"
  (test "identity with ?A accepts an int"
    (assert= (c-identity 42) 42))
  (test "identity with ?A accepts a string"
    (assert= (c-identity "hi") "hi"))
  (test "identity with ?A accepts nil"
    (assert= (c-identity nil) nil))
  (test "(list ?A) accepts a list of ints"
    (assert= (c-my-first (list 1 2 3)) 1))
  (test "(list ?A) accepts a list of strings"
    (assert= (c-my-first (list "a" "b")) "a"))
  (test "(list ?A) still rejects a non-list"
    (assert-error (c-my-first 42)))
  (test "two vars ?A and ?B independently accept any types"
    (assert= (c-const 1 "two") 1)))
