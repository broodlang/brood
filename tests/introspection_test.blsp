;; Introspection primitives for editor tooling (ADR-025; docs/lsp.md):
;; doc, arglist, global-names, bound?. Register-only — discovered and run by
;; `brood test` (and cargo test, via crates/lisp/tests/suite.rs).

(defmodule introspection-test (:use test))

(describe "docstrings"
  (test "a leading string is a docstring when more body follows"
    (defn squared (x) "Return x times itself." (* x x))
    (assert= (doc squared) "Return x times itself.")
    ;; …and it is stripped from the body, not evaluated/returned.
    (assert= (squared 4) 16))
  (test "a lone string body is the return value, not a docstring"
    (defn greeting (who) "hello")
    (assert= (doc greeting) nil)
    (assert= (greeting 'x) "hello"))
  (test "macros carry docstrings too"
    (defmacro inc! (x) "Add one." `(+ ~x 1))
    (assert= (doc inc!) "Add one."))
  (test "a function with a destructured parameter keeps its docstring"
    (defn add-pair ([x y]) "Sum a 2-vector." (+ x y))
    (assert= (doc add-pair) "Sum a 2-vector.")
    ; was dropped by the fn-lowering path
    (assert= (add-pair [3 4]) 7))
  ; …and the doc isn't returned/evaluated
  (test "a multi-clause defn keeps its (leading) docstring"
    (defn sign "Describe a number's sign."
      ((0) :zero)
      ((n) :when (> n 0) :positive)
      ((n) :negative))
    (assert= (doc sign) "Describe a number's sign.")
    (assert= (list (sign -3) (sign 0) (sign 9)) (list :negative :zero :positive)))
  (test "doc of a non-function is nil" (assert= (doc 42) nil) (assert= (doc "a string") nil)))

(describe "arglist"
  (test "required params" (defn pair (a b) (list a b)) (assert= (arglist pair) '(a b)))
  (test "&optional params are listed after a marker"
    (defn opt (a &optional (b 10)) (+ a b))
    (assert= (arglist opt) '(a &optional b)))
  (test "& rest is reconstructed"
    (defn variadic (a b & more) a)
    (assert= (arglist variadic) '(a b & more)))
  (test "arglist of a non-function is nil" (assert= (arglist 42) nil)))

(describe "global table introspection"
  (test "bound? reflects the global table"
    (defn a-defined-name () nil)
    (is (bound? 'introspection-test/a-defined-name))
    (is (bound? 'map))
    ; a prelude binding
    (refute (bound? 'definitely-not-bound-xyz)))
  (test "bound? wants a symbol" (assert-error (bound? 42)))
  (test "global-names includes prelude and user definitions"
    (defn another-name () nil)
    (is (member? 'map (global-names)))
    (is (member? 'introspection-test/another-name (global-names)))))

;; source-location (ADR-031; docs/lsp.md §Cross-file): loading a file records
;; where each *top-level* def/defn/defmacro was defined, so tooling can answer
;; cross-file goto-definition by querying the running image. `sl-subject` must be
;; top-level (a nested def inside a `test` block isn't recorded — by design).
(defn sl-subject (x) (* x x))
;; Sends the parent its own view of the site, to prove a spawned process sees the
;; same shared def-site table (it lives in the runtime code region, like globals).
(defn sl-worker (parent) (send parent (source-location 'introspection-test/sl-subject)))

(describe "source-location (cross-file def sites)"
  (test "records a top-level defn's site in this file"
    (let (loc (source-location 'introspection-test/sl-subject))
      (refute (nil? loc))
      (is (vector? loc))
      (assert= (count loc) 3)
      ; [file line col]
      (is (string? (first loc)))
      ; the file it was loaded from
      (is (int? (first (rest loc))))))
  ; the line
  (test "a prelude global resolves to the materialised prelude file"
    ;; Prelude defns have a recorded site (the unpacked stdlib copy).
    ;; What stays `nil`: a Rust builtin (no .blsp source) or an unknown
    ;; name.
    (let (loc (source-location 'map))
      (is (vector? loc))
      (is (string? (first loc))))
    (assert= (source-location 'no-such-name-xyz) nil))
  (test "the site is visible from a spawned process (shared runtime code)"
    (let (me (self) w (spawn (sl-worker me)))
      ;; the worker's copied-across value equals the parent's own lookup
      (assert= (receive) (source-location 'introspection-test/sl-subject)))))

;; Discovery over the flat namespace (std/prelude.blsp): apropos matches names,
;; doc-search matches docstrings, all-globals lists everything. Built on the
;; global-names/doc primitives above.

(describe "discovery (apropos / all-globals / doc-search)"
  (test "apropos finds globals by name substring"
    (let (hits (apropos "rand"))
      (is (includes? hits 'rand-int))
      (is (includes? hits 'rand-float))
      (refute (includes? hits 'map))))  ; 'map' has no "rand" in it
  (test "apropos accepts a string, symbol, or keyword pattern"
    (assert= (apropos "shuffle") (apropos 'shuffle))
    (assert= (apropos "shuffle") (apropos :shuffle)))
  (test "apropos of a nonsense pattern is empty"
    (assert= (apropos "zzz-no-such-thing-zzz") nil))
  (test "all-globals lists every global and includes the prelude"
    (let (g (all-globals))
      (is (> (count g) 100))
      (is (includes? g 'map))
      (is (includes? g 'rand-int))
      (assert= g (global-names))))  ; it's an alias
  (test "doc-search finds globals whose docstring mentions a word"
    (let (names (map first (doc-search "uniformly random")))
      (is (includes? names 'shuffle))
      (is (includes? names 'sample))))
  (test "doc-search returns [name doc] pairs with real docstrings"
    (let (hits (doc-search "xorshift"))
      (refute (empty? hits))
      (let ([nm d] (first hits))
        (is (symbol? nm))
        (is (string? d)))))
  ;; A multi-term query matches globals carrying *some* of the terms (no
  ;; docstring need hold the whole phrase) — the §3.3 fix. Each of these
  ;; returned nil under the old whole-query substring matcher.
  (test "doc-search ranks by multi-term overlap, not whole-phrase containment"
    (is (includes? (map first (doc-search "remote node distributed")) 'connect))
    (is (includes? (map first (doc-search "remote node distributed")) 'node-start))
    (is (includes? (map first (doc-search "node up down notification")) 'monitor-node))
    (is (includes? (map first (doc-search "raw mode single keypress")) 'term-raw-enter)))
  (test "doc-search is case-insensitive"
    (assert= (map first (doc-search "XORSHIFT")) (map first (doc-search "xorshift"))))
  (test "doc-search of a blank query is empty"
    (assert= (doc-search "") nil)
    (assert= (doc-search "   ") nil)))

;; Runtime introspection: per-process GC observability (Tier-1;
;; docs/memory-review.md §7). gc-stats reports the *calling* process's own heap.
(describe "gc-stats"
  (test "is a map with the documented counter keys"
    (let (s (gc-stats))
      (is (map? s))
      ;; cumulative counters since process start — non-negative integers
      (is (number? (get s :collections)))
      (is (>= (get s :collections) 0))
      (is (number? (get s :copied)))
      (is (number? (get s :reclaimed)))
      ;; live snapshot + the next-collection trigger
      (is (number? (get s :live)))
      (is (>= (get s :live) 0))
      (is (number? (get s :live-bytes)))
      (is (number? (get s :threshold)))
      (is (> (get s :threshold) 0))))
  (test "live count rises after allocating retained data"
    ;; allocate a chunk we keep referenced — :live must reflect it
    (let (before (get (gc-stats) :live)
          kept (range 500)
          after (get (gc-stats) :live))
      (is (> (count kept) 0))
      (is (>= after before)))))
