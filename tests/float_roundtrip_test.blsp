;; Regression: non-finite floats (inf / -inf / nan) must round-trip through
;; pr-str → read-string (found 2026-06-29). The printer emits bare `inf`/`-inf`/
;; `nan`, but the reader's atom classifier had no case for them, so they read back
;; as *symbols* — `(read (pr-str x))` silently turned a float into a symbol. The
;; language produces these floats by design (`1e400`, overflow), so the lossy
;; round-trip was reachable. Fix: the reader classifies `inf`/`-inf`/`nan` as the
;; matching float literals (reserved like `nil`/`true`/`false`).
(defmodule float-roundtrip-test (:use test))

(defn roundtrip (x) (read-string (pr-str x)))

;; The read/write-invariance property (a standard Scheme/float requirement): for
;; every finite float, (= x (read-string (pr-str x))). Brood's printer uses
;; shortest-round-trip formatting, so this must hold exactly. Drive it over many
;; PRNG-generated floats spanning ~10^-20 .. 10^20, plus a curated set of hard
;; values. A 5000-float fuzz run found 0 failures (2026-06-29); this pins it.
(defn rt? (x) (= x (roundtrip x)))

(defn rt-fuzz (i seed bad)
  (if (= i 0) bad
    (let (r  (rand-float seed) m (first r) s (second r)
          r2 (rand-int s 40)   e (- (first r2) 20) s2 (second r2)
          f  (* m (pow 10.0 e)))
      (rt-fuzz (- i 1) s2 (if (rt? f) bad (+ bad 1))))))

(describe "finite float read/write invariance"
  (test "curated hard values round-trip bit-exactly"
    (is (rt? 0.1)) (is (rt? 0.2)) (is (rt? 0.3))
    (is (rt? -0.0)) (is (rt? 1.0))
    (is (rt? 1e308)) (is (rt? 1e-308))
    (is (rt? 1.0000000000000002))     ; 1 ULP above 1.0
    (is (rt? 3.141592653589793))
    (is (rt? 123456789.123456789)))
  (test "2000 PRNG floats across magnitudes all round-trip"
    (assert= (rt-fuzz 2000 987654321 0) 0)))

(describe "non-finite float literals and round-trip"
  (test "1e400 is a positive-infinity float, not a symbol"
    (assert= (type-of 1e400) :float)
    (assert= (type-of (roundtrip 1e400)) :float)
    (is (= 1e400 (roundtrip 1e400))))
  (test "-1e400 round-trips to negative infinity"
    (assert= (type-of (roundtrip -1e400)) :float)
    (is (= -1e400 (roundtrip -1e400))))
  (test "bare inf / -inf literals read as floats"
    (assert= (type-of inf) :float)
    (assert= (type-of -inf) :float)
    (is (= inf 1e400))
    (is (= -inf -1e400)))
  (test "nan is a float that never equals itself; prints and reads as nan"
    (assert= (type-of nan) :float)
    (is (not (= nan nan)))
    (assert= (pr-str nan) "nan")
    (assert= (type-of (read-string "nan")) :float))
  (test "overflow-produced infinity prints as inf and round-trips"
    (let (big (* 1e308 1e308))
      (assert= (pr-str big) "inf")
      (is (= big (roundtrip big))))))
