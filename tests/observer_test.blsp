;; The display/input seam (M3, ADR-046) + process introspection (ADR-050): the
;; `display` render-op protocol and the pure core of the interactive `observe`
;; process viewer. The frame builders are pure data, fully testable without a
;; terminal; the `term-*` primitives (the crossterm frontend) need a real TTY and
;; are exercised by `nest observe`.
;;
;; The closing :isolated block adds cross-process coverage: it drives the
;; `process-info` primitive + `observe--snapshot` against a live runtime, proving
;; the kernel introspection works under the scheduler.

(require 'test)
(require 'observer)        ; pulls in display too

(describe "display render-op constructors"
  (test "clear / text / cursor build tagged op vectors"
    (assert= (clear) [:clear])
    (assert= (text 2 4 "hi") [:text 2 4 "hi"])
    (assert= (text 2 4 "hi" {:bold true}) [:text 2 4 "hi" {:bold true}])
    (assert= (cursor 1 7) [:cursor 1 7]))
  (test "text omits the face slot when none is given"
    (assert= (count (text 0 0 "x")) 4)
    (assert= (count (text 0 0 "x" {:fg :red})) 5))
  (test "frame collects ops into a vector and drops nils"
    (let (f (frame (clear) nil (text 0 0 "a") nil (cursor 0 1)))
      (is (vector? f))
      (assert= (count f) 3)
      (assert= (first f) [:clear])
      (assert= (nth f 2) [:cursor 0 1])))
  (test "an empty frame is the empty vector"
    (assert= (frame) [])
    (assert= (frame nil nil) [])))

(describe "observer pure helpers"
  (test "observe--fit truncates to width, leaves shorter strings alone"
    (assert= (observe--fit "hello" 3) "hel")
    (assert= (observe--fit "hi" 10) "hi")
    (assert= (observe--fit "abc" 0) ""))
  (test "observe--bytes->human scales B / KB / MB"
    (assert= (observe--bytes->human 512) "512 B")
    (assert= (observe--bytes->human 2048) "2 KB")
    (assert= (observe--bytes->human 3145728) "3 MB"))
  (test "observe--opt renders a value or a dash when absent"
    (assert= (observe--opt nil name) "-")
    (assert= (observe--opt :foo name) "foo"))
  (test "observe--cells lays out six fixed-width columns"
    (let (r (observe--cells 7 "worker" "waiting" 3 "8 KB" 1))
      (is (string-contains? r "7"))
      (is (string-contains? r "worker"))
      (is (string-contains? r "waiting"))
      (is (string-contains? r "8 KB"))
      ;; 5 + 12 + 8 + 6 + 8 + 4 columns + 5 single-space gaps
      (assert= (string-length r) 48)))
  (test "observe--proc-cells renders a process-info map (absent fields → dash)"
    (let (r (observe--proc-cells {:id 2 :name nil :status :waiting :mailbox 4 :monitored-by 1}))
      (is (string-contains? r "waiting"))
      (is (string-contains? r "-"))))          ; nil name / absent memory
  (test "observe--window-start keeps the selection on screen, clamped"
    (assert= (observe--window-start 0 5 10) 0)      ; top
    (assert= (observe--window-start 5 5 10) 3)      ; centred (5 - 5/2)
    (assert= (observe--window-start 9 5 10) 5))     ; clamped to maxstart = 10-5
  (test "observe--sel-index follows a pid id across the list, recovers if gone"
    (let (ps [{:id 1} {:id 2} {:id 3}])
      (assert= (observe--sel-index ps 2) 1)
      (assert= (observe--sel-index ps 99) 0)        ; missing → 0
      (assert= (observe--sel-index [] 2) 0)))       ; empty → 0
  (test "observe--sort orders by id (asc) / mailbox / memory (desc)"
    ;; The three keys are deliberately *misaligned* (no two rankings coincide,
    ;; and none matches id order) so a bug that sorts on the wrong field can't
    ;; pass; the input is also pre-scrambled so the id sort genuinely reorders.
    (let (ps [{:id 2 :mailbox 9 :memory 10} {:id 3 :mailbox 1 :memory 30}
              {:id 1 :mailbox 5 :memory 20}])
      (assert= (map (fn (p) (get p :id)) (observe--sort ps :id)) '(1 2 3))
      (assert= (map (fn (p) (get p :id)) (observe--sort ps :mailbox)) '(2 1 3))   ; mbox 9,5,1
      (assert= (map (fn (p) (get p :id)) (observe--sort ps :memory)) '(3 1 2))))  ; mem 30,20,10
  (test "observe--next-sort cycles id → mailbox → memory → tree → id"
    (assert= (observe--next-sort :id) :mailbox)
    (assert= (observe--next-sort :mailbox) :memory)
    (assert= (observe--next-sort :memory) :tree)
    (assert= (observe--next-sort :tree) :id))
  (test "observe--tree-order builds a parent→child forest with depths"
    (let (ps [{:id 1 :parent nil} {:id 4 :parent 2} {:id 2 :parent 1}
              {:id 5 :parent 3} {:id 3 :parent 1}]
          ordered (observe--tree-order ps))
      ;; DFS: 1, then 2 and its child 4, then 3 and its child 5
      (assert= (map (fn (p) (get p :id)) ordered) '(1 2 4 3 5))
      (assert= (map (fn (p) (get p :depth)) ordered) '(0 1 2 1 2))))
  (test "observe--tree-order treats an orphan (parent not in set) as a root"
    (let (ps [{:id 7 :parent 999} {:id 8 :parent 7}]
          ordered (observe--tree-order ps))
      (assert= (map (fn (p) (get p :id)) ordered) '(7 8))
      (assert= (get (first ordered) :depth) 0)))
  (test "observe--node-lines summarises the node panel + link status"
    (let (node {:name :nonode :workers 4 :peak 6 :spawned 10
                :mem 2048 :mem-peak 4096 :peers []}
          ls (observe--node-lines node 3 :ok))
      (is (string-contains? (nth ls 0) "node nonode"))
      (is (string-contains? (nth ls 0) "3 processes"))
      (is (string-contains? (nth ls 1) "workers 4 (peak 6)"))
      (is (string-contains? (nth ls 1) "2 KB"))
      ;; :ok shows no indicator; :stale / :down flag the link
      (refute (string-contains? (nth ls 0) "•"))
      (is (string-contains? (nth (observe--node-lines node 3 :down) 0) "DISCONNECTED"))
      (is (string-contains? (nth (observe--node-lines node 3 :stale) 0) "stale"))))
  (test "observe--apply-result folds a source result into :last / :link"
    (assert= (get (observe--apply-result {:link :ok} {:node {} :procs []}) :link) :ok)
    (assert= (get (observe--apply-result {:link :ok} {:node {} :procs [1]}) :last) {:node {} :procs [1]})
    (assert= (get (observe--apply-result {:link :ok :last :L} :timeout) :link) :stale)
    (assert= (get (observe--apply-result {:link :ok :last :L} :timeout) :last) :L)   ; kept
    (assert= (get (observe--apply-result {:link :ok :last :L} :down) :link) :down)
    ;; :down is sticky — a later good snapshot does NOT revive it
    (assert= (get (observe--apply-result {:link :down :last :L} {:node {} :procs []}) :link) :down)))

(def sample-node {:name :nonode :workers 4 :peak 6 :spawned 10
                  :mem 2048 :mem-peak 4096 :peers []})

(defn pinfo (id name status mbox mon)
  {:id id :node :nonode :name name :status status :mailbox mbox :monitored-by mon})

(describe "observer mouse input"
  (test "observe--mouse? recognises a mouse event, not a key"
    (is (observe--mouse? [:mouse :press :left 3 0]))
    (is (not (observe--mouse? "a")))
    (is (not (observe--mouse? :up)))
    (is (not (observe--mouse? nil))))
  (test "observe--mouse-row->sel maps a body row to a process index, else nil"
    ;; body rows start at 3; cap=10, n=5, sel=2 → window starts at 0
    (assert= (observe--mouse-row->sel 3 2 10 5) 0)     ; first body row
    (assert= (observe--mouse-row->sel 7 2 10 5) 4)     ; fifth (last) process
    (assert= (observe--mouse-row->sel 2 2 10 5) nil)   ; the header row above the list
    (assert= (observe--mouse-row->sel 8 2 10 5) nil)   ; below the 5 processes
    (assert= (observe--mouse-row->sel 99 2 10 5) nil)) ; off screen entirely
  (test "observe--mouse-row->sel accounts for a scrolled window"
    ;; n=20, cap=5, sel=10 → window-start = 8, so the top body row is index 8
    (assert= (observe--window-start 10 5 20) 8)
    (assert= (observe--mouse-row->sel 3 10 5 20) 8)
    (assert= (observe--mouse-row->sel 7 10 5 20) 12))
  (test "observe--apply-mouse: left-press selects the clicked row + clears :msg"
    (let (st {:procs [(pinfo 10 :a :running 0 0) (pinfo 11 :b :running 0 0) (pinfo 12 :c :running 0 0)]
              :n 3 :sel 0 :sel-id 10 :msg "old"}
          clicked (observe--apply-mouse st [:mouse :press :left 5 0] 10))   ; row 5 → index 2
      (assert= (get clicked :sel-id) 12)
      (assert= (get clicked :msg) nil)))
  (test "observe--apply-mouse: the wheel scrolls the selection one row, clamped"
    (let (st {:procs [(pinfo 10 :a :running 0 0) (pinfo 11 :b :running 0 0) (pinfo 12 :c :running 0 0)]
              :n 3 :sel 1 :sel-id 11})
      (assert= (get (observe--apply-mouse st [:mouse :scroll-up nil 0 0] 10) :sel-id) 10)
      (assert= (get (observe--apply-mouse st [:mouse :scroll-down nil 0 0] 10) :sel-id) 12)
      ;; clamps at the ends
      (assert= (get (observe--apply-mouse (assoc st :sel 0 :sel-id 10) [:mouse :scroll-up nil 0 0] 10) :sel-id) 10)
      (assert= (get (observe--apply-mouse (assoc st :sel 2 :sel-id 12) [:mouse :scroll-down nil 0 0] 10) :sel-id) 12)))
  (test "observe--apply-mouse: anything but left-click / wheel is a no-op (state kept)"
    ;; right/middle clicks and a left-click off the list do nothing; so do actions
    ;; the frontends don't emit today (:move/:drag) — robustness to a future one.
    (let (st {:procs [(pinfo 10 :a :running 0 0) (pinfo 11 :b :running 0 0)]
              :n 2 :sel 0 :sel-id 10 :msg "keep"})
      (assert= (observe--apply-mouse st [:mouse :press :right 5 0] 10) st)
      (assert= (observe--apply-mouse st [:mouse :press :middle 5 0] 10) st)
      (assert= (observe--apply-mouse st [:mouse :press :left 99 0] 10) st)
      (assert= (observe--apply-mouse st [:mouse :move nil 5 5] 10) st)
      (assert= (observe--apply-mouse st [:mouse :drag :left 5 5] 10) st))))

(describe "observe-frame (the pure render core)"
  (test "node panel + header + a row per process + detail + footer"
    (let (procs [(pinfo 1 :main :running 0 0) (pinfo 2 nil :waiting 3 1)]
          f (observe-frame sample-node procs 0 60 12 false :id :ok nil))
      (is (vector? f))
      ;; clear + 2 node lines + col-header + 2 body rows + detail + footer = 8
      (assert= (count f) 8)
      (assert= (first f) [:clear])
      (is (string-contains? (nth (nth f 1) 3) "brood observer"))
      (is (string-contains? (nth (nth f 1) 3) "2 processes"))
      ;; header row (index 3) carries the column titles
      (is (string-contains? (nth (nth f 3) 3) "STATUS"))
      ;; first body row (index 4) is a :text op at row 3 carrying its id + status
      (let (row0 (nth f 4))
        (assert= (first row0) :text)
        (assert= (nth row0 1) 3)
        (is (string-contains? (nth row0 3) "main"))
        (is (string-contains? (nth row0 3) "running")))))

  (test "selected row is reverse-highlighted; others get a status face"
    (let (procs [(pinfo 1 :a :running 0 0) (pinfo 2 :b :waiting 0 0)]
          f (observe-frame sample-node procs 1 60 12 false :id :ok nil)
          row0 (nth f 4)        ; index 0, not selected, :running
          row1 (nth f 5))       ; index 1, selected
      (assert= (nth row0 4) {:fg :green})            ; running → green
      (assert= (nth row1 4) {:reverse true})         ; selected → reverse
      (is (string-contains? (nth row1 3) "▸"))))

  (test "detail line names the selection; footer shows sort + paused state"
    (let (procs [(pinfo 1 :zero :running 0 0) (pinfo 2 :one :waiting 9 2)]
          live (observe-frame sample-node procs 1 60 12 false :mailbox :ok nil)
          paused (observe-frame sample-node procs 1 60 12 true :id :ok nil))
      ;; detail (second-to-last op) names the selected pid + its fields
      (is (string-contains? (nth (nth live (- (count live) 2)) 3) "pid 2"))
      (is (string-contains? (nth (nth live (- (count live) 2)) 3) "monitored-by 2"))
      ;; footer shows the active sort key and the pause hint
      (is (string-contains? (nth (last live) 3) "sort(mailbox)"))
      (is (string-contains? (nth (last paused) 3) "PAUSED"))))

  (test "long lists are windowed to the terminal with a position counter"
    (let (procs (map (fn (i) (pinfo i nil :waiting 0 0)) (range 20))
          f (observe-frame sample-node procs 0 60 8 false :id :ok nil))   ; rows=8 → cap = 3
      ;; clear + 2 node + header + 3 body + detail + footer = 9
      (assert= (count f) 9)
      (is (string-contains? (nth (nth f (- (count f) 2)) 3) "/20"))))

  (test "every text op is clipped to the terminal width"
    (let (f (observe-frame sample-node [(pinfo 1 :longname :running 0 0)] 0 20 10 false :id :ok nil))
      (is (every? (fn (op) (or (not (= (first op) :text))
                               (<= (string-length (nth op 3)) 20)))
                  f))))

  (test "command-mode frame renders the minibuffer + cursor"
    (let (ui {:mode :command :edit (lineedit--init "λ " "" []) :msg nil}
          f (observe-frame sample-node [(pinfo 1 :a :running 0 0)] 0 60 12 false :id :ok ui))
      ;; the footer (last text op) is the minibuffer prompt, and a cursor op is placed
      (is (string-contains? (nth (last (filter (fn (op) (= (first op) :text)) f)) 3) "λ"))
      (is (includes? (map first f) :cursor))))
  (test "command-mode minibuffer syntax-highlights the input (shared with the REPL)"
    ;; the input is coloured by the same `highlight-chunks` the REPL line editor uses
    (let (edit (assoc (lineedit--init "λ " "" []) :text "(+ 1 2)" :point 7)
          f (observe-frame sample-node [(pinfo 1 :a :running 0 0)] 0 60 12 false :id :ok
                           {:mode :command :edit edit :msg nil})
          ;; text ops on the minibuffer row (rows-1 = 11) carrying an :fg face — the
          ;; coloured tokens (e.g. the numbers / the operator)
          coloured (filter (fn (op)
                             (and (= (first op) :text)
                                  (= (nth op 1) 11)
                                  (>= (count op) 5)
                                  (map? (nth op 4))
                                  (contains? (nth op 4) :fg)))
                           f))
      (is (> (count coloured) 0))))
  (test "a :msg replaces the detail line"
    (let (f (observe-frame sample-node [(pinfo 1 :a :running 0 0)] 0 60 12 false :id :ok {:msg "=> 42"}))
      (is (string-contains? (nth (nth f (- (count f) 2)) 3) "=> 42")))))

(describe "observer keymap + eval minibuffer (shared with the REPL)"
  (test "*observe-keymap* dispatches nav keys to commands"
    (let (s {:sel-id nil :sort :id :paused false :procs [] :sel 0 :n 0})
      (assert= (get (keymap-dispatch *observe-keymap* s "s" (fn (x _) x)) :sort) :mailbox)
      (assert= (get (keymap-dispatch *observe-keymap* s " " (fn (x _) x)) :paused) true)
      (assert= (get (keymap-dispatch *observe-keymap* s "q" (fn (x _) x)) :done) true)
      (assert= (get (keymap-dispatch *observe-keymap* s ":" (fn (x _) x)) :mode) :command)))
  (test "an unbound key hits the fallback"
    (assert= (keymap-dispatch *observe-keymap* {:n 1} "Z" (fn (s _) (assoc s :hit true)))
             {:n 1 :hit true}))
  (test "observe--eval-string formats a value or an error"
    (is (string-contains? (observe--eval-string "(+ 1 2)") "3"))
    (is (string-contains? (observe--eval-string "(nope)") "error")))
  (test "observe--command-key edits, then submit evals, cancel returns to nav"
    (let (s (observe-cmd-command {:sort :id} nil)             ; enter command mode
          back {:eval observe--eval-string}
          typed (observe--command-key s back "x")             ; insert a char → still editing
          submitted (observe--command-key
                      (assoc s :edit (lineedit--init "λ " "" [])) back :enter))   ; empty submit
      (assert= (get typed :mode) :command)
      (assert= (get (get typed :edit) :text) "x")
      (assert= (get submitted :mode) :nav)                    ; submit leaves command mode
      (assert= (get (observe--command-key s back :ctrl-c) :mode) :nav))))   ; cancel too

(describe "observer kill / confirm / tree (pure)"
  (test "observe-cmd-tree toggles the tree view on and off"
    (assert= (get (observe-cmd-tree {:sort :id} nil) :sort) :tree)
    (assert= (get (observe-cmd-tree {:sort :tree} nil) :sort) :id)
    (assert= (get (observe-cmd-tree {:sort :mailbox} nil) :sort) :tree))   ; any non-tree → tree
  (test "observe-cmd-kill stashes a confirmation for the selected process"
    (let (st {:procs [{:id 10 :pid :p10 :name :a} {:id 11 :pid :p11 :name :b}] :sel 1}
          r (observe-cmd-kill st nil)
          c (get r :confirm))
      (assert= (get c :id) 11)
      (assert= (get c :pid) :p11)
      (assert= (get c :name) :b)))
  (test "observe-cmd-kill is a no-op with no selected process"
    (assert= (observe-cmd-kill {:procs [] :sel 0} nil) {:procs [] :sel 0}))
  (test "observe--confirm-key: y kills via the backend; other keys cancel; both clear :confirm"
    (let (model {:confirm {:pid :p7 :id 7 :name :w}}
          back {:kill (fn (c) (str "killed " (get c :id)))}
          killed (observe--confirm-key model back "y")
          entered (observe--confirm-key model back :enter)
          cancelled (observe--confirm-key model back "n"))
      (assert= (get killed :msg) "killed 7")
      (assert= (get killed :confirm) nil)
      (assert= (get entered :msg) "killed 7")          ; Enter also confirms
      (assert= (get cancelled :msg) "kill cancelled")
      (assert= (get cancelled :confirm) nil)))
  (test "observe--kill-msg guards a nil pid"
    (is (string-contains? (observe--kill-msg nil 9) "error")))
  (test "observe--confirm-line formats the kill prompt (name only when present)"
    (is (string-contains? (observe--confirm-line {:id 7 :name :worker}) "kill pid 7"))
    (is (string-contains? (observe--confirm-line {:id 7 :name :worker}) "(worker)"))
    (is (string-contains? (observe--confirm-line {:id 7 :name nil}) "kill pid 7"))
    (refute (string-contains? (observe--confirm-line {:id 7 :name nil}) "(")))
  (test "*observe-keymap* binds t→tree and x→kill"
    (assert= (get (keymap-dispatch *observe-keymap* {:sort :id} "t" (fn (x _) x)) :sort) :tree)
    (let (s {:sort :id :procs [{:id 5 :pid :p5 :name :w}] :sel 0}
          r (keymap-dispatch *observe-keymap* s "x" (fn (x _) x)))
      (assert= (get (get r :confirm) :id) 5)))
  (test "observe-frame renders the kill-confirm prompt in the footer"
    (let (f (observe-frame sample-node [(pinfo 1 :a :running 0 0)] 0 60 12 false :id :ok
                           {:confirm {:id 1 :name :a}}))
      (is (string-contains? (nth (last f) 3) "kill pid 1"))
      (is (string-contains? (nth (last f) 3) "y/n"))
      (assert= (nth (last f) 4) {:fg :red :bold true}))))   ; :observer/confirm ← :ui/error

(describe "observer minibuffer history (shared with the REPL)"
  (test "command mode seeds the editor with session history; submit appends it"
    (let (s {:sort :id :history '("(+ 1 2)")}
          opened (observe-cmd-command s nil))
      ;; the line editor is seeded with the session history (so ↑ recalls)
      (assert= (get (get opened :edit) :hist) '("(+ 1 2)"))
      (let (typed (assoc opened :edit (assoc (get opened :edit) :text "(* 3 4)"))
            back {:eval (fn (_) "=> 12")}
            submitted (observe--command-key typed back :enter))
        ;; submit pushes the new command onto history, newest first
        (assert= (get submitted :history) '("(* 3 4)" "(+ 1 2)"))))))

;; Cross-process coverage: drive `process-info` + `observe--snapshot` against a
;; live runtime (each :isolated test runs alone).
(describe "process-info over live processes"
  :isolated

  (test "a parked receiver reports :waiting + its mailbox backlog"
    ;; Only handles [:work _], so other messages pile up and it stays parked.
    (let (w (spawn (receive ([:work _] :done))))
      (send w :a) (send w :b)
      (sleep 20)
      (let (info (process-info w))
        (is (map? info))
        (assert= (get info :status) :waiting)
        (is (>= (get info :mailbox) 2))
        (is (number? (get info :id)))
        ;; :memory is published on receive — the parked worker reports its footprint
        (is (number? (get info :memory)))
        (is (> (get info :memory) 0))
        ;; :collections is published on receive too — a fresh worker has run no
        ;; collections yet, but the key is present and non-negative.
        (is (number? (get info :collections)))
        (is (>= (get info :collections) 0)))))

  (test "monitoring a process shows up in :monitored-by"
    (let (m (spawn (receive (_ :done))))
      (monitor m)
      (sleep 10)
      (is (>= (get (process-info m) :monitored-by) 1))))

  (test "process-info of self is a live, running map with an id"
    (let (info (process-info (self)))
      (is (map? info))
      (is (number? (get info :id)))
      ;; self is executing this call, so the status cell reads :running
      (assert= (get info :status) :running)))

  (test "process-info carries the process's :pid value (for kill/exit)"
    (let (w (spawn (receive (_ :done))))
      (sleep 10)
      (let (info (process-info w))
        (is (contains? info :pid))
        (is (pid? (get info :pid)))
        ;; the pid round-trips: it equals the value spawn returned
        (assert= (get info :pid) w))))

  (test ":parent is the spawner's id"
    (let (me (get (process-info (self)) :id)
          kid (spawn (receive (_ :done))))
      (sleep 10)
      (assert= (get (process-info kid) :parent) me)))

  (test "observe--local-source includes this runtime's live processes"
    (let (w (spawn (receive (_ :done))))
      (sleep 10)
      (let (procs (observe--local-source)
            ids (map (fn (p) (get p :id)) procs))
        (is (every? map? procs))
        ;; the inline source sees the just-spawned process
        (is (includes? ids (get (process-info w) :id))))))

  (test "observe--local-snapshot is a frame-ready {:node :procs} snapshot"
    (spawn (receive (_ :done)))
    (let (snap (observe--local-snapshot)
          procs (observe--sort (get snap :procs) :id))
      (is (contains? snap :node))
      (is (every? (fn (p) (and (number? (get p :id)) (number? (get p :mailbox)))) procs))
      (is (>= (count (observe-frame (get snap :node) procs 0 80 24 false :id :ok nil)) 5))))

  (test "the :observe agent replies with a snapshot (the remote-attach seam)"
    ;; observe-serve's agent, exercised same-runtime: request → snapshot reply.
    ;; Remote attach is the same protocol with the request routed over a node link.
    (let (a (spawn (observe--agent-loop)))
      (register :observe a)
      (send {:name :observe :node (node-name)} [:snapshot (self) (ref)])
      (let (reply (receive ([:observe-reply snap] snap) (after 1000 :timeout)))
        (is (map? reply))
        (is (contains? reply :node))
        (is (contains? reply :procs))))))
