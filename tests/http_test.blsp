;; HTTP/1.0 server (std/http.blsp, ADR-062). Pure parsing/rendering/routing tests,
;; plus an end-to-end loopback request through a real spawned server.
;;
;; Register-only — discovered and run by `nest test` (and cargo test).

(defmodule http-test (:use test) (:use net/http) (:use net/tcp))

(describe "http: request parsing"
  (test "method, path, version, and lower-cased headers"
    (let (r (parse-request "GET /hi HTTP/1.1\r\nHost: example\r\nContent-Length: 0\r\n\r\n"))
      (assert= (get r :method) "GET")
      (assert= (get r :path) "/hi")
      (assert= (get r :version) "HTTP/1.1")
      (assert= (get (get r :headers) "host") "example")))
  (test "a body after the blank line is captured"
    (let (r (parse-request "POST /x HTTP/1.0\r\nContent-Length: 5\r\n\r\nhello"))
      (assert= (get r :body) "hello"))))

(describe "http: response rendering"
  (test "status line, Content-Length, and body"
    (let (s (render-response (ok "<p>hi</p>")))
      (is (string-contains? s "HTTP/1.0 200 OK"))
      (is (string-contains? s "Content-Length: 9"))
      (is (string-contains? s "\r\n\r\n<p>hi</p>"))))
  (test "not-found renders a 404"
    (is (string-contains? (render-response (not-found)) "404 Not Found"))))

(describe "http: routing + mime"
  (test "router dispatches by path and falls back to 404"
    (let (h (router {"/" (fn (req) (text-response "home"))}))
      (assert= (get (h {:path "/"}) :body) "home")
      (assert= (get (h {:path "/missing"}) :status) 404)))
  (test "mime-type guesses by extension"
    (assert= (mime-type "a/b.html") "text/html; charset=utf-8")
    (assert= (mime-type "a/b.png") "image/png")
    (assert= (mime-type "a/b.xyz") "application/octet-stream")))

(describe "http: streaming responses (the connection-handoff seam)"
  (test "render-head emits the status line + custom headers, no Content-Length"
    (let (h (render-head 200 {"Content-Type" "text/event-stream"}))
      (is (string-contains? h "HTTP/1.0 200 OK"))
      (is (string-contains? h "Content-Type: text/event-stream"))
      (is (string-contains? h "\r\n\r\n"))
      (refute (string-contains? h "Content-Length"))))
  (test "streaming? distinguishes a stream-response from a plain response"
    (is (streaming? (stream-response 200 {} (fn (sock) nil))))
    (refute (streaming? (ok "hi"))))
  (test "a stream-response keeps the connection open and pushes frames"
    (let (me (self))
      ;; A handler that hands the live socket to a stream-fn pushing two frames,
      ;; then closes — so a draining client sees both before EOF (deterministic).
      (spawn (do
               (let (ls (http-listen 0))
                 (send me [:port (tcp-local-port ls)])
                 (serve-loop ls
                   (fn (req)
                     (stream-response 200 {"Content-Type" "text/event-stream"}
                       (fn (sock)
                         (tcp-send sock "data: one\n\n")
                         (tcp-send sock "data: two\n\n")
                         (tcp-close sock))))))))
      (let (port (receive ([:port p] p) (after 5000 :timeout)))
        (let (c (tcp-connect "127.0.0.1" port))
          (tcp-send c "GET /events HTTP/1.0\r\nHost: localhost\r\n\r\n")
          (let (resp (tcp-drain c))
            (tcp-close c)
            (is (string-contains? resp "text/event-stream"))
            (is (string-contains? resp "data: one"))
            (is (string-contains? resp "data: two"))
            ;; the streaming path sends no Content-Length / Connection: close
            (refute (string-contains? resp "Content-Length"))))))))

(describe "http: client url + response parsing"
  (test "parse-url splits scheme/host/port/path"
    (let (u (net/http/http--parse-url "https://api.github.com/zen"))
      (assert= (get u :scheme) "https")
      (assert= (get u :host) "api.github.com")
      (assert= (get u :port) 443)
      (assert= (get u :path) "/zen")))
  (test "parse-url defaults: http port 80, root path, explicit port"
    (assert= (get (net/http/http--parse-url "http://example.com") :port) 80)
    (assert= (get (net/http/http--parse-url "http://example.com") :path) "/")
    (assert= (get (net/http/http--parse-url "http://h:8080/x") :port) 8080))
  (test "parse-response reads the status line, headers, and body"
    (let (r (parse-response "HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\n\r\nhi there"))
      (assert= (get r :status) 200)
      (assert= (get (get r :headers) "content-type") "text/plain")
      (assert= (get r :body) "hi there"))))

(describe "http: end-to-end over a loopback server"
  (test "a GET gets the handler's response back"
    (let (me (self))
      ;; the server owns its listener, so it runs in its own process. `spawn` is a
      ;; macro wrapping its expr in a thunk — pass the (do …), not a (fn () …).
      (spawn (do
               (let (ls (http-listen 0))
                 (send me [:port (tcp-local-port ls)])
                 (serve-loop ls (router {"/" (fn (req) (ok "<h1>brood</h1>"))})))))
      (let (port (receive ([:port p] p) (after 5000 :timeout)))
        (let (c (tcp-connect "127.0.0.1" port))
          (tcp-send c "GET / HTTP/1.0\r\nHost: localhost\r\n\r\n")
          (let (resp (tcp-drain c))
            (tcp-close c)
            (is (string-contains? resp "200 OK"))
            (is (string-contains? resp "<h1>brood</h1>"))))))))

(describe "http: concurrent connections each get their own process"
  (test "many simultaneous GETs all complete (spawn-per-connection)"
    (let (me (self))
      ;; A handler that echoes the request path, so each concurrent client can
      ;; confirm it got *its own* response and not another connection's.
      (spawn (do
               (let (ls (http-listen 0))
                 (send me [:port (tcp-local-port ls)])
                 (serve-loop ls (fn (req) (text-response (get req :path)))))))
      (let (port (receive ([:port p] p) (after 5000 :timeout))
            n 4)
        ;; Fire N clients at once, each in its own process; the server must serve
        ;; them in N separate handler processes (the connections overlap in time).
        (dotimes (i n)
          (spawn (do
                   (let (path (str "/" i)
                         resp (http-get (str "http://127.0.0.1:" port path)))
                     (send me [:done (get resp :status) (get resp :body)])))))
        ;; Fan-in: every client reports a 200 whose body is its own requested path.
        (dotimes (_ n)
          (receive
            ([:done status body]
              (assert= status 200)
              (is (string-contains? body "/")))
            (after 5000 (is false))))))))

(describe "http: request building (http/http--request-headers)"
  (test "adds Host / User-Agent / Connection, and Content-Length when there's a body"
    (let (h (net/http/http--request-headers {:host "localhost"} "abc" nil))
      (assert= (get h "Host") "localhost")
      (assert= (get h "User-Agent") "brood")
      (assert= (get h "Connection") "close")
      (assert= (get h "Content-Length") "3")))
  (test "no Content-Length for an empty body"
    (refute (contains? (net/http/http--request-headers {:host "h"} "" nil) "Content-Length")))
  (test "caller headers override the defaults and add new ones"
    (let (h (net/http/http--request-headers {:host "h"} "" {"User-Agent" "bw" "X-Token" "k"}))
      (assert= (get h "User-Agent") "bw")  ; overridden
      (assert= (get h "X-Token") "k"))))  ; added

(describe "http: end-to-end POST + headers over a loopback server"
  (test "http-post round-trips the method, body, and a custom header"
    (let (me (self))
      ;; a handler that echoes back the request's method | body | a custom header
      (spawn (do
               (let (ls (http-listen 0))
                 (send me [:port (tcp-local-port ls)])
                 (serve-loop ls
                   (fn (req)
                     (ok (str (get req :method)
                           "|"
                           (get req :body)
                           "|"
                           (get (get req :headers) "x-token"))))))))
      (let (port (receive ([:port p] p) (after 5000 :timeout)))
        (let (resp (http-post (str "http://127.0.0.1:" port "/act")
                     "{\"a\":1}"
                     {:headers {"X-Token" "secret" "Content-Type" "application/json"}}))
          (assert= (get resp :status) 200)
          ;; method echoed as POST, the JSON body intact, the custom header received
          (assert= (get resp :body) "POST|{\"a\":1}|secret")))))
  (test "http-get still works through http-request (delegation intact)"
    (let (me (self))
      (spawn (do
               (let (ls (http-listen 0))
                 (send me [:port (tcp-local-port ls)])
                 (serve-loop ls (fn (req) (text-response (str "got " (get req :path))))))))
      (let (port (receive ([:port p] p) (after 5000 :timeout)))
        (let (resp (http-get (str "http://127.0.0.1:" port "/zen")))
          (assert= (get resp :status) 200)
          (assert= (get resp :body) "got /zen"))))))
