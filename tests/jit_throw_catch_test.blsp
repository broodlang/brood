;; Regression: a Brood error raised inside JIT-compiled code must stay *catchable*
;; — parked and re-raised as a normal Err, never an abort across the extern-"C"
;; JIT callback boundary. Hammer each throwing arm past the tier threshold (~8) in
;; a single process (`:serial`) so the throw originates from native code; the
;; runtime must survive and the catch must fire every time.
;;
;; The third case guards a fixed use-after-free (2026-06-29): a throw from inside
;; JIT-*inlined* NON-TAIL recursion read a freed constant ("bottom") off the
;; ephemeral spliced chunk and aborted. Fix: JIT_INLINE_CHUNK_KEEPALIVE retains the
;; inlined chunk for the process lifetime (jit_lower.rs), like the small-native
;; arm's chunk. This case crashed deterministically against the bug, on the default
;; JIT+inline path; it must now return its exact count.
(defmodule jit-throw-catch-test
  (:use test))

;; div-by-zero in a hot non-recursive arm. Over i=N..1, (rem i 5)=0 floor(N/5) times.
(defn risky (x) (quot 100 x))
(defn hammer (i caught)
  (if (= i 0) caught
    (hammer (- i 1) (+ caught (try (do (risky (rem i 5)) 0) (catch e 1))))))

;; explicit (error ...) in a hot non-recursive arm.
(defn checked (x) (if (< x 0) (error "negative") (* x 2)))
(defn hammer2 (i caught)
  (if (= i 0) caught
    (hammer2 (- i 1) (+ caught (try (do (checked (- (rem i 3) 1)) 0) (catch e 1))))))

;; a throw deep inside warmed NON-TAIL recursion, caught at the top — the arm gets
;; self-inlined, and the thrown error must unwind without reading a freed const.
(defn deep (n) (if (= n 0) (error "bottom") (+ 1 (deep (- n 1)))))
(defn hammer3 (i caught)
  (if (= i 0) caught
    (hammer3 (- i 1) (+ caught (try (deep 30) (catch e 1))))))

(describe "errors raised in JIT'd code stay catchable after the arm tiers" :serial
  (test "div-by-zero in a hot arm is caught every time, runtime survives"
    (assert= (hammer 4000 0) 800))      ; multiples of 5 in 1..4000
  (test "explicit (error) in a hot arm is caught"
    (assert= (hammer2 3000 0) 1000))    ; (rem i 3)-1 < 0 ⇔ rem=0 ⇔ 1000 of 3000
  (test "throw from JIT-inlined non-tail recursion unwinds cleanly (was a UAF abort)"
    (assert= (hammer3 2000 0) 2000)))   ; every (deep 30) throws at the bottom, caught
