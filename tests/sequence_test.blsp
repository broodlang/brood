;; Sequence library — range / take / drop / take-while / drop-while / some? /
;; every? / find / zip / partition / sort / sort-by, all written in Brood over the
;; list primitives. The whole suite runs in parallel (each test is its own green
;; process), so these already exercise the ops on multiple cores; the final
;; :isolated block adds explicit spawn/send/fan-in coverage. Register-only —
;; discovered and run by `nest test` / cargo test.

(defmodule sequence-test (:use test))

(describe "range"
  (test "(range hi) counts 0..hi-1"
    (assert= (range 5) (list 0 1 2 3 4))
    (assert= (range 0) nil)
    (assert= (range 1) (list 0)))
  (test "(range lo hi) is the half-open interval"
    (assert= (range 2 6) (list 2 3 4 5))
    (assert= (range 5 5) nil))
  ; empty when lo == hi
  (test "(range lo hi step) steps by step, ascending or descending"
    (assert= (range 0 10 2) (list 0 2 4 6 8))
    (assert= (range 10 0 -2) (list 10 8 6 4 2))
    (assert= (range 1 10 3) (list 1 4 7))))

(describe "take / drop"
  (test "take returns the first n (or all, if shorter)"
    (assert= (take 3 (range 10)) (list 0 1 2))
    (assert= (take 0 (range 10)) nil)
    (assert= (take 99 (list 1 2 3)) (list 1 2 3))
    (assert= (take 3 nil) nil))
  (test "drop discards the first n (or all, if shorter)"
    (assert= (drop 7 (range 10)) (list 7 8 9))
    (assert= (drop 0 (list 1 2 3)) (list 1 2 3))
    (assert= (drop 99 (list 1 2 3)) nil)
    (assert= (drop 3 nil) nil))
  (test "take and drop at index n partition the sequence"
    (let (xs (range 10)) (assert= (append (take 4 xs) (drop 4 xs)) xs))))

(describe "take-while / drop-while"
  (test "take-while keeps the leading run that satisfies pred"
    (assert= (take-while (fn (x) (< x 4)) (range 10)) (list 0 1 2 3))
    (assert= (take-while even? (list 2 4 5 6)) (list 2 4))
    (assert= (take-while even? (list 1 2 3)) nil))
  (test "drop-while skips the leading run that satisfies pred"
    (assert= (drop-while (fn (x) (< x 4)) (range 10)) (list 4 5 6 7 8 9))
    (assert= (drop-while even? (list 2 4 5 6)) (list 5 6))
    (assert= (drop-while even? (list 1 2 3)) (list 1 2 3))))

(describe "some? / every? / find"
  (test "some? is true iff any element satisfies pred"
    (is (some? even? (list 1 3 4 5)))
    (refute (some? even? (list 1 3 5)))
    (refute (some? even? nil)))
  ; vacuously false on empty
  (test "every? is true iff all elements satisfy pred"
    (is (every? even? (list 2 4 6)))
    (refute (every? even? (list 2 4 5)))
    (is (every? even? nil)))
  ; vacuously true on empty
  (test "find returns the first matching element, or nil"
    (assert= (find even? (list 1 3 4 5 6)) 4)
    (assert= (find even? (list 1 3 5)) nil)
    (assert= (find (fn (x) (> x 100)) (range 10)) nil)))

(describe "index-where"
  ;; The predicate counterpart of index-of (which matches by equality).
  (test "returns the index of the first matching element"
    (assert= (index-where even? (list 1 3 4 5)) 2)
    (assert= (index-where (fn (x) (= x :b)) [:a :b :c]) 1)
    (assert= (index-where (fn (x) (> x 100)) [10 200 3000]) 1))
  (test "is -1 when nothing matches"
    (assert= (index-where even? (list 1 3 5)) -1)
    (assert= (index-where even? nil) -1)
    (assert= (index-where even? []) -1))
  (test "matches at index 0"
    (assert= (index-where odd? (list 1 2 3)) 0)))

(describe "zip"
  (test "zip pairs elements into 2-vectors, stopping at the shorter input"
    (assert= (zip (list 1 2 3) (list :a :b :c)) (list [1 :a] [2 :b] [3 :c]))
    (assert= (zip (list 1 2 3) (list :a :b :c :d)) (list [1 :a] [2 :b] [3 :c]))
    (assert= (zip nil (list :a)) nil)
    (assert= (zip (list 1) nil) nil)))

(describe "partition"
  (test "partition chunks into n-sized groups, dropping a trailing partial"
    (assert= (partition 2 (range 6)) (list (list 0 1) (list 2 3) (list 4 5)))
    (assert= (partition 2 (range 7)) (list (list 0 1) (list 2 3) (list 4 5)))
    (assert= (partition 3 (range 9)) (list (list 0 1 2) (list 3 4 5) (list 6 7 8))))
  (test "partition of too-short input is empty"
    (assert= (partition 5 (range 3)) nil)
    (assert= (partition 1 nil) nil)))

(describe "sort / sort-by"
  (test "sort orders ascending by default"
    (assert= (sort (list 3 1 2 5 4)) (list 1 2 3 4 5))
    (assert= (sort nil) nil)
    (assert= (sort (list 1)) (list 1)))
  (test "sort takes a custom strict less-than predicate"
    (assert= (sort > (list 3 1 2 5 4)) (list 5 4 3 2 1)))
  (test "sort is stable (equal elements keep input order)"
    ;; sort by first component; the second tags the original position.
    (let (pairs (list [1 :a] [0 :b] [1 :c] [0 :d]))
      (assert= (sort (fn (x y) (< (vector-ref x 0) (vector-ref y 0))) pairs)
        (list [0 :b] [0 :d] [1 :a] [1 :c]))))
  (test "sort-by orders by a key function"
    (assert= (sort-by (fn (s) (string-length s)) (list "ccc" "a" "bb")) (list "a" "bb" "ccc"))
    (assert= (sort-by abs (list -3 1 -2 4)) (list 1 -2 -3 4)))
  (test "sort handles a larger, reversed input correctly"
    (assert= (sort (range 50 0 -1)) (range 1 51)))
  ;; Structural sort for non-numeric items, no custom comparator needed —
  ;; lexicographic on vectors, text order on strings/keywords/symbols.
  (test "sort orders vectors lexicographically"
    (assert= (sort (list [2 1] [1 0] [2 0])) (list [1 0] [2 0] [2 1]))
    (assert= (sort (list [3] [1 2] [1 1])) (list [1 1] [1 2] [3])))
  (test "sort orders strings/keywords/symbols by text"
    (assert= (sort (list "c" "a" "b")) (list "a" "b" "c"))
    (assert= (sort (list :c :a :b)) (list :a :b :c)))
  (test "sort on the empty collection is the empty list"
    (assert= (sort nil) nil)
    (assert= (sort []) nil)))

(describe "concat / mapcat / frequencies"
  (test "concat joins any number of sequences, over lists and vectors, into a list"
    (assert= (concat (list 1 2) (list 3 4) (list 5)) (list 1 2 3 4 5))
    (assert= (concat [1 2] [3 4]) (list 1 2 3 4))
    ; vectors read as sequences
    (assert= (concat (list 1) [2 3]) (list 1 2 3))
    ; mixed
    (assert= (concat) nil)
    ; no args -> empty
    (assert= (into [] (concat [1 2] [3 4])) [1 2 3 4]))
  ; (into [] …) for a vector result
  (test "mapcat maps then concatenates the resulting lists"
    (assert= (mapcat (fn (x) (list x x)) (list 1 2 3)) (list 1 1 2 2 3 3))
    (assert= (mapcat (fn (x) (range x)) (list 1 2 3)) (list 0 0 1 0 1 2))
    (assert= (mapcat (fn (x) (list x)) nil) nil))
  ;; Maps are seqable: every list-shaped op walks them as `[k v]` pairs without
  ;; the `(zip (keys m) (vals m))` workaround. Map iteration order is hash-
  ;; driven (ADR-040), so we compare against frequency maps where order matters.
  (test "map/filter/mapcat/fold/reduce/count accept a map as the collection"
    (let (m {:a 1 :b 2 :c 3})
      (assert= (frequencies (map first m)) {:a 1 :b 1 :c 1})
      (assert= (count m) 3)
      (assert= (fold + 0 (map second m)) 6)
      (assert= (reduce + 0 (map second m)) 6)
      (assert= (frequencies (filter (fn ([_ v]) (> v 1)) m)) {[:b 2] 1 [:c 3] 1})
      (assert= (frequencies (mapcat (fn ([k v]) (list k v)) m)) {:a 1 :b 1 :c 1 1 1 2 1 3 1})))
  (test "seq coerces a map to its pairs; entries is an alias for map-pairs"
    (let (m {:x 1 :y 2})
      (assert= (frequencies (seq m)) {[:x 1] 1 [:y 2] 1})
      (assert= (entries m) (map-pairs m))))
  (test "frequencies tallies occurrences into a map"
    (assert= (frequencies (list :a :b :a :a :b)) {:a 3 :b 2})
    (assert= (frequencies nil) {})
    (assert= (get (frequencies (list 1 1 1)) 1) 3)))

(describe "for comprehension"
  (test "basic map" (assert= (for (x (range 4)) (* x x)) (list 0 1 4 9)))
  (test ":when filters" (assert= (for (x (range 8) :when (even? x)) x) (list 0 2 4 6)))
  (test "nested bindings (rightmost varies fastest)"
    (assert= (for (x (range 2) y (range 2)) [x y]) (list [0 0] [0 1] [1 0] [1 1])))
  (test "destructuring a binding"
    ;; ADR-040: map iteration order is hash-driven; compare as a frequency map.
    (assert= (frequencies (for ([k v] (map-pairs {:a 1 :b 2})) [v k]))
      {[1 :a] 1 [2 :b] 1}))
  (test "build a map with into {}"
    (assert= (into {} (for (x (range 3)) [x (* x x)])) {0 0 1 1 2 4}))
  ;; nested bindings + :when together — the fused-fold lowering threads its
  ;; accumulator through both the inner fold and the guard, so exercise the
  ;; combination (the off-diagonal of a 3×3, the Game-of-Life `step` shape).
  (test "nested bindings with a :when guard"
    (assert= (for (x (range 3) y (range 3) :when (not (= x y))) [x y])
      (list [0 1] [0 2] [1 0] [1 2] [2 0] [2 1]))))

(describe "into / times / iterate-times / enumerate / doseq"
  (test "into a map assocs [k v] pairs; into a list appends"
    (assert= (into {:a 1} (list [:b 2] [:c 3])) {:a 1 :b 2 :c 3})
    (assert= (into (list 1 2) (list 3 4)) (list 1 2 3 4)))
  (test "into a vector produces a vector (not a list)"
    (assert= (into [] (list 1 2 3)) [1 2 3])
    (assert= (into [0] (list 1 2)) [0 1 2]))
  (test "into reads a map as its [k v] pairs"
    ;; insertion order may vary on rehash; compare as a frequency map.
    (assert= (frequencies (into [] {:a 1 :b 2})) {[:a 1] 1 [:b 2] 1})
    (assert= (into {} {:a 1 :b 2}) {:a 1 :b 2}))
  (test "times applies f n times" (assert= (times 5 inc 0) 5) (assert= (times 0 inc 9) 9))
  (test "iterate-times yields n+1 successive states"
    (assert= (iterate-times (fn (n) (* n 2)) 1 4) (list 1 2 4 8 16)))
  (test "enumerate pairs items with indices"
    (assert= (enumerate (list :a :b :c)) (list [0 :a] [1 :b] [2 :c]))))

(describe "doseq"
  :isolated
  (test "runs its body for each item (in order) and returns nil"
    (assert= (doseq (x (range 3)) (send (self) [:saw x])) nil)
    ;; the three sends arrived, in order
    (assert= (list (receive ([:saw v] v)) (receive ([:saw v] v)) (receive ([:saw v] v)))
      (list 0 1 2))))

(describe "remove / keep"
  (test "remove is the complement of filter"
    (assert= (remove even? (range 8)) (list 1 3 5 7))
    (assert= (remove (fn (x) true) (range 3)) nil))
  (test "keep takes the non-nil results of f (map+filter fused)"
    (assert= (keep (fn (x) (if (even? x) (* x x) nil)) (range 6)) (list 0 4 16))
    (assert= (keep (fn (x) nil) (range 3)) nil)))

(describe "distinct / dedupe"
  (test "distinct drops duplicates, keeping first occurrence (order-preserving)"
    (assert= (distinct (list 1 1 2 3 3 3 1 4)) (list 1 2 3 4))
    (assert= (distinct nil) nil))
  (test "distinct works on any equal-able items"
    (assert= (distinct (list :a :b :a :c :b)) (list :a :b :c)))
  (test "dedupe collapses only consecutive runs"
    (assert= (dedupe (list 1 1 2 3 3 3 1 4)) (list 1 2 3 1 4))
    (assert= (dedupe nil) nil)))

(describe "group-by"
  (test "group-by buckets items by f, preserving order within a bucket"
    (assert= (group-by even? (range 6)) {true (list 0 2 4) false (list 1 3 5)}))
  (test "group-by on an empty collection is the empty map"
    (assert= (group-by even? nil) {})))

(describe "flatten"
  (test "flatten splices nested lists into one flat list"
    (assert= (flatten (list 1 (list 2 (list 3 4)) 5 (list (list 6)))) (list 1 2 3 4 5 6)))
  (test "flatten leaves a flat list unchanged and treats vectors as leaves"
    (assert= (flatten (list 1 2 3)) (list 1 2 3))
    (assert= (flatten (list [1 2] [3 4])) (list [1 2] [3 4]))))

(describe "interpose / interleave"
  (test "interpose inserts a separator between adjacent items"
    (assert= (interpose :x (list 1 2 3)) (list 1 :x 2 :x 3))
    (assert= (interpose :x (list 1)) (list 1))
    (assert= (interpose :x nil) nil))
  (test "interleave alternates, stopping at the shorter input"
    (assert= (interleave (list 1 2 3) (list :a :b :c :d)) (list 1 :a 2 :b 3 :c))
    (assert= (interleave nil (list 1)) nil)))

(describe "take-last / drop-last"
  (test "take-last returns the final n items (whole list if shorter)"
    (assert= (take-last 2 (range 5)) (list 3 4))
    (assert= (take-last 99 (range 3)) (list 0 1 2))
    (assert= (take-last 0 (range 3)) nil))
  (test "drop-last removes the final n items"
    (assert= (drop-last 2 (range 5)) (list 0 1 2))
    (assert= (drop-last 99 (range 3)) nil)))

(describe "repeat / repeatedly"
  (test "repeat builds a list of n copies"
    (assert= (repeat 3 :x) (list :x :x :x))
    (assert= (repeat 0 :x) nil))
  (test "repeatedly calls a thunk n times, in order"
    (assert= (repeatedly 3 (fn () 7)) (list 7 7 7))
    (assert= (repeatedly 0 (fn () 7)) nil)))

;; ---- explicit concurrency (spawn / send / fan-in) ---------------------------
;; :isolated so these run against a private globals copy and don't contend with
;; the parallel suite for the runner's mailbox. Each worker builds a sequence and
;; sends it back (deep-copied across per-process heaps), proving the list values
;; round-trip; the parent fans them in. Defined once at load (distinct seq- names)
;; so they survive the :isolated rollback.

(defn seq-emit (parent n) (send parent [:r n (sort (range n 0 -1))]))
; build then sort
(defn seq-spawn (parent ns)
  (when (not (empty? ns)) (spawn (seq-emit parent (first ns))) (seq-spawn parent (rest ns))))
(defn seq-collect (got total acc)
  (if (= got total) acc (seq-collect (+ got 1) total (receive ([:r n xs] (assoc acc n xs))))))

(def seq-data (range 1 21))
; a shared global list read by many processes
(defn seq-reader (parent i) (send parent [:s (sum (take i seq-data))]))
; Σ 1..i
(defn seq-spawn-readers (parent n)
  (when (> n 0) (spawn (seq-reader parent n)) (seq-spawn-readers parent (- n 1))))
(defn seq-sum (got total acc)
  (if (= got total) acc (seq-sum (+ got 1) total (receive ([:s v] (+ acc v))))))

(describe "sequences across processes"
  :isolated

  (test "a sorted list round-trips through a worker unchanged (deep copy)"
    (let (me (self) w (spawn (seq-emit me 5))) (assert= (receive ([:r n xs] xs)) (list 1 2 3 4 5))))

  (test "fan-out / fan-in: each worker builds+sorts a list, parent folds a map"
    (seq-spawn (self) (range 1 16))
    ; 15 workers, n = 1..15
    (let (m (seq-collect 0 15 {}))
      (assert= (count m) 15)
      (assert= (get m 1) (list 1))
      (assert= (get m 5) (list 1 2 3 4 5))
      (assert= (get m 15) (range 1 16))))

  (test "many processes concurrently read a shared GLOBAL list"
    ;; worker i sends Σ(1..i); summing i=1..10 of i(i+1)/2 = 220.
    (seq-spawn-readers (self) 10)
    (assert= (seq-sum 0 10 0) 220)))
