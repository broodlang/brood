;; std/telemetry.blsp — Erlang :telemetry-style instrumentation (listener model).
;; A thorough suite: emit→handler delivery, measurements/metadata, event filtering,
;; attach/detach/detach-all/re-attach, multiple handlers, introspection, the span
;; lifecycle, forward, cross-process + concurrent emit, telemetry-sync ordering, the
;; not-started/after-stop no-ops, and — the headline guarantee — that a handler runs
;; in the LISTENER and can crash ONLY the listener, never the emitting process.
;;
;; All blocks are :isolated: the listener registers the name :telemetry and the handler
;; table is a global, and an :isolated unit runs alone with rolled-back globals so tests
;; can't race. Each test starts/stops its own listener and detach-all's. Bodies stay
;; tail-recursive (small green-process stack). Register-only — `nest test` finds it.

(defmodule telemetry-test (:use test) (:use telemetry))

;; ---- helpers ----------------------------------------------------------------
;; A handler that forwards (event measurements metadata) to `pid`.
(defn tel-fwd (pid) (fn (e m md) (send pid [:ev e m md])))
(defn tel-recv () (receive ([:ev e m md] [e m md]) (after 5000 :timeout)))
(defn tel-none () (receive ([:ev e m md] :got) (after 120 :none)))
(defn tel-ids (event) (map (fn (h) (get h :id)) (get (handlers) event nil)))
(defn tel-await (n)
  (if (= n 0) :ok (receive (:done (tel-await (- n 1))) (after 5000 :timeout))))
(defn threw? (thunk) (try (do (thunk) false) (catch e true)))

;; ---- emit + handlers --------------------------------------------------------
(describe "telemetry: emit and handlers"
  :isolated
  (test "emit delivers event + measurements + metadata to a handler"
    (let (me (self))
      (start-telemetry) (detach-all)
      (attach :h :evt (tel-fwd me))
      (emit :evt {:n 1} {:k "v"})
      (let (got (tel-recv))
        (stop-telemetry)
        (assert= got [:evt {:n 1} {:k "v"}]))))

  (test "emit defaults measurements and metadata to {}"
    (let (me (self))
      (start-telemetry) (detach-all)
      (attach :h :evt (tel-fwd me))
      (emit :evt)
      (let (got (tel-recv))
        (stop-telemetry)
        (assert= got [:evt {} {}]))))

  (test "emit always returns nil and never throws"
    (do
      (start-telemetry) (detach-all)
      (assert= (emit :evt) nil)
      (assert= (emit :evt {:n 1}) nil)
      (stop-telemetry)))

  (test "a handler attached to another event does not fire"
    (let (me (self))
      (start-telemetry) (detach-all)
      (attach :h :other (tel-fwd me))
      (emit :evt {:n 1})
      (telemetry-sync)
      (let (r (tel-none))
        (stop-telemetry)
        (assert= r :none))))

  (test "multiple handlers on one event all fire"
    (let (me (self))
      (start-telemetry) (detach-all)
      (attach :a :evt (fn (e m md) (send me :done)))
      (attach :b :evt (fn (e m md) (send me :done)))
      (attach :c :evt (fn (e m md) (send me :done)))
      (emit :evt)
      (let (got (tel-await 3))
        (stop-telemetry)
        (assert= got :ok))))

  (test "detach stops a handler"
    (let (me (self))
      (start-telemetry) (detach-all)
      (attach :h :evt (tel-fwd me))
      (detach :h)
      (emit :evt {:n 1})
      (telemetry-sync)
      (let (r (tel-none))
        (stop-telemetry)
        (assert= r :none))))

  (test "re-attaching the same id replaces, not duplicates"
    (do
      (start-telemetry) (detach-all)
      (attach :h :evt (fn (e m md) nil))
      (attach :h :evt (fn (e m md) nil))
      (let (n (count (tel-ids :evt)))
        (stop-telemetry)
        (assert= n 1))))

  (test "detach-all clears every handler"
    (do
      (start-telemetry) (detach-all)
      (attach :a :evt (fn (e m md) nil))
      (attach :b :ev2 (fn (e m md) nil))
      (detach-all)
      (let (h (handlers))
        (stop-telemetry)
        (assert= h {})))))

;; ---- the isolation guarantee ------------------------------------------------
(describe "telemetry: handlers run in the listener, isolated from the emitter"
  :isolated
  (test "a handler's (self) is the listener, not the emitter"
    (let (lpid (start-telemetry) me (self))
      (detach-all)
      (attach :w :evt (fn (e m md) (send me [:where (self)])))
      (emit :evt)
      (let (where (receive ([:where p] p) (after 5000 :timeout)))
        (stop-telemetry)
        (is (= where lpid))
        (is (not (= where me))))))

  (test "a throwing handler is caught: listener survives, others still run, it is detached"
    (let (lpid (start-telemetry) me (self))
      (detach-all)
      (attach :bad  :evt (fn (e m md) (error "boom")))
      (attach :good :evt (tel-fwd me))
      (emit :evt {:n 1})
      (let (got (tel-recv))
        (telemetry-sync)                 ; ensure dispatch (incl. detach) completed
        (let (alive (= (telemetry-pid) lpid)
              ids   (tel-ids :evt))
          (stop-telemetry)
          (assert= got [:evt {:n 1} {}])
          (is alive)                     ; listener still the same, alive process
          (is (member? :good ids))
          (is (not (member? :bad ids)))))))

  (test "a handler that HARD-KILLS the listener never crashes the emitter"
    (let (lpid (start-telemetry) me (self))
      (detach-all)
      (monitor lpid)
      (attach :crash :boom (fn (e m md) (exit (self) :kill)))
      (emit :boom)                       ; async — the kill happens in the listener
      (let (reason (receive ([:down _ ~lpid r] r) (after 5000 :timeout)))
        (is (not (= reason :timeout)))   ; the listener really died
        (assert= (+ 40 2) 42))))         ; and WE (the emitter) are still running

  (test "telemetry recovers after a listener crash — handlers survive in the global"
    (let (lpid (start-telemetry) me (self))
      (detach-all)
      (monitor lpid)
      (attach :ok    :evt  (tel-fwd me))
      (attach :crash :boom (fn (e m md) (exit (self) :kill)))
      (emit :boom)
      (receive ([:down _ ~lpid _] :ok) (after 5000 :timeout))
      (let (l2 (start-telemetry))        ; restart the listener
        (is (not (= l2 lpid)))
        (emit :evt {:n 1})
        (let (got (tel-recv))
          (detach-all) (stop-telemetry)
          (assert= got [:evt {:n 1} {}]))))))

;; ---- forward ----------------------------------------------------------------
(describe "telemetry: forward"
  :isolated
  (test "forward delivers the event to a process you own"
    (let (me (self))
      (start-telemetry) (detach-all)
      (forward :fwd :evt me)
      (emit :evt {:n 5} {:k :v})
      (let (got (receive ([:telemetry e m md] [e m md]) (after 5000 :timeout)))
        (stop-telemetry)
        (assert= got [:evt {:n 5} {:k :v}])))))

;; ---- span -------------------------------------------------------------------
(describe "telemetry: span"
  :isolated
  (test "span emits :start then :stop with a duration, returns the body value"
    (let (me (self))
      (start-telemetry) (detach-all)
      (attach :s [:job :start] (tel-fwd me))
      (attach :e [:job :stop]  (tel-fwd me))
      (let (result (span [:job] {:tag 1} (+ 1 2))
            start  (tel-recv)
            stop   (tel-recv))
        (stop-telemetry)
        (assert= result 3)
        (assert= (first start) [:job :start])
        (assert= (first stop) [:job :stop])
        (is (>= (get (second stop) :duration) 0)))))

  (test "span emits :exception and re-raises; the emitter survives the throw"
    (let (me (self))
      (start-telemetry) (detach-all)
      (attach :x [:job :exception] (tel-fwd me))
      (let (threw (try (span [:job] {} (error "boom")) :no-throw (catch e (error-message e)))
            ex    (tel-recv))
        (stop-telemetry)
        (assert= threw "boom")
        (assert= (first ex) [:job :exception])
        (assert= (get (nth ex 2) :error) "boom")
        (assert= (+ 1 1) 2)))))          ; emitter alive after the span throw

;; ---- not started / after stop ----------------------------------------------
(describe "telemetry: not started / after stop"
  :isolated
  (test "emit and span are no-ops when telemetry isn't started"
    (do
      (stop-telemetry)
      (assert= (telemetry-pid) nil)
      (assert= (emit :x {:a 1}) nil)
      (assert= (span :x {} 99) 99)       ; span still runs its body and returns it
      (assert= (telemetry-sync) :no-listener)))

  (test "emit after stop is a no-op (no crash)"
    (do
      (start-telemetry) (detach-all)
      (stop-telemetry)
      (assert= (emit :x {:a 1}) nil))))

;; ---- concurrency ------------------------------------------------------------
(describe "telemetry: concurrent emitters"
  :isolated
  (test "telemetry-sync flushes: after sync the handler effect is observable"
    (let (me (self))
      (start-telemetry) (detach-all)
      (attach :h :evt (tel-fwd me))
      (emit :evt {:n 1})
      (telemetry-sync)                   ; listener has now processed the emit
      (let (got (receive ([:ev e m md] [e m md]) (after 0 :none)))
        (stop-telemetry)
        (assert= got [:evt {:n 1} {}]))))

  (test "many processes emit once; every event reaches the handler, none lost"
    (let (me (self) n 200)
      (start-telemetry) (detach-all)
      (attach :h :evt (fn (e m md) (send me :done)))
      (fold (fn (_ i) (spawn (emit :evt {:i i}))) nil (range n))
      (let (got (tel-await n))
        (stop-telemetry)
        (assert= got :ok)))))
