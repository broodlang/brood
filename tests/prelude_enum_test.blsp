(defmodule prelude-enum-test (:use test))

(describe "chunk-every"
  (test "even split"
    (assert= [[1 2] [3 4] [5 6]] (into [] (map (fn (x) (into [] x)) (chunk-every 2 [1 2 3 4 5 6])))))
  (test "trailing chunk kept"
    (assert= [[1 2] [3]] (into [] (map (fn (x) (into [] x)) (chunk-every 2 [1 2 3])))))
  (test "larger than collection"
    (assert= [[1 2 3]] (into [] (map (fn (x) (into [] x)) (chunk-every 5 [1 2 3])))))
  (test "empty collection"
    (assert= nil (chunk-every 3 nil)))
  (test "chunk size 1"
    (assert= [[1] [2] [3]] (into [] (map (fn (x) (into [] x)) (chunk-every 1 [1 2 3]))))))

(describe "chunk-by"
  (test "groups consecutive equal values"
    (assert= [[1 1] [2] [1 1 1]] (into [] (map (fn (x) (into [] x)) (chunk-by identity [1 1 2 1 1 1])))))
  (test "by key function"
    (let (r (chunk-by even? [2 4 1 3 6]))
      (assert= [[2 4] [1 3] [6]] (into [] (map (fn (x) (into [] x)) r)))))
  (test "empty"
    (assert= nil (chunk-by identity nil)))
  (test "all same"
    (assert= [[1 1 1]] (into [] (map (fn (x) (into [] x)) (chunk-by identity [1 1 1]))))))

(describe "scan"
  (test "running sum"
    (assert= '(0 1 3 6 10) (scan + 0 '(1 2 3 4))))
  (test "empty collection"
    (assert= '(0) (scan + 0 nil)))
  (test "single element"
    (assert= '(0 1) (scan + 0 '(1))))
  (test "reductions alias"
    (assert= (scan + 0 '(1 2 3)) (reductions + 0 '(1 2 3)))))

(describe "flat-map"
  (test "basic mapcat"
    (assert= '(1 2 2 4 3 6) (flat-map (fn (x) (list x (* x 2))) '(1 2 3))))
  (test "empty"
    (assert= nil (flat-map (fn (x) (list x)) nil)))
  (test "same as mapcat"
    (assert= (mapcat (fn (x) (list x x)) '(1 2 3))
             (flat-map (fn (x) (list x x)) '(1 2 3)))))

(describe "zip-with"
  (test "addition of pairs"
    (assert= '(5 7 9) (zip-with + '(1 2 3) '(4 5 6))))
  (test "stops at shorter"
    (assert= '(1 4) (zip-with * '(1 2 3) '(1 2))))
  (test "first empty"
    (assert= nil (zip-with + nil '(1 2))))
  (test "builds pairs"
    (assert= '([1 4] [2 5]) (zip-with (fn (a b) [a b]) '(1 2) '(4 5)))))

(describe "intersperse"
  (test "basic"
    (assert= '(1 0 2 0 3) (intersperse 0 '(1 2 3))))
  (test "single element unchanged"
    (assert= '(1) (intersperse 0 '(1))))
  (test "empty"
    (assert= nil (intersperse 0 nil)))
  (test "alias for interpose"
    (assert= (interpose :x '(a b c)) (intersperse :x '(a b c)))))

(describe "min-by"
  (test "by string length"
    (assert= "a" (min-by string-length '("ccc" "bb" "a"))))
  (test "by identity"
    (assert= 1 (min-by identity '(3 1 2))))
  (test "by negative"
    (assert= 5 (min-by (fn (n) (- n)) '(3 1 5 2)))))

(describe "max-by"
  (test "by string length"
    (assert= "ccc" (max-by string-length '("ccc" "bb" "a"))))
  (test "by identity"
    (assert= 3 (max-by identity '(3 1 2))))
  (test "by negative"
    (assert= 1 (max-by (fn (n) (- n)) '(3 1 5 2)))))
