;; `link` / `unlink` / `trap-exit` — Erlang-style process links (ADR-067), the
;; symmetric, bidirectional cousin of `monitor`. A linked peer's death either
;; arrives as a trappable `[:EXIT pid reason]` (if you `(trap-exit true)`) or — for
;; an abnormal reason — takes you down too (propagation, cascading through links).
;; A `:normal` exit never kills a non-trapping peer.
;;
;; Register-only — each test runs in its own green process on the worker pool, so
;; link/trap/propagate is exercised across cores; the `:isolated` block at the end
;; stresses a propagation chain concurrently.

(require 'test)

;; file-local worker bodies (tail-recursive — a test runs in a small-stack proc)
(defn lk-park () (receive (:never :x)))           ; parks forever
(defn lk-crash-on (sig) (receive (~sig (error "boom"))))  ; crash when told

(describe "links: trap-exit delivers [:EXIT], no trap propagates"

  (test "a trapping process gets [:EXIT pid reason] when a linked peer crashes"
    (let (me (self))
      (trap-exit true)
      (let (p (spawn (lk-crash-on :die)))
        (link p)
        (send p :die)
        (assert= true
          (receive ([:EXIT ~p [:error _]] true) (after 2000 :NONE))))
      (trap-exit false)))

  (test "a trapping process gets [:EXIT pid :normal] when a linked peer returns"
    (trap-exit true)
    (let (p (spawn :ok))                          ; returns immediately → :normal
      (link p)
      (assert= :normal
        (receive ([:EXIT ~p r] r) (after 2000 :NONE))))
    (trap-exit false))

  (test "linking an already-dead pid notifies immediately with :noproc"
    (trap-exit true)
    (let (p (spawn :ok))
      (sleep 30)                                  ; let it finish
      (link p)
      (assert= :noproc
        (receive ([:EXIT ~p r] r) (after 2000 :NONE))))
    (trap-exit false)))

(describe "links: propagation and unlink"

  (test "a non-trapping linked peer dies when its partner crashes"
    ;; watcher doesn't trap; it's linked to a crasher → it must die too.
    (let (watcher (spawn (do (trap-exit false) (lk-park)))
          wm      (monitor watcher))
      (spawn (do (link watcher) (sleep 20) (error "crash")))
      (is (not (= :SURVIVED
        (receive ([:down ~wm ~watcher _] :died) (after 2000 :SURVIVED)))))))

  (test "a :normal exit does NOT take down a non-trapping linked peer"
    (let (me (self)
          survivor (spawn (do (trap-exit false)
                              (let (c (spawn :ok))   ; child returns :normal
                                (link c)
                                (sleep 80)           ; outlive the child's normal exit
                                (send me [:alive (self)])
                                (receive (:stop :ok))))))
      (assert= true
        (receive ([:alive ~survivor] true) (after 2000 false)))
      (exit survivor :kill)))

  (test "unlink breaks the coupling — a later crash doesn't propagate"
    (let (watcher (spawn (do (trap-exit false) (lk-park)))
          wm      (monitor watcher))
      (let (c (spawn (do (link watcher) (sleep 20) (unlink watcher) (sleep 20) (error "crash"))))
        ;; after unlink, c's crash must NOT kill watcher
        (assert= :still-linked-free
          (receive ([:down ~wm ~watcher _] :propagated) (after 300 :still-linked-free))))
      (exit watcher :kill))))

(describe "links: cascade through a chain"
  :isolated

  (test "killing the head of a linked chain takes the whole chain down"
    ;; a — b — c linked in a chain (each links the next). Kill a → b dies
    ;; (propagation) → c dies. We monitor c and watch it fall.
    (let (me (self)
          c (spawn (do (trap-exit false) (lk-park)))
          b (spawn (do (trap-exit false) (link c) (lk-park)))
          a (spawn (do (trap-exit false) (link b) (lk-park)))
          cm (monitor c))
      (sleep 40)                                   ; let the chain wire up
      (exit a :stop)                               ; abnormal (≠ :normal) → propagates b→c
      (assert= :chain-down
        (receive ([:down ~cm ~c _] :chain-down) (after 2000 :SURVIVED))))))
