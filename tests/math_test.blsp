;; Math library — the float kernel ops (floor/ceil/round/sqrt/pow, quot) and the
;; Brood layer over them (even?/odd?, variadic min/max). The whole suite runs in
;; parallel (each test is its own green process), so these already exercise the
;; ops on multiple cores; the final :isolated block adds explicit spawn/send/
;; fan-in coverage. Register-only — discovered and run by `nest test` / cargo test.

(defmodule math-test (:use test))

;; sqrt is Brood (Newton's method), so it's approximate — compare within epsilon.
(defn mth-approx? (a b) (< (abs (- a b)) 1e-9))

(describe "rounding (floor / ceil / round)"
  (test "floor rounds toward negative infinity, returning an Int"
    (assert= (floor 3.7) 3)
    (assert= (floor 3.2) 3)
    (assert= (floor -3.2) -4)
    (assert= (type-of (floor 3.7)) :int))
  (test "ceil rounds toward positive infinity"
    (assert= (ceil 3.2) 4)
    (assert= (ceil 3.7) 4)
    (assert= (ceil -3.7) -3))
  (test "round rounds half away from zero"
    (assert= (round 3.5) 4)
    (assert= (round 3.4) 3)
    (assert= (round -3.5) -4))
  (test "an Int passes through the rounders unchanged"
    (assert= (floor 5) 5)
    (assert= (ceil 5) 5)
    (assert= (round 5) 5))
  (test "rounders reject a non-number"
    (assert-error (floor "x"))
    (assert-error (ceil :k))
    (assert-error (round nil)))
  (test "round-to keeps a fixed number of decimal places"
    (assert= (round-to 3.14159 2) 3.14)
    (assert= (round-to 0.015873015873 3) 0.016)
    (assert= (round-to 2.5 0) 3))
  (test "round-to handles both signs (halves away from zero on the scaled value)"
    (assert= (round-to -3.14159 2) -3.14)
    (assert= (round-to -2.5 0) -3)
    (assert= (round-to 12.345 1) 12.3)))

(describe "bench"
  (test "returns its expression's value while timing it"
    (assert= (bench "sum" (reduce + 0 (range 100))) 4950))
  (test "the timed value is whatever the body evaluates to"
    (assert= (bench "noop" [:a :b]) [:a :b])))

(describe "now-ns (fine-grained timing)"
  (test "is a positive integer"
    (is (int? (now-ns)))
    (is (> (now-ns) 0)))
  (test "does not run backwards within a process"
    (let (a (now-ns) b (now-ns)) (is (>= b a)))))

(describe "sqrt and pow"
  (test "sqrt approximates the root and is always a Float"
    (is (mth-approx? (sqrt 16) 4))
    (is (mth-approx? (sqrt 4.0) 2))
    (is (mth-approx? (sqrt 2) 1.4142135623730951))
    (is (mth-approx? (* (sqrt 7) (sqrt 7)) 7))
    ; round-trips
    (assert= (sqrt 0) 0.0)
    (assert= (type-of (sqrt 9)) :float))
  (test "sqrt rejects a negative argument" (assert-error (sqrt -1)))
  (test "pow stays an Int when both args are non-negative ints"
    (assert= (pow 2 10) 1024)
    (assert= (pow 5 0) 1)
    (assert= (pow 10 3) 1000)
    (assert= (type-of (pow 2 3)) :int))
  (test "a negative exponent gives the reciprocal as a float"
    (assert= (pow 2 -1) 0.5)
    (assert= (pow 2 -3) 0.125)
    (assert= (type-of (pow 2 -1)) :float))
  (test "a float base with an integer exponent stays a float"
    (assert= (pow 2.0 3) 8.0)
    (assert= (pow 1.5 2) 2.25))
  (test "pow requires an integer exponent (use sqrt for roots)" (assert-error (pow 2 0.5)))
  (test "pow and sqrt reject a non-number" (assert-error (sqrt "x")) (assert-error (pow :a 2))))

(describe "quot, even? and odd?"
  (test "quot is truncated integer division"
    (assert= (quot 17 5) 3)
    (assert= (quot -17 5) -3)
    ; truncates toward zero (unlike floor)
    (assert= (type-of (quot 17 5)) :int))
  (test "quot by zero raises" (assert-error (quot 1 0)))
  (test "quot/rem reconstruct the dividend" (assert= (+ (* (quot 17 5) 5) (rem 17 5)) 17))
  (test "even? / odd? classify integers"
    (is (even? 0))
    (is (even? 4))
    (is (even? -2))
    (refute (even? 3))
    (is (odd? 1))
    (is (odd? -3))
    (refute (odd? 4))))

(describe "variadic min / max"
  (test "max / min over many args keep the extreme"
    (assert= (max 3 1 4 1 5 9 2 6) 9)
    (assert= (min 3 1 4 1 5 9 2 6) 1))
  (test "max / min on a single arg return it" (assert= (max 7) 7) (assert= (min 7) 7))
  (test "max / min work on floats and mixed numbers"
    (assert= (max 1 2.5 2) 2.5)
    (assert= (min 1 2.5 0.5) 0.5)))

(describe "bitwise operators"
  (test "and / or / xor on small ints"
    (assert= (bit-and 12 10) 8)
    (assert= (bit-or 12 10) 14)
    (assert= (bit-xor 12 10) 6)
    (assert= (bit-and 0 255) 0)
    (assert= (bit-or 0 0) 0))
  (test "not is two's-complement: (bit-not n) = -(n+1)"
    (assert= (bit-not 0) -1)
    (assert= (bit-not -1) 0)
    (assert= (bit-not 5) -6))
  (test "shift-left multiplies by powers of two"
    (assert= (bit-shift-left 1 0) 1)
    (assert= (bit-shift-left 1 13) 8192)
    (assert= (bit-shift-left 3 4) 48))
  (test "shift-right is arithmetic (sign-preserving)"
    (assert= (bit-shift-right 48 4) 3)
    (assert= (bit-shift-right -8 1) -4)
    (assert= (bit-shift-right 1 0) 1))
  (test "shift round-trips below the high bits"
    (assert= (bit-shift-right (bit-shift-left 1234 8) 8) 1234))
  (test "a shift amount outside [0, 64) is a clean error, not a crash"
    (assert-error (bit-shift-left 1 64))
    (assert-error (bit-shift-right 1 -1)))
  (test "bitwise ops reject non-integers"
    (assert-error (bit-and 1 "x"))
    (assert-error (bit-not :k))
    (assert-error (bit-shift-left 1.5 2))))

;; ---- explicit concurrency (spawn / send / fan-in) ---------------------------
;; :isolated so these run against a private globals copy and don't contend with
;; the parallel suite for the runner's mailbox. Workers compute math results on
;; the scheduler's green-process pool; the parent fans them in. Defined once at
;; load (distinct mth- names) so they survive the :isolated rollback.

(defn mth-emit (parent n) (send parent [:r n (* n n) (pow n 3)]))
(defn mth-spawn (parent ns)
  (when (not (empty? ns)) (spawn (mth-emit parent (first ns))) (mth-spawn parent (rest ns))))
(defn mth-collect (got total acc)
  (if (= got total)
    acc
    (mth-collect (+ got 1) total (receive ([:r n sq cu] (assoc acc n [sq cu]))))))

(def mth-consts {:two 2 :ten 10})
; a shared global read by many processes
(defn mth-reader (parent i) (send parent [:p (pow (get mth-consts :two) i)]))
(defn mth-spawn-readers (parent n)
  (when (> n 0) (spawn (mth-reader parent n)) (mth-spawn-readers parent (- n 1))))
(defn mth-sum (got total acc)
  (if (= got total) acc (mth-sum (+ got 1) total (receive ([:p v] (+ acc v))))))

(describe "math across processes"
  :isolated

  (test "fan-out / fan-in: workers compute squares and cubes, parent folds them"
    (mth-spawn (self) (range 1 21))
    ; 20 workers, n = 1..20
    (let (m (mth-collect 0 20 {}))
      (assert= (count m) 20)
      (assert= (get m 2) [4 8])
      (assert= (get m 12) [144 1728])
      (assert= (get m 20) [400 8000])))

  (test "many processes concurrently read a shared GLOBAL map of constants"
    ;; Σ 2^i for i in 1..10 = 2^11 - 2 = 2046.
    (mth-spawn-readers (self) 10)
    (assert= (mth-sum 0 10 0) 2046))

  (test "an int result survives the round-trip across heaps (deep copy on send)"
    (let (me (self) w (spawn (mth-emit me 7)))
      (assert= (receive ([:r n sq cu] [n sq cu])) [7 49 343]))))
