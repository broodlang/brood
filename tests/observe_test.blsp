;; The display/input seam (M3, ADR-046): the `display` render-op protocol and the
;; pure core of the interactive `observe` process viewer. The frame builders are
;; pure data, so they are fully testable without a terminal; the `term-*`
;; primitives (the crossterm frontend) need a real TTY and are exercised by
;; `nest observe`.
;;
;; The closing :isolated block adds cross-process coverage: it spawns real
;; processes and drives the `mailbox-size` primitive + `observe--snapshot` from a
;; live runtime, proving the one new Rust accessor works under the scheduler.

(require 'test)
(require 'observe)        ; pulls in display too

(describe "display render-op constructors"
  (test "clear / text / cursor build tagged op vectors"
    (assert= (clear) [:clear])
    (assert= (text 2 4 "hi") [:text 2 4 "hi"])
    (assert= (text 2 4 "hi" {:bold true}) [:text 2 4 "hi" {:bold true}])
    (assert= (cursor 1 7) [:cursor 1 7]))
  (test "text omits the face slot when none is given"
    (assert= (count (text 0 0 "x")) 4)
    (assert= (count (text 0 0 "x" {:fg :red})) 5))
  (test "frame collects ops into a vector and drops nils"
    (let (f (frame (clear) nil (text 0 0 "a") nil (cursor 0 1)))
      (is (vector? f))
      (assert= (count f) 3)
      (assert= (first f) [:clear])
      (assert= (nth f 2) [:cursor 0 1])))
  (test "an empty frame is the empty vector"
    (assert= (frame) [])
    (assert= (frame nil nil) [])))

(describe "observer pure helpers"
  (test "observe--fit truncates to width, leaves shorter strings alone"
    (assert= (observe--fit "hello" 3) "hel")
    (assert= (observe--fit "hi" 10) "hi")
    (assert= (observe--fit "abc" 0) ""))
  (test "observe--bytes->human scales B / KB / MB"
    (assert= (observe--bytes->human 512) "512 B")
    (assert= (observe--bytes->human 2048) "2 KB")
    (assert= (observe--bytes->human 3145728) "3 MB"))
  (test "observe--row lays out a marker + pid + mailbox in fixed columns"
    (let (r (observe--row "▸ " "p1" 7))
      (is (string-contains? r "▸"))
      (is (string-contains? r "p1"))
      (is (string-contains? r "7"))
      ;; 2-wide marker + 24-wide pid + 8-wide mailbox
      (assert= (string-length r) 34)))
  (test "observe--window-start keeps the selection on screen, clamped"
    (assert= (observe--window-start 0 5 10) 0)      ; top
    (assert= (observe--window-start 5 5 10) 3)      ; centred (5 - 5/2)
    (assert= (observe--window-start 9 5 10) 5))     ; clamped to maxstart = 10-5
  (test "observe--sel-index follows a pid across the list, recovers if gone"
    (let (ps [{:pid "a" :mailbox 0} {:pid "b" :mailbox 0} {:pid "c" :mailbox 0}])
      (assert= (observe--sel-index ps "b") 1)
      (assert= (observe--sel-index ps "gone") 0)    ; missing → 0
      (assert= (observe--sel-index [] "b") 0)))     ; empty → 0
  (test "observe--node-lines summarises the node panel"
    (let (node {:name :nonode :workers 4 :peak 6 :spawned 10
                :mem 2048 :mem-peak 4096 :peers []}
          ls (observe--node-lines node 3))
      (is (string-contains? (nth ls 0) "node nonode"))
      (is (string-contains? (nth ls 0) "3 processes"))
      (is (string-contains? (nth ls 1) "workers 4 (peak 6)"))
      (is (string-contains? (nth ls 1) "2 KB")))))

(def sample-node {:name :nonode :workers 4 :peak 6 :spawned 10
                  :mem 2048 :mem-peak 4096 :peers []})

(describe "observe-frame (the pure render core)"
  (test "node panel + header + a row per process + detail + footer"
    (let (procs [{:pid "#<pid nonode/1>" :mailbox 0}
                 {:pid "#<pid nonode/2>" :mailbox 3}]
          f (observe-frame sample-node procs 0 60 12 false))
      (is (vector? f))
      ;; clear + 2 node lines + col-header + 2 body rows + detail + footer = 8
      (assert= (count f) 8)
      (assert= (first f) [:clear])
      ;; node panel line 1 names the node and process count
      (is (string-contains? (nth (nth f 1) 3) "brood observer"))
      (is (string-contains? (nth (nth f 1) 3) "2 processes"))
      ;; first body row is a :text op at row 3 carrying its pid
      (let (row0 (nth f 4))
        (assert= (first row0) :text)
        (assert= (nth row0 1) 3)
        (is (string-contains? (nth row0 3) "nonode/1")))))

  (test "the selected row is marked and highlighted; others are plain"
    (let (procs [{:pid "a" :mailbox 0} {:pid "b" :mailbox 0}]
          f (observe-frame sample-node procs 1 60 12 false)
          row0 (nth f 4)        ; process row at index 0 (not selected)
          row1 (nth f 5))       ; process row at index 1 (selected)
      (assert= (count row0) 4)                       ; no face
      (assert= (count row1) 5)                       ; styled
      (assert= (nth row1 4) {:reverse true})
      (is (string-contains? (nth row1 3) "▸"))))

  (test "detail line names the selection; footer reflects paused state"
    (let (procs [{:pid "p-zero" :mailbox 0} {:pid "p-one" :mailbox 9}]
          live (observe-frame sample-node procs 1 60 12 false)
          paused (observe-frame sample-node procs 1 60 12 true))
      ;; detail is the second-to-last op
      (is (string-contains? (nth (nth live (- (count live) 2)) 3) "p-one"))
      (is (string-contains? (nth (last live) 3) "pause"))
      (is (string-contains? (nth (last paused) 3) "PAUSED"))))

  (test "long lists are windowed to the terminal with a position counter"
    (let (procs (map (fn (i) {:pid (str "#<pid nonode/" i ">") :mailbox 0})
                     (range 20))
          f (observe-frame sample-node procs 0 60 8 false))   ; rows=8 → cap = 3
      ;; clear + 2 node + header + 3 body + detail + footer = 9
      (assert= (count f) 9)
      ;; the detail line shows a [sel/total] position counter when windowed
      (is (string-contains? (nth (nth f (- (count f) 2)) 3) "/20"))))

  (test "every text op is clipped to the terminal width"
    (let (f (observe-frame sample-node [{:pid "#<pid nonode/1>" :mailbox 0}] 0 20 10 false))
      (is (every? (fn (op) (or (not (= (first op) :text))
                               (<= (string-length (nth op 3)) 20)))
                  f)))))

;; Cross-process coverage: drive the new `mailbox-size` primitive and
;; `observe--snapshot` against a live runtime (each :isolated test runs alone).
(describe "observe against live processes"
  :isolated

  (test "mailbox-size reads a process's receive backlog"
    ;; A worker that only handles [:work _], so other messages pile up.
    (let (w (spawn (receive ([:work _] :done))))
      (send w :a) (send w :b)
      (sleep 20)
      (is (>= (mailbox-size w) 2))))

  (test "mailbox-size of a live process with an empty mailbox is 0, not nil"
    (is (= (mailbox-size (self)) 0)))

  (test "observe--snapshot yields {:pid :mailbox} maps for live processes"
    (let (w (spawn (receive (_ :done)))
          snap (observe--snapshot))
      (is (vector? (into [] snap)))
      (is (every? (fn (p) (and (string? (get p :pid))
                               (number? (get p :mailbox))))
                  snap))
      ;; the snapshot is a frame-ready input
      (is (>= (count (observe-frame (observe--node-info) snap 0 80 24 false)) 5)))))
