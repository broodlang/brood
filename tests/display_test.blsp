;; The render-op constructors (std/display.blsp): pure data→data, so they're fully
;; testable without a frontend — assert on the exact op vectors they build. Focus is
;; on `bar` (the full-width status / mode / buffer-bar component, ADR-046); the other
;; constructors are one-liners exercised throughout the suite.

(defmodule display-test (:use test) (:use editor/display))

(describe "bar — full-width status / buffer bar"
  (test "pads to the full width so a :bg/:reverse face fills the line"
    (assert= (bar 0 6 "hi" {:face {:reverse true}})
      [:text 0 0 "hi    " {:reverse true}]))

  (test "left is the default alignment"
    (assert= (bar 0 6 "hi" {}) [:text 0 0 "hi    "])
    (assert= (bar 0 6 "hi" {:align :left}) [:text 0 0 "hi    "]))

  (test ":center and :right position the text within the bar"
    (assert= (bar 0 6 "hi" {:align :center}) [:text 0 0 "  hi  "])
    (assert= (bar 0 6 "hi" {:align :right}) [:text 0 0 "    hi"]))

  (test "a string wider than the bar is truncated, never wrapped"
    (assert= (bar 0 4 "toolong" {}) [:text 0 0 "tool"]))

  (test "no :face yields a bare text op (no style map)"
    (assert= (bar 2 3 "x" {}) [:text 2 0 "x  "]))

  (test ":scale magnifies: width/scale characters, :scale merged into the face"
    ;; width 12 at scale 3 → 4 cells of text; \"G5\" centred → \" G5 \".
    (assert= (bar 5 12 "G5" {:face {:bg :blue} :align :center :scale 3})
      [:text 5 0 " G5 " {:bg :blue :scale 3}]))

  (test ":scale on a faceless bar still carries the scale"
    (assert= (bar 0 4 "ab" {:scale 2}) [:text 0 0 "ab" {:scale 2}])))

(describe "rect — a solid filled panel"
  (test "builds a [:rect row col w h face] op verbatim"
    (assert= (rect 3 5 20 4 {:bg :blue}) [:rect 3 5 20 4 {:bg :blue}]))
  (test "carries an RGB hex background (the chrome-panel use)"
    (assert= (rect 0 0 10 2 {:bg "#313244"}) [:rect 0 0 10 2 {:bg "#313244"}])))

(describe "cursor — optional caret style"
  (test "no style is the bare block-caret op"
    (assert= (cursor 2 7) [:cursor 2 7]))
  (test "a style keyword rides along (:bar / :underline / :block)"
    (assert= (cursor 2 7 :bar) [:cursor 2 7 :bar])
    (assert= (cursor 0 0 :underline) [:cursor 0 0 :underline])))

(describe "zone / zone-at — model-side hit-testing"
  (test "zone is plain data: rect + id (+ optional cursor)"
    (assert= (zone [2 3 4 1] :branch) {:rect [2 3 4 1] :id :branch :cursor nil})
    (assert= (zone [0 0 5 1] :x :hand) {:rect [0 0 5 1] :id :x :cursor :hand}))

  (test "zone-at returns the zone whose rect contains the cell, else nil"
    (let (zs [(zone [2 5 4 1] :a) (zone [10 5 3 1] :b)])
      (assert= (zone-at zs 3 5) (zone [2 5 4 1] :a))   ; inside a
      (assert= (zone-at zs 5 5) (zone [2 5 4 1] :a))   ; right edge of a (x+w-1)
      (assert= (zone-at zs 6 5) nil)                    ; gap between a and b
      (assert= (zone-at zs 10 5) (zone [10 5 3 1] :b))  ; inside b
      (assert= (zone-at zs 3 6) nil)))                  ; wrong row

  (test "zone-at is last-wins so a later (topmost) zone shadows an overlap"
    (let (zs [(zone [0 0 10 1] :under) (zone [3 0 4 1] :over)])
      (assert= (get (zone-at zs 4 0) :id) :over)
      (assert= (get (zone-at zs 1 0) :id) :under)))

  (test "zone-cursor-ops emits cursor-zone only for zones that request a shape"
    (assert= (zone-cursor-ops [(zone [2 3 4 1] :a) (zone [0 0 5 1] :b :hand)])
      (list [:cursor-zone 0 0 5 1 :hand]))))

(describe "card — floating overlay surface (surfaces + hairlines, no shadow)"
  (test "card-rect clamps the top-left so a w×h card stays on screen"
    (assert= (card-rect 3 5 10 4 80 24) [3 5])          ; fits — unchanged
    (assert= (card-rect 22 5 10 4 80 24) [20 5])        ; pushed up to fit height
    (assert= (card-rect 3 78 10 4 80 24) [3 70])        ; pushed left to fit width
    (assert= (card-rect -2 -2 10 4 80 24) [0 0]))       ; clamped to the origin

  (test "terminal card-surface is a single flat rect (no radius, no border)"
    (assert= (card-surface 3 5 10 4 {:bg "#313244"})
      (list [:rect 3 5 10 4 {:bg "#313244"}])))

  (test "GUI card-surface is a rounded frect; a :border adds a larger frect behind it"
    (assert= (card-surface 3 5 10 4 {:bg :blue} true)
      (list [:frect 5.0 3.0 10.0 4.0 {:bg :blue} 1.0 0.5]))
    (assert= (card-surface 3 5 10 4 {:bg :blue} true {:border {:bg :grey} :radius 0.4})
      (list [:frect 4.93 2.93 10.14 4.14 {:bg :grey} 1.0 (+ 0.4 0.07)]
            [:frect 5.0 3.0 10.0 4.0 {:bg :blue} 1.0 0.4])))

  (test "tooltip stacks its lines over a card sized to the widest line, anchored above"
    ;; two lines, widest 5 chars → w = 7, n = 2; anchored above row 10 → top row 8.
    (assert= (tooltip 10 4 ["main" "clean"] {:bg :blue} {:fg :white} 80 24)
      (list [:rect 8 4 7 2 {:bg :blue}]
            [:text 8 4 " main  " {:fg :white}]
            [:text 9 4 " clean " {:fg :white}]))))
