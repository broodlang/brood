;; The reusable app framework (std/ui.blsp): the `ui-run` loop and the display
;; composition. The frontends themselves (`*term-display*`/`gui-display`) need a
;; real terminal / window, so here we drive `ui-run` with a *scripted* display —
;; `:poll` reading the test process's own mailbox, `:draw` echoing frames back —
;; which is enough to exercise the loop (render → poll → update → done) and the
;; broadcast composition without any IO.

(defmodule ui-test (:use test) (:use editor/ui) (:use editor/display) (:use io))

;; Collect every [:saw x] message now in the mailbox, in send order — the tests
;; below have `view` announce each model it renders with `(send me [:saw …])`, so
;; the drained sequence is exactly the frames that rendered cleanly.
(defn drain-saw (acc)
  (receive ([:saw x] (drain-saw (cons x acc))) (after 0 (reverse acc))))

;; A scripted display: inputs arrive as `[:input …]` messages (selectively polled,
;; so interleaved `[:saw …]` render-echoes are skipped and survive for `drain-saw`).
(defn r--display (me)
  {:enter (fn () nil)
   :leave (fn () :left)
   :size (fn () [80 24])
   :draw (fn (f) nil)
   :poll (fn (ms) (receive ([:input i] i) (after 0 :tick)))})

(describe "ui-run — the TEA app loop"
  (test "loops until the model is :done, then returns the :leave result"
    (let (me (self))
      (send me "x")  ; one input waiting in our mailbox
      (assert=
        (ui-run {:done false}
          (fn (m c r) [])  ; view: empty frame
          (fn (m input c r) (assoc m :done true))  ; first input quits
          {:enter (fn () nil)
           :leave (fn () :left)
           :size (fn () [80 24])
           :draw (fn (f) nil)
           :poll (fn (ms) (receive (m m) (after 0 :tick)))})
        :left)))

  (test "a nil poll (timeout) is delivered to update as :tick"
    (let (me (self))
      (ui-run {:done false}
        (fn (m c r) [])
        (fn (m input c r) (do (send me [:saw input]) (assoc m :done true)))
        {:enter (fn () nil)
         :leave (fn () nil)
         :size (fn () [80 24])
         :draw (fn (f) nil)
         :poll (fn (ms) nil)})  ; nil ⇒ :tick
      (assert= (receive ([:saw x] x) (after 200 :none)) :tick)))

  (test "view gets the model + size, and its frame is what gets drawn"
    (let (me (self))
      (ui-run {:done false :label "hi"}
        (fn (m c r) [(text 0 0 (str (get m :label) " " c "x" r))])
        (fn (m input c r) (assoc m :done true))
        {:enter (fn () nil)
          :leave
          (fn () nil)
          :size
          (fn () [40 10])
          :draw
          (fn (f) (send me [:frame f]))  ; echo the drawn frame
          :poll
          (fn (ms) nil)})
      (let (f (receive ([:frame fr] fr) (after 200 :none)))
        (is (string-contains? (nth (first f) 3) "hi 40x10")))))

  (test "tick-ms comes from the model (default 1000)"
    (assert= (editor/ui/ui--tick-ms {}) 1000)
    (assert= (editor/ui/ui--tick-ms {:tick-ms 250}) 250))

  (test "a :close input (the window's X button) quits regardless of update"
    (let (me (self))
      (send me :close)  ; the close button, waiting in the mailbox
      (assert=
        (ui-run {:done false}
          (fn (m c r) [])
          ;; update NEVER sets :done — only :close can stop this loop,
          ;; proving ui-run quits on :close without update's help.
          (fn (m input c r) (do (send me [:update-saw input]) m))
          {:enter (fn () nil)
           :leave (fn () :left)
           :size (fn () [80 24])
           :draw (fn (f) nil)
           :poll (fn (ms) (receive (m m) (after 0 :tick)))})
        :left)
      ;; update is bypassed entirely for :close (the loop quits before calling it).
      (assert= (receive ([:update-saw x] x) (after 100 :never-called)) :never-called)))

  (test "quit-request? recognises :close, not the Escape key or other input"
    (is (quit-request? :close))
    (is (not (quit-request? :escape)))  ; the Escape key is NOT a close request
    (is (not (quit-request? "q")))
    (is (not (quit-request? :tick)))))

(describe "display-broadcast — one frame to many frontends"
  (test "fans :draw to every member and reports the smallest common size"
    (let (me (self)
          d1 {:enter (fn () nil)
              :leave (fn () nil)
              :size (fn () [80 24])
              :draw (fn (f) (send me [:d1 f]))
              :poll (fn (ms) nil)}
          d2 {:enter (fn () nil)
              :leave (fn () nil)
              :size (fn () [60 30])
              :draw (fn (f) (send me [:d2 f]))
              :poll (fn (ms) nil)}
          b (display-broadcast [d1 d2]))
      (assert= ((get b :size)) [60 24])  ; min cols (60), min rows (24)
      ((get b :draw) [:FRAME])
      (assert= (receive ([:d1 f] f) (after 200 :none)) [:FRAME])
      (assert= (receive ([:d2 f] f) (after 200 :none)) [:FRAME]))))

(describe "ui-run — let-it-crash at the render loop (resilient loop)"
  (test "a throwing view rolls back to the last good frame and keeps looping"
    (let (me (self))
      (send me [:input :go-b])     ; a -> b   (good)
      (send me [:input :go-boom])  ; b -> bad (a model whose view throws)
      (send me [:input :go-c])     ; recover, then -> c
      (send me [:input :quit])
      (assert=
        (ui-run {:tag :a}
          (fn (m c r)
            (when (get m :boom) (throw "view boom"))  ; the wedged model can't render
            (send me [:saw (get m :tag)])             ; announce a clean render
            [])
          (fn (m input c r)
            (cond
              (= input :go-b)    {:tag :b}
              (= input :go-boom) {:tag :bad :boom true}
              (= input :go-c)    {:tag :c}
              (= input :quit)    (assoc m :done true)
              :else m))
          (r--display me))
        :left)
      ;; a, b, (bad throws — no render), b again (rolled back + re-rendered), c.
      ;; the repeated :b proves the loop recovered to the last good frame.
      (assert= (drain-saw []) (list :a :b :b :c))))

  (test "a throwing update drops the bad input and keeps the current model"
    (let (me (self))
      (send me [:input :inc])   ; 0 -> 1
      (send me [:input :boom])  ; update throws — dropped, model unchanged
      (send me [:input :inc])   ; continues off n=1 (not 0), so reaches 2
      (send me [:input :quit])
      (ui-run {:n 0}
        (fn (m c r) (send me [:saw (get m :n)]) [])
        (fn (m input c r)
          (cond
            (= input :inc)  (assoc m :n (+ (get m :n) 1))
            (= input :boom) (throw "update boom")
            (= input :quit) (assoc m :done true)
            :else m))
        (r--display me))
      ;; rendered n: 0, 1, 1 (boom dropped — model held at 1), 2.
      (assert= (drain-saw []) (list 0 1 1 2))))

  (test "a throw on the FIRST render is fatal — re-raised, and :leave still runs"
    (let (me (self))
      (assert=
        (try
          (ui-run {}
            (fn (m c r) (throw :startup-boom))  ; first render throws, no last-good yet
            (fn (m input c r) m)
            {:enter (fn () nil)
             :leave (fn () (send me [:left]))  ; teardown must still happen
             :size (fn () [80 24])
             :draw (fn (f) nil)
             :poll (fn (ms) :tick)})
          (catch e e))
        :startup-boom)
      ;; the outer try restored the terminal (ran :leave) before re-raising
      (is (= [:left] (receive ([:left] [:left]) (after 100 :no))))))

  (test "a recovered error is logged to stderr (via *err*)"
    (let (me (self))
      (send me [:input :boom])
      (send me [:input :quit])
      (let (logged
            (with-err (fn-port (fn (s) (send me [:err s])))
              (ui-run {:n 0}
                (fn (m c r) [])
                (fn (m input c r)
                  (cond
                    (= input :boom) (throw "kaboom!")
                    (= input :quit) (assoc m :done true)
                    :else m))
                (r--display me))
              (receive ([:err s] s) (after 0 ""))))
        (is (string-contains? logged "update error"))
        (is (string-contains? logged "kaboom!"))))))

;; overlay-route — the modal-overlay dispatch fallthrough shared by the editor's
;; transient overlays and the observer's minibuffer.
(describe "overlay-route"
  ;; two overlays: a capture-all "mini" (owns every key) and a "pop" that owns only "x".
  (def overlays
    (list {:active? (fn (m) (get m :mini)) :owns? nil
           :handle (fn (m k) (assoc m :typed k)) :exit nil}
          {:active? (fn (m) (get m :pop)) :owns? (fn (m k) (= k "x"))
           :handle (fn (m k) (assoc m :popped k)) :exit (fn (m) (assoc m :pop nil :exited true))}))
  (defn fallback (m k) (assoc m :dispatched k))
  (test "no overlay open → fallback"
    (assert= (get (overlay-route overlays {} "a" fallback) :dispatched) "a"))
  (test "capture-all overlay handles every key (owns? nil)"
    (let (r (overlay-route overlays {:mini true} "a" fallback))
      (assert= (get r :typed) "a")
      (is (nil? (get r :dispatched)))))
  (test "an owning overlay handles its key"
    (assert= (get (overlay-route overlays {:pop true} "x" fallback) :popped) "x"))
  (test "a non-owned key exits the overlay then falls through (dismiss-and-process)"
    (let (r (overlay-route overlays {:pop true} "a" fallback))
      (is (get r :exited))
      (is (nil? (get r :pop)))
      (assert= (get r :dispatched) "a")))
  (test "list order is precedence (first active wins)"
    (assert= (get (overlay-route overlays {:mini true :pop true} "x" fallback) :typed) "x"))
  (test "overlay-active returns the first active overlay, or nil"
    (is (nil? (overlay-active overlays {})))
    (assert= (get (overlay-active overlays {:pop true}) :active?) (get (second overlays) :active?))))

;; ui--coalesce-drag — collapse a flood of per-cell mouse :drag events to the latest,
;; so a fast drag renders once at the final position instead of once per cell crossed.
(describe "ui--coalesce-drag"
  (test "non-drag messages pass through untouched (incl. nil on timeout)"
    (assert= (editor/ui/ui--coalesce-drag "x") "x")
    (assert= (editor/ui/ui--coalesce-drag :tick) :tick)
    (assert= (editor/ui/ui--coalesce-drag [:mouse :press :left 3 3 []]) [:mouse :press :left 3 3 []])
    (is (nil? (editor/ui/ui--coalesce-drag nil))))
  (test "queued drags collapse to the latest; other messages stay in the mailbox"
    (let (me (self))
      (send me [:mouse :drag :left 6 6 []])
      (send me [:mouse :drag :left 7 7 []])
      (send me "k")  ; a key after the drags — must survive
      ;; pass in the first drag (as the poll would); the queued drags drain to the last
      (assert= (editor/ui/ui--coalesce-drag [:mouse :drag :left 5 5 []]) [:mouse :drag :left 7 7 []])
      (assert= (receive (m m) (after 200 :none)) "k"))))  ; the key is still there
