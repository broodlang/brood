;; `with-out-str` — capture printed output as a string. The prelude macro over the
;; `%capture-begin`/`%capture-take` kernel surface (a process-scoped, nesting,
;; spawn-inherited capture stack). Register-only — discovered and run by
;; `nest test` (and cargo test, via crates/lisp/tests/suite.rs).

(defmodule capture-test (:use test))

(describe "with-out-str"
  (test "captures printed output as a string"
    (assert= (with-out-str (print "hello")) "hello"))

  (test "captures across several prints in the body"
    (assert= (with-out-str (print "a") (print "b") (println "c")) "abc\n"))

  (test "empty string when the body prints nothing, discarding the body's value"
    (assert= (with-out-str 42) "")
    (assert= (with-out-str (+ 1 2)) ""))

  (test "captured output does not reach the next capture (buffer is popped)"
    ;; if the first call leaked its buffer, the second would also see "first".
    (assert= (with-out-str (print "first")) "first")
    (assert= (with-out-str (print "second")) "second"))

  (test "nested captures compose: inner drains only its own output"
    (let (result (with-out-str (print "outer-1")
                   (let (inner (with-out-str (print "inner")))
                     (assert= inner "inner")
                     (print "outer-2"))))
      (assert= result "outer-1outer-2"))))

;; ---- error safety -----------------------------------------------------------
(defn cap-boom () (print "discarded") (throw "boom"))

(describe "with-out-str error safety"
  (test "a throwing body re-raises and leaves no dangling capture"
    ;; the throw must propagate (not be swallowed by the macro's internal catch)…
    (assert= (try (with-out-str (cap-boom)) (catch e e)) "boom")
    ;; …and the buffer pushed before the throw must have been popped, so a fresh
    ;; capture starts clean rather than inheriting the orphaned buffer.
    (assert= (with-out-str (print "clean")) "clean")))

;; ---- across processes -------------------------------------------------------
;; Capture is process-scoped but inherited by spawned children (same Arc), so a
;; printer running in a child process is captured by the parent's with-out-str.
(defn cap-child (parent) (print "from-child") (send parent :done))

(describe "with-out-str across processes"
  :isolated

  (test "captures output printed by a spawned child"
    (let (out (with-out-str (let (me (self)) (spawn (cap-child me)) (receive (:done nil)))))
      (assert= out "from-child")))

  (test "many children fan their output into one capture"
    (let (out (with-out-str (let (me (self))
                              (spawn (cap-child me))
                              (spawn (cap-child me))
                              (spawn (cap-child me))
                              (receive (:done (receive (:done (receive (:done nil)))))))))
      (assert= out "from-childfrom-childfrom-child"))))
