;; tree-sitter-parse (ROADMAP §C): foreign-language parsing into the SAME
;; positioned-CST node shape `parse-source-positioned` gives for Brood —
;; `{:kind :start :end :named}` per node, `:text` on leaves, `:kids` on nodes
;; with children, half-open CHARACTER offsets. So std/tool/sexp's structural
;; navigation and the editor's :fontify service run over a Ruby/Elixir tree
;; unchanged. Mechanism in crate::treesit (feature "treesit"); these assert the
;; data shape the Brood side depends on.
;;
;; Register-only — discovered and run by `nest test` (and `brood --test`).

(defmodule tree-sitter-test (:use test))

;; ---- helpers ---------------------------------------------------------------

;; The first descendant of `node` (depth-first) whose :kind = `k`, or nil.
(defn tst-find (node k)
  (if (= (get node :kind) k)
    node
    (first (filter (fn (x) (not (nil? x)))
             (map (fn (c) (tst-find c k)) (or (get node :kids) []))))))

;; The ruby/elixir grammars are opt-in (--features treesit-grammars); the kernel
;; ships none by default. Detect each and skip the grammar-dependent suites when
;; absent, so a bare `cargo test` (no grammars) stays green — `make test` builds
;; them in and runs them.
(defn tst-grammar? (lang)
  (try (do (tree-sitter-parse "" lang) true) (catch _ false)))
(def tst-ruby? (tst-grammar? :ruby))
(def tst-elixir? (tst-grammar? :elixir))

;; The first descendant (incl. self) for which `(pred node)` is truthy, or nil.
(defn tst-search (node pred)
  (if (pred node)
    node
    (first (filter (fn (x) (not (nil? x)))
             (map (fn (c) (tst-search c pred)) (or (get node :kids) []))))))

;; ---- grammar-dependent suites (skipped without --features treesit-grammars) -
(when (and tst-ruby? tst-elixir?)

;; ---- ruby ------------------------------------------------------------------

(describe "tree-sitter-parse ruby"
  (test "root is a positioned :program node with children"
    (let (root (tree-sitter-parse "x = 1\n" :ruby))
      (assert= (get root :kind) :program)
      (assert= (get root :start) 0)
      (assert= (get root :end) 6)          ; includes the trailing newline
      (is (get root :named))
      (is (not (empty? (get root :kids))))))

  (test "an assignment node nests identifier/operator/integer leaves"
    (let (root (tree-sitter-parse "x = 1\n" :ruby)
          asgn (tst-find root :assignment))
      (refute (nil? asgn))
      (is (not (nil? (tst-find asgn :identifier))))
      (is (not (nil? (tst-find asgn :integer))))))

  (test "leaves carry :text spanning their char offsets"
    (let (root (tree-sitter-parse "x = 1\n" :ruby)
          ident (tst-find root :identifier))
      (assert= (get ident :text) "x")
      (assert= (get ident :start) 0)
      (assert= (get ident :end) 1)
      (is (get ident :named))))

  (test "anonymous tokens are :named false"
    (let (root (tree-sitter-parse "x = 1\n" :ruby)
          op (tst-find root :=))
      (refute (nil? op))
      (refute (get op :named))
      (assert= (get op :text) "=")))

  (test "char offsets, not byte offsets, for multibyte source"
    ;; "café" is 4 chars / 5 bytes; the string literal's end must be a CHAR offset.
    (let (root (tree-sitter-parse "s = \"café\"\n" :ruby)
          str (tst-find root :string))
      (refute (nil? str))
      (assert= (get str :start) 4)
      (assert= (get str :end) 10))))        ; 4 + len("\"café\"") = 4 + 6 chars

;; ---- elixir ----------------------------------------------------------------

(describe "tree-sitter-parse elixir"
  (test "root is a :source node"
    (let (root (tree-sitter-parse "x = 1\n" :elixir))
      (assert= (get root :kind) :source)
      (is (not (empty? (get root :kids))))))

  (test "an assignment is a binary_operator over identifier and integer"
    (let (root (tree-sitter-parse "x = 1\n" :elixir)
          bin (tst-find root :binary_operator))
      (refute (nil? bin))
      (is (not (nil? (tst-find bin :identifier))))
      (is (not (nil? (tst-find bin :integer)))))))

;; ---- error recovery --------------------------------------------------------
;; tree-sitter is error-tolerant: it returns a tree even for broken source, and
;; the projected CST surfaces the recovery state so an editor can draw squiggles.

(describe "tree-sitter-parse error recovery"
  (test "a syntax error surfaces an :error node"
    (let (root (tree-sitter-parse "@\n" :ruby)
          err (tst-search root (fn (n) (get n :error))))
      (refute (nil? err))
      (is (get err :error))))

  (test "an inserted token surfaces a zero-width :missing node"
    ;; `def foo` with no matching `end` makes tree-sitter insert a zero-width
    ;; MISSING `end` for recovery — :kind can't signal that, so :missing must.
    (let (root (tree-sitter-parse "def foo\n" :ruby)
          miss (tst-search root (fn (n) (get n :missing))))
      (refute (nil? miss))
      (is (get miss :missing))
      (assert= (get miss :start) (get miss :end))))   ; zero width

  (test "valid source carries no :error or :missing nodes"
    (let (root (tree-sitter-parse "x = 1\n" :ruby))
      (is (nil? (tst-search root (fn (n) (or (get n :error) (get n :missing)))))))))

;; ---- incremental reparse ---------------------------------------------------
;; `tree-sitter-reparse` caches the prior tree per buffer key and edits it in
;; place; the result must be IDENTICAL to a from-scratch `tree-sitter-parse`
;; (incrementality is a pure optimization), across inserts/deletes/multibyte.

(describe "tree-sitter-reparse"
  (test "incremental result equals a from-scratch parse after each edit"
    (let (k 9001
          edits (list "x = 1\n"               ; initial
                      "x = 12\n"              ; insert a char
                      "x = 12\ny = 3\n"       ; append a line
                      "x = 12\n"              ; delete the line
                      "café = 12\n"           ; multibyte edit
                      "def f\n  café\nend\n"  ; larger change
                      "def f\n  café\nend\n") ; identical (no-op reparse)
          ok (reduce (fn (acc s)
                       (and acc (= (tree-sitter-reparse k s :ruby)
                                   (tree-sitter-parse s :ruby))))
                     true edits))
      (is ok)
      ;; forget drops the buffer's cached tree and reports the count.
      (assert= (tree-sitter-forget k) 1)
      (assert= (tree-sitter-forget k) 0)))   ; already gone

  (test "first reparse with no cache equals a fresh parse"
    (let (k 9002)
      (assert= (tree-sitter-reparse k "y = 2\n" :elixir)
        (tree-sitter-parse "y = 2\n" :elixir))
      (tree-sitter-forget k))))

)  ; end (when (and tst-ruby? tst-elixir?) …) — grammar-dependent suites

;; ---- errors ----------------------------------------------------------------
;; Runs regardless of grammars: an unknown language throws whether or not any
;; grammar is built in.

(describe "tree-sitter-parse errors"
  (test "an unknown language throws"
    (assert-error (tree-sitter-parse "x" :python))))
