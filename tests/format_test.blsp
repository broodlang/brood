;; In-language tests for the formatter (std/format.blsp). Register-only —
;; discovered and run by `nest test` (and cargo test, via crates/lisp/tests/
;; suite.rs).
;;
;; The contract is: format-source is idempotent on every well-formed input,
;; preserves comments, preserves blank-line intent between top-level forms,
;; collapses short forms onto a single line, and breaks long ones over multiple.

(defmodule format-test (:use test) (:use format))

(describe "format: trivial inputs"
  (test "empty input yields empty output" (assert= (format-source "") ""))
  (test "a single form gets a trailing newline" (assert= (format-source "(+ 1 2)") "(+ 1 2)\n"))
  (test "whitespace is normalised inside a form"
    (assert= (format-source "(+   1    2)") "(+ 1 2)\n"))
  (test "extra blank lines between top-level forms collapse to one"
    (assert= (format-source "(def a 1)\n\n\n\n(def b 2)") "(def a 1)\n\n(def b 2)\n"))
  (test "no blank line between forms stays no-blank"
    (assert= (format-source "(def a 1)\n(def b 2)") "(def a 1)\n(def b 2)\n")))

(describe "format: short forms collapse"
  ;; The formatter respects author newlines on forms the user already broke
  ;; (`5b19787`, "formatter respects author newlines"), so a multi-line let or
  ;; defn given multi-line input stays multi-line — only whitespace inside each
  ;; line is normalised. Tests written before that change pinned the collapse
  ;; behaviour; the new behaviour pins the preservation.
  (test "a single-line let stays a single line"
    (assert= (format-source "(let (a 1     b 2) (+ a b))") "(let (a 1 b 2) (+ a b))\n"))
  (test "an already-multi-line let stays multi-line"
    (assert= (format-source "(let (a 1\n      b 2)\n  (+ a b))")
      "(let (a 1\n      b 2)\n  (+ a b))\n"))
  (test "a single-line defn stays a single line"
    (assert= (format-source "(defn add (x y) (+   x  y))") "(defn add (x y) (+ x y))\n"))
  (test "an already-multi-line defn keeps the body break but normalises the header"
    ;; defn header (name + params) is always one line by rule, so the input's
    ;; `defn\n  (x y)` collapses to `defn add (x y)`. The body's newline before
    ;; `(+ x y)` is the author's break — the formatter preserves it.
    (assert= (format-source "(defn add\n  (x y)\n  (+ x y))")
      "(defn add (x y)\n  (+ x y))\n")))

(describe "format: long forms break"
  (test "a long generic call rides the first arg on the head line, rest at +2"
    (let (in "(very-long-function-name aaaaaaaaaaaaa bbbbbbbbbbbbb cccccccccccccc ddddddddddddd eeeeeeeeeeeee ffffffffffff)"
          out (format-source in))
      ;; Call-style with first-arg-ride: head + arg1 on first line, rest at +2.
      (is (string-contains? out "(very-long-function-name aaaaaaaaaaaaa\n  bbbbbbbbbbbbb"))))
  (test "a too-long defn keeps name + params on the head line + indents the body"
    (let (in "(defn long-function-name (x y z) (some-long-body-form x y z w v u u1 u2) (another-long-body x y z w v))"
          out (format-source in))
      ;; defn is in the header table (count = 2): name + params ride along.
      (is (string-contains? out "(defn long-function-name (x y z)\n  (some-long-body-form"))))
  (test "let bindings break as pairs aligned under the first element"
    (let (in "(let (aaaaaaaaaaa-binding 1 bbbbbbbbbbb-binding 2 ccccccccccc-binding 3 ddddddddddd-binding 4 eeeeeeeeeee-binding 5) body)"
          out (format-source in))
      ;; Each binding pair on its own line, aligned at column 6 (one past `(`).
      (is (string-contains? out "aaaaaaaaaaa-binding 1\n      bbbbbbbbbbb-binding 2"))))
  (test "cond clauses break as test+result pairs at +2"
    (let (in "(cond (some-test-form x y z) (some-result-form a b) (another-test-form x y z) (another-result-form a b) else default)"
          out (format-source in))
      ;; Each `test result` pair on one body-indent line.
      (is (string-contains? out
            "(some-test-form x y z) (some-result-form a b)\n  (another-test-form")))))

(describe "format: comments are preserved"
  (test "a top-level comment is kept"
    (assert= (format-source ";; hello\n(def x 1)") ";; hello\n(def x 1)\n"))
  (test "an inline comment forces multi-line on its enclosing list"
    (let (in "(defn f (x) ;; doc\n  x)" out (format-source in))
      (is (string-contains? out ";; doc"))
      ;; The body item moves to a new line at +2 indent.
      (is (string-contains? out "\n  x)"))))
  (test "blank lines between two top-level comments are preserved"
    (assert= (format-source ";; a\n\n;; b\n(def x 1)") ";; a\n\n;; b\n(def x 1)\n")))

(describe "format: a comment just before a closing delimiter"
  ;; Regression (the bug that broke tests/adversarial_test.blsp): when the last
  ;; child of a broken list is a comment, the close delimiter must drop to its
  ;; own line. Appended directly it lands inside the comment (`;; note)`), which
  ;; comments out the `)` and leaves the list unclosed — an unparseable file.
  (test "the closing paren drops below a trailing comment, not into it"
    (let (out (format-source "(describe \"x\"\n  (test \"a\" (is true))\n  ;; note\n  )"))
      (is (string-contains? out ";; note\n)"))  ; `)` on its own line
      (is (not (string-contains? out ";; note)")))))  ; never swallowed
  (test "the result is re-readable (not just CST-parseable)"
    ;; parse-source is lenient on unclosed lists; the real reader is not — pin it.
    (let (out (format-source "(describe \"x\"\n  (test \"a\")\n  ;; note\n  )"))
      (is (= (read-string (str "(do " out ")")) (read-string "(do (describe \"x\" (test \"a\")))")))))
  (test "idempotent with a trailing comment"
    (let (out (format-source "(foo\n  (bar)\n  ;; note\n  )"))
      (assert= out (format-source out))))
  ;; The pair-body emitter (cond/case) used to skip over a comment while hunting
  ;; for a clause's partner form, DROPPING the comment. It must be preserved.
  (test "a comment after the last cond clause is not dropped"
    (let (out (format-source "(cond\n  (a 1)\n  ;; fallback\n  )"))
      (is (string-contains? out ";; fallback"))
      (is (string-contains? out ";; fallback\n)"))))
  (test "a comment between cond clauses is preserved and breaks the pair"
    (let (out (format-source "(cond\n  (a 1)\n  ;; mid\n  (b 2))"))
      (is (string-contains? out ";; mid"))
      (is (string-contains? out "(b 2)")))))

(describe "format: comment markers preserved verbatim"
  ;; Lisp convention is `;` for trailing comments, `;;` at the current code
  ;; column, `;;;` for top-level banners. The formatter must not "normalise"
  ;; the marker count — that's authorial intent.
  (test "single ; marker survives"
    (let (out (format-source "; one\n(def x 1)"))
      (is (string-contains? out "; one"))))
  (test ";; marker (current-line column) survives"
    (let (out (format-source ";; section\n(def x 1)"))
      (is (string-contains? out ";; section"))))
  (test ";;; marker (top-level banner) survives"
    (let (out (format-source ";;; banner\n(def x 1)"))
      (is (string-contains? out ";;; banner"))))
  (test "trailing comment after code stays on the same line"
    (let (out (format-source "(def x 1) ; trailing"))
      (is (string-contains? out "(def x 1)"))
      (is (string-contains? out "; trailing"))
      ;; And specifically: not pushed onto its own line.
      (is (not (string-contains? out "(def x 1)\n; trailing")))))
  (test "trailing comment after a closing paren is preserved"
    (let (out (format-source "(defn f () 0) ;; nullary"))
      (is (string-contains? out "(defn f () 0)"))
      (is (string-contains? out ";; nullary"))))
  (test "comment-only input gets a single trailing newline, nothing else"
    (assert= (format-source ";; just a comment") ";; just a comment\n")))

(describe "format: strings"
  (test "a short string literal is preserved byte-for-byte"
    (assert= (format-source "(def s \"hello world\")") "(def s \"hello world\")\n"))
  (test "escape sequences inside a string survive unchanged"
    (assert= (format-source "(def s \"a\\tb\\nc\")") "(def s \"a\\tb\\nc\")\n"))
  (test "a multi-line string literal preserves its internal newlines"
    (let (in "(def doc \"line one\nline two\nline three\")"
          out (format-source in))
      ;; The string content stays byte-for-byte — including the literal
      ;; newlines (we can't reflow inside a string literal).
      (is (string-contains? out "\"line one\nline two\nline three\""))))
  (test "a string longer than the width budget pushes itself to its own line, content untouched"
    (let (long-content "this is a really long string that exceeds the eighty column width budget the formatter uses"
          in (str "(def msg \"" long-content "\")")
          out (format-source in))
      ;; Content is preserved verbatim.
      (is (string-contains? out (str "\"" long-content "\"")))
      ;; And the form breaks: string lands on its own line at +2 indent.
      (is (string-contains? out (str "(def msg\n  \"" long-content "\""))))))

(describe "format: reader macros + collections"
  (test "quote stays attached to its form" (assert= (format-source "'(a b c)") "'(a b c)\n"))
  (test "quasi / unquote / splice are emitted with their prefixes"
    (assert= (format-source "`(a ~b ~@c)") "`(a ~b ~@c)\n"))
  (test "vectors fit on one line when they fit" (assert= (format-source "[ 1  2  3 ]") "[1 2 3]\n"))
  (test "maps keep alternating key/value pairs"
    (assert= (format-source "{ :a 1   :b 2 }") "{:a 1 :b 2}\n"))
  (test "empty containers stay empty"
    (assert= (format-source "()") "()\n")
    (assert= (format-source "[]") "[]\n")
    (assert= (format-source "{}") "{}\n")))

(describe "format: idempotency"
  (test "idempotent on a representative grab-bag"
    (let (samples (list ""
                    "(+ 1 2)"
                    "(defn add (x y) (+ x y))"
                    ";; comment only"
                    "(defn long-fn (x y z) (foo) (bar) (baz))"
                    "'(a b c)"
                    "(let (a 1 b 2) (+ a b))"
                    "(cond (= x 1) :one (= x 2) :two else :many)"
                    "(if (and a b) c d)"
                    "{:a 1 :b 2}"
                    "[1 [2 [3 [4]]]]"
                    ;; comment + string cases that the new describes above cover.
                    "; trailing\n;; section\n;;; banner\n(def x 1)"
                    "(def x 1) ; trailing"
                    "(defn f () 0) ;; nullary"
                    "(def s \"hello world\")"
                    "(def s \"a\\tb\\nc\")"
                    "(def doc \"line one\nline two\nline three\")"))
      (fold (fn (_ s)
              (let (once (format-source s) twice (format-source once)) (assert= once twice)))
        nil
        samples)))
  (test "the prelude is idempotent (format(format(prelude)) == format(prelude))"
    ;; The prelude is the largest single-file Brood program we have; idempotency
    ;; on it is a high-confidence smoke test of the whole walker.
    (let (src (slurp "std/prelude.blsp") once (format-source src) twice (format-source once))
      (assert= once twice))))
