;; File & filesystem library (std/file.blsp). Fixtures live under a unique
;; /tmp directory per test, so cases don't collide.
;;
;; Register-only — discovered and run by `nest test` (and cargo test).

(require 'test)
(require 'file)

;; A fresh /tmp dir per call. The name must be unique **across runs**, not just
;; within one: `gensym`'s counter resets every process/run, so a name like
;; `brood-file-__114` recurs — and a killed run leaves its dir behind, so the next
;; run's tests `make-dir` onto leftover files (list-files sees extras, append-file
;; appends to stale content). `(now-ns)` (nanoseconds since the epoch) varies across
;; runs and between calls; the trailing `gensym` is a tiebreaker for two processes
;; that read the same nanosecond. Path-safe (digits + `_` only).
(defn ftmp ()
  (let (d (path-join "/tmp" (str "brood-file-" (now-ns) "-" (name (gensym "")))))
    (make-dir d)
    d))

(describe "file: whole-file read/write/append"
  (test "write-file then read-file round-trips"
    (let (p (path-join (ftmp) "a.txt"))
      (write-file p "hello")
      (assert= (read-file p) "hello")))
  (test "append-file adds to existing content (and creates if absent)"
    (let (p (path-join (ftmp) "b.txt"))
      (append-file p "one")
      (append-file p "two")
      (assert= (read-file p) "onetwo"))))

(describe "file: size / delete / rename"
  (test "file-size reports byte length, nil when missing"
    (let (p (path-join (ftmp) "s.txt"))
      (write-file p "12345")
      (assert= (file-size p) 5)
      (assert= (file-size (path-join (ftmp) "nope.txt")) nil)))
  (test "delete-file removes a file and is idempotent"
    (let (p (path-join (ftmp) "d.txt"))
      (write-file p "x")
      (is (file? p))
      (delete-file p)
      (refute (path-exists? p))
      (assert= (delete-file p) nil)))            ; no-op when already gone
  (test "rename-file moves content to a new path"
    (let (d (ftmp) a (path-join d "a.txt") b (path-join d "b.txt"))
      (write-file a "moved")
      (rename-file a b)
      (refute (path-exists? a))
      (assert= (read-file b) "moved"))))

(describe "file: line I/O"
  (test "write-lines / read-lines round-trip without a trailing blank line"
    (let (p (path-join (ftmp) "c.txt"))
      (write-lines p ["alpha" "beta" "gamma"])
      (assert= (read-lines p) (list "alpha" "beta" "gamma"))))
  (test "read-lines of an empty file is nil"
    (let (p (path-join (ftmp) "empty.txt"))
      (write-file p "")
      (assert= (read-lines p) nil))))

(describe "file: predicates"
  (test "file? is true for a regular file, false for a directory"
    (let (d (ftmp) p (path-join d "f.txt"))
      (write-file p "x")
      (is (file? p))
      (refute (file? d))
      (is (dir? d))))
  (test "path-exists? covers files and directories"
    (let (d (ftmp) p (path-join d "f.txt"))
      (write-file p "x")
      (is (path-exists? p))
      (is (path-exists? d))
      (refute (path-exists? (path-join d "nope.txt"))))))

(describe "file: directory listing"
  (test "list-files and list-dirs separate files from subdirectories"
    (let (d (ftmp))
      (write-file (path-join d "f1.txt") "a")
      (write-file (path-join d "f2.txt") "b")
      (make-dir (path-join d "sub"))
      (assert= (sort (list-files d)) (list "f1.txt" "f2.txt"))
      (assert= (list-dirs d) (list "sub"))))
  (test "walk-files collects files recursively as full paths"
    (let (d (ftmp))
      (write-file (path-join d "top.txt") "a")
      (make-dir (path-join d "sub"))
      (write-file (path-join (path-join d "sub") "deep.txt") "b")
      (assert= (sort (walk-files d))
        (sort (list (path-join d "top.txt") (path-join (path-join d "sub") "deep.txt")))))))

(describe "file: path helpers"
  (test "path-extension"
    (assert= (path-extension "a/b.txt") ".txt")
    (assert= (path-extension "a/b") "")
    (assert= (path-extension ".bashrc") ""))
  (test "path-stem"
    (assert= (path-stem "a/b.txt") "b")
    (assert= (path-stem "a/b") "b")))
