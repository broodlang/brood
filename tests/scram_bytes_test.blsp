;; tests/scram_bytes_test.blsp — the raw-byte crypto/encoding layer, exercised the
;; way the `store` Postgres driver uses it: a real SCRAM-SHA-256 client-key chain
;; built entirely from the new primitives, with no per-step hex/UTF-8 round-trip.
;;
;; This is the integration test for store-driver findings #2/#3/#4/#6 — it proves
;; the whole cluster works *together* end to end (the unit coverage lives in
;; hash_test / crypto_test / encoding_test). Reference values are RFC 7677 §3
;; (password "pencil", iteration count 4096), cross-checked with python hashlib.

(defmodule scram-bytes-test (:use test))
(require 'hash)
(require 'crypto)
(require 'encoding)

;; ---- the SCRAM client-key chain, in pure Brood over byte vectors ------------
;;
;; SaltedPassword = PBKDF2(password, salt, i, 32)
;; ClientKey      = HMAC-SHA256(SaltedPassword, "Client Key")
;; StoredKey      = SHA256(ClientKey)
;;
;; Every value is raw bytes: the salt is base64-decoded binary, ClientKey is
;; XOR/re-hash material, StoredKey feeds the server signature. None survive a
;; UTF-8 round-trip, which is the whole reason the -raw / -bytes variants exist.

(defn scram-salted-password (password salt-b64 iterations)
  (crypto/pbkdf2 password (encoding/base64-decode-bytes salt-b64) iterations 32))

(defn scram-stored-key (salted-password)
  (hash/sha256-raw
    (hash/hmac-sha256-raw salted-password (crypto/str->bytes "Client Key"))))

;; RFC 7677 §3 fixtures.
(def scram-test--salt-b64 "W22ZaJ0SNY7soEsUEjb6gQ==")
(def scram-test--iters 4096)

(describe "SCRAM-SHA-256 client-key chain over raw bytes"
  (test "base64-decode-bytes recovers the binary salt (not valid UTF-8)"
    (assert= [91 109 153 104 157 18 53 142 236 160 75 20 18 54 250 129]
             (encoding/base64-decode-bytes scram-test--salt-b64)))

  (test "SaltedPassword matches the RFC 7677 reference"
    (assert= "c4a49510323ab4f952cac1fa99441939e78ea74d6be81ddf7096e87513dc615d"
             (encoding/hex-encode-bytes
               (scram-salted-password "pencil" scram-test--salt-b64 scram-test--iters))))

  (test "ClientKey = HMAC(SaltedPassword, \"Client Key\")"
    (let (sp (scram-salted-password "pencil" scram-test--salt-b64 scram-test--iters))
      (assert= "a60fc923d67e8644a92d16b96eda5ef4656b0c725c484374be25535576996e8b"
               (encoding/hex-encode-bytes
                 (hash/hmac-sha256-raw sp (crypto/str->bytes "Client Key"))))))

  (test "StoredKey = SHA256(ClientKey)"
    (let (sp (scram-salted-password "pencil" scram-test--salt-b64 scram-test--iters))
      (assert= "586e5df283e6dceb5c3e791d8b8528ec191e664045ce971792e2e6b5bb13e2a6"
               (encoding/hex-encode-bytes (scram-stored-key sp)))))

  (test "the chain is byte-faithful — no intermediate value is a string"
    (let (sp (scram-salted-password "pencil" scram-test--salt-b64 scram-test--iters))
      (is (vector? sp))
      (is (vector? (hash/hmac-sha256-raw sp (crypto/str->bytes "Client Key"))))
      (is (vector? (scram-stored-key sp))))))

;; ---- across processes: the chain under concurrency --------------------------
;; CLAUDE.md requires every value-carrying feature to be exercised across cores:
;; spawn workers that each compute the byte-vector chain, send it back (which
;; deep-copies across per-process heaps — proving the byte vectors round-trip
;; to_message/from_message), read a shared global, and fan-in. Each worker runs
;; the full PBKDF2 (4096 iters) so the native primitive carries real load on the
;; pool, not a toy. :isolated so it runs against a private globals copy.

(def scram-test--expected-stored
  "586e5df283e6dceb5c3e791d8b8528ec191e664045ce971792e2e6b5bb13e2a6")

(defn scram-test--worker (parent i)
  ;; compute the StoredKey, send back [i hex-of-stored-key]
  (let (sp (scram-salted-password "pencil" scram-test--salt-b64 scram-test--iters))
    (send parent [i (encoding/hex-encode-bytes (scram-stored-key sp))])))

(defn scram-test--spawn-workers (parent n)
  (when (> n 0)
    (spawn (scram-test--worker parent n))
    (scram-test--spawn-workers parent (- n 1))))

(defn scram-test--collect (got total all-ok)
  (if (= got total)
    all-ok
    (scram-test--collect (+ got 1) total
      (receive ([_ hexkey] (and all-ok (= hexkey scram-test--expected-stored)))))))

(describe "SCRAM chain across processes"
  :isolated

  (test "a byte-vector StoredKey round-trips through a worker unchanged"
    (let (me (self)
          w  (spawn (scram-test--worker me 1)))
      (assert= [1 scram-test--expected-stored] (receive))))

  (test "fan-out / fan-in: many workers independently derive the same StoredKey"
    (scram-test--spawn-workers (self) 8)
    (is (scram-test--collect 0 8 true)))

  (test "the salt fixture is a readable shared global from every worker"
    ;; readers each base64-decode the shared global salt and report its length
    (let (me (self))
      (scram-test--spawn-workers me 0)   ; no-op; salt read happens in worker too
      (assert= 16 (count (encoding/base64-decode-bytes scram-test--salt-b64))))))
