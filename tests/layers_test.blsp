;; std/layers — composable behaviour layers (Phase 1: the buffer-free core).
;; Register-only — run by `nest test` (and cargo test, via crates/lisp/tests/suite.rs).

(defmodule layers-test (:use test) (:use editor/keymap) (:use editor/layers))
(require 'editor/keymap)
(require 'editor/layers)

;; ---- fixtures: commands, hooks, and layers (def'd globals, by qualified symbol) ----
;; A test context is a map {:log <string> :layers <list>}; commands/hooks append to
;; :log so the path through dispatch/hooks is visible.
(defn cmd-x (s k) (assoc s :log (str (get s :log) "X")))  ; layers-test/cmd-x
(defn cmd-y (s k) (assoc s :log (str (get s :log) "Y")))

(defn hk-a-on (s) (assoc s :log (str (get s :log) "[a-on]")))
(defn hk-a-off (s) (assoc s :log (str (get s :log) "[a-off]")))
(defn hk-b-on (s) (assoc s :log (str (get s :log) "[b-on]")))
(defn hk-focus (s) (assoc s :log (str (get s :log) "F")))
(defn hk-boom (s) (throw "boom"))

(def layer-a
  {:name 'a
   :keymap (keymap-bind {} ["x"] 'layers-test/cmd-x)
   :hooks {:activate '(layers-test/hk-a-on)
           :deactivate '(layers-test/hk-a-off)
           :on-focus '(layers-test/hk-focus)}})
(def layer-b
  {:name 'b
   :keymap (keymap-bind {} ["y"] 'layers-test/cmd-y)
   :hooks {:activate '(layers-test/hk-b-on) :on-focus '(layers-test/hk-focus)}})
(def layer-hi {:name 'hi :keymap (keymap-bind {} ["x"] 'layers-test/cmd-y)})  ; binds x→Y
(def layer-boom {:name 'boom :hooks {:activate '(layers-test/hk-boom)}})
(def layer-chord {:name 'chord :keymap (keymap-bind {} [:ctrl-x :ctrl-e] 'layers-test/cmd-x)})

(defn no-fb (s k) s)  ; a no-op fallback

;; ---- collection & precedence ------------------------------------------------
(describe "layer-collect & precedence"
  (test "collects a facet from active layers, highest-precedence (head) first"
    (let (ctx (push-layer (push-layer {:log ""} 'layers-test/layer-a) 'layers-test/layer-hi))
      ;; pushed a, then hi → hi is the head (highest precedence)
      (assert= (map (fn (km) (get km "x")) (layer-collect ctx :keymap))
        (list 'layers-test/cmd-y 'layers-test/cmd-x))))
  (test "layers lacking the facet are dropped"
    (let (ctx (push-layer {:log ""} 'layers-test/layer-boom))
      ; boom has no :keymap
      (is (empty? (layer-collect ctx :keymap))))))

;; ---- stack ops --------------------------------------------------------------
(describe "stack ops"
  (test "push / active? / remove by :name"
    (let (ctx (push-layer {:log ""} 'layers-test/layer-a))
      (is (layer-active? ctx 'a))
      (is (not (layer-active? ctx 'b)))
      (is (not (layer-active? (remove-layer ctx 'a) 'a))))))

;; ---- lifecycle hooks --------------------------------------------------------
(describe "activate / deactivate"
  (test "activate-layer runs the layer's :activate hooks"
    (assert= (get (activate-layer {:log ""} 'layers-test/layer-a) :log) "[a-on]"))

  (test "activate-layer fires only the new layer's :activate, not already-active ones"
    (let (ctx (activate-layer {:log ""} 'layers-test/layer-a))
      ; [a-on]
      (assert= (get (activate-layer ctx 'layers-test/layer-b) :log) "[a-on][b-on]")))

  (test "deactivate-layer runs :deactivate then removes"
    (let (ctx (activate-layer {:log ""} 'layers-test/layer-a)
          ctx2 (deactivate-layer ctx 'a))
      (assert= (get ctx2 :log) "[a-on][a-off]")
      (is (not (layer-active? ctx2 'a)))))

  (test "deactivate of an inactive name is a no-op"
    (assert= (deactivate-layer {:log ""} 'nope) {:log ""}))

  (test "a throwing hook is isolated — state unchanged, layer still on"
    (let (ctx (activate-layer {:log "keep"} 'layers-test/layer-boom))
      (assert= (get ctx :log) "keep")
      (is (layer-active? ctx 'boom))))

  (test "replace-base-layer deactivates the old base and activates the new"
    (let (ctx (activate-layer {:log ""} 'layers-test/layer-a)
          ctx2 (replace-base-layer ctx 'layers-test/layer-b))
      (assert= (get ctx2 :log) "[a-on][a-off][b-on]")
      (is (layer-active? ctx2 'b))
      (is (not (layer-active? ctx2 'a))))))

;; ---- fanned events ----------------------------------------------------------
(describe "run-event (fanned across active layers)"
  (test "fans an event across every active layer, highest precedence first"
    (let (ctx (activate-layer (activate-layer {:log ""} 'layers-test/layer-a) 'layers-test/layer-b))
      ;; both a and b handle :on-focus → hk-focus appends F, once per layer
      (assert= (get (run-event ctx :on-focus) :log) "[a-on][b-on]FF")))
  (test "no-op when no active layer handles the event"
    (let (ctx (activate-layer {:log ""} 'layers-test/layer-a))
      (assert= (run-event ctx :on-blur) ctx))))

;; ---- keymap composition + dispatch ------------------------------------------
(describe "active-keymap & layer-dispatch"
  (test "active-keymap merges layers with the head winning"
    (let (ctx (push-layer (push-layer {:log ""} 'layers-test/layer-a) 'layers-test/layer-hi))
      (assert= (get (active-keymap ctx) "x") 'layers-test/cmd-y)))  ; hi (head) wins

  (test "layer-dispatch resolves through the layers and runs the command"
    (let (ctx (activate-layer {:log ""} 'layers-test/layer-a)
          r (layer-dispatch ctx nil "x" no-fb))
      (assert= (get (first r) :log) "[a-on]X")
      (assert= (second r) nil)))

  (test "an unbound key falls through to the fallback"
    (let (ctx (activate-layer {:log ""} 'layers-test/layer-a)
          r (layer-dispatch ctx nil "z" (fn (s _) (assoc s :log (str (get s :log) "?")))))
      (assert= (get (first r) :log) "[a-on]?")))

  (test "a chord living in a layer dispatches across two keystrokes"
    (let (ctx (push-layer {:log ""} 'layers-test/layer-chord)
          r1 (layer-dispatch ctx nil :ctrl-x no-fb))
      (assert= (second r1) {:ctrl-e 'layers-test/cmd-x})  ; pending sub-keymap
      (let (r2 (layer-dispatch (first r1) (second r1) :ctrl-e no-fb))
        (assert= (get (first r2) :log) "X")
        (assert= (second r2) nil)))))

;; ---- across processes -------------------------------------------------------
;; Layers and commands are shared code (def'd globals), resolved by symbol, so the
;; whole machinery works off the root process.
(defn lt-worker (parent)
  (let (ctx (activate-layer {:log ""} 'layers-test/layer-a)
        r (layer-dispatch ctx nil "x" layers-test/no-fb))
    (send parent (get (first r) :log))))

(describe "layers across processes"
  :isolated
  (test "activate + dispatch resolve and run inside a spawned process"
    (let (me (self))
      (spawn (lt-worker me))
      (assert= (receive) "[a-on]X"))))

;; ---- Phase 2: buffer-type binding -------------------------------------------
;; :isolated so register-* (which rebinds the global registries) can't leak into
;; other test files; unique :type keys keep tests independent within the block too.
(describe "buffer-type binding"
  :isolated

  (test "register-type-layers / layers-for-type round-trip"
    (register-type-layers :t-rt (list 'layers-test/layer-a 'layers-test/layer-b))
    (assert= (layers-for-type :t-rt) (list 'layers-test/layer-a 'layers-test/layer-b))
    (is (empty? (layers-for-type :t-missing))))

  (test "buffer-type-for matches a filename suffix"
    (register-file-type ".foo" :t-foo)
    (assert= (buffer-type-for {:file "x.foo"}) :t-foo))

  (test "buffer-type-for matches a predicate spec"
    (register-file-type (fn (f) (= f "Makefile")) :t-make)
    (assert= (buffer-type-for {:file "Makefile"}) :t-make))

  (test "most-recently-registered rule wins (first match, newest-first)"
    (register-file-type ".bar" :t-bar1)
    (register-file-type ".bar" :t-bar2)
    (assert= (buffer-type-for {:file "x.bar"}) :t-bar2))

  (test "no file → explicit :type, else :fundamental"
    (assert= (buffer-type-for {:type :special}) :special)
    (assert= (buffer-type-for {}) :fundamental))

  (test "a file with no matching rule and no :type → :fundamental"
    (assert= (buffer-type-for {:file "x.no-such-ext"}) :fundamental))

  (test "set-buffer-type sets :type without seeding layers"
    (let (b (set-buffer-type {} :special))
      (assert= (get b :type) :special)
      (is (nil? (get b :layers)))))

  (test "init-buffer-layers seeds layers in registry order, activating base-first"
    (register-type-layers :t-init (list 'layers-test/layer-a 'layers-test/layer-b))
    (let (b (init-buffer-layers (set-buffer-type {:log ""} :t-init)))
      (assert= (get b :type) :t-init)
      ;; registry order preserved (layer-a head/highest, layer-b base/last)…
      (assert= (get b :layers) (list 'layers-test/layer-a 'layers-test/layer-b))
      ;; …but :activate fires base-first, so layer-b ([b-on]) before layer-a ([a-on])
      (assert= (get b :log) "[b-on][a-on]")))

  (test "init-buffer-layers resolves type from filename when no :type is set"
    (register-file-type ".lisp-ext" :t-byfile)
    (register-type-layers :t-byfile (list 'layers-test/layer-a))
    (let (b (init-buffer-layers {:log "" :file "x.lisp-ext"}))
      (assert= (get b :type) :t-byfile)
      (is (layer-active? b 'a))
      (assert= (get b :log) "[a-on]"))))

;; ---- Phase 3: scopes, focus/close, teardown ---------------------------------
(defn hk-blur (s) (assoc s :log (str (get s :log) "B!")))
(defn hk-close (s) (assoc s :log (str (get s :log) "C")))
(defn hk-cl-off (s) (assoc s :log (str (get s :log) "D")))
(def layer-fb
  {:name 'fb :hooks {:on-focus '(layers-test/hk-focus) :on-blur '(layers-test/hk-blur)}})
(def layer-close
  {:name 'cl :hooks {:on-close '(layers-test/hk-close) :deactivate '(layers-test/hk-cl-off)}})

(describe "scopes & focus lifecycle"
  (test "scope-keymap composes scopes, the earlier (higher-precedence) scope winning"
    (let (buffer (push-layer {} 'layers-test/layer-hi)
           ; binds x→cmd-y
           window
           (push-layer {} 'layers-test/layer-a))
      ; binds x→cmd-x
      ;; buffer scope listed first → shadows the window
      (assert= (get (scope-keymap (list buffer window)) "x") 'layers-test/cmd-y)))

  (test "scope-dispatch resolves through the scopes but runs the command on the state"
    (let (buffer (push-layer {} 'layers-test/layer-a)
           ; binds x→cmd-x
           model
           {:log "M"}
           r
           (scope-dispatch (list buffer) model nil "x" no-fb))
      ;; cmd-x runs on the model (not the buffer the keymap came from)
      (assert= (get (first r) :log) "MX")
      (assert= (second r) nil)))

  (test "switch-focus fires :on-blur on the old context and :on-focus on the new"
    (let (from (activate-layer {:log ""} 'layers-test/layer-fb)
          to (activate-layer {:log ""} 'layers-test/layer-fb)
          r (switch-focus from to))
      (assert= (get (first r) :log) "B!")  ; from blurred
      (assert= (get (second r) :log) "F")))  ; to focused

  (test "switch-focus tolerates a nil side"
    (assert= (switch-focus nil (activate-layer {:log ""} 'layers-test/layer-fb))
      [nil {:log "F" :layers (list 'layers-test/layer-fb)}]))

  (test "close-context fans :on-close then deactivates every layer"
    (let (ctx (activate-layer {:log ""} 'layers-test/layer-close)
          closed (close-context ctx))
      (assert= (get closed :log) "CD")  ; :on-close (C) then :deactivate (D)
      (is (not (layer-active? closed 'cl))))))

;; ---- Phase 3: async cleanup (the reason :on-close exists) -------------------
;; A layer that spawns a worker on focus must be able to kill it on close. The
;; worker is one-shot: on :stop it acks its parent and exits.
(defn demo-worker (parent) (receive (:stop (send parent :stopped))))
(defn demo-start (ctx) (assoc ctx :worker (spawn (demo-worker (get ctx :parent)))))
(defn demo-stop (ctx) (send (get ctx :worker) :stop) ctx)
(def layer-async
  {:name 'async :hooks {:on-focus '(layers-test/demo-start) :on-close '(layers-test/demo-stop)}})

(describe "layers async lifecycle across processes"
  :isolated
  (test "an :on-focus-spawned worker is torn down by :on-close"
    (let (me (self)
           ctx
           (activate-layer {:parent me} 'layers-test/layer-async)
           focused
           (run-event ctx :on-focus)  ; spawns the worker, pid in :worker
           _
           (close-context focused))
      ; :on-close sends it :stop
      ;; the worker acks its stop — proving :on-focus spawned and :on-close cleaned up
      (assert= (receive) :stopped))))

;; ---- active-layers + always-on system layers --------------------------------
(describe "system layers & active-layers"
  :isolated
  (test "active-layers resolves refs to maps, highest precedence first"
    (let (ctx (push-layer (push-layer {} 'layers-test/layer-a) 'layers-test/layer-hi))
      (assert= (map (fn (l) (get l :name)) (active-layers ctx)) (list 'hi 'a))))
  (test "system layers are appended (lowest precedence) to every buffer"
    (register-type-layers :t-sys (list 'layers-test/layer-a))
    (register-system-layer 'layers-test/layer-b)
    (let (b (init-buffer-layers (set-buffer-type {} :t-sys)))
      (assert= (map (fn (l) (get l :name)) (active-layers b)) (list 'a 'b)))))
