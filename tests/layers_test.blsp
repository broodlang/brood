;; std/layers — composable behaviour layers (Phase 1: the buffer-free core).
;; Register-only — run by `nest test` (and cargo test, via crates/lisp/tests/suite.rs).

(defmodule layers-test (:use test) (:use keymap) (:use layers))
(require 'keymap)
(require 'layers)

;; ---- fixtures: commands, hooks, and layers (def'd globals, by qualified symbol) ----
;; A test context is a map {:log <string> :layers <list>}; commands/hooks append to
;; :log so the path through dispatch/hooks is visible.
(defn cmd-x (s k) (assoc s :log (str (get s :log) "X")))   ; layers-test/cmd-x
(defn cmd-y (s k) (assoc s :log (str (get s :log) "Y")))

(defn hk-a-on  (s) (assoc s :log (str (get s :log) "[a-on]")))
(defn hk-a-off (s) (assoc s :log (str (get s :log) "[a-off]")))
(defn hk-b-on  (s) (assoc s :log (str (get s :log) "[b-on]")))
(defn hk-focus (s) (assoc s :log (str (get s :log) "F")))
(defn hk-boom  (s) (throw "boom"))

(def layer-a
  {:name 'a
   :keymap (keymap-bind {} ["x"] 'layers-test/cmd-x)
   :hooks {:activate '(layers-test/hk-a-on) :deactivate '(layers-test/hk-a-off)
           :on-focus '(layers-test/hk-focus)}})
(def layer-b
  {:name 'b
   :keymap (keymap-bind {} ["y"] 'layers-test/cmd-y)
   :hooks {:activate '(layers-test/hk-b-on) :on-focus '(layers-test/hk-focus)}})
(def layer-hi  {:name 'hi    :keymap (keymap-bind {} ["x"] 'layers-test/cmd-y)})  ; binds x→Y
(def layer-boom {:name 'boom :hooks {:activate '(layers-test/hk-boom)}})
(def layer-chord {:name 'chord :keymap (keymap-bind {} [:ctrl-x :ctrl-e] 'layers-test/cmd-x)})

(defn no-fb (s k) s)   ; a no-op fallback

;; ---- collection & precedence ------------------------------------------------
(describe "layer-collect & precedence"
  (test "collects a facet from active layers, highest-precedence (head) first"
    (let (ctx (push-layer (push-layer {:log ""} 'layers-test/layer-a) 'layers-test/layer-hi))
      ;; pushed a, then hi → hi is the head (highest precedence)
      (assert= (map (fn (km) (get km "x")) (layer-collect ctx :keymap))
               (list 'layers-test/cmd-y 'layers-test/cmd-x))))
  (test "layers lacking the facet are dropped"
    (let (ctx (push-layer {:log ""} 'layers-test/layer-boom))   ; boom has no :keymap
      (is (empty? (layer-collect ctx :keymap))))))

;; ---- stack ops --------------------------------------------------------------
(describe "stack ops"
  (test "push / active? / remove by :name"
    (let (ctx (push-layer {:log ""} 'layers-test/layer-a))
      (is (layer-active? ctx 'a))
      (is (not (layer-active? ctx 'b)))
      (is (not (layer-active? (remove-layer ctx 'a) 'a))))))

;; ---- lifecycle hooks --------------------------------------------------------
(describe "activate / deactivate"
  (test "activate-layer runs the layer's :activate hooks"
    (assert= (get (activate-layer {:log ""} 'layers-test/layer-a) :log) "[a-on]"))

  (test "activate-layer fires only the new layer's :activate, not already-active ones"
    (let (ctx (activate-layer {:log ""} 'layers-test/layer-a))       ; [a-on]
      (assert= (get (activate-layer ctx 'layers-test/layer-b) :log) "[a-on][b-on]")))

  (test "deactivate-layer runs :deactivate then removes"
    (let (ctx (activate-layer {:log ""} 'layers-test/layer-a)
          ctx2 (deactivate-layer ctx 'a))
      (assert= (get ctx2 :log) "[a-on][a-off]")
      (is (not (layer-active? ctx2 'a)))))

  (test "deactivate of an inactive name is a no-op"
    (assert= (deactivate-layer {:log ""} 'nope) {:log ""}))

  (test "a throwing hook is isolated — state unchanged, layer still on"
    (let (ctx (activate-layer {:log "keep"} 'layers-test/layer-boom))
      (assert= (get ctx :log) "keep")
      (is (layer-active? ctx 'boom))))

  (test "replace-base-layer deactivates the old base and activates the new"
    (let (ctx (activate-layer {:log ""} 'layers-test/layer-a)
          ctx2 (replace-base-layer ctx 'layers-test/layer-b))
      (assert= (get ctx2 :log) "[a-on][a-off][b-on]")
      (is (layer-active? ctx2 'b))
      (is (not (layer-active? ctx2 'a))))))

;; ---- fanned events ----------------------------------------------------------
(describe "run-event (fanned across active layers)"
  (test "fans an event across every active layer, highest precedence first"
    (let (ctx (activate-layer (activate-layer {:log ""} 'layers-test/layer-a)
                              'layers-test/layer-b))
      ;; both a and b handle :on-focus → hk-focus appends F, once per layer
      (assert= (get (run-event ctx :on-focus) :log) "[a-on][b-on]FF")))
  (test "no-op when no active layer handles the event"
    (let (ctx (activate-layer {:log ""} 'layers-test/layer-a))
      (assert= (run-event ctx :on-blur) ctx))))

;; ---- keymap composition + dispatch ------------------------------------------
(describe "active-keymap & layer-dispatch"
  (test "active-keymap merges layers with the head winning"
    (let (ctx (push-layer (push-layer {:log ""} 'layers-test/layer-a) 'layers-test/layer-hi))
      (assert= (get (active-keymap ctx) "x") 'layers-test/cmd-y)))   ; hi (head) wins

  (test "layer-dispatch resolves through the layers and runs the command"
    (let (ctx (activate-layer {:log ""} 'layers-test/layer-a)
          r (layer-dispatch ctx nil "x" no-fb))
      (assert= (get (first r) :log) "[a-on]X")
      (assert= (second r) nil)))

  (test "an unbound key falls through to the fallback"
    (let (ctx (activate-layer {:log ""} 'layers-test/layer-a)
          r (layer-dispatch ctx nil "z" (fn (s _) (assoc s :log (str (get s :log) "?")))))
      (assert= (get (first r) :log) "[a-on]?")))

  (test "a chord living in a layer dispatches across two keystrokes"
    (let (ctx (push-layer {:log ""} 'layers-test/layer-chord)
          r1 (layer-dispatch ctx nil :ctrl-x no-fb))
      (assert= (second r1) {:ctrl-e 'layers-test/cmd-x})            ; pending sub-keymap
      (let (r2 (layer-dispatch (first r1) (second r1) :ctrl-e no-fb))
        (assert= (get (first r2) :log) "X")
        (assert= (second r2) nil)))))

;; ---- across processes -------------------------------------------------------
;; Layers and commands are shared code (def'd globals), resolved by symbol, so the
;; whole machinery works off the root process.
(defn lt-worker (parent)
  (let (ctx (activate-layer {:log ""} 'layers-test/layer-a)
        r (layer-dispatch ctx nil "x" layers-test/no-fb))
    (send parent (get (first r) :log))))

(describe "layers across processes"
  :isolated
  (test "activate + dispatch resolve and run inside a spawned process"
    (let (me (self))
      (spawn (lt-worker me))
      (assert= (receive) "[a-on]X"))))
