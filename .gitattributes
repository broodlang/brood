# Brood source (.blsp) is a Lisp; until Brood is its own Linguist language,
# highlight it as Clojure — the closest common grammar (handles [] vectors,
# {} maps, and :keywords, all of which Brood uses).
# linguist-detectable=false keeps .blsp out of the repo language stats (this is
# a Rust implementation of a Lisp, not a Clojure project) while still applying
# the grammar for highlighting.
*.blsp linguist-language=Clojure linguist-detectable=false
